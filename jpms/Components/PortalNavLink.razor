<a href="@Href" class="block p-4 hover:bg-slate-50 transition">
    <p class="text-sm font-medium text-slate-900">@Label</p>
    <p class="text-xs text-slate-500 mt-1">@Detail</p>
</a>

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = "";
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Detail { get; set; } = "";
}
