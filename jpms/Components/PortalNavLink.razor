<a href="@Href" class="block p-4 hover:bg-surface-raised transition">
    <p class="text-sm font-medium text-content">@Label</p>
    <p class="text-xs text-content-subtle mt-1">@Detail</p>
</a>

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = "";
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Detail { get; set; } = "";
}
