@inject ICvrStore CvrStore

<div class="rounded-xl border border-line bg-surface overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-4 py-3">Reference</th>
                <th class="px-4 py-3">Name</th>
                <th class="px-4 py-3 hidden md:table-cell">Stage</th>
                <th class="px-4 py-3 text-right">Tender</th>
                <th class="px-4 py-3 text-right">Forecast margin</th>
                <th class="px-4 py-3 text-right hidden sm:table-cell">Margin %</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @foreach (var project in Projects)
            {
                var snapshot = CvrStore.LatestSnapshot(project.ProjectId);
                <tr>
                    <td class="px-4 py-3 font-mono text-xs text-content-muted">@project.Reference</td>
                    <td class="px-4 py-3 text-content font-medium">@project.Name</td>
                    <td class="px-4 py-3 hidden md:table-cell"><ProjectStageBadge Stage="project.Stage" /></td>
                    <td class="px-4 py-3 text-right text-content-muted">@(snapshot is null ? "—" : Money(snapshot.TenderValue))</td>
                    <td class="px-4 py-3 text-right text-content font-medium">@(snapshot is null ? "—" : Money(snapshot.MarginPounds))</td>
                    <td class="px-4 py-3 text-right text-content-muted hidden sm:table-cell">
                        @(snapshot is null ? "—" : $"{snapshot.MarginPercent:0.0}%")
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Project> Projects { get; set; } = Array.Empty<Project>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
