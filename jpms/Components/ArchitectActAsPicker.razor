@inject PortalContext PortalContext

<section class="rounded-xl border border-line bg-surface p-5 mb-5">
    <p class="text-xs uppercase tracking-wider text-content-subtle font-semibold mb-2">Demo mode</p>
    <h2 class="text-sm font-medium text-content-muted mb-2">Sign in as an architect</h2>
    <p class="text-sm text-content-muted mb-3">
        In production each architect receives a unique secure link. For demo, enter any email.
    </p>
    <form @onsubmit="Apply" @onsubmit:preventDefault="true" class="flex flex-wrap items-center gap-2">
        <input type="email" @bind="email" placeholder="alex@studioarchitects.example"
               class="rounded-lg border border-line-strong px-3 py-2 text-sm flex-1 min-w-[16rem]" />
        <button type="submit"
                class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-3 py-2 hover:bg-accent-hover transition"
                disabled="@string.IsNullOrWhiteSpace(email)">
            Continue
        </button>
    </form>
</section>

@code {
    private string email = "";

    protected override void OnInitialized() =>
        email = PortalContext.ActingArchitectEmail ?? "";

    private void Apply()
    {
        if (string.IsNullOrWhiteSpace(email)) return;
        PortalContext.ActAsArchitect(email.Trim());
    }
}
