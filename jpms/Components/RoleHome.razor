<section class="px-6 py-6 md:px-8">

    <div class="mb-8 md:mb-10">
        <p class="eyebrow mb-2">JPMS</p>
        <h1 class="text-3xl md:text-4xl font-semibold text-content leading-tight mb-3">
            Welcome, @FirstName.
        </h1>
        <p class="text-base md:text-lg text-content-muted leading-relaxed">
            You're signed in as <span class="font-medium text-content">@Email</span>.
            You're viewing as <RoleBadge Role="Role" />.
        </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-8">
        <Stat Label="Active role" Value="@Role.DisplayName()" />
        <Stat Label="Provider"    Value="Microsoft" />
        <Stat Label="Status"      Value="Approved" />
    </div>

    <h2 class="text-sm font-medium text-content-muted mb-3">Where to next</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4">
        @foreach (var destination in Destinations)
        {
            <a href="@destination.Href"
               class="panel p-5 flex items-center gap-3 hover:border-line-strong hover:bg-surface-raised transition">
                <NavIcon Route="@destination.Href" Class="w-5 h-5 text-accent shrink-0" />
                <span class="text-base font-medium text-content">@destination.Label</span>
            </a>
        }
    </div>

</section>

@code {
    [Parameter, EditorRequired] public Role Role { get; set; }
    [Parameter, EditorRequired] public string DisplayName { get; set; } = "";
    [Parameter, EditorRequired] public string Email { get; set; } = "";

    private IEnumerable<NavigationItem> Destinations =>
        NavigationCatalog.ItemsFor(Role).Where(item => item.Href != "/dashboard");

    private string FirstName => FirstWordOf(DisplayName) ?? Role.DisplayName();

    private static string? FirstWordOf(string fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName)) return null;
        return fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
    }
}
