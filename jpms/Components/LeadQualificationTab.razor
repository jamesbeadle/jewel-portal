@inject AuthService Auth
@inject ILeadStore LeadStore

<section class="rounded-xl border border-line bg-surface p-5">
    <h2 class="text-sm font-medium text-content-muted mb-3">Qualification scorecard</h2>

    <form @onsubmit="HandleSave" @onsubmit:preventDefault="true" class="space-y-4">
        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">
                Score (0–100)
            </label>
            <input type="number" min="0" max="100" @bind="score"
                   class="field w-32" />
        </div>

        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">
                Notes
            </label>
            <textarea @bind="notes" rows="5"
                      placeholder="Budget alignment, client readiness, design maturity, decision-maker access, fit with delivery capacity…"
                      class="field"></textarea>
        </div>

        <div class="flex items-center justify-between">
            <p class="text-xs text-content-subtle">
                @if (existing is not null)
                {
                    <text>Last assessed @existing.AssessedAt.LocalDateTime.ToString("d MMM yyyy HH:mm") by @existing.AssessedByEmail.</text>
                }
            </p>
            <button type="submit"
                    class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
                Save assessment
            </button>
        </div>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public Lead Lead { get; set; } = default!;

    private int score;
    private string notes = "";
    private QualificationAssessment? existing;

    protected override void OnParametersSet()
    {
        existing = LeadStore.GetQualification(Lead.LeadId);
        score = existing?.Score ?? 50;
        notes = existing?.Notes ?? "";
    }

    private void HandleSave()
    {
        var assessment = new QualificationAssessment(
            Lead.LeadId, score, notes,
            Auth.CurrentUser?.Email ?? "unknown", DateTimeOffset.UtcNow);
        LeadStore.SaveQualification(assessment);

        if (Lead.Stage == LeadStage.NewLead)
        {
            LeadStore.Upsert(Lead with { Stage = LeadStage.Qualified });
        }
    }
}
