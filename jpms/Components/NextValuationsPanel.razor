@using Jewel.JPMS.Features.Projects
@inject ProjectListReadModel Projects
@implements IDisposable

@*
    Finance director's dashboard panel: every visible project (Completed projects excluded —
    nothing left to value) with its next expected valuation date, soonest first (projects
    without a date sit at the bottom as "Not set"). Overdue dates
    are flagged red, dates within the next seven days amber, so the FD can see at a glance which
    valuations need chasing. Rows link to the project; the date itself is set from the project's
    Setup tab.
*@

<section class="rounded-xl border border-line bg-surface overflow-hidden">
    <header class="flex items-center justify-between gap-3 px-5 py-3 border-b border-line bg-surface-raised">
        <h2 class="text-sm font-medium text-content-muted">Upcoming valuations</h2>
        @if (Overdue > 0)
        {
            <span class="text-xs text-negative font-medium">@Overdue overdue</span>
        }
    </header>

    @if (Projects.Current is null)
    {
        <p class="px-5 py-4 text-sm text-content-subtle">Loading…</p>
    }
    else if (Ordered.Count == 0)
    {
        <p class="px-5 py-4 text-sm text-content-subtle">No projects yet.</p>
    }
    else
    {
        <table class="w-full text-sm border-collapse">
            <thead>
                <tr class="text-left border-b border-line">
                    <th class="px-5 py-2 text-[11px] uppercase tracking-wider text-content-subtle font-semibold">Project</th>
                    <th class="px-5 py-2 text-[11px] uppercase tracking-wider text-content-subtle font-semibold hidden sm:table-cell">Client</th>
                    <th class="px-5 py-2 text-[11px] uppercase tracking-wider text-content-subtle font-semibold text-right">Next valuation</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Ordered)
                {
                    var status = StatusOf(project.NextExpectedValuationDate);
                    <tr class="border-b border-line last:border-b-0 hover:bg-surface-raised/60 transition">
                        <td class="px-5 py-2.5">
                            <a href="@($"/projects/{project.ProjectId}/financials")" class="hover:underline underline-offset-4">
                                <span class="font-mono text-xs text-content-subtle mr-2">@project.Reference</span>
                                <span class="text-content font-medium">@project.Name</span>
                            </a>
                        </td>
                        <td class="px-5 py-2.5 text-content-muted hidden sm:table-cell">@project.ClientName</td>
                        <td class="px-5 py-2.5 text-right whitespace-nowrap">
                            @if (project.NextExpectedValuationDate is { } date)
                            {
                                <span class="@(status switch
                                             {
                                                 DateStatus.Overdue => "text-negative",
                                                 DateStatus.DueSoon => "text-amber-400",
                                                 _ => "text-content",
                                             })">@date.ToString("d MMM yyyy")</span>
                                @if (status == DateStatus.Overdue)
                                {
                                    <span class="ml-2 text-[11px] uppercase tracking-wider font-semibold text-negative bg-negative/10 border border-negative/30 rounded px-1.5 py-0.5">Overdue</span>
                                }
                                else if (status == DateStatus.DueSoon)
                                {
                                    <span class="ml-2 text-[11px] uppercase tracking-wider font-semibold text-amber-400 bg-amber-400/10 border border-amber-400/30 rounded px-1.5 py-0.5">Due soon</span>
                                }
                            }
                            else
                            {
                                <span class="text-content-subtle">Not set</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@code {
    private enum DateStatus { Overdue, DueSoon, Later, NotSet }

    private IReadOnlyList<Project> Ordered =>
        (Projects.Current ?? Array.Empty<Project>())
            .Where(project => project.Stage != ProjectStage.Completed)
            .OrderBy(project => project.NextExpectedValuationDate is null)
            .ThenBy(project => project.NextExpectedValuationDate)
            .ThenBy(project => project.Reference, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private int Overdue =>
        Ordered.Count(project => StatusOf(project.NextExpectedValuationDate) == DateStatus.Overdue);

    private static DateStatus StatusOf(DateTimeOffset? date)
    {
        if (date is null) return DateStatus.NotSet;
        var today = DateTime.Today;
        if (date.Value.Date < today) return DateStatus.Overdue;
        if (date.Value.Date <= today.AddDays(7)) return DateStatus.DueSoon;
        return DateStatus.Later;
    }

    protected override async Task OnInitializedAsync()
    {
        Projects.OnChanged += StateHasChanged;
        // Store convention: refresh once from OnInitializedAsync — await the first load, then
        // stale-while-revalidate on subsequent visits so the cached list shows immediately.
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
        else _ = RefreshInBackgroundAsync();
    }

    private async Task RefreshInBackgroundAsync()
    {
        // Fire-and-forget must swallow failures: the cached list is still shown, and the next
        // navigation retries.
        try { await Projects.RefreshAsync(CancellationToken.None); }
        catch { }
    }

    public void Dispose() => Projects.OnChanged -= StateHasChanged;
}
