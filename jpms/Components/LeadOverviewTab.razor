@inject ILeadStore LeadStore

<div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-6">
    <Stat Label="Source"     Value="@Lead.Source.DisplayName()" />
    <Stat Label="Stage"      Value="@Lead.Stage.DisplayName()" />
    <Stat Label="Value"      Value="@FormatValue(Lead.EstimatedValue)" />
</div>

<section class="rounded-xl border border-line bg-surface p-5 mb-6">
    <h2 class="text-sm font-medium text-content-muted mb-3">Contact</h2>
    <dl class="text-sm space-y-2">
        <div class="flex justify-between gap-3">
            <dt class="text-content-subtle">Name</dt><dd class="text-content font-medium">@Lead.ContactName</dd>
        </div>
        <div class="flex justify-between gap-3">
            <dt class="text-content-subtle">Email</dt><dd class="text-content break-all">@Lead.ContactEmail</dd>
        </div>
        <div class="flex justify-between gap-3">
            <dt class="text-content-subtle">Phone</dt><dd class="text-content">@Lead.ContactPhone</dd>
        </div>
        @if (!string.IsNullOrWhiteSpace(Lead.CompanyName))
        {
            <div class="flex justify-between gap-3">
                <dt class="text-content-subtle">Company</dt><dd class="text-content">@Lead.CompanyName</dd>
            </div>
        }
        <div class="flex justify-between gap-3">
            <dt class="text-content-subtle">Captured</dt>
            <dd class="text-content">@Lead.CapturedAt.LocalDateTime.ToString("d MMM yyyy")</dd>
        </div>
    </dl>
</section>

<StageProgressionPanel Lead="Lead" />

@code {
    [Parameter, EditorRequired] public Lead Lead { get; set; } = default!;

    private static string FormatValue(decimal? value) =>
        value is null ? "—" : value.Value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
