@inject ICommercialStore CommercialStore

<section class="rounded-xl border border-slate-200 bg-white p-5 mb-4">
    <h3 class="text-sm font-medium text-slate-700 mb-3">Set a cost code budget</h3>
    <form @onsubmit="Save" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <FormField Label="Cost code" Value="@costCode" OnChange="@(value => costCode = value)" Required="true" />
            <FormField Label="Allocated £" InputType="number" Value="@allocatedAmount" OnChange="@(value => allocatedAmount = value)" />
            <FormField Label="Spent £" InputType="number" Value="@spentAmount" OnChange="@(value => spentAmount = value)" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-900 text-white font-medium text-sm px-4 py-2 hover:bg-slate-800 transition">
            Set budget
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private string costCode = "";
    private string allocatedAmount = "0";
    private string spentAmount = "0";

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(costCode)) return;
        CommercialStore.SaveBudget(new CostCodeBudget(
            "", ProjectId, costCode,
            FormNumber.ParseAmount(allocatedAmount), FormNumber.ParseAmount(spentAmount)));
        costCode = "";
        allocatedAmount = "0";
        spentAmount = "0";
    }
}
