@inject ICvrStore CvrStore

<section class="rounded-xl border border-slate-200 bg-white p-5 mb-4">
    <h3 class="text-sm font-medium text-slate-700 mb-3">Record a prelim forecast for a week</h3>
    <form @onsubmit="Save" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            <FormField Label="Prelim item" Value="@prelimDescription" OnChange="@(value => prelimDescription = value)" Required="true" />
            <FormField Label="Week number" InputType="number" Value="@weekNumber" OnChange="@(value => weekNumber = value)" />
            <FormField Label="Tendered £" InputType="number" Value="@tenderedAmount" OnChange="@(value => tenderedAmount = value)" />
            <FormField Label="Actual £" InputType="number" Value="@actualAmount" OnChange="@(value => actualAmount = value)" />
            <FormField Label="Forecast £" InputType="number" Value="@forecastAmount" OnChange="@(value => forecastAmount = value)" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-900 text-white font-medium text-sm px-4 py-2 hover:bg-slate-800 transition">
            Record forecast
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private string prelimDescription = "";
    private string weekNumber = "1";
    private string tenderedAmount = "0";
    private string actualAmount = "0";
    private string forecastAmount = "0";

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(prelimDescription)) return;
        CvrStore.SavePrelimForecast(ProjectId, prelimDescription, new PrelimForecastEntry(
            "", "", FormNumber.ParseCount(weekNumber),
            FormNumber.ParseAmount(tenderedAmount), FormNumber.ParseAmount(actualAmount), FormNumber.ParseAmount(forecastAmount)));
        tenderedAmount = "0";
        actualAmount = "0";
        forecastAmount = "0";
    }
}
