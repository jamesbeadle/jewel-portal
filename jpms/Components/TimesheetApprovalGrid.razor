@inject ICommercialStore CommercialStore

<div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-left text-[11px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-4 py-3">Person</th>
                <th class="px-4 py-3 hidden sm:table-cell">Worked on</th>
                <th class="px-4 py-3">Cost code</th>
                <th class="px-4 py-3 text-right">Hours</th>
                <th class="px-4 py-3">Status</th>
                <th class="px-4 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @foreach (var timesheet in Timesheets)
            {
                <tr>
                    <td class="px-4 py-3 text-slate-900 font-medium break-all">@timesheet.PersonEmail</td>
                    <td class="px-4 py-3 text-slate-600 hidden sm:table-cell">@timesheet.WorkedOn.LocalDateTime.ToString("d MMM yyyy")</td>
                    <td class="px-4 py-3"><CostCodeChip Code="@timesheet.CostCode" /></td>
                    <td class="px-4 py-3 text-right text-slate-900 font-medium">@timesheet.Hours.ToString("0.#")</td>
                    <td class="px-4 py-3">
                        <span class="text-[11px] font-medium @(timesheet.IsApproved ? "text-emerald-700" : "text-amber-700")">
                            @(timesheet.IsApproved ? "Approved" : "Pending")
                        </span>
                    </td>
                    <td class="px-4 py-3 text-right">
                        @if (!timesheet.IsApproved)
                        {
                            <button type="button" @onclick="() => Approve(timesheet.TimesheetId)"
                                    class="text-xs font-medium text-slate-700 hover:text-slate-900 underline underline-offset-4">
                                Approve
                            </button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Timesheet> Timesheets { get; set; } = Array.Empty<Timesheet>();

    private void Approve(string timesheetId) => CommercialStore.ApproveTimesheet(timesheetId);
}
