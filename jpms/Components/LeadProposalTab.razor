@inject ILeadStore LeadStore

<section class="rounded-xl border border-line bg-surface p-5 mb-5">
    <h2 class="text-sm font-medium text-content-muted mb-3">Issue proposal</h2>

    @if (existing is null)
    {
        <form @onsubmit="HandleIssue" @onsubmit:preventDefault="true" class="flex flex-wrap items-end gap-2">
            <div>
                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Proposal value (GBP)</label>
                <input type="number" min="0" @bind="value"
                       class="w-48 rounded-lg border border-line-strong px-3 py-2 text-sm" />
            </div>
            <button type="submit"
                    class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
                Issue proposal
            </button>
        </form>
    }
    else
    {
        <p class="text-sm text-content-muted">
            Issued @existing.IssuedAt.LocalDateTime.ToString("d MMM yyyy") at
            <span class="font-medium">@FormatValue(existing.Value)</span>.
        </p>
    }
</section>

@if (existing is not null)
{
    <NegotiationHistoryPanel Lead="Lead" Proposal="existing" />
}

@code {
    [Parameter, EditorRequired] public Lead Lead { get; set; } = default!;

    private decimal value;
    private Proposal? existing;

    protected override void OnParametersSet()
    {
        existing = LeadStore.GetProposal(Lead.LeadId);
        value = Lead.EstimatedValue ?? 0;
    }

    private void HandleIssue()
    {
        var proposal = new Proposal(
            $"PR-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}",
            Lead.LeadId, value, DateTimeOffset.UtcNow, Array.Empty<NegotiationRound>());
        LeadStore.SaveProposal(proposal);
        LeadStore.Upsert(Lead with { Stage = LeadStage.ProposalIssued });
    }

    private static string FormatValue(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
