<div class="rounded-xl border border-line bg-surface overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[10px] uppercase tracking-wider text-content-subtle font-semibold">
                <th rowspan="2" class="px-3 py-3 align-bottom">Package</th>
                <th colspan="3" class="px-3 py-2 text-center border-l border-line">Order</th>
                <th colspan="3" class="px-3 py-2 text-center border-l border-line">Variation</th>
                <th colspan="3" class="px-3 py-2 text-center border-l border-line">Combined</th>
                <th rowspan="2" class="px-3 py-3 align-bottom text-right border-l border-line">Movement</th>
            </tr>
            <tr class="text-right text-[10px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-3 py-2 border-l border-line">Cost</th>
                <th class="px-3 py-2">Value</th>
                <th class="px-3 py-2">Profit</th>
                <th class="px-3 py-2 border-l border-line">Cost</th>
                <th class="px-3 py-2">Value</th>
                <th class="px-3 py-2">Profit</th>
                <th class="px-3 py-2 border-l border-line">Cost</th>
                <th class="px-3 py-2">Value</th>
                <th class="px-3 py-2">Margin %</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line text-right">
            @foreach (var row in Rows)
            {
                <tr>
                    <td class="px-3 py-2 text-content font-medium text-left">@row.PackageName</td>
                    <td class="px-3 py-2 text-content-muted border-l border-line">@Money(row.OrderCost)</td>
                    <td class="px-3 py-2 text-content-muted">@Money(row.OrderValue)</td>
                    <td class="px-3 py-2 text-content font-medium">@Money(row.OrderProfit)</td>
                    <td class="px-3 py-2 text-content-muted border-l border-line">@Money(row.VariationCost)</td>
                    <td class="px-3 py-2 text-content-muted">@Money(row.VariationValue)</td>
                    <td class="px-3 py-2 text-content font-medium">@Money(row.VariationProfit)</td>
                    <td class="px-3 py-2 text-content-muted border-l border-line">@Money(row.CombinedCost)</td>
                    <td class="px-3 py-2 text-content-muted">@Money(row.CombinedValue)</td>
                    <td class="px-3 py-2 text-content font-medium">@row.CombinedProfitOnCostPercent.ToString("0.0")%</td>
                    <td class="px-3 py-2 font-medium border-l border-line @MovementColour(row.MovementSinceLastSnapshot)">
                        @MovementText(row.MovementSinceLastSnapshot)
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<CvrPackageRow> Rows { get; set; } = Array.Empty<CvrPackageRow>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string MovementText(decimal value)
    {
        if (value == 0) return "—";
        var prefix = value > 0 ? "+" : "";
        return $"{prefix}{Money(value)}";
    }

    private static string MovementColour(decimal value)
    {
        if (value > 0) return "text-emerald-700";
        if (value < 0) return "text-rose-700";
        return "text-content-subtle";
    }
}
