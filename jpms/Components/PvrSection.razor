@inject ICommercialStore CommercialStore

<div class="space-y-5">
    <section class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="text-sm font-medium text-slate-700 mb-2">Programme Valuation Report</h2>
        <p class="text-sm text-slate-600">
            Per Claim Period. Each PVR is built from approved progress and approved variations —
            review, not rebuild. Latest period totals roll into the cashflow forecast.
        </p>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
        <ClaimPeriodForm ProjectId="@ProjectId" OnAdded="StateHasChanged" />
        <ValuationDraftForm ProjectId="@ProjectId" />
    </div>

    <ValuationTable Valuations="Valuations" />

    @if (Draft is not null)
    {
        <section class="rounded-xl border border-amber-200 bg-amber-50 p-5">
            <h3 class="text-sm font-medium text-amber-900 mb-2">Period @Draft.ValuationId — draft</h3>
            <p class="text-sm text-amber-800 mb-3">
                Gross @Money(Draft.GrossValue) · retention @Draft.RetentionPercent.ToString("0.#")% · net @Money(Draft.NetValue).
            </p>
            <button type="button" @onclick="IssueDraft"
                    class="rounded-lg bg-slate-900 text-white font-medium text-sm px-3 py-2 hover:bg-slate-800 transition">
                Issue PVR
            </button>
        </section>
    }
</div>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private IReadOnlyList<Valuation> Valuations => CommercialStore.ValuationsFor(ProjectId);
    private Valuation? Draft => Valuations.FirstOrDefault(valuation => !valuation.IsIssued);

    private void IssueDraft()
    {
        if (Draft is null) return;
        CommercialStore.SaveValuation(Draft with { IsIssued = true, IssuedAt = DateTimeOffset.UtcNow });
    }

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
