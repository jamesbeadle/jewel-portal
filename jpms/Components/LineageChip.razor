@*
    One node in the RecordLineage bar. The active chip (the record whose page you are on) is
    highlighted and inert; every other chip is a link. Eyebrow = record type (RFI / VOQ / VO / BPI
    reference), Label = the human reference or title, Status = small status tag on the right.
*@

@if (IsActive)
{
    <span class="inline-flex items-center gap-2 rounded-lg border border-accent/40 bg-accent/10 px-2.5 py-1.5"
          aria-current="page" title="@Title">
        <span class="text-[10px] uppercase tracking-wide font-semibold text-accent">@Eyebrow</span>
        <span class="font-mono text-xs font-semibold text-content max-w-[16rem] truncate">@Label</span>
        <span class="text-[10px] text-content-muted whitespace-nowrap">@Status</span>
    </span>
}
else
{
    <a href="@Href" title="@Title"
       class="inline-flex items-center gap-2 rounded-lg border border-line bg-surface-raised px-2.5 py-1.5 hover:border-content-subtle hover:bg-surface transition-colors">
        <span class="text-[10px] uppercase tracking-wide font-semibold text-content-subtle">@Eyebrow</span>
        <span class="font-mono text-xs font-semibold text-content max-w-[16rem] truncate">@Label</span>
        <span class="text-[10px] text-content-muted whitespace-nowrap">@Status</span>
    </a>
}

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = "";
    [Parameter] public bool IsActive { get; set; }
    [Parameter, EditorRequired] public string Eyebrow { get; set; } = "";
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter] public string Status { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
}
