@inject ILeadStore LeadStore

<section class="rounded-xl border border-line bg-surface p-5 mb-5">
    <h2 class="text-sm font-medium text-content-muted mb-3">Track outstanding information</h2>
    <form @onsubmit="HandleAdd" @onsubmit:preventDefault="true" class="flex flex-wrap items-end gap-2">
        <div class="flex-1 min-w-[10rem]">
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Kind</label>
            <select @bind="kind" class="field">
                <option value="Drawing">Drawing</option>
                <option value="Consent">Planning consent</option>
                <option value="Brief">Brief</option>
                <option value="Other">Other</option>
            </select>
        </div>
        <div class="flex-[2] min-w-[14rem]">
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Description</label>
            <input type="text" @bind="description"
                   class="field" />
        </div>
        <button type="submit"
                class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
            Add
        </button>
    </form>
</section>

<section class="rounded-xl border border-line bg-surface overflow-hidden">
    <header class="px-5 py-3 border-b border-line bg-surface-raised flex items-center justify-between">
        <h2 class="text-sm font-medium text-content-muted">Outstanding items</h2>
        <span class="text-xs text-content-subtle">@Outstanding.Count outstanding · @Received.Count received</span>
    </header>
    <ul class="divide-y divide-line">
        @foreach (var item in AllItems)
        {
            <li class="p-4 text-sm flex items-start justify-between gap-3">
                <div>
                    <p class="font-medium text-content">@item.Description</p>
                    <p class="text-xs text-content-subtle mt-1">
                        @item.Kind · requested @item.RequestedAt.LocalDateTime.ToString("d MMM yyyy")
                    </p>
                </div>
                <button type="button" @onclick="() => Toggle(item)"
                        class="text-xs font-medium text-content-subtle hover:text-content underline underline-offset-4">
                    @(item.IsReceived ? "Mark outstanding" : "Mark received")
                </button>
            </li>
        }
    </ul>
</section>

@code {
    [Parameter, EditorRequired] public Lead Lead { get; set; } = default!;

    private string kind = "Drawing";
    private string description = "";

    private IReadOnlyList<InfoChaseItem> AllItems => LeadStore.InfoChaseFor(Lead.LeadId);
    private IReadOnlyList<InfoChaseItem> Outstanding => AllItems.Where(item => !item.IsReceived).ToList().AsReadOnly();
    private IReadOnlyList<InfoChaseItem> Received => AllItems.Where(item => item.IsReceived).ToList().AsReadOnly();

    private void HandleAdd()
    {
        if (string.IsNullOrWhiteSpace(description)) return;
        var item = new InfoChaseItem(
            $"IC-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}",
            Lead.LeadId, kind, description, false, DateTimeOffset.UtcNow);
        LeadStore.SaveInfoChaseItem(item);
        description = "";
    }

    private void Toggle(InfoChaseItem item) =>
        LeadStore.SaveInfoChaseItem(item with { IsReceived = !item.IsReceived });
}
