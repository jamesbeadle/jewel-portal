@inject ICommercialInputsStore InputsStore

<section class="rounded-xl border border-line bg-surface p-5 mb-4">
    <h3 class="text-sm font-medium text-content-muted mb-3">Raise a contra charge</h3>
    <form @onsubmit="Save" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            <FormField Label="Subcontractor" Value="@subcontractorReference" OnChange="@(value => subcontractorReference = value)" Required="true" />
            <FormField Label="Raised on" InputType="date" Value="@raisedOn" OnChange="@(value => raisedOn = value)" />
            <FormField Label="Category" Value="@category" OnChange="@(value => category = value)" />
            <FormField Label="Description" Value="@description" OnChange="@(value => description = value)" />
            <FormField Label="Amount £" InputType="number" Value="@amount" OnChange="@(value => amount = value)" />
            <FormField Label="Recovered £" InputType="number" Value="@recoveredAmount" OnChange="@(value => recoveredAmount = value)" />
            <FormField Label="Status" Value="@status" OnChange="@(value => status = value)" />
        </div>
        <button type="submit" class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
            Raise contra charge
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private string subcontractorReference = "";
    private string raisedOn = "";
    private string category = "";
    private string description = "";
    private string amount = "0";
    private string recoveredAmount = "0";
    private string status = "Open";

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(subcontractorReference)) return;
        var raisedOnDate = DateTimeOffset.TryParse(raisedOn, out var parsed) ? parsed : DateTimeOffset.UtcNow;
        InputsStore.RecordContraCharge(new ContraCharge(
            "", ProjectId, subcontractorReference, raisedOnDate, description, category,
            FormNumber.ParseAmount(amount), status, FormNumber.ParseAmount(recoveredAmount)));
        subcontractorReference = "";
        description = "";
        amount = "0";
        recoveredAmount = "0";
    }
}
