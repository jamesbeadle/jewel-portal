@inject AuthService Auth
@inject IAccessRequestStore Requests
@inject NavigationManager Nav

<section class="max-w-md mx-auto px-4 py-12 md:py-16">

    <div class="text-center mb-8">
        <span class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-amber-100 text-amber-700 text-xl mb-5" aria-hidden="true">!</span>
        <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-2">No account yet</p>
        <h1 class="text-2xl md:text-3xl font-semibold text-slate-900 leading-tight mb-3">You're signed in, but you don't have JPMS access</h1>
        <p class="text-base text-slate-700 leading-relaxed">
            <span class="font-medium text-slate-900">@Email</span> isn't on the company's approved list yet.
            Request access and a Jewel administrator will review your account.
        </p>
    </div>

    @if (isSubmitted)
    {
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 p-6 text-center">
            <p class="text-sm font-medium text-emerald-800 mb-1">Request submitted</p>
            <p class="text-sm text-emerald-900 leading-relaxed">
                Thanks. An administrator will be in touch once your account has been approved.
            </p>
            <button type="button" @onclick="SignOut"
                    class="w-full mt-5 rounded-lg border border-emerald-200 bg-white text-emerald-800 font-medium px-4 py-2.5 hover:border-emerald-300 transition">
                Sign out
            </button>
        </div>
    }
    else
    {
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
            <dl class="grid grid-cols-1 gap-3 mb-5 text-sm">
                <div class="flex justify-between gap-3">
                    <dt class="text-slate-500">Name</dt>
                    <dd class="text-slate-900 font-medium text-right">@DisplayName</dd>
                </div>
                <div class="flex justify-between gap-3">
                    <dt class="text-slate-500">Email</dt>
                    <dd class="text-slate-900 font-medium text-right break-all">@Email</dd>
                </div>
            </dl>

            <button type="button" @onclick="SubmitRequest"
                    class="w-full rounded-lg bg-slate-900 text-white font-medium px-4 py-2.5 hover:bg-slate-800 transition">
                Request access
            </button>

            <button type="button" @onclick="SignOut"
                    class="w-full mt-2 rounded-lg border border-slate-200 bg-white text-slate-700 font-medium px-4 py-2.5 hover:border-slate-300 transition">
                Sign out
            </button>
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public string Email       { get; set; } = "";
    [Parameter, EditorRequired] public string DisplayName { get; set; } = "";

    private bool isSubmitted;

    private void SubmitRequest()
    {
        if (Auth.CurrentUser is null) return;
        Requests.Submit(Auth.CurrentUser);
        isSubmitted = true;
    }

    private void SignOut() => Nav.NavigateTo("/logout", forceLoad: true);
}
