@inject IProcurementStore ProcurementStore

<div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-left text-[11px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-4 py-3">Package</th>
                <th class="px-4 py-3 hidden sm:table-cell">Trade</th>
                <th class="px-4 py-3 hidden md:table-cell">Quotes</th>
                <th class="px-4 py-3">Status</th>
                <th class="px-4 py-3 hidden lg:table-cell">Created</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @foreach (var package in Packages)
            {
                <tr>
                    <td class="px-4 py-3 text-slate-900 font-medium">@package.Title</td>
                    <td class="px-4 py-3 text-slate-700 hidden sm:table-cell">@package.Trade</td>
                    <td class="px-4 py-3 text-slate-600 hidden md:table-cell">@ProcurementStore.QuotesFor(package.BidPackageId).Count</td>
                    <td class="px-4 py-3">
                        <span class="inline-flex items-center rounded-full bg-slate-50 border border-slate-200 px-2 py-0.5 text-[11px] font-medium text-slate-700">@package.Status</span>
                    </td>
                    <td class="px-4 py-3 text-slate-500 hidden lg:table-cell">@package.CreatedAt.LocalDateTime.ToString("d MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<BidPackage> Packages { get; set; } = Array.Empty<BidPackage>();
}
