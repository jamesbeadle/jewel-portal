@using Jewel.JPMS.Features.Directory
@inject IUserDirectory UserDirectory
@inject IAccessRequestStore Requests
@inject DirectoryReadModel Directory
@inject AccessRequestsReadModel AccessRequests
@implements IDisposable

<section class="px-6 py-6 md:px-8">

    <header class="mb-6 md:mb-8">
        <h1 class="eyebrow mb-1">JPMS · Administrator</h1>
        <p class="text-[10px] text-content-subtle break-all leading-snug">You are signed in as @CurrentUser.Email</p>
    </header>

    <AdminStatsRow />
    <PendingRequestsPanel />
    <ApprovedUsersPanel CurrentUserEmail="@CurrentUser.Email" />
    <WhatsNextPanel />

</section>

@code {
    [Parameter, EditorRequired] public AuthenticatedUser CurrentUser { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        UserDirectory.OnChange += StateHasChanged;
        Requests.OnChange += StateHasChanged;

        // Load the directory and access-request data up front, matching the
        // pattern used by every other page (e.g. ProjectPageShell). Without this
        // the panels render before the first fetch completes and stay empty until
        // the user navigates away and back.
        if (Directory.Current is null) await Directory.RefreshAsync(CancellationToken.None);
        if (AccessRequests.Current is null) await AccessRequests.RefreshAsync(CancellationToken.None);
    }

    public void Dispose()
    {
        UserDirectory.OnChange -= StateHasChanged;
        Requests.OnChange -= StateHasChanged;
    }
}
