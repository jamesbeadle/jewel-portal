<section class="rounded-xl border border-line bg-surface p-5">
    @if (Vat is null)
    {
        <p class="text-sm text-content-subtle italic">No VAT analysis yet. Drafted at project completion and confirmed by client.</p>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
            <Stat Label="Zero-rated"     Value="@Money(Vat.ZeroRatedAmount)" />
            <Stat Label="Standard-rated" Value="@Money(Vat.StandardRatedAmount)" />
        </div>
        @if (!string.IsNullOrWhiteSpace(Vat.Notes))
        {
            <p class="text-sm text-content-muted mb-2">@Vat.Notes</p>
        }
        <p class="text-xs text-content-subtle">
            <span class="@(Vat.IsClientConfirmed ? "text-emerald-700" : "text-amber-700") font-medium">
                Client: @(Vat.IsClientConfirmed ? "Confirmed" : "Pending")
            </span>
            <span class="mx-2 text-content-subtle">·</span>
            <span class="@(Vat.IsArchitectConfirmed ? "text-emerald-700" : "text-amber-700") font-medium">
                Architect: @(Vat.IsArchitectConfirmed ? "Confirmed" : "Pending")
            </span>
        </p>
    }
</section>

@code {
    [Parameter] public VatAnalysis? Vat { get; set; }

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
