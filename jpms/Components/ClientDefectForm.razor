@inject ICloseoutStore CloseoutStore

<section class="rounded-xl border border-line bg-surface p-5 mb-5">
    <h2 class="text-sm font-medium text-content-muted mb-3">Raise a defect</h2>
    <form @onsubmit="HandleRaise" @onsubmit:preventDefault="true" class="space-y-3">
        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Location</label>
            <input type="text" @bind="location" required placeholder="Room, area or feature"
                   class="w-full rounded-lg border border-line-strong px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Description</label>
            <textarea @bind="description" required rows="3"
                      class="w-full rounded-lg border border-line-strong px-3 py-2 text-sm"></textarea>
        </div>
        <button type="submit"
                class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-3 py-2 hover:bg-accent-hover transition"
                disabled="@(string.IsNullOrWhiteSpace(description) || string.IsNullOrWhiteSpace(location))">
            Raise defect
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private string description = "";
    private string location = "";

    private void HandleRaise()
    {
        var defect = new Defect(
            $"DF-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}",
            ProjectId, description, location, "site.manager@jewelenterprises.co.uk",
            DefectStatus.Open, DateTimeOffset.UtcNow, null);
        CloseoutStore.SaveDefect(defect);
        description = ""; location = "";
    }
}
