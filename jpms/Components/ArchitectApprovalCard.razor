@inject AuthService Auth
@inject IChangeRegister ChangeRegister

<div class="p-5">
    <div class="flex items-start justify-between gap-3 mb-2">
        <div>
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">@Record.Reference · @ProjectName</p>
            <h3 class="text-sm font-semibold text-content">@Record.Title</h3>
            @if (Record.Value is not null)
            {
                <p class="text-sm text-content-muted mt-1">Value: @Money(Record.Value.Value)</p>
            }
        </div>
        <span class="text-[11px] font-medium text-amber-700">@Record.Status</span>
    </div>
    <p class="text-sm text-content-muted mb-3">@Record.Description</p>

    <div class="flex items-center gap-2">
        <button type="button" @onclick="() => Decide(ChangeStatus.Approved)"
                class="rounded-lg bg-emerald-600 text-white font-medium text-sm px-3 py-2 hover:bg-emerald-700 transition">
            Approve
        </button>
        <button type="button" @onclick="() => Decide(ChangeStatus.Rejected)"
                class="rounded-lg border border-line bg-surface text-content-muted font-medium text-sm px-3 py-2 hover:border-line-strong transition">
            Reject
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ChangeRecord Record { get; set; } = default!;
    [Parameter, EditorRequired] public string ProjectName { get; set; } = "";

    private void Decide(ChangeStatus status)
    {
        var responseText = status == ChangeStatus.Approved ? "Approved." : "Rejected.";
        ChangeRegister.Upsert(Record with
        {
            Status = status,
            RespondedAt = DateTimeOffset.UtcNow,
            ResponseText = responseText,
            RespondedByEmail = Auth.CurrentUser?.Email ?? "architect@unknown"
        });
    }

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
