@inject IChangeRegister ChangeRegister

<div class="p-5">
    <div class="flex items-start justify-between gap-3 mb-2">
        <div>
            <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1">@Record.Reference · @ProjectName</p>
            <h3 class="text-sm font-semibold text-slate-900">@Record.Title</h3>
            @if (Record.Value is not null)
            {
                <p class="text-sm text-slate-700 mt-1">Value: @Money(Record.Value.Value)</p>
            }
        </div>
        <span class="text-[11px] font-medium text-amber-700">@Record.Status</span>
    </div>
    <p class="text-sm text-slate-700 mb-3">@Record.Description</p>

    <div class="flex items-center gap-2">
        <button type="button" @onclick="() => Decide(ChangeStatus.Approved)"
                class="rounded-lg bg-emerald-600 text-white font-medium text-sm px-3 py-2 hover:bg-emerald-700 transition">
            Approve
        </button>
        <button type="button" @onclick="() => Decide(ChangeStatus.Rejected)"
                class="rounded-lg border border-slate-200 bg-white text-slate-700 font-medium text-sm px-3 py-2 hover:border-slate-300 transition">
            Reject
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public ChangeRecord Record { get; set; } = default!;
    [Parameter, EditorRequired] public string ProjectName { get; set; } = "";

    private void Decide(ChangeStatus status)
    {
        ChangeRegister.Upsert(Record with { Status = status, RespondedAt = DateTimeOffset.UtcNow });
    }

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
