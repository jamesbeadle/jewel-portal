<div class="rounded-xl border border-slate-200 bg-white overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-right text-[10px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-3 py-3 text-left">Package</th>
                <th class="px-3 py-3">Cost Incurred</th>
                <th class="px-3 py-3">Cost Committed</th>
                <th class="px-3 py-3">QS Accruals</th>
                <th class="px-3 py-3">Prelim Forecast</th>
                <th class="px-3 py-3">Cost to Complete</th>
                <th class="px-3 py-3 bg-slate-100">Forecast Final Cost</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 text-right">
            @foreach (var row in Rows)
            {
                <tr>
                    <td class="px-3 py-2 text-left text-slate-900 font-medium">@row.PackageName</td>
                    <td class="px-3 py-2 text-slate-700">@Money(row.CostIncurred)</td>
                    <td class="px-3 py-2 text-slate-700">@Money(row.CostCommitted)</td>
                    <td class="px-3 py-2 text-slate-700">@Money(row.QsAccrualAmount)</td>
                    <td class="px-3 py-2 text-slate-700">@Money(row.PrelimForecast)</td>
                    <td class="px-3 py-2 text-slate-700">@Money(row.CostToComplete)</td>
                    <td class="px-3 py-2 text-slate-900 font-medium bg-slate-50">@Money(row.ForecastFinalCost)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ForecastComponent> Rows { get; set; } = Array.Empty<ForecastComponent>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
