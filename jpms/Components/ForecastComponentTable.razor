<div class="rounded-xl border border-line bg-surface overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-right text-[10px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-3 py-3 text-left">Package</th>
                <th class="px-3 py-3">Cost Incurred</th>
                <th class="px-3 py-3">Cost Committed</th>
                <th class="px-3 py-3">QS Accruals</th>
                <th class="px-3 py-3">Prelim Forecast</th>
                <th class="px-3 py-3">Cost to Complete</th>
                <th class="px-3 py-3 bg-surface-raised">Forecast Final Cost</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line text-right">
            @foreach (var row in Rows)
            {
                <tr>
                    <td class="px-3 py-2 text-left text-content font-medium">@row.PackageName</td>
                    <td class="px-3 py-2 text-content-muted">@Money(row.CostIncurred)</td>
                    <td class="px-3 py-2 text-content-muted">@Money(row.CostCommitted)</td>
                    <td class="px-3 py-2 text-content-muted">@Money(row.QsAccrualAmount)</td>
                    <td class="px-3 py-2 text-content-muted">@Money(row.PrelimForecast)</td>
                    <td class="px-3 py-2 text-content-muted">@Money(row.CostToComplete)</td>
                    <td class="px-3 py-2 text-content font-medium bg-surface-raised">@Money(row.ForecastFinalCost)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ForecastComponent> Rows { get; set; } = Array.Empty<ForecastComponent>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
