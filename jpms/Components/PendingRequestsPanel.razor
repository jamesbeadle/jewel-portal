@inject IAccessRequestStore Requests

<section class="panel overflow-hidden mb-6">
    <header class="panel-header flex items-center justify-between">
        <h2 class="text-sm font-medium text-content">Pending access requests</h2>
        <span class="text-xs text-content-subtle">@PendingRequests.Count</span>
    </header>

    @if (PendingRequests.Count == 0)
    {
        <div class="p-5">
            <p class="text-content-subtle italic text-sm">
                No pending requests. New requests appear here when a signed-in user clicks <em>Request access</em>.
            </p>
        </div>
    }
    else
    {
        <ul class="divide-y divide-line">
            @foreach (var request in PendingRequests)
            {
                <PendingRequestRow Request="request" />
            }
        </ul>
    }
</section>

@code {
    private IReadOnlyList<AccessRequest> PendingRequests => Requests.Pending();
}
