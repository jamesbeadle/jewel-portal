@inject AuthService Auth
@inject ILeadStore LeadStore

<section class="rounded-xl border border-line bg-surface p-5 mb-5">
    <h2 class="text-sm font-medium text-content-muted mb-3">Book a site visit</h2>
    <form @onsubmit="HandleBook" @onsubmit:preventDefault="true" class="space-y-3">
        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Date & time</label>
            <input type="datetime-local" @bind="scheduledAt"
                   class="field" />
        </div>
        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Notes</label>
            <textarea @bind="notes" rows="3"
                      placeholder="Brief for the visit, who needs to attend…"
                      class="field"></textarea>
        </div>
        <button type="submit"
                class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
            Book visit
        </button>
    </form>
</section>

<section class="rounded-xl border border-line bg-surface overflow-hidden">
    <header class="px-5 py-3 border-b border-line bg-surface-raised flex items-center justify-between">
        <h2 class="text-sm font-medium text-content-muted">Recorded visits</h2>
        <span class="text-xs text-content-subtle">@Visits.Count</span>
    </header>
    @if (Visits.Count == 0)
    {
        <p class="p-5 text-sm text-content-subtle italic">No visits booked yet.</p>
    }
    else
    {
        <ul class="divide-y divide-line">
            @foreach (var visit in Visits)
            {
                <li class="p-4 text-sm">
                    <p class="font-medium text-content">@visit.ScheduledAt.LocalDateTime.ToString("dddd d MMM yyyy, HH:mm")</p>
                    <p class="text-content-muted mt-1">@visit.Notes</p>
                    <p class="text-xs text-content-subtle mt-1">@visit.PhotoCount photos · @(visit.IsComplete ? "Complete" : "Booked")</p>
                </li>
            }
        </ul>
    }
</section>

@code {
    [Parameter, EditorRequired] public Lead Lead { get; set; } = default!;

    private DateTime scheduledAt = DateTime.Now.AddDays(3);
    private string notes = "";

    private IReadOnlyList<SiteVisit> Visits =>
        LeadStore.SiteVisitsFor(Lead.LeadId);

    private void HandleBook()
    {
        var visit = new SiteVisit(
            $"SV-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}",
            Lead.LeadId, new DateTimeOffset(scheduledAt, TimeSpan.Zero),
            new[] { Auth.CurrentUser?.Email ?? "" }, notes, 0, false);
        LeadStore.SaveSiteVisit(visit);
        notes = "";
        if (Lead.Stage is LeadStage.Qualified or LeadStage.NewLead)
        {
            LeadStore.Upsert(Lead with { Stage = LeadStage.SurveyBooked });
        }
    }
}
