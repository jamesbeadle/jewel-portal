@inject AuthService Auth
@inject ILeadStore LeadStore

<section class="rounded-xl border border-slate-200 bg-white p-5 mb-5">
    <h2 class="text-sm font-medium text-slate-700 mb-3">Book a site visit</h2>
    <form @onsubmit="HandleBook" @onsubmit:preventDefault="true" class="space-y-3">
        <div>
            <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Date & time</label>
            <input type="datetime-local" @bind="scheduledAt"
                   class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Notes</label>
            <textarea @bind="notes" rows="3"
                      placeholder="Brief for the visit, who needs to attend…"
                      class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"></textarea>
        </div>
        <button type="submit"
                class="rounded-lg bg-slate-900 text-white font-medium text-sm px-4 py-2 hover:bg-slate-800 transition">
            Book visit
        </button>
    </form>
</section>

<section class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <header class="px-5 py-3 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
        <h2 class="text-sm font-medium text-slate-700">Recorded visits</h2>
        <span class="text-xs text-slate-500">@Visits.Count</span>
    </header>
    @if (Visits.Count == 0)
    {
        <p class="p-5 text-sm text-slate-500 italic">No visits booked yet.</p>
    }
    else
    {
        <ul class="divide-y divide-slate-200">
            @foreach (var visit in Visits)
            {
                <li class="p-4 text-sm">
                    <p class="font-medium text-slate-900">@visit.ScheduledAt.LocalDateTime.ToString("dddd d MMM yyyy, HH:mm")</p>
                    <p class="text-slate-600 mt-1">@visit.Notes</p>
                    <p class="text-xs text-slate-500 mt-1">@visit.PhotoCount photos · @(visit.IsComplete ? "Complete" : "Booked")</p>
                </li>
            }
        </ul>
    }
</section>

@code {
    [Parameter, EditorRequired] public Lead Lead { get; set; } = default!;

    private DateTime scheduledAt = DateTime.Now.AddDays(3);
    private string notes = "";

    private IReadOnlyList<SiteVisit> Visits =>
        LeadStore.SiteVisitsFor(Lead.LeadId);

    private void HandleBook()
    {
        var visit = new SiteVisit(
            $"SV-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}",
            Lead.LeadId, new DateTimeOffset(scheduledAt, TimeSpan.Zero),
            new[] { Auth.CurrentUser?.Email ?? "" }, notes, 0, false);
        LeadStore.SaveSiteVisit(visit);
        notes = "";
        if (Lead.Stage is LeadStage.Qualified or LeadStage.NewLead)
        {
            LeadStore.Upsert(Lead with { Stage = LeadStage.SurveyBooked });
        }
    }
}
