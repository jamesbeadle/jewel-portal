<div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-left text-[11px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-4 py-3">Task</th>
                <th class="px-4 py-3 hidden sm:table-cell">Start</th>
                <th class="px-4 py-3 hidden sm:table-cell">End</th>
                <th class="px-4 py-3">Progress</th>
                <th class="px-4 py-3 hidden md:table-cell">BoQ link</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @foreach (var task in Tasks)
            {
                <tr>
                    <td class="px-4 py-3 text-slate-900 font-medium">@task.Title</td>
                    <td class="px-4 py-3 text-slate-600 hidden sm:table-cell">@task.PlannedStart.LocalDateTime.ToString("d MMM")</td>
                    <td class="px-4 py-3 text-slate-600 hidden sm:table-cell">@task.PlannedEnd.LocalDateTime.ToString("d MMM")</td>
                    <td class="px-4 py-3">
                        <div class="flex items-center gap-2 w-32">
                            <div class="flex-1 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                <div class="h-full bg-emerald-500" style="width: @((int)task.ProgressPercent)%"></div>
                            </div>
                            <span class="text-xs text-slate-700 font-medium">@task.ProgressPercent.ToString("0")%</span>
                        </div>
                    </td>
                    <td class="px-4 py-3 hidden md:table-cell">
                        @if (!string.IsNullOrEmpty(task.BoqLineItemId))
                        {
                            <span class="font-mono text-xs text-slate-500">@task.BoqLineItemId</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ProgrammeTask> Tasks { get; set; } = Array.Empty<ProgrammeTask>();
}
