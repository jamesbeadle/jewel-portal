<nav class="border-b border-line mb-6 overflow-x-auto">
    <ul class="flex items-center gap-1 text-sm whitespace-nowrap">
        @foreach (var tab in Tabs)
        {
            <li>
                @if (tab.Enabled)
                {
                    <a href="@HrefFor(tab.Slug)" class="@ClassFor(tab.Slug)">@tab.Label</a>
                }
                else
                {
                    <span class="@DisabledClass" title="Coming soon" aria-disabled="true">@tab.Label</span>
                }
            </li>
        }
    </ul>
</nav>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter, EditorRequired] public string ActiveTab { get; set; } = "overview";

    private record Tab(string Slug, string Label, bool Enabled);

    // Removed tabs (BoQ, Procurement, Mobilisation, H&S, Site, Commercial, Close-out) will be
    // reintroduced here once their functionality is fully scoped.
    // Ordered to follow the commercial flow: requests raise variations, and approved variations land
    // on the valuation report (which also carries valuation invoices — the old Cash Calls tab).
    private static readonly Tab[] Tabs =
    {
        new("overview",            "Overview",            true),
        new("requests",            "Requests",            true),
        new("variations",          "Variations",          true),
        new("valuation",           "Valuation Report",    true),
        new("bid-package-invites", "Bid Package Invites", true),
        new("schedule",            "Schedule",            true),
        new("financials",          "Financials",          true),
        new("drawings",            "Drawings",            true)
    };

    private string HrefFor(string slug) =>
        slug == "overview" ? $"/projects/{ProjectId}" : $"/projects/{ProjectId}/{slug}";

    private const string DisabledClass =
        "inline-block px-3 py-2 border-b-2 border-transparent text-content-subtle/40 cursor-not-allowed select-none";

    private string ClassFor(string slug)
    {
        var isActive = slug == ActiveTab;
        if (isActive)
        {
            return "inline-block px-3 py-2 border-b-2 border-accent text-content font-medium";
        }
        return "inline-block px-3 py-2 border-b-2 border-transparent text-content-subtle hover:text-content hover:border-line-strong";
    }
}
