@using Jewel.JPMS.Features.Projects
@inject ProjectListReadModel Projects
@inject PortalContext PortalContext
@implements IDisposable

<section class="rounded-xl border border-slate-200 bg-white p-5 mb-5">
    <p class="text-xs uppercase tracking-wider text-slate-500 font-semibold mb-2">Demo mode</p>
    <h2 class="text-sm font-medium text-slate-700 mb-2">Choose your project</h2>
    <p class="text-sm text-slate-600 mb-3">
        In production each client opens their project from a personalised secure link.
    </p>
    <div class="flex flex-wrap items-center gap-2">
        <select @bind="selectedId" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
            <option value="">— Select project —</option>
            @foreach (var project in Projects.Current ?? Array.Empty<Project>())
            {
                <option value="@project.ProjectId">@project.Name · @project.ClientName</option>
            }
        </select>
        <button type="button" @onclick="Apply"
                class="rounded-lg bg-slate-900 text-white font-medium text-sm px-3 py-2 hover:bg-slate-800 transition"
                disabled="@string.IsNullOrEmpty(selectedId)">
            Continue
        </button>
    </div>
</section>

@code {
    private string selectedId = "";

    protected override async Task OnInitializedAsync()
    {
        selectedId = PortalContext.ActingClientProjectId ?? "";
        Projects.OnChanged += StateHasChanged;
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
    }

    public void Dispose() => Projects.OnChanged -= StateHasChanged;

    private void Apply()
    {
        if (string.IsNullOrEmpty(selectedId)) return;
        PortalContext.ActAsClientOn(selectedId);
    }
}
