@inject IProcurementStore ProcurementStore
@inject NavigationManager Nav

<section class="rounded-xl border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-medium text-slate-700 mb-3">Submit your quote</h2>

    @if (existing is not null)
    {
        <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-4 mb-4">
            <p class="text-sm font-medium text-emerald-900">Quote submitted</p>
            <p class="text-sm text-emerald-800 mt-1">@Money(existing.Value) · @existing.ReceivedAt.LocalDateTime.ToString("d MMM yyyy")</p>
            @if (!string.IsNullOrWhiteSpace(existing.Notes))
            {
                <p class="text-sm text-emerald-800 mt-1">@existing.Notes</p>
            }
        </div>
    }

    <form @onsubmit="HandleSubmit" @onsubmit:preventDefault="true" class="space-y-3">
        <div>
            <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Quote value (GBP) *</label>
            <input type="number" min="0" step="0.01" @bind="value" required
                   class="w-48 rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        </div>
        <div>
            <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Notes</label>
            <textarea @bind="notes" rows="3"
                      placeholder="Assumptions, exclusions, lead time…"
                      class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"></textarea>
        </div>
        <div class="flex items-center gap-2">
            <button type="submit"
                    class="rounded-lg bg-slate-900 text-white font-medium text-sm px-4 py-2 hover:bg-slate-800 transition">
                @(existing is null ? "Submit quote" : "Update quote")
            </button>
            <button type="button" @onclick="HandleDecline"
                    class="rounded-lg border border-slate-200 bg-white text-slate-700 font-medium text-sm px-4 py-2 hover:border-slate-300 transition">
                Decline to quote
            </button>
        </div>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public BidPackage Package { get; set; } = default!;
    [Parameter, EditorRequired] public string SubcontractorId { get; set; } = "";

    private decimal value;
    private string notes = "";
    private Quote? existing;

    protected override void OnParametersSet()
    {
        existing = ProcurementStore.QuotesFor(Package.BidPackageId)
            .FirstOrDefault(q => q.SubcontractorId == SubcontractorId);
        value = existing?.Value ?? 0m;
        notes = existing?.Notes ?? "";
    }

    private void HandleSubmit() => Save(isDeclined: false);

    private void HandleDecline() => Save(isDeclined: true);

    private void Save(bool isDeclined)
    {
        if (string.IsNullOrEmpty(SubcontractorId)) return;
        var quote = new Quote(
            existing?.QuoteId ?? $"QT-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}",
            Package.BidPackageId, SubcontractorId, value, notes,
            DateTimeOffset.UtcNow, isDeclined);
        ProcurementStore.SaveQuote(quote);
        Nav.NavigateTo("/portal/subcontractor/bids");
    }

    private static string Money(decimal money) =>
        money.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
