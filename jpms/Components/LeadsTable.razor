@inject NavigationManager Nav

<div class="rounded-xl border border-line bg-surface overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-4 py-3">Reference</th>
                <th class="px-4 py-3">Contact</th>
                <th class="px-4 py-3 hidden md:table-cell">Site</th>
                <th class="px-4 py-3 hidden lg:table-cell">Source</th>
                <th class="px-4 py-3 hidden lg:table-cell">Value</th>
                <th class="px-4 py-3">Stage</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @foreach (var lead in Leads)
            {
                <tr class="hover:bg-surface-raised cursor-pointer transition"
                    @onclick="() => OpenLead(lead.LeadId)">
                    <td class="px-4 py-3 font-mono text-xs text-content-muted">@lead.Reference</td>
                    <td class="px-4 py-3 text-content font-medium">@lead.ContactName</td>
                    <td class="px-4 py-3 text-content-muted hidden md:table-cell">@lead.SiteAddress</td>
                    <td class="px-4 py-3 text-content-muted hidden lg:table-cell">@lead.Source.DisplayName()</td>
                    <td class="px-4 py-3 text-content-muted hidden lg:table-cell">@FormatValue(lead.EstimatedValue)</td>
                    <td class="px-4 py-3"><LeadStageBadge Stage="lead.Stage" /></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Lead> Leads { get; set; } = Array.Empty<Lead>();

    private void OpenLead(string leadId) => Nav.NavigateTo($"/leads/{leadId}");

    private static string FormatValue(decimal? value) =>
        value is null ? "—" : value.Value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
