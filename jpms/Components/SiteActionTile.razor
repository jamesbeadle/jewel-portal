<a href="@Href"
   class="block rounded-2xl border border-line bg-surface p-5 active:bg-surface-raised transition shadow-sm">
    <div class="flex items-center gap-3">
        <span class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-accent text-accent-ink text-2xl shrink-0"
              aria-hidden="true">
            @Glyph
        </span>
        <div class="min-w-0">
            <p class="text-base font-semibold text-content">@Label</p>
            @if (!string.IsNullOrEmpty(Detail))
            {
                <p class="text-xs text-content-subtle mt-0.5">@Detail</p>
            }
        </div>
    </div>
</a>

@code {
    [Parameter, EditorRequired] public string Href { get; set; } = "";
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Glyph { get; set; } = "";
    [Parameter] public string Detail { get; set; } = "";
}
