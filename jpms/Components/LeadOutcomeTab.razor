@inject AuthService Auth
@inject ILeadStore LeadStore
@inject IProjectStore ProjectStore
@inject NavigationManager Nav

<section class="rounded-xl border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-medium text-slate-700 mb-3">Lead outcome</h2>

    @if (existing is not null)
    {
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 mb-4">
            <p class="text-sm font-medium text-slate-900">
                @(existing.IsWon ? "Won" : "Lost") — @existing.DecidedAt.LocalDateTime.ToString("d MMM yyyy")
            </p>
            <p class="text-sm text-slate-700 mt-1">@existing.Reason</p>
            @if (existing.IsWon && !string.IsNullOrEmpty(existing.CreatedProjectId))
            {
                <p class="text-xs mt-2">
                    <a class="text-slate-900 underline" href="@($"/projects/{existing.CreatedProjectId}")">
                        Open project shell →
                    </a>
                </p>
            }
        </div>
    }

    <form @onsubmit="HandleSave" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="flex items-center gap-4">
            <label class="inline-flex items-center gap-2 text-sm">
                <input type="radio" name="outcomeChoice" checked="@isWon"
                       @onchange="() => isWon = true" /> Won
            </label>
            <label class="inline-flex items-center gap-2 text-sm">
                <input type="radio" name="outcomeChoice" checked="@(!isWon)"
                       @onchange="() => isWon = false" /> Lost
            </label>
        </div>
        <div>
            <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Reason</label>
            <textarea @bind="reason" rows="3"
                      class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"></textarea>
        </div>
        <button type="submit"
                class="rounded-lg bg-slate-900 text-white font-medium text-sm px-4 py-2 hover:bg-slate-800 transition">
            @(isWon ? "Mark Won & create project shell" : "Mark Lost")
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public Lead Lead { get; set; } = default!;

    private bool isWon = true;
    private string reason = "";
    private LeadOutcome? existing;

    protected override void OnParametersSet()
    {
        existing = LeadStore.GetOutcome(Lead.LeadId);
        isWon = existing?.IsWon ?? true;
        reason = existing?.Reason ?? "";
    }

    private void HandleSave()
    {
        string? projectId = isWon ? CreateProjectShell() : null;
        var outcome = new LeadOutcome(
            Lead.LeadId, isWon, reason,
            Auth.CurrentUser?.Email ?? "unknown", DateTimeOffset.UtcNow, projectId);
        LeadStore.SaveOutcome(outcome);
        LeadStore.Upsert(Lead with { Stage = isWon ? LeadStage.Won : LeadStage.Lost });
        if (projectId is not null) Nav.NavigateTo($"/projects/{projectId}");
    }

    private string CreateProjectShell()
    {
        var projectId = $"PRJ-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}";
        var existingProjectCount = ProjectStore.All().Count;
        var reference = $"JBB-{DateTime.UtcNow:yyyy}-{existingProjectCount + 1:000}";
        var project = new Project(
            projectId, reference,
            Lead.SiteAddress,
            string.IsNullOrWhiteSpace(Lead.CompanyName) ? Lead.ContactName : Lead.CompanyName,
            Organisation.JewelBespokeBuild,
            ProjectStage.PreConstruction,
            Lead.OwnerEmail, DateTimeOffset.UtcNow);
        ProjectStore.Upsert(project);
        return projectId;
    }
}
