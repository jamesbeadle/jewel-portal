@using Jewel.JPMS.Cqrs
@using Jewel.JPMS.Contracts.Projects
@using Jewel.JPMS.Features.Projects
@inject AuthService Auth
@inject ILeadStore LeadStore
@inject ICommandSender Commands
@inject ProjectListReadModel Projects
@inject NavigationManager Nav

<section class="rounded-xl border border-line bg-surface p-5">
    <h2 class="text-sm font-medium text-content-muted mb-3">Lead outcome</h2>

    @if (existing is not null)
    {
        <div class="rounded-lg border border-line bg-surface-raised p-4 mb-4">
            <p class="text-sm font-medium text-content">
                @(existing.IsWon ? "Won" : "Lost") — @existing.DecidedAt.LocalDateTime.ToString("d MMM yyyy")
            </p>
            <p class="text-sm text-content-muted mt-1">@existing.Reason</p>
            @if (existing.IsWon && !string.IsNullOrEmpty(existing.CreatedProjectId))
            {
                <p class="text-xs mt-2">
                    <a class="text-content underline" href="@($"/projects/{existing.CreatedProjectId}")">
                        Open project shell →
                    </a>
                </p>
            }
        </div>
    }

    <form @onsubmit="HandleSave" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="flex items-center gap-4">
            <label class="inline-flex items-center gap-2 text-sm">
                <input type="radio" name="outcomeChoice" checked="@isWon"
                       @onchange="() => isWon = true" /> Won
            </label>
            <label class="inline-flex items-center gap-2 text-sm">
                <input type="radio" name="outcomeChoice" checked="@(!isWon)"
                       @onchange="() => isWon = false" /> Lost
            </label>
        </div>
        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Reason</label>
            <textarea @bind="reason" rows="3"
                      class="field"></textarea>
        </div>
        <button type="submit"
                class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
            @(isWon ? "Mark Won & create project shell" : "Mark Lost")
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public Lead Lead { get; set; } = default!;

    private bool isWon = true;
    private string reason = "";
    private LeadOutcome? existing;

    protected override void OnParametersSet()
    {
        existing = LeadStore.GetOutcome(Lead.LeadId);
        isWon = existing?.IsWon ?? true;
        reason = existing?.Reason ?? "";
    }

    private async Task HandleSave()
    {
        string? projectId = isWon ? await CreateWonProjectShell() : null;
        var outcome = new LeadOutcome(
            Lead.LeadId, isWon, reason,
            Auth.CurrentUser?.Email ?? "unknown", DateTimeOffset.UtcNow, projectId);
        LeadStore.SaveOutcome(outcome);
        LeadStore.Upsert(Lead with { Stage = isWon ? LeadStage.Won : LeadStage.Lost });
        if (projectId is not null) Nav.NavigateTo($"/projects/{projectId}");
    }

    private async Task<string> CreateWonProjectShell()
    {
        await Projects.RefreshAsync(CancellationToken.None);
        var existingProjectCount = Projects.Current?.Count ?? 0;
        var reference = $"JBB-{DateTime.UtcNow:yyyy}-{existingProjectCount + 1:000}";
        var clientName = string.IsNullOrWhiteSpace(Lead.CompanyName) ? Lead.ContactName : Lead.CompanyName;
        var createdProject = await Commands.SendAsync(
            new CreateProjectShell(reference, Lead.SiteAddress, clientName, Organisation.JewelBespokeBuild, Lead.OwnerEmail),
            CancellationToken.None);
        await Projects.RefreshAsync(CancellationToken.None);
        return createdProject.ProjectId;
    }
}
