@inject IProjectStore ProjectStore

@if (Project is null)
{
    <section class="max-w-4xl mx-auto px-4 py-12">
        <h1 class="text-2xl font-semibold text-slate-900 mb-2">Project not found</h1>
        <p class="text-slate-700">
            <a class="text-slate-900 underline" href="/projects">Back to projects</a>.
        </p>
    </section>
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/projects" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Projects</a>
            <span class="text-slate-400 mx-2">/</span>
            <a href="@($"/projects/{Project.ProjectId}")" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">@Project.Reference</a>
        </nav>

        <header class="mb-4">
            <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1 font-mono">@Project.Reference</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900 leading-tight">@Project.Name</h1>
            <p class="text-sm text-slate-600 mt-1">@Project.ClientName · @Project.Organisation.ShortCode() · <ProjectStageBadge Stage="Project.Stage" /></p>
        </header>

        <ProjectTabNav ProjectId="Project.ProjectId" ActiveTab="@ActiveTab" />

        @ChildContent
    </section>
}

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter, EditorRequired] public string ActiveTab { get; set; } = "overview";
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private Project? Project => ProjectStore.Find(ProjectId);
}
