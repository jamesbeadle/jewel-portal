@using Jewel.JPMS.Features.Projects
@inject ProjectListReadModel Projects
@inject CurrentProjectService CurrentProject
@inject NavigationManager Nav
@implements IDisposable

@if (Projects.Current is null)
{
    @* The project list hasn't loaded yet — render a quiet loading state rather than
       flashing "Project not found" before the data arrives. *@
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (Project is null)
{
    <section class="px-6 md:px-8 py-12">
        <h1 class="text-2xl font-semibold text-content mb-2">Project not found</h1>
        <p class="text-content-muted">
            <a class="text-content underline" href="/projects">Back to projects</a>.
        </p>
    </section>
}
else
{
    <section class="px-6 md:px-8 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/projects" class="text-content-subtle hover:text-content underline underline-offset-4">Projects</a>
            <span class="text-content-subtle mx-2">/</span>
            <a href="@($"/projects/{Project.ProjectId}")" class="text-content-subtle hover:text-content underline underline-offset-4">@Project.Reference</a>
        </nav>

        <header class="mb-4">
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1 font-mono">@Project.Reference</p>
            <div class="flex items-center gap-2">
                @* Cycle through active (non-Completed) projects by reference, looping at either
                   end, staying on the current tab. Hidden when there's nowhere else to go. *@
                @if (Neighbour(-1) is { } previous)
                {
                    <button type="button" @onclick="() => GoTo(previous)"
                            aria-label="Previous project" title="@($"{previous.Reference} · {previous.Name}")"
                            class="inline-flex items-center justify-center w-8 h-8 rounded-md text-content-subtle hover:text-content hover:bg-surface-raised shrink-0">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 6l-6 6 6 6" /></svg>
                    </button>
                }

                @* The title doubles as the project switcher: click it for the full list of active
                   projects, or step with the arrows either side. *@
                <div class="relative">
                    <button type="button" @onclick="() => switcherOpen = !switcherOpen"
                            class="flex items-center gap-2 rounded-lg px-1 -mx-1 hover:bg-surface-raised transition"
                            aria-haspopup="listbox" aria-expanded="@switcherOpen" title="Switch project">
                        <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">@Project.Name</h1>
                        <svg class="w-5 h-5 text-content-subtle shrink-0 transition-transform @(switcherOpen ? "rotate-180" : "")"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6" /></svg>
                    </button>

                    @if (switcherOpen)
                    {
                        @* Click-away layer, then the list. *@
                        <button type="button" class="fixed inset-0 z-30 cursor-default" aria-hidden="true"
                                @onclick="() => switcherOpen = false" tabindex="-1"></button>
                        <div class="absolute left-0 top-full z-40 mt-2 w-80 max-h-96 overflow-y-auto rounded-xl border border-line bg-surface shadow-lg py-1"
                             role="listbox">
                            @foreach (var candidate in Cycle)
                            {
                                var isCurrent = string.Equals(candidate.ProjectId, ProjectId, StringComparison.OrdinalIgnoreCase);
                                <button type="button" role="option" aria-selected="@isCurrent"
                                        class="w-full text-left px-3 py-2 text-sm transition @(isCurrent ? "bg-surface-raised text-content font-semibold" : "text-content-muted hover:text-content hover:bg-surface-raised")"
                                        @onclick="() => SwitchTo(candidate)">
                                    <span class="font-mono text-xs text-content-subtle mr-2">@candidate.Reference</span>@candidate.Name
                                </button>
                            }
                        </div>
                    }
                </div>

                @if (Neighbour(1) is { } next)
                {
                    <button type="button" @onclick="() => GoTo(next)"
                            aria-label="Next project" title="@($"{next.Reference} · {next.Name}")"
                            class="inline-flex items-center justify-center w-8 h-8 rounded-md text-content-subtle hover:text-content hover:bg-surface-raised shrink-0">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6" /></svg>
                    </button>
                }
            </div>
            <p class="text-sm text-content-muted mt-1">@Project.ClientName · @Project.Organisation.ShortCode() · <ProjectStageBadge Stage="Project.Stage" /></p>
        </header>

        <ProjectTabNav ProjectId="@Project.ProjectId" ActiveTab="@ActiveTab" />

        @ChildContent
    </section>
}

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    // Empty on the project landing page (the section cards) — ProjectTabNav renders nothing there.
    [Parameter] public string ActiveTab { get; set; } = "";
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool switcherOpen;

    private Project? Project => Projects.Find(ProjectId);

    // The switcher/arrow loop: active (non-Completed) projects ordered by reference.
    private List<Project> Cycle =>
        (Projects.Current ?? (IReadOnlyList<Project>)Array.Empty<Project>())
            .Where(project => project.Stage != ProjectStage.Completed)
            .OrderBy(project => project.Reference, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private Project? Neighbour(int step)
    {
        var cycle = Cycle;
        var index = cycle.FindIndex(project =>
            string.Equals(project.ProjectId, ProjectId, StringComparison.OrdinalIgnoreCase));

        // Viewing a Completed project (not in the loop): both arrows enter the loop at its
        // nearest end rather than disappearing entirely.
        if (index < 0)
            return cycle.Count == 0 ? null : (step > 0 ? cycle[0] : cycle[^1]);

        if (cycle.Count < 2) return null;
        return cycle[(index + step + cycle.Count) % cycle.Count];
    }

    private void SwitchTo(Project project)
    {
        switcherOpen = false;
        if (!string.Equals(project.ProjectId, ProjectId, StringComparison.OrdinalIgnoreCase))
            GoTo(project);
    }

    private void GoTo(Project project) =>
        Nav.NavigateTo(string.IsNullOrEmpty(ActiveTab)
            ? $"/projects/{project.ProjectId}"
            : $"/projects/{project.ProjectId}/{ActiveTab}");

    protected override async Task OnInitializedAsync()
    {
        Projects.OnChanged += StateHasChanged;
        // Every project page passing through the shell marks its project as the one the user is
        // working on — the side nav's project-scoped entries follow it.
        _ = CurrentProject.RememberAsync(ProjectId);
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
        else _ = RefreshInBackgroundAsync(); // stale-while-revalidate: header/stage update on tab nav
    }

    private async Task RefreshInBackgroundAsync()
    {
        // Fire-and-forget must swallow failures: the cached list is still shown, and the next
        // navigation retries.
        try { await Projects.RefreshAsync(CancellationToken.None); }
        catch { }
    }

    public void Dispose() => Projects.OnChanged -= StateHasChanged;
}
