<div class="mb-2 flex items-center justify-end">
    <ExportToExcelButton FileName="Leads by source"
                         Disabled="@(Rows.Count == 0)"
                         BuildWorkbook="BuildExportWorkbook" />
</div>
<div class="rounded-xl border border-line bg-surface overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Source</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right">Leads</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right">Won</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right">Win rate</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right">Pipeline value</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @foreach (var row in Rows)
            {
                <tr>
                    <td class="px-4 py-3 text-content font-medium">@row.Source.DisplayName()</td>
                    <td class="px-4 py-3 text-right text-content-muted">@row.Count</td>
                    <td class="px-4 py-3 text-right text-content-muted">@row.Won</td>
                    <td class="px-4 py-3 text-right text-content-muted">@row.WinRate</td>
                    <td class="px-4 py-3 text-right text-content-muted">@FormatValue(row.PipelineValue)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Lead> Leads { get; set; } = Array.Empty<Lead>();

    private record SourceRow(LeadSource Source, int Count, int Won, string WinRate, decimal PipelineValue);

    private IReadOnlyList<SourceRow> Rows =>
        Leads
            .GroupBy(lead => lead.Source)
            .Select(group => new SourceRow(
                group.Key,
                group.Count(),
                group.Count(lead => lead.Stage == LeadStage.Won),
                group.Any() ? $"{100.0 * group.Count(lead => lead.Stage == LeadStage.Won) / group.Count():0}%" : "—",
                group.Sum(lead => lead.EstimatedValue ?? 0)))
            .OrderByDescending(row => row.PipelineValue)
            .ToList()
            .AsReadOnly();

    private static string FormatValue(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private ExcelWorkbook? BuildExportWorkbook(bool _)
    {
        var rows = Rows;
        if (rows.Count == 0) return null;

        var workbook = new ExcelWorkbook();
        var sheet = workbook.AddSheet("Leads by source",
            new ExcelColumn("Source"),
            new ExcelColumn("Leads", ExcelFormat.Integer),
            new ExcelColumn("Won", ExcelFormat.Integer),
            new ExcelColumn("Win rate", ExcelFormat.Percent),
            new ExcelColumn("Pipeline value", ExcelFormat.Currency));

        foreach (var row in rows)
        {
            sheet.AddRow(
                row.Source.DisplayName(),
                row.Count,
                row.Won,
                row.Count > 0 ? (decimal)row.Won / row.Count : (decimal?)null,
                row.PipelineValue);
        }
        return workbook;
    }
}
