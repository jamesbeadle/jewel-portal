<div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-left text-[11px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-4 py-3">Source</th>
                <th class="px-4 py-3 text-right">Leads</th>
                <th class="px-4 py-3 text-right">Won</th>
                <th class="px-4 py-3 text-right">Win rate</th>
                <th class="px-4 py-3 text-right">Pipeline value</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @foreach (var row in Rows)
            {
                <tr>
                    <td class="px-4 py-3 text-slate-900 font-medium">@row.Source.DisplayName()</td>
                    <td class="px-4 py-3 text-right text-slate-700">@row.Count</td>
                    <td class="px-4 py-3 text-right text-slate-700">@row.Won</td>
                    <td class="px-4 py-3 text-right text-slate-700">@row.WinRate</td>
                    <td class="px-4 py-3 text-right text-slate-700">@FormatValue(row.PipelineValue)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Lead> Leads { get; set; } = Array.Empty<Lead>();

    private record SourceRow(LeadSource Source, int Count, int Won, string WinRate, decimal PipelineValue);

    private IReadOnlyList<SourceRow> Rows =>
        Leads
            .GroupBy(lead => lead.Source)
            .Select(group => new SourceRow(
                group.Key,
                group.Count(),
                group.Count(lead => lead.Stage == LeadStage.Won),
                group.Any() ? $"{100.0 * group.Count(lead => lead.Stage == LeadStage.Won) / group.Count():0}%" : "—",
                group.Sum(lead => lead.EstimatedValue ?? 0)))
            .OrderByDescending(row => row.PipelineValue)
            .ToList()
            .AsReadOnly();

    private static string FormatValue(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
