@inject ILeadStore LeadStore

<section class="rounded-xl border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-medium text-slate-700 mb-3">Move stage</h2>
    <p class="text-xs text-slate-500 mb-3">
        Each tab progresses the lead automatically when its action is completed. Use this only to correct a stage manually.
    </p>
    <div class="flex flex-wrap items-center gap-2">
        <select @bind="selectedStage"
                class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
            @foreach (var stage in Enum.GetValues<LeadStage>())
            {
                <option value="@stage">@stage.DisplayName()</option>
            }
        </select>
        <button type="button" @onclick="HandleSave"
                class="rounded-lg bg-slate-900 text-white font-medium text-sm px-3 py-2 hover:bg-slate-800 transition">
            Update stage
        </button>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public Lead Lead { get; set; } = default!;

    private LeadStage selectedStage;

    protected override void OnParametersSet() => selectedStage = Lead.Stage;

    private void HandleSave()
    {
        if (selectedStage == Lead.Stage) return;
        LeadStore.Upsert(Lead with { Stage = selectedStage });
    }
}
