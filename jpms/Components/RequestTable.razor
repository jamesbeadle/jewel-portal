@inject NavigationManager Nav

<div class="rounded-xl border border-line bg-surface overflow-x-auto overflow-y-auto max-h-[85vh]">
    <table class="w-full text-sm data-table">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                @if (SelectionEnabled)
                {
                    <th class="sticky top-0 z-20 bg-surface-raised pl-4 pr-1 py-3 w-8">
                        <input type="checkbox" class="cursor-pointer align-middle"
                               title="Select all shown"
                               checked="@AllSelectableSelected"
                               disabled="@(!SelectableRecords.Any())"
                               @onchange="e => OnToggleSelectAll.InvokeAsync((bool)e.Value!)" />
                    </th>
                }
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Ref</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden sm:table-cell">Kind</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Subject</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden lg:table-cell">Raised To</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden xl:table-cell">Drawing / Detail</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden lg:table-cell">Issued</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden lg:table-cell">Response Due</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right hidden md:table-cell">Days Out</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right hidden md:table-cell">Value</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Status</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @foreach (var record in Records)
            {
                <tr class="align-top @(CanOpen ? "is-clickable cursor-pointer" : "")" @onclick="() => Open(record)">
                    @if (SelectionEnabled)
                    {
                        <td class="pl-4 pr-1 py-3 w-8" @onclick:stopPropagation="true">
                            @if (IsSelectable(record))
                            {
                                <input type="checkbox" class="cursor-pointer align-middle"
                                       checked="@SelectedIds.Contains(record.RequestId)"
                                       @onchange="() => OnToggleSelect.InvokeAsync(record)" />
                            }
                        </td>
                    }
                    <td class="px-4 py-3 font-mono text-xs text-content-muted whitespace-nowrap">@record.Reference</td>
                    <td class="px-4 py-3 text-content-muted hidden sm:table-cell whitespace-nowrap" title="@record.Kind.LongName()">@record.Kind.DisplayName()</td>
                    <td class="px-4 py-3 text-content font-medium">
                        @record.Title
                        @* One variation badge, two states: linked (clickable, carries the VOQ/VO ref
                           and jumps to the variation) or flagged-only (plain amber — the RFI implies
                           a variation but no VOQ/VO is attached yet). *@
                        @if (CanOpen && LinkedVoqs is not null && LinkedVoqs.TryGetValue(record.RequestId, out var linkedVoq))
                        {
                            <a class="ml-1.5 inline-flex items-center rounded bg-amber-500/10 border border-amber-500/30 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-600 hover:underline underline-offset-2"
                               title="Costed into @linkedVoq.Reference — open the variation"
                               href="@VoqHref(linkedVoq)"
                               @onclick:stopPropagation="true">Variation · @linkedVoq.Reference</a>
                        }
                        else if (record.ImpliesVariation)
                        {
                            <span class="ml-1.5 inline-flex items-center rounded bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-600"
                                  title="Implies a variation — no VOQ/VO linked yet. Open the record to link one.">Variation</span>
                        }
                        @if (record.CriticalPath)
                        {
                            <span class="ml-1.5 inline-flex items-center rounded bg-rose-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-rose-600"
                                  title="Programme-related — the answer gates work on the programme's critical path">Critical path</span>
                        }
                        @if (record.MergedIntoRequestId is not null)
                        {
                            <span class="ml-1.5 inline-flex items-center rounded bg-surface-raised border border-line px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-content-muted"
                                  title="Merged into another request — its conversation, queries and emails live there now">Merged</span>
                        }
                    </td>
                    <td class="px-4 py-3 text-content-muted hidden lg:table-cell whitespace-nowrap">@Dash(record.RaisedTo)</td>
                    <td class="px-4 py-3 text-content-subtle hidden xl:table-cell font-mono text-xs">@Dash(record.DrawingRef)</td>
                    @* The user-set issue date once recorded; falls back to the raised date until one is set. *@
                    <td class="px-4 py-3 text-content-subtle hidden lg:table-cell whitespace-nowrap">@((record.IssuedAt ?? record.RaisedAt).LocalDateTime.ToString("d MMM yyyy"))</td>
                    <td class="px-4 py-3 text-content-subtle hidden lg:table-cell whitespace-nowrap">@Date(record.ResponseDue)</td>
                    <td class="px-4 py-3 text-right hidden md:table-cell whitespace-nowrap">
                        @if (record.DaysOutstanding is int days)
                        {
                            <span class="@(record.IsOverdue ? "text-red-600 font-semibold" : "text-content-muted")">@days</span>
                        }
                        else
                        {
                            <span class="text-content-subtle">—</span>
                        }
                    </td>
                    <td class="px-4 py-3 text-right text-content-muted hidden md:table-cell whitespace-nowrap">
                        @(record.Value is null ? "—" : Money(record.Value.Value))
                    </td>
                    <td class="px-4 py-3" @onclick:stopPropagation="true">
                        @if (CanChangeStatus)
                        {
                            @* The chip doubles as the status control (same as the detail page's pill):
                               click it, pick the new status. The cell swallows the click so changing
                               a status never also navigates into the row. *@
                            <div class="relative">
                                <button type="button"
                                        class="inline-flex items-center gap-1 whitespace-nowrap rounded-full px-2 py-0.5 text-[11px] font-medium @StatusClass(record.Status)"
                                        title="Change status"
                                        disabled="@(StatusBusyRequestId == record.RequestId)"
                                        @onclick="() => ToggleStatusMenu(record.RequestId)">
                                    @StatusLabel(record.Status) <span class="text-[9px]" aria-hidden="true">▾</span>
                                </button>
                                @if (statusMenuRequestId == record.RequestId)
                                {
                                    <div class="absolute right-0 mt-2 w-48 rounded-lg border border-line bg-surface shadow-lg z-30 overflow-hidden">
                                        <ul class="divide-y divide-line">
                                            @foreach (var option in StatusOptions)
                                            {
                                                var status = option;
                                                var isCurrent = status == record.Status;
                                                <li>
                                                    <button type="button"
                                                            class="w-full text-left px-3 py-2 text-sm transition @(isCurrent ? "text-content-subtle cursor-default" : "text-content hover:bg-surface-raised")"
                                                            disabled="@isCurrent"
                                                            title="@StatusHint(status)"
                                                            @onclick="() => PickStatus(record, status)">
                                                        @StatusLabel(status)@(isCurrent ? " ✓" : "")
                                                    </button>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="inline-flex items-center whitespace-nowrap rounded-full px-2 py-0.5 text-[11px] font-medium @StatusClass(record.Status)">
                                @StatusLabel(record.Status)
                            </span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Request> Records { get; set; } = Array.Empty<Request>();
    [Parameter] public string? ProjectId { get; set; }

    // Optional bulk selection: the parent owns the selected-id set and decides which rows may be
    // selected (the register limits it to RFIs). Checkbox cells stop click propagation so ticking
    // a row doesn't also navigate into it.
    [Parameter] public bool SelectionEnabled { get; set; }

    /// <summary>A linked VOQ/VO per request id — the register passes these so an RFI row's
    /// Variation badge can jump straight to the variation that prices it (and back, via the
    /// variation's Request column). Null when the caller has no variation context.</summary>
    public sealed record LinkedVoq(string VariationOrderQuoteId, string Reference, bool HasVariationOrder);
    [Parameter] public IReadOnlyDictionary<string, LinkedVoq>? LinkedVoqs { get; set; }

    // Land on the VO panel when one has been raised — the money lives there, not on the quote.
    private string VoqHref(LinkedVoq linked) =>
        $"/projects/{ProjectId}/voq/{linked.VariationOrderQuoteId}{(linked.HasVariationOrder ? "?focus=vo" : "")}";
    [Parameter] public Func<Request, bool>? RowSelectable { get; set; }
    [Parameter] public IReadOnlyCollection<string> SelectedIds { get; set; } = Array.Empty<string>();
    [Parameter] public EventCallback<Request> OnToggleSelect { get; set; }
    [Parameter] public EventCallback<bool> OnToggleSelectAll { get; set; }

    // Optional in-row status changes: the parent owns the actual command (and its safeguards —
    // closing still goes through the agent gate there); this component only renders the picker.
    [Parameter] public bool CanChangeStatus { get; set; }
    [Parameter] public EventCallback<(Request Record, RequestStatus Status)> OnStatusChange { get; set; }
    /// <summary>The request whose status change is in flight — its chip is disabled meanwhile.</summary>
    [Parameter] public string? StatusBusyRequestId { get; set; }

    // The row whose status dropdown is open (same dismiss pattern as the app's other menus:
    // every pick closes it, the toggle is the dismiss).
    private string? statusMenuRequestId;

    // Lifecycle order: the ball starts with us (Needs action), goes to the correspondent (Open),
    // may come back needing a variation order quote (Needs variation), then closes.
    private static readonly RequestStatus[] StatusOptions =
    {
        RequestStatus.NeedsAction, RequestStatus.Open,
        RequestStatus.NeedsVariation, RequestStatus.Closed
    };

    private void ToggleStatusMenu(string requestId) =>
        statusMenuRequestId = statusMenuRequestId == requestId ? null : requestId;

    private async Task PickStatus(Request record, RequestStatus status)
    {
        statusMenuRequestId = null;
        if (status == record.Status) return;
        await OnStatusChange.InvokeAsync((record, status));
    }

    private static string? StatusHint(RequestStatus status) => status switch
    {
        RequestStatus.Closed => "Closes with today's date — the agent gate still applies. Open the record to close against an earlier date.",
        _ => status.Hint()
    };

    private bool IsSelectable(Request record) => RowSelectable?.Invoke(record) ?? true;

    private IEnumerable<Request> SelectableRecords => Records.Where(IsSelectable);

    private bool AllSelectableSelected =>
        SelectableRecords.Any() && SelectableRecords.All(r => SelectedIds.Contains(r.RequestId));

    private bool CanOpen => !string.IsNullOrWhiteSpace(ProjectId);

    private void Open(Request record)
    {
        if (CanOpen)
            Nav.NavigateTo($"/projects/{ProjectId}/requests/view/{record.RequestId}");
    }

    private static string Dash(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string Date(DateTimeOffset? value) =>
        value is null ? "—" : value.Value.LocalDateTime.ToString("d MMM yyyy");

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string StatusLabel(RequestStatus status) => status.DisplayName();

    private static string StatusClass(RequestStatus status) => status switch
    {
        RequestStatus.NeedsAction    => "bg-amber-500/10 text-amber-600",
        RequestStatus.Open           => "bg-blue-500/10 text-blue-600",
        RequestStatus.NeedsVariation => "bg-violet-500/10 text-violet-600",
        RequestStatus.Closed         => "bg-surface-raised border border-line text-content-muted",
        _                            => "bg-surface-raised border border-line text-content-muted"
    };
}
