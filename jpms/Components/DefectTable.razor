<div class="rounded-xl border border-line bg-surface overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-4 py-3">Description</th>
                <th class="px-4 py-3 hidden sm:table-cell">Location</th>
                <th class="px-4 py-3 hidden md:table-cell">Assigned</th>
                <th class="px-4 py-3">Status</th>
                <th class="px-4 py-3 hidden lg:table-cell">Raised</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @foreach (var defect in Defects)
            {
                <tr>
                    <td class="px-4 py-3 text-content font-medium">@defect.Description</td>
                    <td class="px-4 py-3 text-content-muted hidden sm:table-cell">@defect.Location</td>
                    <td class="px-4 py-3 text-content-muted hidden md:table-cell">@defect.AssignedToEmail</td>
                    <td class="px-4 py-3">
                        <span class="text-[11px] font-medium @StatusColour(defect.Status)">@defect.Status</span>
                    </td>
                    <td class="px-4 py-3 text-content-subtle hidden lg:table-cell">@defect.RaisedAt.LocalDateTime.ToString("d MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Defect> Defects { get; set; } = Array.Empty<Defect>();

    private static string StatusColour(DefectStatus status) => status switch
    {
        DefectStatus.Open       => "text-rose-700",
        DefectStatus.InProgress => "text-amber-700",
        DefectStatus.Resolved   => "text-sky-700",
        DefectStatus.Verified   => "text-emerald-700",
        _ => "text-content-muted"
    };
}
