<div>
    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">
        @Label @(Required ? "*" : "")
    </label>
    <input type="@InputType"
           value="@Value"
           @oninput="HandleInput"
           required="@Required"
           class="w-full rounded-lg border border-line-strong px-3 py-2 text-sm text-content placeholder:text-content-subtle focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent" />
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> OnChange { get; set; }
    [Parameter] public string InputType { get; set; } = "text";
    [Parameter] public bool Required { get; set; }

    private Task HandleInput(ChangeEventArgs args) =>
        OnChange.InvokeAsync(args.Value?.ToString() ?? "");
}
