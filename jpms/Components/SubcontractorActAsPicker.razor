@inject ISubcontractorStore SubcontractorStore
@inject PortalContext PortalContext

<section class="rounded-xl border border-slate-200 bg-white p-5 mb-5">
    <p class="text-xs uppercase tracking-wider text-slate-500 font-semibold mb-2">Demo mode</p>
    <h2 class="text-sm font-medium text-slate-700 mb-2">Choose which subcontractor account to view as</h2>
    <p class="text-sm text-slate-600 mb-3">
        In production each subcontractor receives a unique secure link by email. For this demo, pick any.
    </p>
    <div class="flex flex-wrap items-center gap-2">
        <select @bind="selectedId" class="rounded-lg border border-slate-300 px-3 py-2 text-sm">
            <option value="">— Select subcontractor —</option>
            @foreach (var sub in SubcontractorStore.All())
            {
                <option value="@sub.SubcontractorId">@sub.CompanyName · @sub.PrimaryTrade</option>
            }
        </select>
        <button type="button" @onclick="Apply"
                class="rounded-lg bg-slate-900 text-white font-medium text-sm px-3 py-2 hover:bg-slate-800 transition"
                disabled="@string.IsNullOrEmpty(selectedId)">
            Continue
        </button>
    </div>
</section>

@code {
    private string selectedId = "";

    protected override void OnInitialized() =>
        selectedId = PortalContext.ActingSubcontractorId ?? "";

    private void Apply()
    {
        if (string.IsNullOrEmpty(selectedId)) return;
        PortalContext.ActAsSubcontractor(selectedId);
    }
}
