@inject ISubcontractorStore SubcontractorStore
@inject PortalContext PortalContext

<section class="rounded-xl border border-line bg-surface p-5 mb-5">
    <p class="text-xs uppercase tracking-wider text-content-subtle font-semibold mb-2">Demo mode</p>
    <h2 class="text-sm font-medium text-content-muted mb-2">Choose which subcontractor account to view as</h2>
    <p class="text-sm text-content-muted mb-3">
        In production each subcontractor receives a unique secure link by email. For this demo, pick any.
    </p>
    <div class="flex flex-wrap items-center gap-2">
        <select @bind="selectedId" class="rounded-lg border border-line-strong px-3 py-2 text-sm">
            <option value="">— Select subcontractor —</option>
            @foreach (var sub in SubcontractorStore.All())
            {
                <option value="@sub.SubcontractorId">@sub.CompanyName · @sub.PrimaryTrade</option>
            }
        </select>
        <button type="button" @onclick="Apply"
                class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-3 py-2 hover:bg-accent-hover transition"
                disabled="@string.IsNullOrEmpty(selectedId)">
            Continue
        </button>
    </div>
</section>

@code {
    private string selectedId = "";

    protected override void OnInitialized() =>
        selectedId = PortalContext.ActingSubcontractorId ?? "";

    private void Apply()
    {
        if (string.IsNullOrEmpty(selectedId)) return;
        PortalContext.ActAsSubcontractor(selectedId);
    }
}
