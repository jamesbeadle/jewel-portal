@inject AuthService Auth
@inject IDrawingStore DrawingStore

<form @onsubmit="HandleUpload" @onsubmit:preventDefault="true"
      class="rounded-2xl border border-slate-200 bg-white p-5 space-y-3">

    <div>
        <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">File name *</label>
        <input type="text" @bind="fileName" required placeholder="A-100_Rev-D.pdf"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
        <p class="text-xs text-slate-500 mt-1">JPMS auto-extracts the revision letter from the filename suffix.</p>
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Drawing code *</label>
        <input type="text" @bind="drawingCode" required placeholder="A-100"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Title *</label>
        <input type="text" @bind="title" required
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Issued by</label>
        <input type="email" @bind="issuedBy" placeholder="architect@example.com"
               class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
    </div>

    <button type="submit"
            class="w-full rounded-lg bg-slate-900 text-white font-medium px-4 py-2.5 hover:bg-slate-800 transition">
        Upload revision
    </button>
</form>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter] public EventCallback OnUploaded { get; set; }

    private string fileName = "";
    private string drawingCode = "";
    private string title = "";
    private string issuedBy = "";

    private async Task HandleUpload()
    {
        var existing = DrawingStore.DrawingsFor(ProjectId)
            .FirstOrDefault(drawing => drawing.DrawingCode == drawingCode);

        var drawingId = existing?.DrawingId ?? $"DR-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}";
        if (existing is null)
        {
            DrawingStore.Upsert(new Drawing(drawingId, ProjectId, drawingCode, title, "", DateTimeOffset.UtcNow));
        }

        var label = ExtractRevisionLabel(fileName);
        var isAmbiguous = string.IsNullOrEmpty(label);
        var revision = new DrawingRevision(
            $"RV-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}",
            drawingId, label.Length == 0 ? "?" : label, fileName,
            string.IsNullOrWhiteSpace(issuedBy) ? Auth.CurrentUser?.Email ?? "unknown" : issuedBy,
            DateTimeOffset.UtcNow, null, isAmbiguous, 0);
        DrawingStore.AddRevision(revision);
        fileName = ""; drawingCode = ""; title = ""; issuedBy = "";
        await OnUploaded.InvokeAsync();
    }

    private static string ExtractRevisionLabel(string fileName)
    {
        var match = System.Text.RegularExpressions.Regex.Match(fileName, @"[_-]Rev[_-]?([A-Za-z0-9]+)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        return match.Success ? match.Groups[1].Value.ToUpperInvariant() : "";
    }
}
