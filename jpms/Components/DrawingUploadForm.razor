@inject AuthService Auth
@inject IDrawingStore DrawingStore
@using Microsoft.AspNetCore.Components.Forms

<EditForm Model="this" OnValidSubmit="HandleUpload"
      class="rounded-2xl border border-line bg-surface p-5 space-y-3">

    <div class="inline-flex rounded-lg border border-line-strong p-0.5 gap-0.5">
        <button type="button" @onclick="() => SetMode(isRevision: false)"
                class="rounded-md text-sm px-3 py-1.5 transition @(!isRevision ? "bg-accent text-accent-ink font-medium" : "text-content-muted hover:bg-surface-raised")">
            New drawing
        </button>
        <button type="button" @onclick="() => SetMode(isRevision: true)" disabled="@(ExistingDrawings.Count == 0)"
                class="rounded-md text-sm px-3 py-1.5 transition disabled:opacity-50 @(isRevision ? "bg-accent text-accent-ink font-medium" : "text-content-muted hover:bg-surface-raised")">
            Revision of existing drawing
        </button>
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Drawing file *</label>
        <InputFile OnChange="OnFileSelected" class="w-full text-sm text-content-muted" />
        @if (selectedFile is not null)
        {
            <p class="text-xs text-content-subtle mt-1">@selectedFile.Name · @FormatSize(selectedFile.Size)</p>
        }
    </div>

    @if (isRevision)
    {
        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Existing drawing *</label>
            <select @bind="selectedDrawingId"
                    class="w-full rounded-lg border border-line-strong bg-surface px-3 py-2 text-sm text-content focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent">
                <option value="">Select a drawing…</option>
                @foreach (var drawing in ExistingDrawings)
                {
                    <option value="@drawing.DrawingId">@drawing.DrawingCode — @drawing.Title</option>
                }
            </select>
        </div>
    }
    else
    {
        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Drawing code *</label>
            <input type="text" @bind="drawingCode" required placeholder="A-100"
                   class="field" />
        </div>

        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Title *</label>
            <input type="text" @bind="title" required placeholder="Garden, shed, …"
                   class="field" />
        </div>
    }

    <div>
        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Revision *</label>
        <input type="text" @bind="revisionLabel" required placeholder="A"
               class="field" />
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Issued by</label>
        <input type="email" @bind="issuedBy" placeholder="architect@example.com"
               class="field" />
    </div>

    @if (error is not null)
    {
        <p class="text-sm text-red-700 bg-red-50 border border-red-200 rounded-lg px-3 py-2">@error</p>
    }

    <p class="text-xs text-content-subtle">New uploads are saved as <span class="font-medium">Unapproved</span>. They become the latest drawing only once approved.</p>

    <button type="submit" disabled="@busy"
            class="w-full rounded-lg bg-accent text-accent-ink font-medium px-4 py-2.5 hover:bg-accent-hover transition disabled:opacity-60">
        @(busy ? "Uploading…" : isRevision ? "Upload revision" : "Upload drawing")
    </button>
</EditForm>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter] public EventCallback OnUploaded { get; set; }

    private IBrowserFile? selectedFile;
    private bool isRevision;
    private string selectedDrawingId = "";
    private string drawingCode = "";
    private string title = "";
    private string revisionLabel = "";
    private string issuedBy = "";
    private bool busy;
    private string? error;

    private IReadOnlyList<Drawing> ExistingDrawings => DrawingStore.DrawingsFor(ProjectId);

    private void SetMode(bool isRevision)
    {
        this.isRevision = isRevision;
        error = null;
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        error = null;
        if (string.IsNullOrWhiteSpace(revisionLabel))
        {
            var extracted = ExtractRevisionLabel(selectedFile.Name);
            if (extracted.Length > 0) revisionLabel = extracted;
        }
    }

    private async Task HandleUpload()
    {
        if (selectedFile is null) { error = "Choose a file to upload."; return; }
        if (string.IsNullOrWhiteSpace(revisionLabel)) { error = "Enter a revision label."; return; }

        string drawingId;
        if (isRevision)
        {
            if (string.IsNullOrEmpty(selectedDrawingId)) { error = "Select the drawing this revision belongs to."; return; }
            drawingId = selectedDrawingId;
        }
        else
        {
            var duplicate = ExistingDrawings
                .FirstOrDefault(drawing => string.Equals(drawing.DrawingCode, drawingCode.Trim(), StringComparison.OrdinalIgnoreCase));
            if (duplicate is not null)
            {
                error = $"“{duplicate.DrawingCode}” is already in the register. Switch to “Revision of existing drawing” to add a new version of it.";
                return;
            }
            drawingId = "";
        }

        busy = true;
        error = null;
        try
        {
            if (!isRevision)
            {
                drawingId = (await DrawingStore.RegisterDrawingAsync(ProjectId, drawingCode.Trim(), title, CancellationToken.None)).DrawingId;
            }

            var issuedByEmail = string.IsNullOrWhiteSpace(issuedBy) ? Auth.CurrentUser?.Email ?? "" : issuedBy;
            await DrawingStore.UploadRevisionAsync(
                ProjectId, drawingId, revisionLabel.Trim().ToUpperInvariant(), issuedByEmail, selectedFile, CancellationToken.None);

            selectedFile = null; drawingCode = ""; title = ""; revisionLabel = ""; issuedBy = ""; selectedDrawingId = "";
            await OnUploaded.InvokeAsync();
        }
        catch (Exception ex)
        {
            error = $"Upload failed: {ex.Message}";
        }
        finally
        {
            busy = false;
        }
    }

    private static string ExtractRevisionLabel(string fileName)
    {
        var match = System.Text.RegularExpressions.Regex.Match(
            fileName, @"[_-]Rev[_-]?([A-Za-z0-9]+)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        return match.Success ? match.Groups[1].Value.ToUpperInvariant() : "";
    }

    private static string FormatSize(long bytes)
    {
        if (bytes >= 1024 * 1024) return $"{bytes / (1024.0 * 1024.0):0.#} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes} B";
    }
}
