@inject ICommercialInputsStore InputsStore

<section class="rounded-xl border border-line bg-surface p-5 mb-4">
    <h3 class="text-sm font-medium text-content-muted mb-3">Record subcontractor retention</h3>
    <form @onsubmit="Save" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            <FormField Label="Subcontractor" Value="@subcontractorReference" OnChange="@(value => subcontractorReference = value)" Required="true" />
            <FormField Label="Certified £" InputType="number" Value="@certifiedAmount" OnChange="@(value => certifiedAmount = value)" />
            <FormField Label="Retention %" InputType="number" Value="@retentionPercent" OnChange="@(value => retentionPercent = value)" />
            <FormField Label="First release £" InputType="number" Value="@firstReleasedAmount" OnChange="@(value => firstReleasedAmount = value)" />
            <FormField Label="Final release £" InputType="number" Value="@finalReleasedAmount" OnChange="@(value => finalReleasedAmount = value)" />
        </div>
        <button type="submit" class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
            Record retention
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private string subcontractorReference = "";
    private string certifiedAmount = "0";
    private string retentionPercent = "0";
    private string firstReleasedAmount = "0";
    private string finalReleasedAmount = "0";

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(subcontractorReference)) return;
        InputsStore.RecordRetention(new SubcontractorRetention(
            "", ProjectId, subcontractorReference,
            FormNumber.ParseAmount(certifiedAmount), FormNumber.ParseAmount(retentionPercent),
            FormNumber.ParseAmount(firstReleasedAmount), FormNumber.ParseAmount(finalReleasedAmount)));
        subcontractorReference = "";
        certifiedAmount = "0";
        firstReleasedAmount = "0";
        finalReleasedAmount = "0";
    }
}
