@inject ILeadStore LeadStore

<section class="rounded-xl border border-line bg-surface p-5 mb-5">
    <h2 class="text-sm font-medium text-content-muted mb-3">Log negotiation round</h2>
    <form @onsubmit="HandleLog" @onsubmit:preventDefault="true" class="flex flex-wrap items-end gap-2">
        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Revised value</label>
            <input type="number" min="0" @bind="revisedValue"
                   class="w-48 rounded-lg border border-line-strong px-3 py-2 text-sm" />
        </div>
        <div class="flex-1 min-w-[14rem]">
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Notes</label>
            <input type="text" @bind="notes"
                   class="w-full rounded-lg border border-line-strong px-3 py-2 text-sm" />
        </div>
        <button type="submit"
                class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
            Log
        </button>
    </form>
</section>

<section class="rounded-xl border border-line bg-surface overflow-hidden">
    <header class="px-5 py-3 border-b border-line bg-surface-raised">
        <h2 class="text-sm font-medium text-content-muted">Negotiation history</h2>
    </header>
    @if (Proposal.NegotiationRounds.Count == 0)
    {
        <p class="p-5 text-sm text-content-subtle italic">No rounds logged.</p>
    }
    else
    {
        <ul class="divide-y divide-line">
            @foreach (var round in Proposal.NegotiationRounds.Reverse())
            {
                <li class="p-4 text-sm">
                    <p class="font-medium text-content">@FormatValue(round.RevisedValue)</p>
                    <p class="text-content-muted">@round.Notes</p>
                    <p class="text-xs text-content-subtle mt-1">@round.At.LocalDateTime.ToString("d MMM yyyy HH:mm")</p>
                </li>
            }
        </ul>
    }
</section>

@code {
    [Parameter, EditorRequired] public Lead Lead { get; set; } = default!;
    [Parameter, EditorRequired] public Proposal Proposal { get; set; } = default!;

    private decimal revisedValue;
    private string notes = "";

    private void HandleLog()
    {
        var newRounds = Proposal.NegotiationRounds
            .Append(new NegotiationRound(DateTimeOffset.UtcNow, revisedValue, notes))
            .ToList()
            .AsReadOnly();
        LeadStore.SaveProposal(Proposal with { NegotiationRounds = newRounds });
        notes = "";
        if (Lead.Stage == LeadStage.ProposalIssued)
        {
            LeadStore.Upsert(Lead with { Stage = LeadStage.Negotiation });
        }
    }

    private static string FormatValue(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
