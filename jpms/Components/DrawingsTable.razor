@inject NavigationManager Nav

<div class="rounded-xl border border-line bg-surface overflow-x-auto overflow-y-auto max-h-[85vh]">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Code</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Title</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-center">Latest approved</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-center">Status</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-center">Pipeline</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden md:table-cell">Added</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @foreach (var drawing in Drawings)
            {
                <tr class="hover:bg-surface-raised cursor-pointer transition"
                    @onclick="() => OpenDrawing(drawing)">
                    <td class="px-4 py-3 font-mono text-xs text-content-muted">@drawing.DrawingCode</td>
                    <td class="px-4 py-3 text-content font-medium">@drawing.Title</td>
                    <td class="px-4 py-3 text-center">
                        @if (string.IsNullOrEmpty(drawing.CurrentApprovedRevisionLabel))
                        {
                            <span class="text-xs text-content-subtle italic">—</span>
                        }
                        else
                        {
                            <span class="inline-flex items-center justify-center rounded bg-emerald-50 border border-emerald-200 px-2 py-0.5 text-xs font-mono font-medium text-emerald-800">
                                Rev @drawing.CurrentApprovedRevisionLabel
                            </span>
                        }
                    </td>
                    <td class="px-4 py-3 text-center whitespace-nowrap">
                        @if (drawing.UnapprovedCount > 0)
                        {
                            <span class="inline-flex items-center rounded-full bg-amber-50 border border-amber-200 px-1.5 py-0.5 text-[10px] font-medium text-amber-800">
                                @drawing.UnapprovedCount pending
                            </span>
                        }
                        @if (drawing.ArchivedCount > 0)
                        {
                            <span class="ml-1 inline-flex items-center rounded-full bg-surface-raised border border-line px-1.5 py-0.5 text-[10px] font-medium text-content-subtle">
                                @drawing.ArchivedCount archived
                            </span>
                        }
                        @if (drawing.UnapprovedCount == 0 && drawing.ArchivedCount == 0 && !string.IsNullOrEmpty(drawing.CurrentApprovedRevisionLabel))
                        {
                            <span class="inline-flex items-center rounded-full bg-emerald-50 border border-emerald-200 px-1.5 py-0.5 text-[10px] font-medium text-emerald-800">
                                Approved
                            </span>
                        }
                    </td>
                    <td class="px-4 py-3 text-center whitespace-nowrap">
                        @* Pipeline status of the latest revision: has Bluebeam extracted its
                           metadata, and has the change analysis run? Pending states are shown
                           just as loudly so un-analysed drawings can't be silently missed. *@
                        @if (drawing.LatestMetadataExtractedAt is { } extractedAt)
                        {
                            <span class="inline-flex items-center rounded-full bg-emerald-50 border border-emerald-200 px-1.5 py-0.5 text-[10px] font-medium text-emerald-800"
                                  title="Metadata extracted @extractedAt.LocalDateTime.ToString("d MMM yyyy, HH:mm")">
                                Metadata ✓
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center rounded-full bg-amber-50 border border-amber-200 px-1.5 py-0.5 text-[10px] font-medium text-amber-800"
                                  title="The latest revision's metadata has not been extracted yet">
                                Not extracted
                            </span>
                        }
                        @if (drawing.LatestAnalysedAt is { } analysedAt)
                        {
                            <span class="ml-1 inline-flex items-center rounded-full bg-emerald-50 border border-emerald-200 px-1.5 py-0.5 text-[10px] font-medium text-emerald-800"
                                  title="Change analysis run @analysedAt.LocalDateTime.ToString("d MMM yyyy, HH:mm")">
                                Analysed ✓
                            </span>
                        }
                        else
                        {
                            <span class="ml-1 inline-flex items-center rounded-full bg-amber-50 border border-amber-200 px-1.5 py-0.5 text-[10px] font-medium text-amber-800"
                                  title="The latest revision has not been analysed yet">
                                Not analysed
                            </span>
                        }
                    </td>
                    <td class="px-4 py-3 text-content-muted hidden md:table-cell">
                        @drawing.CreatedAt.LocalDateTime.ToString("d MMM yyyy")
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Drawing> Drawings { get; set; } = Array.Empty<Drawing>();

    private void OpenDrawing(Drawing drawing) =>
        Nav.NavigateTo($"/projects/{drawing.ProjectId}/drawings/{drawing.DrawingId}");
}
