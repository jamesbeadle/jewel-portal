@using Jewel.JPMS.Contracts.Requests
@inject AuthService Auth
@inject IRequestRegister RequestRegister

<div class="panel p-5">
    <h3 class="eyebrow mb-4">Conversation</h3>

    @if (!loaded)
    {
        <p class="text-sm text-content-subtle">Loading…</p>
    }
    else
    {
        @if (messages.Count == 0)
        {
            <p class="text-sm text-content-subtle italic mb-4">No messages yet. Start the discussion below.</p>
        }
        else
        {
            <ol class="space-y-4 mb-5">
                @foreach (var message in messages)
                {
                    <li class="border-l-2 pl-3 @(message.Visibility == MessageVisibility.Internal ? "border-amber-500/50" : "border-line-strong")">
                        <div class="flex flex-wrap items-center gap-2 mb-0.5">
                            <span class="text-sm font-medium text-content">@AuthorLabel(message)</span>
                            <span class="text-xs text-content-subtle">@message.PostedAt.LocalDateTime.ToString("d MMM yyyy, HH:mm")</span>
                            @if (message.Visibility == MessageVisibility.Internal)
                            {
                                <span class="inline-flex items-center rounded bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-600">Internal</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center rounded bg-surface-raised border border-line px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-content-muted">Shared</span>
                            }
                        </div>
                        @if (message.Direction == MessageDirection.Inbound && !string.IsNullOrEmpty(message.MailboxId)
                             && expanded.Contains(message.MessageId))
                        {
                            @* Expanded email: the full body (incl. the quoted thread), fetched live on demand.
                               The listed Body is only Graph's short preview snippet, so long emails and their
                               history only appear here. HTML is sanitised server-side before it reaches us. *@
                            <div class="rounded-lg bg-surface-raised border border-line p-3 max-h-[28rem] overflow-y-auto">
                                @if (!details.TryGetValue(message.MessageId, out var detail) || detail is null)
                                {
                                    <p class="text-sm text-content-subtle italic">Loading full email…</p>
                                }
                                else if (!string.IsNullOrWhiteSpace(detail.BodyHtml) && detail.BodyIsHtml)
                                {
                                    <div class="rounded bg-white text-gray-900 p-3 text-sm overflow-x-auto">@((MarkupString)detail.BodyHtml)</div>
                                }
                                else if (!string.IsNullOrWhiteSpace(detail.BodyHtml))
                                {
                                    <p class="text-sm text-content whitespace-pre-wrap">@detail.BodyHtml</p>
                                }
                                else
                                {
                                    <p class="text-sm text-content whitespace-pre-wrap">@message.Body</p>
                                }
                            </div>
                            @if (details.TryGetValue(message.MessageId, out var loadedDetail)
                                 && loadedDetail is { Attachments.Count: > 0 })
                            {
                                <p class="text-xs text-content-subtle mt-1">
                                    @loadedDetail.Attachments.Count attachment@(loadedDetail.Attachments.Count == 1 ? "" : "s"):
                                    @string.Join(", ", loadedDetail.Attachments.Select(a => a.Name))
                                </p>
                            }
                        }
                        else
                        {
                            <p class="text-sm text-content whitespace-pre-wrap">@message.Body</p>
                        }
                        @if (message.Direction == MessageDirection.Inbound && !string.IsNullOrEmpty(message.MailboxId))
                        {
                            <div class="mt-1 flex flex-wrap items-center gap-3">
                                <button type="button"
                                        class="text-xs font-medium text-accent hover:underline"
                                        @onclick="() => ToggleExpandAsync(message)">
                                    @(expanded.Contains(message.MessageId) ? "Show summary" : "Show full email")
                                </button>
                                @if (CanDraftReply)
                                {
                                    <button type="button"
                                            class="text-xs font-medium text-accent hover:underline"
                                            disabled="@(replyingId is not null)"
                                            @onclick="() => DraftReplyAsync(message)">
                                        @(replyingId == message.MessageId ? "Drafting reply…" : "Reply with official PDF")
                                    </button>
                                }
                            </div>
                            @if (replyForMessageId == message.MessageId && replyError is not null)
                            {
                                <p class="mt-2 rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@replyError</p>
                            }
                            @if (replyForMessageId == message.MessageId && replyDraft is not null)
                            {
                                <div class="mt-2 rounded-lg bg-emerald-500/10 border border-emerald-500/30 px-3 py-2">
                                    <p class="text-sm font-medium text-emerald-600">
                                        Reply draft created in the projects mailbox — official PDF attached, in this email's thread.
                                    </p>
                                    <p class="text-xs text-content-subtle mt-1">To: @string.Join(", ", replyDraft.Recipients)</p>
                                    @if (replyDraft.Cc is { Count: > 0 } replyCc)
                                    {
                                        <p class="text-xs text-content-subtle">CC: @string.Join(", ", replyCc)</p>
                                    }
                                    <p class="text-xs text-content-subtle">Review the recipients and send it from Outlook — nothing has been sent.</p>
                                    @if (!string.IsNullOrWhiteSpace(replyDraft.WebLink))
                                    {
                                        <a href="@replyDraft.WebLink" target="_blank" rel="noopener"
                                           class="text-xs text-accent hover:underline underline-offset-2">Open the draft in Outlook</a>
                                    }
                                </div>
                            }
                        }
                    </li>
                }
            </ol>
        }

        <div class="border-t border-line pt-4">
            @if (error is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@error</p>
            }
            <textarea class="field mb-2" rows="3" value="@draft" @oninput="OnDraftInput"
                      placeholder="Add to the conversation…"></textarea>
            <div class="flex flex-wrap items-center justify-between gap-3">
                <label class="inline-flex items-center gap-2 text-sm text-content-muted cursor-pointer">
                    <input type="checkbox" checked="@internalOnly" @onchange="OnVisibilityChanged" class="rounded border-line-strong" />
                    Internal only (hide from client &amp; external parties)
                </label>
                <button type="button" class="btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(draft))" @onclick="Post">
                    @(busy ? "Posting…" : "Post message")
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string RequestId { get; set; } = "";

    /// <summary>Whether the signed-in user may stage reply drafts carrying the official PDF —
    /// mirrors the page-level draft gate (directors, PMs, site managers, architects).</summary>
    [Parameter] public bool CanDraftReply { get; set; }

    private bool loaded;
    private bool busy;
    private string? error;
    private string draft = "";
    private bool internalOnly;
    private IReadOnlyList<RequestMessage> messages = Array.Empty<RequestMessage>();

    // Inbound emails render their short preview by default; expanding fetches the FULL body (with the
    // quoted thread + attachment names) live from the mailbox, cached per message for the page's life.
    private readonly HashSet<string> expanded = new();
    private readonly Dictionary<string, MailboxMessageDetail?> details = new();

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        messages = await RequestRegister.ListMessagesAsync(RequestId);
        loaded = true;
    }

    private void OnDraftInput(ChangeEventArgs e) => draft = e.Value?.ToString() ?? "";

    private void OnVisibilityChanged(ChangeEventArgs e) => internalOnly = e.Value is true;

    private async Task Post()
    {
        if (busy || string.IsNullOrWhiteSpace(draft)) return;
        error = null;
        var user = Auth.CurrentUser;
        if (user is null) { error = "You must be signed in to post."; return; }

        // Author is set authoritatively by the API from the signed-in session; the
        // values supplied here are placeholders the server overrides.
        var command = new PostRequestMessage(
            RequestId,
            draft.Trim(),
            internalOnly ? MessageVisibility.Internal : MessageVisibility.Shared,
            user.Email,
            user.DisplayName);

        try
        {
            busy = true;
            await RequestRegister.PostMessageAsync(command);
            draft = "";
            internalOnly = false;
            await LoadAsync();
        }
        catch
        {
            error = "Couldn't post your message. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ToggleExpandAsync(RequestMessage message)
    {
        if (!expanded.Add(message.MessageId))
        {
            expanded.Remove(message.MessageId);
            return;
        }

        if (details.ContainsKey(message.MessageId) || string.IsNullOrEmpty(message.MailboxId))
            return;

        try
        {
            var detail = await RequestRegister.GetEmailDetailAsync(RequestId, message.MailboxId, message.EmailMessageId);
            details[message.MessageId] = detail;
        }
        catch
        {
            // Fetch failed — fall back to the preview body inside the expanded pane.
            details[message.MessageId] = new MailboxMessageDetail(message.MailboxId, "", false, Array.Empty<IntakeAttachment>());
        }
    }

    // ---- Reply with the official PDF: an Outlook draft in this email's thread ----

    private string? replyingId;        // message currently being drafted against (disables the buttons)
    private string? replyForMessageId; // where the latest outcome (error or draft) is displayed
    private string? replyError;
    private RequestEmailDraft? replyDraft;

    private async Task DraftReplyAsync(RequestMessage message)
    {
        if (replyingId is not null || string.IsNullOrEmpty(message.MailboxId)) return;
        replyError = null;
        replyDraft = null;
        replyForMessageId = message.MessageId;
        replyingId = message.MessageId;
        try
        {
            replyDraft = await RequestRegister.PrepareReplyDraftAsync(RequestId, message.MailboxId!);
        }
        catch (CommandFailedException ex)
        {
            replyError = $"Couldn't create the reply draft: {ex.Message}";
        }
        catch
        {
            replyError = "Couldn't create the reply draft. Check the mailbox connection and try again.";
        }
        finally
        {
            replyingId = null;
        }
    }

    private static string AuthorLabel(RequestMessage message) =>
        string.IsNullOrWhiteSpace(message.AuthorName) ? message.AuthorEmail : message.AuthorName;
}
