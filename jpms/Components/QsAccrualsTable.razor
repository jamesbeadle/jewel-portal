<div class="rounded-xl border border-slate-200 bg-white overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-right text-[11px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-4 py-3 text-left">Category</th>
                <th class="px-4 py-3 text-left">Description</th>
                <th class="px-4 py-3">Add</th>
                <th class="px-4 py-3">Omit</th>
                <th class="px-4 py-3">Liability</th>
                <th class="px-4 py-3 bg-slate-100">Net</th>
                <th class="px-4 py-3 text-left">Signed off</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 text-right">
            @foreach (var accrual in Accruals)
            {
                <tr>
                    <td class="px-4 py-2 text-left text-slate-900 font-medium">@accrual.Category</td>
                    <td class="px-4 py-2 text-left text-slate-700">@accrual.Description</td>
                    <td class="px-4 py-2 text-emerald-700">@(accrual.AddAmount == 0 ? "—" : Money(accrual.AddAmount))</td>
                    <td class="px-4 py-2 text-rose-700">@(accrual.OmitAmount == 0 ? "—" : Money(accrual.OmitAmount))</td>
                    <td class="px-4 py-2 text-amber-700">@(accrual.LiabilityAmount == 0 ? "—" : Money(accrual.LiabilityAmount))</td>
                    <td class="px-4 py-2 text-slate-900 font-medium bg-slate-50">@Money(accrual.NetAmount)</td>
                    <td class="px-4 py-2 text-left text-slate-500 text-xs">
                        @accrual.SignedOffByEmail<br />
                        @accrual.SignedOffAt.LocalDateTime.ToString("d MMM yyyy")
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<QsAccrual> Accruals { get; set; } = Array.Empty<QsAccrual>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
