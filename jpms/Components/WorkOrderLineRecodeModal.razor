@using Jewel.JPMS.Contracts.Procurement
@using Jewel.JPMS.Models
@inject ICommandSender Commands

@* Re-codes / splits one priced work-order line across cost centres by £ amount — for
   orders priced wholesale under one code (a groundworker's package all under SUB-GWK)
   whose lines really belong to several centres (foundations, blockwork, slab…). One
   part simply moves the line; several parts must total the line exactly — this reshapes
   where committed value sits, it never changes the order's value. Used from the Work
   Orders tab. *@
<Modal IsOpen="IsOpen"
       Title="@($"Re-code across cost centres · {LineLabel}")"
       ConfirmLabel="@(busy ? "Saving…" : "Save")"
       ConfirmDisabled="@(busy || !CanSave)"
       OnConfirm="SaveAsync"
       OnCancel="OnClose"
       Class="max-w-2xl">
    <div class="space-y-3">
        <p class="text-sm text-content-subtle">
            Line total <span class="text-content font-medium">@MoneyExact(LineTotal)</span>,
            currently on <span class="text-content font-medium">@CurrentCostCode</span>.
            Give each cost centre its share — the parts must add up to the line exactly.
            One part moves the whole line; the order's value never changes.
        </p>

        <div class="space-y-2">
            @for (var index = 0; index < rows.Count; index++)
            {
                var rowIndex = index;
                var row = rows[rowIndex];
                <div class="flex items-center gap-2">
                    <select class="bg-surface border border-line rounded-lg px-2 py-1.5 text-content text-sm flex-1"
                            disabled="@busy"
                            @onchange="e => SetRowCode(rowIndex, e.Value?.ToString())">
                        <option value="" selected="@(row.CostCode is null)">Choose a cost centre…</option>
                        @foreach (var centre in CostCenters.OrderBy(c => c.Code, StringComparer.OrdinalIgnoreCase).ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase))
                        {
                            <option value="@centre.Code" selected="@(string.Equals(row.CostCode, centre.Code, StringComparison.OrdinalIgnoreCase))">
                                @($"{centre.Code} — {centre.Name}")
                            </option>
                        }
                    </select>
                    <input type="number" step="any" placeholder="Amount £" disabled="@busy"
                           class="bg-surface border border-line rounded-lg px-2 py-1.5 text-right text-content text-sm w-36"
                           value="@row.AmountText"
                           @onchange="e => SetRowAmount(rowIndex, e.Value?.ToString())" />
                    <button type="button" aria-label="Remove this part" disabled="@(busy || rows.Count == 1)"
                            class="inline-flex items-center justify-center w-7 h-7 rounded-md text-content-subtle hover:text-negative hover:bg-surface-raised"
                            @onclick="() => rows.RemoveAt(rowIndex)">
                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
                    </button>
                </div>
            }
        </div>

        <button type="button" disabled="@busy" @onclick="AddRow"
                class="text-xs font-medium text-content-subtle hover:text-content underline underline-offset-4">
            + Add another cost centre
        </button>

        <div class="rounded-lg border border-line bg-surface-raised px-3 py-2 text-sm flex items-center justify-between gap-4">
            <span class="text-content-muted">Allocated @MoneyExact(AllocatedTotal) of @MoneyExact(LineTotal)</span>
            <span class="@(Remainder == 0m ? "text-content-subtle" : "text-negative font-medium")">
                @MoneyExact(Remainder) unaccounted
            </span>
        </div>

        @if (ClientValidationError is not null)
        {
            <p class="text-sm text-negative">@ClientValidationError</p>
        }
        @if (saveError is not null)
        {
            <p class="text-sm text-negative">@saveError</p>
        }
    </div>
</Modal>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public string ProjectId { get; set; } = "";

    /// <summary>The work-order line being re-coded.</summary>
    [Parameter] public string LineId { get; set; } = "";

    /// <summary>Short human label, e.g. "WO-0012 · Foundations".</summary>
    [Parameter] public string LineLabel { get; set; } = "";

    /// <summary>The line's total (signed) — the parts must re-total it exactly.</summary>
    [Parameter] public decimal LineTotal { get; set; }

    /// <summary>The centre the line currently sits on, seeding the first part.</summary>
    [Parameter] public string CurrentCostCode { get; set; } = "";

    /// <summary>The active cost-code master, offered by the selects.</summary>
    [Parameter] public IReadOnlyList<CostCenter> CostCenters { get; set; } = Array.Empty<CostCenter>();

    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>Raised after a successful save so the page can refresh its store.</summary>
    [Parameter] public EventCallback OnSaved { get; set; }

    private sealed class Row
    {
        public string? CostCode { get; set; }
        public string AmountText { get; set; } = "";
    }

    private List<Row> rows = new();
    private string? seededForLineId;
    private bool busy;
    private string? saveError;

    protected override void OnParametersSet()
    {
        if (!IsOpen)
        {
            seededForLineId = null;
            saveError = null;
            return;
        }
        if (seededForLineId == LineId) return;
        seededForLineId = LineId;
        saveError = null;
        // Seed with the line as it stands — the whole total on its current centre —
        // ready for the user to carve amounts off onto other centres.
        rows = new List<Row>
        {
            new Row
            {
                CostCode = string.IsNullOrWhiteSpace(CurrentCostCode) ? null : CurrentCostCode,
                AmountText = LineTotal.ToString(System.Globalization.CultureInfo.InvariantCulture)
            }
        };
    }

    private void AddRow() => rows.Add(new Row());

    private void SetRowCode(int index, string? costCode)
    {
        rows[index].CostCode = string.IsNullOrEmpty(costCode) ? null : costCode;
        // Convenience: an empty amount defaults to whatever the line still has spare.
        if (rows[index].CostCode is not null && string.IsNullOrWhiteSpace(rows[index].AmountText) && Remainder != 0m)
            rows[index].AmountText = Remainder.ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    private void SetRowAmount(int index, string? text) => rows[index].AmountText = text ?? "";

    private static decimal? Parse(string text) =>
        decimal.TryParse(text, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var value)
            ? value
            : null;

    private decimal AllocatedTotal => rows.Sum(row => Parse(row.AmountText) ?? 0m);

    private decimal Remainder => LineTotal - AllocatedTotal;

    private string? ClientValidationError
    {
        get
        {
            var filled = rows.Where(row => row.CostCode is not null || !string.IsNullOrWhiteSpace(row.AmountText)).ToList();
            if (filled.Count == 0) return "Choose at least one cost centre.";
            if (filled.Any(row => row.CostCode is null)) return "Choose a cost centre for every part.";
            if (filled.Any(row => Parse(row.AmountText) is null)) return "Every part needs an amount.";
            if (filled.Count > 1 && filled.Any(row => Parse(row.AmountText)!.Value == 0m))
                return "Every part needs a non-zero amount.";
            if (filled.Select(row => row.CostCode!).Distinct(StringComparer.OrdinalIgnoreCase).Count() != filled.Count)
                return "Each cost centre can only appear once — combine the amounts instead.";
            if (filled.Count > 1 && filled.Any(row => Math.Sign(Parse(row.AmountText)!.Value) != Math.Sign(LineTotal)))
                return LineTotal < 0m ? "This is a negative line — amounts must be negative." : "Amounts must be positive.";
            if (Remainder != 0m)
                return $"The parts must total the line exactly — {MoneyExact(Remainder)} is unaccounted for.";
            return null;
        }
    }

    private bool CanSave => ClientValidationError is null;

    private async Task SaveAsync()
    {
        if (busy || !CanSave) return;
        busy = true;
        saveError = null;
        var parts = rows
            .Where(row => row.CostCode is not null && Parse(row.AmountText) is not null)
            .Select(row => new WorkOrderLinePart(row.CostCode!, Parse(row.AmountText)!.Value))
            .ToList();
        try
        {
            await Commands.SendAsync(new RecodeWorkOrderLine(ProjectId, LineId, parts), CancellationToken.None);
            seededForLineId = null; // reseed from the saved state on next open
            await OnSaved.InvokeAsync();
        }
        catch (CommandFailedException ex)
        {
            saveError = $"Couldn't save the re-code: {ex.Message}";
        }
        finally
        {
            busy = false;
        }
    }

    private static string MoneyExact(decimal value) =>
        value.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
