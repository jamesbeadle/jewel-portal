@using Jewel.JPMS.Contracts.Todos
@inject ITodoStore Todos
@inject IRequestRegister Requests
@inject IVariationStore Variations
@inject IDrawingStore Drawings
@inject SessionService Session
@inject NavigationManager Nav
@implements IDisposable

@*
    The project's to-do list, shown on the To-do tab. Items are added here directly or created
    from an email at the triage stage ("Create new → To-do item"), in which case the email is tagged
    "JPMS/TODO-####" per item. Each row is a single fixed-height line of title + key facts (never
    the multiline notes) — clicking one opens the detail modal (TodoDetailModal) with the full
    detail including those notes, the item's linked emails read live by tag,
    and the actions: completing there moves the item to the Done section below, and delete lives
    there too. Full manage: add, complete/reopen, delete.

    Keyword search: the search box filters the to-do items AND surfaces this project's related
    records that match the keywords — requests (ref / kind / title / description), variations
    (VOQs and VOs) and drawings — each row navigating to the record. Every whitespace-separated
    keyword must match somewhere on a record (AND across keywords, case-insensitive), so
    "canopy rfi" narrows rather than widens. Requests and drawings come from their cached
    registers (refreshed on entry, stale-while-revalidate per the store convention); VOQs / VOs
    are fetched once in the background when the tab loads.
*@

<div class="panel p-5">
    <div class="flex items-center justify-between gap-2 mb-1">
        <div class="flex items-center gap-3">
            <h2 class="text-sm font-semibold text-content">To-do list</h2>
            @if (items.Count > 0)
            {
                <span class="text-[11px] text-content-subtle">@items.Count(i => i.IsComplete) of @items.Count done</span>
            }
        </div>
        @if (CanManage && !loading)
        {
            <button type="button" class="btn-primary text-xs px-2.5 py-1.5" @onclick="OpenAdd">Add item</button>
        }
    </div>
    <p class="text-xs text-content-subtle mb-4">
        Items added here or captured from an email at triage. Click an item for its full detail and
        linked emails@(CanManage ? ", and to mark it done" : "").
    </p>

    @if (error is not null)
    {
        <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@error</p>
    }

    @if (loading)
    {
        <JewelSpinner Class="py-8" Label="Loading" />
    }
    else
    {
        <div class="relative mb-4">
            <input type="search" class="field w-full text-sm pr-8" placeholder="Search keywords — filters the list and finds related requests, variations and drawings"
                   value="@search" @oninput="OnSearchInput" />
            @if (HasQuery)
            {
                <button type="button" title="Clear search"
                        class="absolute right-2 top-1/2 -translate-y-1/2 text-content-faint hover:text-content-muted text-sm leading-none"
                        @onclick="ClearSearch">✕</button>
            }
        </div>

        @if (items.Count == 0)
        {
            <p class="text-sm text-content-subtle italic mb-4">No to-do items on this project yet.</p>
        }
        else
        {
            var visible = HasQuery ? items.Where(MatchesTodo).ToList() : items;
            var open = visible.Where(i => !i.IsComplete).ToList();
            var done = visible.Where(i => i.IsComplete).ToList();

            @if (HasQuery && visible.Count == 0)
            {
                <p class="text-sm text-content-subtle italic mb-4">No to-do items match "@search".</p>
            }
            else if (open.Count == 0 && !HasQuery)
            {
                <p class="text-sm text-content-subtle italic mb-4">Nothing open — every item is done.</p>
            }
            else
            {
                <div class="space-y-2 mb-4">
                    @foreach (var item in open)
                    {
                        <button type="button" @key="item.TodoItemId" title="Open this item"
                                class="w-full rounded-lg border border-line px-3 py-2 text-left hover:border-line-strong hover:bg-surface-raised"
                                @onclick="() => selected = item">
                            <p class="truncate text-sm text-content">
                                <span class="font-mono text-xs text-content-muted mr-2">@item.Reference</span>@item.Title
                            </p>
                            <div class="mt-1 flex items-center gap-x-3 overflow-hidden text-[11px] text-content-subtle">
                                @if (item.DueAt is not null)
                                {
                                    <span class="whitespace-nowrap @(IsOverdue(item) ? "text-negative font-medium" : "")">Due @item.DueAt.Value.LocalDateTime.ToString("d MMM yyyy")</span>
                                }
                                @if (item.AssigneeRole is Role assignedRole)
                                {
                                    <span class="whitespace-nowrap">Assigned to @assignedRole.DisplayName()</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.CreatedByEmail))
                                {
                                    <span class="truncate">Added by @item.CreatedByEmail</span>
                                }
                            </div>
                        </button>
                    }
                </div>
            }

            @if (done.Count > 0)
            {
                <h3 class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold mb-2">Done</h3>
                <div class="space-y-2 mb-4">
                    @foreach (var item in done)
                    {
                        <button type="button" @key="item.TodoItemId" title="Open this item"
                                class="w-full rounded-lg border border-line px-3 py-2 text-left hover:border-line-strong hover:bg-surface-raised"
                                @onclick="() => selected = item">
                            <p class="truncate text-sm text-content-subtle line-through">
                                <span class="font-mono text-xs text-content-muted mr-2">@item.Reference</span>@item.Title
                            </p>
                            <div class="mt-1 flex items-center gap-x-3 overflow-hidden text-[11px] text-content-subtle">
                                @if (item.CompletedAt is not null)
                                {
                                    <span class="whitespace-nowrap">Done @item.CompletedAt.Value.LocalDateTime.ToString("d MMM yyyy")</span>
                                }
                                @if (item.AssigneeRole is Role assignedRole)
                                {
                                    <span class="whitespace-nowrap">Assigned to @assignedRole.DisplayName()</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.CreatedByEmail))
                                {
                                    <span class="truncate">Added by @item.CreatedByEmail</span>
                                }
                            </div>
                        </button>
                    }
                </div>
            }
        }

        @if (HasQuery)
        {
            var matchedRequests = MatchedRequests;
            var matchedVoqs = MatchedVoqs;
            var matchedVos = MatchedVos;
            var matchedDrawings = MatchedDrawings;
            var anyRelated = matchedRequests.Count + matchedVoqs.Count + matchedVos.Count + matchedDrawings.Count > 0;

            <div class="border-t border-line pt-4 mt-2">
                <h3 class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold mb-2">Related records</h3>

                @if (!anyRelated)
                {
                    <p class="text-sm text-content-subtle italic">
                        @(relatedLoading ? "Looking for related records…" : $"No requests, variations or drawings on this project match \"{search}\".")
                    </p>
                }
                else
                {
                    @if (matchedRequests.Count > 0)
                    {
                        <p class="text-xs text-content-subtle mb-2">Requests (@matchedRequests.Count)</p>
                        <div class="space-y-2 mb-4">
                            @foreach (var record in matchedRequests.Take(MaxRelated))
                            {
                                <button type="button" @key="record.RequestId" title="Open this request"
                                        class="w-full rounded-lg border border-line px-3 py-2 text-left hover:border-line-strong hover:bg-surface-raised"
                                        @onclick="() => OpenRequest(record)">
                                    <p class="truncate text-sm text-content">
                                        <span class="font-mono text-xs text-content-muted mr-2">@record.Reference</span>@record.Title
                                    </p>
                                    <div class="mt-1 flex items-center gap-x-3 overflow-hidden text-[11px] text-content-subtle">
                                        <span class="whitespace-nowrap" title="@record.Kind.LongName()">@record.Kind.DisplayName()</span>
                                        <span class="whitespace-nowrap">@RequestStatusLabel(record.Status)</span>
                                        @if (!string.IsNullOrWhiteSpace(record.RaisedTo))
                                        {
                                            <span class="truncate">Raised to @record.RaisedTo</span>
                                        }
                                    </div>
                                </button>
                            }
                        </div>
                        @if (matchedRequests.Count > MaxRelated)
                        {
                            <p class="text-[11px] text-content-subtle mb-4">
                                Showing @MaxRelated of @matchedRequests.Count — refine the keywords, or search from the
                                <a class="underline underline-offset-2 hover:text-content-muted" href="@($"/projects/{ProjectId}/requests")">Requests tab</a>.
                            </p>
                        }
                    }

                    @if (matchedVoqs.Count > 0 || matchedVos.Count > 0)
                    {
                        <p class="text-xs text-content-subtle mb-2">Variations (@(matchedVoqs.Count + matchedVos.Count))</p>
                        <div class="space-y-2 mb-4">
                            @foreach (var voq in matchedVoqs.Take(MaxRelated))
                            {
                                <button type="button" @key="voq.VariationOrderQuoteId" title="Open this variation order quote"
                                        class="w-full rounded-lg border border-line px-3 py-2 text-left hover:border-line-strong hover:bg-surface-raised"
                                        @onclick="() => OpenVoq(voq.VariationOrderQuoteId)">
                                    <p class="truncate text-sm text-content">
                                        <span class="font-mono text-xs text-content-muted mr-2">@voq.Reference</span>@voq.Title
                                    </p>
                                    <div class="mt-1 flex items-center gap-x-3 overflow-hidden text-[11px] text-content-subtle">
                                        <span class="whitespace-nowrap">VOQ · @voq.Status</span>
                                    </div>
                                </button>
                            }
                            @foreach (var vo in matchedVos.Take(MaxRelated))
                            {
                                <button type="button" @key="vo.VariationOrderId" title="Open the VOQ this variation order was approved from"
                                        class="w-full rounded-lg border border-line px-3 py-2 text-left hover:border-line-strong hover:bg-surface-raised"
                                        @onclick="() => OpenVoq(vo.VariationOrderQuoteId)">
                                    <p class="truncate text-sm text-content">
                                        <span class="font-mono text-xs text-content-muted mr-2">@vo.VariationRef</span>@vo.Title
                                    </p>
                                    <div class="mt-1 flex items-center gap-x-3 overflow-hidden text-[11px] text-content-subtle">
                                        <span class="whitespace-nowrap">VO · @vo.Status</span>
                                    </div>
                                </button>
                            }
                        </div>
                    }

                    @if (matchedDrawings.Count > 0)
                    {
                        <p class="text-xs text-content-subtle mb-2">Drawings (@matchedDrawings.Count)</p>
                        <div class="space-y-2 mb-4">
                            @foreach (var drawing in matchedDrawings.Take(MaxRelated))
                            {
                                <button type="button" @key="drawing.DrawingId" title="Open this drawing"
                                        class="w-full rounded-lg border border-line px-3 py-2 text-left hover:border-line-strong hover:bg-surface-raised"
                                        @onclick="() => OpenDrawing(drawing)">
                                    <p class="truncate text-sm text-content">
                                        <span class="font-mono text-xs text-content-muted mr-2">@drawing.DrawingCode</span>@drawing.Title
                                    </p>
                                    <div class="mt-1 flex items-center gap-x-3 overflow-hidden text-[11px] text-content-subtle">
                                        <span class="whitespace-nowrap">
                                            @(string.IsNullOrEmpty(drawing.CurrentApprovedRevisionLabel) ? "No approved revision" : $"Rev {drawing.CurrentApprovedRevisionLabel} approved")
                                        </span>
                                    </div>
                                </button>
                            }
                        </div>
                        @if (matchedDrawings.Count > MaxRelated)
                        {
                            <p class="text-[11px] text-content-subtle mb-4">
                                Showing @MaxRelated of @matchedDrawings.Count — refine the keywords, or use the
                                <a class="underline underline-offset-2 hover:text-content-muted" href="@($"/projects/{ProjectId}/drawings")">Drawings tab</a>.
                            </p>
                        }
                    }
                }
            </div>
        }
    }
</div>

<TodoDetailModal Item="@selected" Busy="@busy" Error="@(selected is null ? null : error)"
                 CanComplete="@CanManage" CanDelete="@CanManage"
                 OnClose="() => selected = null"
                 OnToggleComplete="ToggleComplete" OnDelete="Delete" />

<Modal IsOpen="@addOpen" Title="Add a to-do item" ConfirmLabel="Add to-do item" CancelLabel="Cancel"
       OnConfirm="Add" OnCancel="CloseAdd">
    <div class="space-y-3">
        @if (addError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@addError</p>
        }

        <FormField Label="Title" Value="@newTitle" OnChange="v => newTitle = v" Required="true" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Assigned role</label>
                <SearchSelect Options="@AssigneeOptions" Value="@newAssignee" ValueChanged="v => newAssignee = v"
                              Placeholder="Unassigned" WidthClass="w-full" />
            </div>
            <FormField Label="Due" Value="@newDue" OnChange="v => newDue = v" InputType="date" />
        </div>

        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Notes</label>
            <textarea class="field" rows="2" value="@newNotes" @oninput="OnNewNotesInput"></textarea>
        </div>
    </div>
</Modal>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private IReadOnlyList<TodoItem> items = Array.Empty<TodoItem>();

    // The assignee picker's option pool: the ROLES a to-do can be assigned to (internal
    // office/management roles — TodoRoles.AssignableAsTodoAssignee, served by
    // ListTodoAssignableRoles), fetched once when the tab loads. Items are assigned to a role,
    // not a person, so they survive staff changes. Assignment is picker-only.
    private IReadOnlyList<SearchSelect.Option> AssigneeOptions = Array.Empty<SearchSelect.Option>();
    private bool loading = true;
    private bool busy;
    private string? error;

    // The item open in the detail modal (null = closed). Complete/reopen and delete happen there;
    // a successful action closes it, and the refreshed list re-groups the item into Open/Done.
    private TodoItem? selected;

    // Keyword search state. The query filters the to-do list and drives the "Related records"
    // sections. Requests and drawings read synchronously from their cached stores; VOQs / VOs have
    // no cached register, so they are fetched once in the background when the tab loads and held
    // here for the session's stay on the tab.
    private const int MaxRelated = 8;
    private string search = "";
    private IReadOnlyList<VariationOrderQuote> voqs = Array.Empty<VariationOrderQuote>();
    private IReadOnlyList<VariationOrder> vos = Array.Empty<VariationOrder>();
    private bool relatedLoading = true;

    // "Add a to-do item" modal state. The form lives in the modal; opening it starts from a clean
    // slate, and a successful add closes it.
    private bool addOpen;
    private string? addError;
    private string newTitle = "";
    private string newNotes = "";
    private string newAssignee = "";
    private string newDue = "";

    // Managing the list mirrors the server-side TodoRoles gate: directors, project managers and site
    // managers (administrators carry every role). Everyone else sees the list read-only.
    private bool CanManage =>
        Session.AvailableRoles.Any(role => role is Role.Admin or Role.ManagingDirector or Role.ProjectManager or Role.SiteManager);

    protected override async Task OnInitializedAsync()
    {
        // Related-record sources for the keyword search. Refresh on entry per the store
        // convention: cached requests/drawings serve matches immediately, then update when the
        // background reload lands. VOQs / VOs load once alongside (no cached register to lean on).
        Requests.OnChange += HandleRegisterChange;
        Drawings.OnChange += HandleRegisterChange;
        Requests.Refresh(ProjectId);
        Drawings.Refresh(ProjectId);
        _ = LoadVariationsAsync();

        await LoadAsync();
        if (CanManage) await LoadAssignableRolesAsync();
    }

    public void Dispose()
    {
        Requests.OnChange -= HandleRegisterChange;
        Drawings.OnChange -= HandleRegisterChange;
    }

    private void HandleRegisterChange() => _ = InvokeAsync(StateHasChanged);

    private async Task LoadVariationsAsync()
    {
        // A failed load simply leaves variations out of the search results rather than blocking
        // the tab — requests and drawings still match.
        try
        {
            voqs = await Variations.ListForProjectAsync(ProjectId);
            vos = await Variations.ListVariationOrdersForProjectAsync(ProjectId);
        }
        catch { }
        finally
        {
            relatedLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadAssignableRolesAsync()
    {
        // A failed load leaves the picker with no options rather than blocking the tab — the add
        // modal still works, the item just goes in unassigned.
        try
        {
            AssigneeOptions = (await Todos.ListAssignableRolesAsync())
                .Select(role => new SearchSelect.Option(RoleValue(role), role.DisplayName()))
                .ToList();
        }
        catch { }
    }

    private async Task LoadAsync()
    {
        loading = true;
        try { items = await Todos.ListForProjectAsync(ProjectId); }
        catch { error = "Couldn't load the to-do list. Please try again."; }
        finally { loading = false; }
    }

    private void OnNewNotesInput(ChangeEventArgs e) => newNotes = e.Value?.ToString() ?? "";

    private void OpenAdd()
    {
        newTitle = newNotes = newAssignee = newDue = "";
        addError = null;
        addOpen = true;
    }

    private void CloseAdd()
    {
        addOpen = false;
        addError = null;
    }

    private async Task Add()
    {
        if (busy) return;
        if (string.IsNullOrWhiteSpace(newTitle)) { addError = "A title is required."; return; }
        addError = null;
        await Run(async () =>
        {
            await Todos.AddAsync(new AddTodoItem(
                ProjectId,
                newTitle.Trim(),
                NullIfBlank(newNotes),
                ParseRole(newAssignee),
                ParseDate(newDue)));
            CloseAdd();
        });
        // A failed add leaves the modal open with the panel-level error mirrored inside it.
        if (error is not null && addOpen) addError = error;
    }

    private async Task ToggleComplete(TodoItem item)
    {
        if (busy) return;
        await Run(() => Todos.UpdateAsync(new UpdateTodoItem(
            item.TodoItemId,
            item.Title,
            NullIfBlank(item.Notes),
            item.AssigneeRole,
            item.DueAt,
            !item.IsComplete)));
        // Success closes the detail modal — the reloaded list shows the item in its new section.
        // A failure keeps it open with the error surfaced inside.
        if (error is null) selected = null;
    }

    private async Task Delete(TodoItem item)
    {
        if (busy) return;
        await Run(() => Todos.DeleteAsync(item.TodoItemId));
        if (error is null) selected = null;
    }

    private async Task Run(Func<Task> action)
    {
        error = null;
        try
        {
            busy = true;
            await action();
            // Take the server's fresh open-first/done-pile order: with completion happening in the
            // detail modal (not via an inline checkbox), re-grouping on reload is the expected
            // "moves to the done section" behaviour rather than a row jumping under the cursor.
            items = await Todos.ListForProjectAsync(ProjectId);
        }
        catch (CommandFailedException ex) { error = ex.Message; }
        catch { error = "That action didn't complete. Please try again."; }
        finally { busy = false; }
    }

    // ---- Keyword search ------------------------------------------------------------------------

    private bool HasQuery => !string.IsNullOrWhiteSpace(search);

    private void OnSearchInput(ChangeEventArgs e) => search = e.Value?.ToString() ?? "";

    private void ClearSearch() => search = "";

    // Every whitespace-separated keyword must appear in at least one of the record's fields
    // (case-insensitive) — AND across keywords so extra words narrow the results.
    private bool MatchesKeywords(params string?[] fields)
    {
        var tokens = search.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return tokens.All(token =>
            fields.Any(field => field is not null && field.Contains(token, StringComparison.OrdinalIgnoreCase)));
    }

    private bool MatchesTodo(TodoItem item) => MatchesKeywords(item.Reference, item.Title, item.Notes);

    private IReadOnlyList<Request> MatchedRequests =>
        Requests.ForProject(ProjectId)
            .Where(r => MatchesKeywords(r.Reference, r.DisplayNumber, r.Kind.DisplayName(), r.Kind.LongName(), r.Title, r.Description))
            .ToList();

    private IReadOnlyList<VariationOrderQuote> MatchedVoqs =>
        voqs.Where(v => MatchesKeywords(v.Reference, v.DisplayNumber, v.Title, v.Description)).ToList();

    private IReadOnlyList<VariationOrder> MatchedVos =>
        vos.Where(v => MatchesKeywords(v.VariationRef, v.Title, v.Description)).ToList();

    private IReadOnlyList<Drawing> MatchedDrawings =>
        Drawings.DrawingsFor(ProjectId).Where(d => MatchesKeywords(d.DrawingCode, d.Title)).ToList();

    private void OpenRequest(Request record) =>
        Nav.NavigateTo($"/projects/{ProjectId}/requests/view/{record.RequestId}");

    private void OpenVoq(string voqId) =>
        Nav.NavigateTo($"/projects/{ProjectId}/voq/{voqId}");

    private void OpenDrawing(Drawing drawing) =>
        Nav.NavigateTo($"/projects/{ProjectId}/drawings/{drawing.DrawingId}");

    private static string RequestStatusLabel(RequestStatus status) => status switch
    {
        RequestStatus.AwaitingResponse => "Awaiting response",
        _ => status.ToString()
    };

    // --------------------------------------------------------------------------------------------

    private static bool IsOverdue(TodoItem item) =>
        !item.IsComplete && item.DueAt is not null && item.DueAt.Value < DateTimeOffset.Now.Date;

    private static string? NullIfBlank(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static DateTimeOffset? ParseDate(string value) =>
        DateTimeOffset.TryParse(value, out var parsed) ? parsed : null;

    // Role <-> SearchSelect value plumbing: options carry the role's int as a string ("" = unassigned).
    private static string RoleValue(Role role) => ((int)role).ToString();

    private static Role? ParseRole(string value) =>
        int.TryParse(value, out var parsed) ? (Role)parsed : null;
}
