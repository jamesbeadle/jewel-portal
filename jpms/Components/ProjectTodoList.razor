@using Jewel.JPMS.Contracts.Todos
@inject ITodoStore Todos
@inject SessionService Session

@*
    The project's to-do list, shown on the To-do tab. Items are added here directly or created
    from an email at the triage stage ("Create new → To-do item"), in which case the email is tagged
    "JPMS/TODO-####" per item — the item's reference chip is that tag stem. Full manage: add,
    complete/reopen, delete.
*@

<div class="panel p-5">
    <div class="flex items-center justify-between gap-2 mb-1">
        <div class="flex items-center gap-3">
            <h2 class="text-sm font-semibold text-content">To-do list</h2>
            @if (items.Count > 0)
            {
                <span class="text-[11px] text-content-subtle">@items.Count(i => i.IsComplete) of @items.Count done</span>
            }
        </div>
        @if (CanManage && !loading)
        {
            <button type="button" class="btn-primary text-xs px-2.5 py-1.5" @onclick="OpenAdd">Add item</button>
        }
    </div>
    <p class="text-xs text-content-subtle mb-4">
        Items added here or captured from an email at triage. An item created from an email carries its
        TODO reference as a mailbox tag, so its linked mail is always a tag-filter away in the Tagged view.
    </p>

    @if (error is not null)
    {
        <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@error</p>
    }

    @if (loading)
    {
        <JewelSpinner Class="py-8" Label="Loading" />
    }
    else
    {
        @if (items.Count == 0)
        {
            <p class="text-sm text-content-subtle italic mb-4">No to-do items on this project yet.</p>
        }
        else
        {
            <div class="space-y-2 mb-4">
                @foreach (var item in items)
                {
                    <div @key="item.TodoItemId" class="flex items-start gap-3 rounded-lg border border-line px-3 py-2">
                        <input type="checkbox" class="mt-1" checked="@item.IsComplete" disabled="@(!CanManage || busy)"
                               @onchange="() => ToggleComplete(item)" title="@(item.IsComplete ? "Reopen" : "Mark done")" />
                        <div class="min-w-0 flex-1">
                            <p class="text-sm @(item.IsComplete ? "text-content-subtle line-through" : "text-content")">
                                <span class="font-mono text-xs text-content-muted mr-2">@item.Reference</span>@item.Title
                            </p>
                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                            {
                                <p class="text-xs text-content-muted mt-0.5 whitespace-pre-wrap">@item.Notes</p>
                            }
                            <div class="flex flex-wrap items-center gap-x-3 gap-y-0.5 mt-1 text-[11px] text-content-subtle">
                                @if (item.DueAt is not null)
                                {
                                    <span class="@(IsOverdue(item) ? "text-negative font-medium" : "")">Due @item.DueAt.Value.LocalDateTime.ToString("d MMM yyyy")</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.AssigneeEmail))
                                {
                                    <span>Assigned to @item.AssigneeEmail</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.CreatedByEmail))
                                {
                                    <span>Added by @item.CreatedByEmail</span>
                                }
                                @if (item.CompletedAt is not null)
                                {
                                    <span>Done @item.CompletedAt.Value.LocalDateTime.ToString("d MMM yyyy")</span>
                                }
                            </div>
                        </div>
                        @if (CanManage)
                        {
                            <button type="button" class="text-content-subtle hover:text-negative text-xs mt-1" disabled="@busy"
                                    @onclick="() => Delete(item)" title="Delete this item">✕</button>
                        }
                    </div>
                }
            </div>
        }

    }
</div>

<Modal IsOpen="@addOpen" Title="Add a to-do item" ConfirmLabel="Add to-do item" CancelLabel="Cancel"
       OnConfirm="Add" OnCancel="CloseAdd">
    <div class="space-y-3">
        @if (addError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@addError</p>
        }

        <FormField Label="Title" Value="@newTitle" OnChange="v => newTitle = v" Required="true" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <FormField Label="Assignee email" Value="@newAssignee" OnChange="v => newAssignee = v" />
            <FormField Label="Due" Value="@newDue" OnChange="v => newDue = v" InputType="date" />
        </div>

        <div>
            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Notes</label>
            <textarea class="field" rows="2" value="@newNotes" @oninput="OnNewNotesInput"></textarea>
        </div>
    </div>
</Modal>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private IReadOnlyList<TodoItem> items = Array.Empty<TodoItem>();
    private bool loading = true;
    private bool busy;
    private string? error;

    // "Add a to-do item" modal state. The form lives in the modal; opening it starts from a clean
    // slate, and a successful add closes it.
    private bool addOpen;
    private string? addError;
    private string newTitle = "";
    private string newNotes = "";
    private string newAssignee = "";
    private string newDue = "";

    // Managing the list mirrors the server-side TodoRoles gate: directors, project managers and site
    // managers (administrators carry every role). Everyone else sees the list read-only.
    private bool CanManage =>
        Session.AvailableRoles.Any(role => role is Role.Admin or Role.ManagingDirector or Role.ProjectManager or Role.SiteManager);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        loading = true;
        try { items = await Todos.ListForProjectAsync(ProjectId); }
        catch { error = "Couldn't load the to-do list. Please try again."; }
        finally { loading = false; }
    }

    private void OnNewNotesInput(ChangeEventArgs e) => newNotes = e.Value?.ToString() ?? "";

    private void OpenAdd()
    {
        newTitle = newNotes = newAssignee = newDue = "";
        addError = null;
        addOpen = true;
    }

    private void CloseAdd()
    {
        addOpen = false;
        addError = null;
    }

    private async Task Add()
    {
        if (busy) return;
        if (string.IsNullOrWhiteSpace(newTitle)) { addError = "A title is required."; return; }
        addError = null;
        await Run(async () =>
        {
            await Todos.AddAsync(new AddTodoItem(
                ProjectId,
                newTitle.Trim(),
                NullIfBlank(newNotes),
                NullIfBlank(newAssignee),
                ParseDate(newDue)));
            CloseAdd();
        });
        // A failed add leaves the modal open with the panel-level error mirrored inside it.
        if (error is not null && addOpen) addError = error;
    }

    private async Task ToggleComplete(TodoItem item)
    {
        if (busy) return;
        await Run(() => Todos.UpdateAsync(new UpdateTodoItem(
            item.TodoItemId,
            item.Title,
            NullIfBlank(item.Notes),
            NullIfBlank(item.AssigneeEmail),
            item.DueAt,
            !item.IsComplete)));
    }

    private async Task Delete(TodoItem item)
    {
        if (busy) return;
        await Run(() => Todos.DeleteAsync(item.TodoItemId));
    }

    private async Task Run(Func<Task> action)
    {
        error = null;
        try
        {
            busy = true;
            await action();
            items = PreserveOrder(items, await Todos.ListForProjectAsync(ProjectId));
        }
        catch (CommandFailedException ex) { error = ex.Message; }
        catch { error = "That action didn't complete. Please try again."; }
        finally { busy = false; }
    }

    // Keep rows where they are while the user works the list: without this, ticking an item makes the
    // reloaded list re-sort it into the done pile at the bottom, which reads as "I clicked the top item
    // and the bottom one got checked". Existing items keep their on-screen position (a ticked item is
    // struck through in place); new items append at the end. The server's open-first/done-pile order
    // still applies fresh the next time the tab loads.
    private static IReadOnlyList<TodoItem> PreserveOrder(IReadOnlyList<TodoItem> current, IReadOnlyList<TodoItem> refreshed)
    {
        var position = current
            .Select((item, index) => (item.TodoItemId, index))
            .ToDictionary(entry => entry.TodoItemId, entry => entry.index);
        return refreshed
            .OrderBy(item => position.TryGetValue(item.TodoItemId, out var index) ? index : int.MaxValue)
            .ToList()
            .AsReadOnly();
    }

    private static bool IsOverdue(TodoItem item) =>
        !item.IsComplete && item.DueAt is not null && item.DueAt.Value < DateTimeOffset.Now.Date;

    private static string? NullIfBlank(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static DateTimeOffset? ParseDate(string value) =>
        DateTimeOffset.TryParse(value, out var parsed) ? parsed : null;
}
