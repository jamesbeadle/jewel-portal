@namespace Jewel.JPMS.Components.Icons

@* stroke-width 34 on the 530-wide viewBox ≈ 1.3px at the sidebar's 20px render size —
   matches the visual weight of the 24px nav icons (and the favicon). 13 was ~0.5px. *@
<svg class="@Class" viewBox="0 0 530 460" fill="none" stroke="currentColor"
     stroke-width="34" stroke-linejoin="miter" stroke-linecap="butt"
     xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <path d="M 140 30 L 390 30 L 510 175 L 265 430 L 20 175 Z" />
    <path d="M 55 175 L 475 175" />
    <path d="M 185 30 L 185 175" />
    <path d="M 345 30 L 345 175" />
    <path d="M 185 175 L 265 430" />
    <path d="M 345 175 L 265 430" />
</svg>

@code {
    [Parameter] public string Class { get; set; } = "w-5 h-5";
}
