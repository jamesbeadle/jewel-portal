<section class="rounded-xl border border-line bg-surface overflow-hidden">
    <header class="px-5 py-3 border-b border-line bg-surface-raised">
        <h2 class="text-sm font-medium text-content-muted">Site reports</h2>
    </header>
    @if (Reports.Count == 0)
    {
        <p class="p-5 text-sm text-content-subtle italic">No site reports issued yet.</p>
    }
    else
    {
        <ul class="divide-y divide-line">
            @foreach (var report in Reports)
            {
                <li class="p-4 text-sm">
                    <div class="flex items-start justify-between gap-3 mb-2">
                        <p class="font-medium text-content">Period ending @report.PeriodEnd.LocalDateTime.ToString("d MMM yyyy")</p>
                        <span class="text-xs font-semibold @(report.IsIssued ? "text-emerald-700" : "text-amber-700")">
                            @(report.IsIssued ? "Issued" : "Draft")
                        </span>
                    </div>
                    <p class="text-content-muted mb-2">@report.Narrative</p>
                    <p class="text-xs text-content-subtle">
                        @report.AttendanceDays days on site · @report.OpenSnags open snags · @report.ProgressPercent.ToString("0.#")% complete
                    </p>
                </li>
            }
        </ul>
    }
</section>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<SiteReport> Reports { get; set; } = Array.Empty<SiteReport>();
}
