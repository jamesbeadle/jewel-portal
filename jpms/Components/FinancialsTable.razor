@using Jewel.JPMS.Models
@using Jewel.JPMS.Contracts.Commercial

<div class="rounded-xl border border-line bg-surface overflow-x-auto">
    <table class="w-full text-sm border-collapse">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="sticky left-0 z-10 bg-surface-raised px-4 py-3 w-[88px]">Code</th>
                <th class="sticky left-[88px] z-10 bg-surface-raised px-4 py-3 min-w-[200px]">Cost Centre</th>
                @foreach (var col in Columns)
                {
                    <th class="px-4 py-3 text-right whitespace-nowrap">@col.Label</th>
                }
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @* Master cost centres first, then values sitting on codes that are not in
               the active master (legacy / retired) — shown rather than silently
               swallowed. (Loop variable must not be named "code": @code in markup
               parses as the Razor directive.) *@
            @foreach (var entry in Rows)
            {
                <tr>
                    <td class="sticky left-0 z-10 bg-surface px-4 py-3 font-mono text-[11px] text-content-subtle whitespace-nowrap">@entry.Code</td>
                    @if (entry.InMaster)
                    {
                        <td class="sticky left-[88px] z-10 bg-surface px-4 py-3 text-content font-medium whitespace-nowrap">@entry.Name</td>
                    }
                    else
                    {
                        <td class="sticky left-[88px] z-10 bg-surface px-4 py-3 text-content-subtle italic whitespace-nowrap">(not in cost-code master)</td>
                    }
                    @foreach (var col in Columns)
                    {
                        @if (col.Label == UnderOverLabel && byCode.ContainsKey(entry.Code))
                        {
                            <td class="px-4 py-3 text-right">
                                <button type="button"
                                        class="underline decoration-dotted underline-offset-2 hover:decoration-solid @CellClass(col, entry.Code)"
                                        title="Show cost centre breakdown"
                                        @onclick="() => OnUnderOverSelected.InvokeAsync(entry.Code)">
                                    @CellText(col, entry.Code)
                                </button>
                            </td>
                        }
                        else
                        {
                            <td class="px-4 py-3 text-right @CellClass(col, entry.Code)">@CellText(col, entry.Code)</td>
                        }
                    }
                </tr>
            }
        </tbody>
        <tfoot class="border-t-2 border-line-strong bg-surface-raised">
            <tr class="font-semibold text-content">
                <td class="sticky left-0 z-10 bg-surface-raised px-4 py-3"></td>
                <td class="sticky left-[88px] z-10 bg-surface-raised px-4 py-3 whitespace-nowrap">Total</td>
                @foreach (var col in Columns)
                {
                    <td class="px-4 py-3 text-right">@TotalText(col)</td>
                }
            </tr>
        </tfoot>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<CostCenter> CostCenters { get; set; } = Array.Empty<CostCenter>();
    [Parameter] public IReadOnlyList<ProjectFinancialSummaryRow> SummaryRows { get; set; } = Array.Empty<ProjectFinancialSummaryRow>();

    /// <summary>Raised with the cost code when a row's Under/Over Expected figure is clicked.</summary>
    [Parameter] public EventCallback<string> OnUnderOverSelected { get; set; }

    private enum Format { Money, Percent }

    private sealed record Column(string Label, Format Format);

    // Budget allocation model (FD-agreed):
    //   Budgeted Sales       = the valuation report's counting lines per cost centre — what we bill the client (LIVE)
    //   Budgeted Cost        = Budgeted Sales less the assumed margin (FinancialSummaryAssumptions.MarginPercent) (LIVE)
    //   Assigned Budget      = sum of purchase orders raised to suppliers (committed cost — later)
    //   Unallocated Budget   = Budgeted Cost - Assigned Budget (later)
    //   Completion %         = latest claim's cumulative claimed value / budgeted sales (LIVE)
    //   Expected Actual Cost = Budgeted Cost × Completion % (LIVE)
    //   Actual Cost          = Xero purchase lines allocated to this project (LIVE)
    //   Under/Over Expected  = Expected Actual Cost - Actual Cost; positive = under (LIVE, click for detail)
    private static readonly Column[] Columns =
    {
        new("Budgeted Sales",        Format.Money),
        new("Budgeted Cost",         Format.Money),
        new("Assigned Budget",       Format.Money),
        new("Unallocated Budget",    Format.Money),
        new("Completion %",          Format.Percent),
        new("Expected Actual Cost",  Format.Money),
        new("Actual Cost",           Format.Money),
        new("Under/Over Expected",   Format.Money),
        new("Expected Actual Sales", Format.Money),
        new("Actual Sales",          Format.Money),
        new("Under/Over Billed",     Format.Money),
        new("Gross Profit",          Format.Money)
    };

    private const string UnderOverLabel = "Under/Over Expected";

    private Dictionary<string, ProjectFinancialSummaryRow> byCode = new(StringComparer.OrdinalIgnoreCase);

    protected override void OnParametersSet() =>
        byCode = SummaryRows.ToDictionary(row => row.CostCode, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<(string Code, string Name, bool InMaster)> Rows =>
        CostCenters.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase)
            .Select(centre => (Code: centre.Code, Name: centre.Name, InMaster: true))
            .Concat(UnmatchedCodes.Select(unmatched => (Code: unmatched, Name: "", InMaster: false)));

    private IEnumerable<string> UnmatchedCodes =>
        SummaryRows.Select(row => row.CostCode)
            .Where(rowCode => !CostCenters.Any(centre => string.Equals(centre.Code, rowCode, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(rowCode => rowCode, StringComparer.OrdinalIgnoreCase);

    private decimal ValueFor(Column col, string costCode)
    {
        if (!byCode.TryGetValue(costCode, out var row)) return 0m;
        return col.Label switch
        {
            "Budgeted Sales" => row.BudgetedSales,
            "Budgeted Cost" => row.BudgetedCost,
            "Completion %" => row.CompletionPercent,
            "Expected Actual Cost" => row.ExpectedActualCost,
            "Actual Cost" => row.ActualCost,
            UnderOverLabel => row.UnderOverExpected,
            _ => 0m
        };
    }

    private string CellText(Column col, string costCode) =>
        col.Format == Format.Percent ? Percent(ValueFor(col, costCode)) : Money(ValueFor(col, costCode));

    private string CellClass(Column col, string costCode)
    {
        var value = ValueFor(col, costCode);
        if (value == 0m) return "text-content-muted";
        // Under/over: green when under the expected cost, red when over.
        if (col.Label == UnderOverLabel) return value > 0m ? "text-positive" : "text-negative";
        return "text-content";
    }

    private string TotalText(Column col)
    {
        if (col.Format == Format.Percent)
        {
            // Weighted by budgeted sales, matching the per-row calculation.
            var totalSales = SummaryRows.Sum(row => row.BudgetedSales);
            var weighted = totalSales == 0m
                ? 0m
                : SummaryRows.Sum(row => row.CompletionPercent * row.BudgetedSales) / totalSales;
            return Percent(weighted);
        }
        var total = col.Label switch
        {
            "Budgeted Sales" => SummaryRows.Sum(row => row.BudgetedSales),
            "Budgeted Cost" => SummaryRows.Sum(row => row.BudgetedCost),
            "Expected Actual Cost" => SummaryRows.Sum(row => row.ExpectedActualCost),
            "Actual Cost" => SummaryRows.Sum(row => row.ActualCost),
            UnderOverLabel => SummaryRows.Sum(row => row.UnderOverExpected),
            _ => 0m
        };
        return Money(total);
    }

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string Percent(decimal value) =>
        $"{value.ToString(value == Math.Truncate(value) ? "0" : "0.#")}%";
}
