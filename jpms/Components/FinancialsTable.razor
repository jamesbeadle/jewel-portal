@using Jewel.JPMS.Models
@using Jewel.JPMS.Contracts.Commercial

<label class="mb-3 flex w-fit items-center gap-2 text-sm text-content-subtle cursor-pointer select-none">
    <input type="checkbox" class="cursor-pointer align-middle" @bind="hideZeroRows" />
    Hide zero rows
</label>

<div class="rounded-xl border border-line bg-surface overflow-x-auto">
    <table class="w-full text-sm border-collapse">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="sticky left-0 z-10 bg-surface-raised px-4 py-3 w-[88px]">Code</th>
                <th class="sticky left-[88px] z-10 bg-surface-raised px-4 py-3 min-w-[200px]">Cost Centre</th>
                @* Sales side: what we bill the client. *@
                <th class="px-4 py-3 text-right whitespace-nowrap">Contract Sales Value</th>
                <th class="px-4 py-3 text-right whitespace-nowrap">% Complete</th>
                <th class="px-4 py-3 text-right whitespace-nowrap">Claim Value</th>
                @* Cost side: what we expect to pay out. *@
                <th class="px-4 py-3 text-right whitespace-nowrap border-l border-line">Target Cost Value</th>
                <th class="px-4 py-3 text-right whitespace-nowrap">WO Committed</th>
                <th class="px-4 py-3 text-right whitespace-nowrap">Drawdown</th>
                <th class="px-4 py-3 text-right whitespace-nowrap">Cost % Complete</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @* Master cost centres first, then values sitting on codes that are not in
               the active master (legacy / retired) — shown rather than silently
               swallowed. (Loop variable must not be named "code": @code in markup
               parses as the Razor directive.) *@
            @foreach (var entry in VisibleRows)
            {
                var costCode = entry.Code;
                var woCommitted = WoCommittedFor(costCode);
                var drawdown = DrawdownFor(costCode);
                <tr>
                    <td class="sticky left-0 z-10 bg-surface px-4 py-3 font-mono text-[11px] text-content-subtle whitespace-nowrap">@entry.Code</td>
                    @if (entry.InMaster)
                    {
                        <td class="sticky left-[88px] z-10 bg-surface px-4 py-3 text-content font-medium whitespace-nowrap">@entry.Name</td>
                    }
                    else
                    {
                        <td class="sticky left-[88px] z-10 bg-surface px-4 py-3 text-content-subtle italic whitespace-nowrap">(not in cost-code master)</td>
                    }

                    <td class="px-4 py-3 text-right @MoneyClass(ContractSalesFor(costCode))">@Money(ContractSalesFor(costCode))</td>
                    <td class="px-4 py-3 text-right @MoneyClass(SalesCompletionFor(costCode))">@Percent(SalesCompletionFor(costCode))</td>
                    <td class="px-4 py-3 text-right @MoneyClass(ClaimValueFor(costCode))">@Money(ClaimValueFor(costCode))</td>

                    <td class="px-4 py-3 text-right border-l border-line @MoneyClass(TargetCostFor(costCode))">@Money(TargetCostFor(costCode))</td>

                    @if (woCommitted != 0m)
                    {
                        <td class="px-4 py-3 text-right">
                            <button type="button"
                                    class="underline decoration-dotted underline-offset-2 hover:decoration-solid text-content"
                                    title="Show this cost centre's work orders"
                                    @onclick="() => OnWorkOrderCommittedSelected.InvokeAsync(costCode)">
                                @Money(woCommitted)
                            </button>
                        </td>
                    }
                    else
                    {
                        <td class="px-4 py-3 text-right text-content-muted">@Money(0m)</td>
                    }

                    <td class="px-4 py-3 text-right @DrawdownClass(drawdown)">@Money(drawdown)</td>

                    <td class="px-4 py-3 text-right">
                        <input type="number" min="0" max="100" step="1"
                               class="w-20 rounded-md border border-line bg-surface px-2 py-1 text-right text-sm text-content
                                      focus:outline-none focus:border-line-strong"
                               title="Cost-side completion for this cost centre (0–100)"
                               value="@InputValue(CostCompletionFor(costCode))"
                               disabled="@IsSaving(costCode)"
                               @onchange="args => HandleCostCompletionChangedAsync(costCode, args)" />
                    </td>
                </tr>
            }
        </tbody>
        <tfoot class="border-t-2 border-line-strong bg-surface-raised">
            <tr class="font-semibold text-content">
                <td class="sticky left-0 z-10 bg-surface-raised px-4 py-3"></td>
                <td class="sticky left-[88px] z-10 bg-surface-raised px-4 py-3 whitespace-nowrap">Total</td>
                <td class="px-4 py-3 text-right">@Money(TotalContractSales)</td>
                <td class="px-4 py-3 text-right">@Percent(WeightedSalesCompletion)</td>
                <td class="px-4 py-3 text-right">@Money(TotalClaimValue)</td>
                <td class="px-4 py-3 text-right border-l border-line">@Money(TotalTargetCost)</td>
                <td class="px-4 py-3 text-right">@Money(TotalWoCommitted)</td>
                <td class="px-4 py-3 text-right">@Money(TotalDrawdown)</td>
                <td class="px-4 py-3 text-right pr-6">@Percent(WeightedCostCompletion)</td>
            </tr>
        </tfoot>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<CostCenter> CostCenters { get; set; } = Array.Empty<CostCenter>();
    [Parameter] public IReadOnlyList<ProjectFinancialSummaryRow> SummaryRows { get; set; } = Array.Empty<ProjectFinancialSummaryRow>();

    /// <summary>Committed work-order value (order line totals) per cost code, from the
    /// project's work orders. Rendered as the WO Committed column.</summary>
    [Parameter] public IReadOnlyDictionary<string, decimal> WorkOrderCommittedByCode { get; set; } =
        new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);

    /// <summary>Raised with the cost code when a row's WO Committed figure is clicked.</summary>
    [Parameter] public EventCallback<string> OnWorkOrderCommittedSelected { get; set; }

    /// <summary>Raised when a row's Cost % Complete is edited; the parent persists it and
    /// refreshes the summary. The cost code being saved renders its input disabled until
    /// the refreshed rows arrive.</summary>
    [Parameter] public EventCallback<(string CostCode, decimal Percent)> OnCostCompletionChanged { get; set; }

    // Report shape (agreed 2026-07): sales side then cost side, per cost centre.
    //   Contract Sales Value = the valuation report's counting lines (contract works,
    //                          provisional sums, contingency and variations; declined/TBC excluded)
    //   % Complete           = sales-side completion from the latest claim — edited on the valuation
    //   Claim Value          = the latest claim's cumulative claimed £ (Contract Sales Value × % Complete)
    //   Target Cost Value    = Contract Sales Value ÷ (1 + FinancialSummaryAssumptions.MarkupPercent)
    //                          — what the centre should cost us; target cost + markup = sales value
    //   WO Committed         = committed work-order line totals (click for the centre's work orders)
    //   Drawdown             = Target Cost Value minus WO Committed — budget still to be
    //                          spent outside work orders; negative = over-committed
    //   Cost % Complete      = cost-side completion, edited inline here

    private Dictionary<string, ProjectFinancialSummaryRow> byCode = new(StringComparer.OrdinalIgnoreCase);

    // Hide cost centres with no figures in any column; on by default.
    private bool hideZeroRows = true;

    // The cost code whose Cost % Complete edit is currently in flight, if any.
    private string? savingCostCode;

    protected override void OnParametersSet()
    {
        byCode = SummaryRows.ToDictionary(row => row.CostCode, StringComparer.OrdinalIgnoreCase);
        // New rows have arrived (or the parent re-rendered after the save): re-enable the input.
        savingCostCode = null;
    }

    private decimal ContractSalesFor(string costCode) =>
        byCode.TryGetValue(costCode, out var row) ? row.BudgetedSales : 0m;

    private decimal SalesCompletionFor(string costCode) =>
        byCode.TryGetValue(costCode, out var row) ? row.CompletionPercent : 0m;

    private decimal ClaimValueFor(string costCode) =>
        byCode.TryGetValue(costCode, out var row) ? row.ClaimedToDate : 0m;

    private decimal CostCompletionFor(string costCode) =>
        byCode.TryGetValue(costCode, out var row) ? row.CostCompletionPercent : 0m;

    private decimal WoCommittedFor(string costCode) =>
        WorkOrderCommittedByCode.TryGetValue(costCode, out var committed) ? committed : 0m;

    // Contract sales value less the assumed margin — what the centre should cost us.
    private decimal TargetCostFor(string costCode) =>
        byCode.TryGetValue(costCode, out var row) ? row.BudgetedCost : 0m;

    // Target cost not yet committed to work orders.
    private decimal DrawdownFor(string costCode) =>
        TargetCostFor(costCode) - WoCommittedFor(costCode);

    private bool IsSaving(string costCode) =>
        string.Equals(savingCostCode, costCode, StringComparison.OrdinalIgnoreCase);

    private async Task HandleCostCompletionChangedAsync(string costCode, ChangeEventArgs args)
    {
        if (!decimal.TryParse(Convert.ToString(args.Value),
                System.Globalization.NumberStyles.Number,
                System.Globalization.CultureInfo.InvariantCulture,
                out var percent)) { StateHasChanged(); return; }
        percent = Math.Clamp(percent, 0m, 100m);
        if (percent == CostCompletionFor(costCode)) return;
        savingCostCode = costCode;
        await OnCostCompletionChanged.InvokeAsync((costCode, percent));
    }

    private bool HasAnyValue(string costCode) =>
        (byCode.TryGetValue(costCode, out var row) &&
         (row.BudgetedSales != 0m || row.CompletionPercent != 0m || row.ClaimedToDate != 0m ||
          row.BudgetedCost != 0m || row.CostCompletionPercent != 0m)) ||
        WoCommittedFor(costCode) != 0m;

    private IEnumerable<(string Code, string Name, bool InMaster)> VisibleRows =>
        CostCenters.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase)
            .Select(centre => (Code: centre.Code, Name: centre.Name, InMaster: true))
            .Concat(UnmatchedCodes.Select(unmatched => (Code: unmatched, Name: "", InMaster: false)))
            .Where(entry => !hideZeroRows || HasAnyValue(entry.Code));

    private IEnumerable<string> UnmatchedCodes =>
        SummaryRows.Select(row => row.CostCode)
            .Union(WorkOrderCommittedByCode.Keys, StringComparer.OrdinalIgnoreCase)
            .Where(rowCode => !CostCenters.Any(centre => string.Equals(centre.Code, rowCode, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(rowCode => rowCode, StringComparer.OrdinalIgnoreCase);

    private decimal TotalContractSales => SummaryRows.Sum(row => row.BudgetedSales);
    private decimal TotalClaimValue => SummaryRows.Sum(row => row.ClaimedToDate);
    private decimal TotalTargetCost => SummaryRows.Sum(row => row.BudgetedCost);
    private decimal TotalWoCommitted => WorkOrderCommittedByCode.Values.Sum();
    private decimal TotalDrawdown => TotalTargetCost - TotalWoCommitted;

    // Weighted by contract sales value, matching the per-row calculation.
    private decimal WeightedSalesCompletion =>
        TotalContractSales == 0m
            ? 0m
            : SummaryRows.Sum(row => row.CompletionPercent * row.BudgetedSales) / TotalContractSales;

    // Weighted by expected cost (budgeted cost), the base the cost side draws down against.
    private decimal WeightedCostCompletion
    {
        get
        {
            var totalExpectedCost = SummaryRows.Sum(row => row.BudgetedCost);
            return totalExpectedCost == 0m
                ? 0m
                : SummaryRows.Sum(row => row.CostCompletionPercent * row.BudgetedCost) / totalExpectedCost;
        }
    }

    private string MoneyClass(decimal value) => value == 0m ? "text-content-muted" : "text-content";

    // Negative drawdown = more committed to work orders than the expected cost allows.
    private string DrawdownClass(decimal value) =>
        value == 0m ? "text-content-muted" : value < 0m ? "text-negative" : "text-content";

    private static string InputValue(decimal value) =>
        value.ToString(value == Math.Truncate(value) ? "0" : "0.#");

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string Percent(decimal value) =>
        $"{value.ToString(value == Math.Truncate(value) ? "0" : "0.#")}%";
}
