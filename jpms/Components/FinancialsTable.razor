@using Jewel.JPMS.Models
@using Jewel.JPMS.Contracts.Commercial

<div class="rounded-xl border border-line bg-surface overflow-x-auto">
    <table class="w-full text-sm border-collapse">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="sticky left-0 z-10 bg-surface-raised px-4 py-3 w-[88px]">Code</th>
                <th class="sticky left-[88px] z-10 bg-surface-raised px-4 py-3 min-w-[200px]">Cost Centre</th>
                @foreach (var col in Columns)
                {
                    <th class="px-4 py-3 text-right whitespace-nowrap">@col.Label</th>
                }
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @foreach (var centre in Ordered)
            {
                <tr>
                    <td class="sticky left-0 z-10 bg-surface px-4 py-3 font-mono text-[11px] text-content-subtle whitespace-nowrap">@centre.Code</td>
                    <td class="sticky left-[88px] z-10 bg-surface px-4 py-3 text-content font-medium whitespace-nowrap">@centre.Name</td>
                    @foreach (var col in Columns)
                    {
                        <td class="px-4 py-3 text-right @CellClass(col, centre.Code)">@CellText(col, centre.Code)</td>
                    }
                </tr>
            }
            @foreach (var unmatched in UnmatchedCodes)
            {
                @* Values sitting on codes that are not in the active master (legacy /
                   retired) — shown rather than silently swallowed. (Loop variable must
                   not be named "code": @code in markup parses as the Razor directive.) *@
                <tr>
                    <td class="sticky left-0 z-10 bg-surface px-4 py-3 font-mono text-[11px] text-content-subtle whitespace-nowrap">@unmatched</td>
                    <td class="sticky left-[88px] z-10 bg-surface px-4 py-3 text-content-subtle italic whitespace-nowrap">(not in cost-code master)</td>
                    @foreach (var col in Columns)
                    {
                        <td class="px-4 py-3 text-right @CellClass(col, unmatched)">@CellText(col, unmatched)</td>
                    }
                </tr>
            }
        </tbody>
        <tfoot class="border-t-2 border-line-strong bg-surface-raised">
            <tr class="font-semibold text-content">
                <td class="sticky left-0 z-10 bg-surface-raised px-4 py-3"></td>
                <td class="sticky left-[88px] z-10 bg-surface-raised px-4 py-3 whitespace-nowrap">Total</td>
                @foreach (var col in Columns)
                {
                    <td class="px-4 py-3 text-right">@TotalText(col)</td>
                }
            </tr>
        </tfoot>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<CostCenter> CostCenters { get; set; } = Array.Empty<CostCenter>();
    [Parameter] public IReadOnlyList<ProjectFinancialSummaryRow> SummaryRows { get; set; } = Array.Empty<ProjectFinancialSummaryRow>();

    private enum Format { Money, Percent }

    private sealed record Column(string Label, Format Format);

    // Budget allocation model (FD-agreed):
    //   Budgeted Cost      = the valuation report's counting lines per cost centre (LIVE)
    //   Actual Cost        = Xero purchase lines allocated to this project (LIVE)
    //   Assigned Budget    = sum of purchase orders raised to suppliers (committed cost — later)
    //   Unallocated Budget = Budgeted Cost - Assigned Budget (later)
    //   Under/Over Budget  = measured against PO commitments (later)
    private static readonly Column[] Columns =
    {
        new("Budgeted Cost",         Format.Money),
        new("Assigned Budget",       Format.Money),
        new("Unallocated Budget",    Format.Money),
        new("Completion %",          Format.Percent),
        new("Expected Actual Cost",  Format.Money),
        new("Actual Cost",           Format.Money),
        new("Under/Over Budget",     Format.Money),
        new("Budgeted Sales",        Format.Money),
        new("Expected Actual Sales", Format.Money),
        new("Actual Sales",          Format.Money),
        new("Under/Over Billed",     Format.Money),
        new("Gross Profit",          Format.Money)
    };

    private Dictionary<string, ProjectFinancialSummaryRow> byCode = new(StringComparer.OrdinalIgnoreCase);

    protected override void OnParametersSet() =>
        byCode = SummaryRows.ToDictionary(row => row.CostCode, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<CostCenter> Ordered =>
        CostCenters.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<string> UnmatchedCodes =>
        SummaryRows.Select(row => row.CostCode)
            .Where(code => !CostCenters.Any(centre => string.Equals(centre.Code, code, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(code => code, StringComparer.OrdinalIgnoreCase);

    private decimal ValueFor(Column col, string code)
    {
        if (!byCode.TryGetValue(code, out var row)) return 0m;
        return col.Label switch
        {
            "Budgeted Cost" => row.BudgetedCost,
            "Actual Cost" => row.ActualCost,
            _ => 0m
        };
    }

    private string CellText(Column col, string code) =>
        col.Format == Format.Percent ? "0%" : Money(ValueFor(col, code));

    private string CellClass(Column col, string code) =>
        ValueFor(col, code) == 0m ? "text-content-muted" : "text-content";

    private string TotalText(Column col)
    {
        if (col.Format == Format.Percent) return "0%";
        var total = col.Label switch
        {
            "Budgeted Cost" => SummaryRows.Sum(row => row.BudgetedCost),
            "Actual Cost" => SummaryRows.Sum(row => row.ActualCost),
            _ => 0m
        };
        return Money(total);
    }

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
