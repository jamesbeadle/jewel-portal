@using Jewel.JPMS.Models
@using Jewel.JPMS.Contracts.Commercial

<div class="mb-3 flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap items-center gap-4">
        <input class="text-sm bg-surface border border-line rounded-lg px-3 py-1.5 text-content placeholder:text-content-subtle w-64"
               placeholder="Search cost centre or code…"
               value="@search" @oninput="e => search = e.Value?.ToString() ?? string.Empty" />
        <label class="flex w-fit items-center gap-2 text-sm text-content-subtle cursor-pointer select-none">
            <input type="checkbox" class="cursor-pointer align-middle" @bind="hideZeroRows" />
            Hide zero rows
        </label>
        <label class="flex w-fit items-center gap-2 text-sm text-content-subtle cursor-pointer select-none"
               title="Net off the sales, work orders and invoiced cost already accounted for by reconciliation packages — the packaged money's position shows on the package rows instead. Untick to see gross figures.">
            <input type="checkbox" class="cursor-pointer align-middle" @bind="hidePackagedScope" />
            Hide scope in packages
        </label>
    </div>
    @if (SelectionCount > 0)
    {
        <div class="flex items-center gap-3">
            <span class="text-sm text-content-subtle">@SelectionCount selected</span>
            <button type="button" class="btn-primary text-sm" disabled="@(SelectionCount < 2)"
                    title="Combine the selected rows into one named report line — selected roll-ups are merged in"
                    @onclick="RequestGroup">
                Roll up @SelectionCount rows
            </button>
            <button type="button" class="btn-secondary text-sm" @onclick="ClearSelection">Clear</button>
        </div>
    }
</div>

@* max-h + overflow-y makes this wrapper the vertical scroll container, so the sticky
   header row stays visible while the rows scroll under it. Corner cells (checkbox /
   code / name) are sticky on both axes and sit above everything else. *@
<div class="rounded-xl border border-line bg-surface overflow-x-auto overflow-y-auto max-h-[85vh]">
    <table class="w-full text-sm border-collapse">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="sticky left-0 top-0 z-30 bg-surface-raised px-3 py-3 w-[36px]"></th>
                <th class="sticky left-[36px] top-0 z-30 bg-surface-raised px-4 py-3 w-[88px]">@SortHeader("code", "Code")</th>
                <th class="sticky left-[124px] top-0 z-30 bg-surface-raised px-4 py-3 min-w-[200px]">@SortHeader("name", "Cost Centre")</th>
                @* Sales side: what we bill the client. *@
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">@SortHeader("sales", "Contract Sales Value")</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">@SortHeader("complete", "% Complete")</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">@SortHeader("claim", "Claim Value")</th>
                @* Cost side: what we expect to pay out. *@
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap border-l border-line">@SortHeader("target", "Target Cost Value")</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">@SortHeader("wo", "Work Orders")</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">@SortHeader("acos", "Actual Cost of Sales")</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">@SortHeader("nonwo", "Non-WO Cost of Sales")</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">@SortHeader("drawdown", "Drawdown")</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">@SortHeader("pl", "Profit / Loss")</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">@SortHeader("costpct", "Cost % Complete")</th>
                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 w-[80px]"><span class="sr-only">Lock</span></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @* Named roll-ups and remaining individual centres, alphabetically. Master cost
               centres first among individuals, then values sitting on codes that are not in
               the active master (legacy / retired) — shown rather than silently swallowed.
               (Loop variable must not be named "code": @code in markup parses as the Razor
               directive.) *@
            @foreach (var line in VisibleLines)
            {
                var reportLine = line;
                var woCommitted = WoCommittedFor(reportLine.CostCodes);
                var contractSales = ContractSalesFor(reportLine.CostCodes);
                var drawdown = DrawdownFor(reportLine.CostCodes);
                var profitLoss = ProfitLossFor(reportLine.CostCodes);
                var allLocked = AllFinalised(reportLine.CostCodes);
                var anyLocked = AnyFinalised(reportLine.CostCodes);
                <tr>
                    <td class="sticky left-0 z-10 bg-surface px-3 py-3">
                        @if (reportLine.IsGroup)
                        {
                            <input type="checkbox" class="cursor-pointer align-middle"
                                   title="Select to merge this roll-up with other rows into one line"
                                   checked="@selectedGroupIds.Contains(reportLine.Key)"
                                   @onchange="() => ToggleGroupSelection(reportLine.Key)" />
                        }
                        else
                        {
                            <input type="checkbox" class="cursor-pointer align-middle"
                                   title="Select to roll up with other rows"
                                   checked="@selectedCodes.Contains(reportLine.Key)"
                                   @onchange="() => ToggleSelection(reportLine.Key)" />
                        }
                    </td>
                    @if (reportLine.IsGroup)
                    {
                        <td class="sticky left-[36px] z-10 bg-surface px-4 py-3 font-mono text-[11px] text-content-subtle whitespace-nowrap"
                            title="@string.Join(", ", reportLine.CostCodes)">@($"{reportLine.CostCodes.Count} centres")</td>
                        <td class="sticky left-[124px] z-10 bg-surface px-4 py-3 whitespace-nowrap">
                            <span class="text-content font-medium" title="@string.Join(", ", reportLine.CostCodes)">@reportLine.Name</span>
                            <button type="button"
                                    class="ml-2 text-[11px] text-content-subtle underline underline-offset-2 hover:text-content"
                                    title="Split this roll-up back into its cost centres"
                                    @onclick="() => OnUngroupRequested.InvokeAsync(reportLine.Key)">
                                Ungroup
                            </button>
                        </td>
                    }
                    else
                    {
                        <td class="sticky left-[36px] z-10 bg-surface px-4 py-3 font-mono text-[11px] text-content-subtle whitespace-nowrap">@reportLine.Code</td>
                        @if (reportLine.InMaster)
                        {
                            <td class="sticky left-[124px] z-10 bg-surface px-4 py-3 text-content font-medium whitespace-nowrap">@reportLine.Name</td>
                        }
                        else
                        {
                            <td class="sticky left-[124px] z-10 bg-surface px-4 py-3 text-content-subtle italic whitespace-nowrap">(not in cost-code master)</td>
                        }
                    }

                    @if (contractSales != 0m)
                    {
                        <td class="px-4 py-3 text-right">
                            <button type="button"
                                    class="underline decoration-dotted underline-offset-2 hover:decoration-solid text-content"
                                    title="Show the valuation lines behind this figure"
                                    @onclick="() => OnContractSalesSelected.InvokeAsync((Heading(reportLine), reportLine.CostCodes))">
                                @Money(contractSales)
                            </button>
                        </td>
                    }
                    else
                    {
                        <td class="px-4 py-3 text-right text-content-muted">@Money(0m)</td>
                    }
                    <td class="px-4 py-3 text-right @MoneyClass(SalesCompletionFor(reportLine.CostCodes))">@Percent(SalesCompletionFor(reportLine.CostCodes))</td>
                    <td class="px-4 py-3 text-right @MoneyClass(ClaimValueFor(reportLine.CostCodes))">@Money(ClaimValueFor(reportLine.CostCodes))</td>

                    <td class="px-4 py-3 text-right border-l border-line @MoneyClass(TargetCostFor(reportLine.CostCodes))">@Money(TargetCostFor(reportLine.CostCodes))</td>

                    @if (woCommitted != 0m)
                    {
                        <td class="px-4 py-3 text-right">
                            <button type="button"
                                    class="underline decoration-dotted underline-offset-2 hover:decoration-solid text-content"
                                    title="Show this line's work orders"
                                    @onclick="() => OnWorkOrderCommittedSelected.InvokeAsync((Heading(reportLine), reportLine.CostCodes))">
                                @Money(woCommitted)
                            </button>
                        </td>
                    }
                    else
                    {
                        <td class="px-4 py-3 text-right text-content-muted">@Money(0m)</td>
                    }

                    @if (CostOfSalesFor(reportLine.CostCodes) != 0m)
                    {
                        <td class="px-4 py-3 text-right">
                            <button type="button"
                                    class="underline decoration-dotted underline-offset-2 hover:decoration-solid text-content"
                                    title="Show the allocated purchase invoices behind this figure, and link them to work orders"
                                    @onclick="() => OnCostOfSalesSelected.InvokeAsync((Heading(reportLine), reportLine.CostCodes))">
                                @Money(CostOfSalesFor(reportLine.CostCodes))
                            </button>
                        </td>
                    }
                    else
                    {
                        <td class="px-4 py-3 text-right text-content-muted">@Money(0m)</td>
                    }

                    <td class="px-4 py-3 text-right @MoneyClass(NonWoCostOfSalesFor(reportLine.CostCodes))">@Money(NonWoCostOfSalesFor(reportLine.CostCodes))</td>

                    @if (allLocked)
                    {
                        <td class="px-4 py-3 text-right text-content-muted" title="Locked — the remaining value now reads as profit / loss">—</td>
                    }
                    else
                    {
                        <td class="px-4 py-3 text-right @DrawdownClass(drawdown)">@Money(drawdown)</td>
                    }

                    @if (anyLocked)
                    {
                        <td class="px-4 py-3 text-right font-medium @(profitLoss == 0m ? "text-content-muted" : profitLoss > 0m ? "text-positive" : "text-negative")">@Money(profitLoss)</td>
                    }
                    else
                    {
                        <td class="px-4 py-3 text-right text-content-muted" title="Lock the line to realise its remaining drawdown as profit / loss">—</td>
                    }

                    <td class="px-4 py-3 text-right">
                        <input type="number" min="0" max="100" step="1"
                               class="w-20 rounded-md border border-line bg-surface px-2 py-1 text-right text-sm text-content
                                      focus:outline-none focus:border-line-strong"
                               title="@(reportLine.IsGroup
                                          ? "Cost-side completion — writes this percentage to every centre in the roll-up"
                                          : "Cost-side completion for this cost centre (0–100)")"
                               value="@InputValue(CostCompletionFor(reportLine.CostCodes))"
                               disabled="@IsSaving(reportLine.Key)"
                               @onchange="args => HandleCostCompletionChangedAsync(reportLine, args)" />
                    </td>

                    <td class="px-4 py-3 text-right whitespace-nowrap">
                        <button type="button"
                                class="text-xs font-medium underline underline-offset-4 @(allLocked ? "text-content" : "text-content-subtle hover:text-content")"
                                title="@LockTitle(reportLine, allLocked, anyLocked)"
                                @onclick="() => OnFinalisationToggled.InvokeAsync((reportLine.CostCodes, !allLocked))">
                            @(allLocked ? "Unlock" : anyLocked ? "Lock all" : "Lock")
                        </button>
                    </td>
                </tr>
            }
            @* Reconciliation packages as first-class lines: the scope netted off the
               centres above lives here, so the table — and its total — still covers the
               whole project. Only rendered while "Hide scope in packages" is on;
               unticked, the centres carry the gross figures and these rows would
               double-count. Managed (edit / lock / dissolve) in the Packages section
               below the table. *@
            @foreach (var package in VisiblePackages)
            {
                <tr class="bg-surface-raised/40">
                    <td class="sticky left-0 z-10 bg-surface px-3 py-3"></td>
                    <td class="sticky left-[36px] z-10 bg-surface px-4 py-3 font-mono text-[11px] text-content-subtle whitespace-nowrap">PKG</td>
                    <td class="sticky left-[124px] z-10 bg-surface px-4 py-3 whitespace-nowrap">
                        <span class="text-content font-medium">@package.Name</span>
                        <span class="ml-2 inline-block rounded-full border border-line px-2 py-0.5 text-[11px] text-content-subtle"
                              title="A reconciliation package: work orders matched against the valuation lines that priced their scope — manage it in the Packages section below">Package</span>
                        @if (package.IsLocked)
                        {
                            <span class="ml-1 inline-block rounded-full border border-line px-2 py-0.5 text-[11px] text-content-subtle"
                                  title="Locked — figures frozen; profit / loss realised against actual invoiced cost">Locked</span>
                        }
                    </td>
                    <td class="px-4 py-3 text-right whitespace-nowrap @MoneyClass(package.SalesValue)">@Money(package.SalesValue)</td>
                    <td class="px-4 py-3 text-right text-content-muted">
                        @Percent(package.SalesValue == 0m ? 0m : Math.Round(package.ClaimedToDate / package.SalesValue * 100m, 1))
                    </td>
                    <td class="px-4 py-3 text-right whitespace-nowrap @MoneyClass(package.ClaimedToDate)">@Money(package.ClaimedToDate)</td>
                    <td class="px-4 py-3 text-right whitespace-nowrap border-l border-line @MoneyClass(package.TargetCost)">@Money(package.TargetCost)</td>
                    <td class="px-4 py-3 text-right whitespace-nowrap @MoneyClass(package.WoCommitted)">@Money(package.WoCommitted)</td>
                    <td class="px-4 py-3 text-right whitespace-nowrap @MoneyClass(package.InvoicedToDate)">@Money(package.InvoicedToDate)</td>
                    <td class="px-4 py-3 text-right text-content-muted"
                        title="Packages only hold work orders, so they never carry non-work-order spend">—</td>
                    @if (package.IsLocked)
                    {
                        <td class="px-4 py-3 text-right text-content-muted" title="Locked — the remainder is realised as profit / loss">—</td>
                        <td class="px-4 py-3 text-right font-medium @(package.ProfitLoss == 0m ? "text-content-muted" : package.ProfitLoss > 0m ? "text-positive" : "text-negative")">@Money(package.ProfitLoss)</td>
                    }
                    else
                    {
                        <td class="px-4 py-3 text-right @(package.Drawdown < 0m ? "text-negative" : package.Drawdown == 0m ? "text-content-muted" : "text-content")">@Money(package.Drawdown)</td>
                        <td class="px-4 py-3 text-right text-content-muted" title="Lock the package below to realise its remainder as profit / loss">—</td>
                    }
                    <td class="px-4 py-3 text-right text-content-muted">—</td>
                    <td class="px-4 py-3 text-right whitespace-nowrap">
                        <span class="text-xs text-content-subtle" title="Edit, lock or dissolve this package in the Packages section below the table">below</span>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot class="border-t-2 border-line-strong bg-surface-raised">
            <tr class="font-semibold text-content">
                <td class="sticky left-0 z-10 bg-surface-raised px-3 py-3"></td>
                <td class="sticky left-[36px] z-10 bg-surface-raised px-4 py-3"></td>
                <td class="sticky left-[124px] z-10 bg-surface-raised px-4 py-3 whitespace-nowrap">Total</td>
                <td class="px-4 py-3 text-right">@Money(TotalContractSales)</td>
                <td class="px-4 py-3 text-right">@Percent(WeightedSalesCompletion)</td>
                <td class="px-4 py-3 text-right">@Money(TotalClaimValue)</td>
                <td class="px-4 py-3 text-right border-l border-line">@Money(TotalTargetCost)</td>
                <td class="px-4 py-3 text-right">@Money(TotalWoCommitted)</td>
                <td class="px-4 py-3 text-right">@Money(TotalCostOfSales)</td>
                <td class="px-4 py-3 text-right">@Money(TotalNonWoCostOfSales)</td>
                <td class="px-4 py-3 text-right">@Money(TotalDrawdown)</td>
                <td class="px-4 py-3 text-right @(TotalProfitLoss == 0m ? "" : TotalProfitLoss > 0m ? "text-positive" : "text-negative")">@Money(TotalProfitLoss)</td>
                <td class="px-4 py-3 text-right pr-6">@Percent(WeightedCostCompletion)</td>
                <td class="px-4 py-3"></td>
            </tr>
        </tfoot>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<CostCenter> CostCenters { get; set; } = Array.Empty<CostCenter>();
    [Parameter] public IReadOnlyList<ProjectFinancialSummaryRow> SummaryRows { get; set; } = Array.Empty<ProjectFinancialSummaryRow>();

    /// <summary>Named roll-ups: each renders as one aggregated line instead of its members.</summary>
    [Parameter] public IReadOnlyList<CostCentreGroup> Groups { get; set; } = Array.Empty<CostCentreGroup>();

    /// <summary>Committed work-order value (order line totals) per cost code, from the
    /// project's work orders. Rendered as the WO Committed column.</summary>
    [Parameter] public IReadOnlyDictionary<string, decimal> WorkOrderCommittedByCode { get; set; } =
        new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);

    /// <summary>Reconciliation package rows, rendered as first-class lines (and counted
    /// in the total) while "Hide scope in packages" is on — the scope netted off the
    /// centres sits here, so the table still covers the whole project.</summary>
    [Parameter] public IReadOnlyList<PackageReconciliationRow> Packages { get; set; } = Array.Empty<PackageReconciliationRow>();

    /// <summary>Raised with a heading and the line's cost codes when a Contract Sales Value figure
    /// is clicked (one code for an individual row, all members for a roll-up).</summary>
    [Parameter] public EventCallback<(string Heading, IReadOnlyList<string> CostCodes)> OnContractSalesSelected { get; set; }

    /// <summary>Raised with a heading and the line's cost codes when a Work Orders figure is clicked.</summary>
    [Parameter] public EventCallback<(string Heading, IReadOnlyList<string> CostCodes)> OnWorkOrderCommittedSelected { get; set; }

    /// <summary>Raised with a heading and the line's cost codes when an Actual Cost of Sales figure is clicked.</summary>
    [Parameter] public EventCallback<(string Heading, IReadOnlyList<string> CostCodes)> OnCostOfSalesSelected { get; set; }

    /// <summary>Raised when a line's lock button is clicked: the line's cost codes and the state
    /// to apply to all of them (lock everything unless every member is already locked).</summary>
    [Parameter] public EventCallback<(IReadOnlyList<string> CostCodes, bool Finalise)> OnFinalisationToggled { get; set; }

    /// <summary>Raised when the user asks to roll the selection up: the individually
    /// selected cost codes plus any selected roll-ups (which will be merged into the new
    /// group). The parent collects a name and creates the group.</summary>
    [Parameter] public EventCallback<(IReadOnlyList<string> CostCodes, IReadOnlyList<string> GroupIds)> OnGroupRequested { get; set; }

    /// <summary>Raised with the group id when a roll-up's Ungroup button is clicked.</summary>
    [Parameter] public EventCallback<string> OnUngroupRequested { get; set; }

    /// <summary>Raised when a line's Cost % Complete is edited; the parent persists the value
    /// to every listed cost code (one for an individual row, all members for a roll-up) and
    /// refreshes the summary. The line being saved renders its input disabled until then.</summary>
    [Parameter] public EventCallback<(IReadOnlyList<string> CostCodes, decimal Percent)> OnCostCompletionChanged { get; set; }

    // Report shape (agreed 2026-07): sales side then cost side, per report line. A line is
    // either one cost centre or a named roll-up of several (aggregated by simple sum; the
    // two percentages are value-weighted).
    //   Contract Sales Value = the valuation report's counting lines (contract works,
    //                          provisional sums, contingency and variations; declined/TBC excluded)
    //   % Complete           = sales-side completion from the latest claim — edited on the valuation
    //   Claim Value          = the latest claim's cumulative claimed £
    //   Target Cost Value    = Contract Sales Value ÷ (1 + FinancialSummaryAssumptions.MarkupPercent)
    //                          — what the line should cost us; target cost + markup = sales value
    //   Work Orders          = committed work-order line totals (click for the line's work orders)
    //   Actual Cost of Sales = allocated Xero purchase spend, net of credit notes (click for
    //                          the invoices, where each can be linked to a work order)
    //   Non-WO Cost of Sales = the share of that spend not linked to any work order
    //   Drawdown             = Target Cost Value − Work Orders − Non-WO Cost of Sales — funds
    //                          still available on the line; negative = overspent. Locked
    //                          (finalised) centres show — here and report in Profit / Loss instead
    //   Profit / Loss        = the same remainder for locked centres — realised by finalising,
    //                          so it no longer reads as money available to spend
    //   Cost % Complete      = cost-side completion, edited inline here

    /// <summary>One rendered row: an individual cost centre or a named roll-up.</summary>
    private sealed record ReportLine(
        string Key,                        // cost code, or group id for roll-ups
        string Code,
        string Name,
        bool InMaster,
        bool IsGroup,
        IReadOnlyList<string> CostCodes);

    private Dictionary<string, ProjectFinancialSummaryRow> byCode = new(StringComparer.OrdinalIgnoreCase);

    // Hide cost centres with no figures in any column; on by default. Roll-ups are always
    // shown — they exist because someone deliberately created them.
    private bool hideZeroRows = true;

    // Net reconciliation-package scope out of every figure; on by default. The packaged
    // money's position lives on the package rows below, so counting it here too would
    // double-count it — e.g. a packaged purchase invoice still showing in the centre's
    // Actual Cost of Sales.
    private bool hidePackagedScope = true;

    // Filters rows by cost centre name or code; roll-ups match on their name or any
    // member code. Selected rows stay visible so a selection can't silently vanish
    // mid-roll-up. Totals stay project-wide, matching the hide-zero behaviour.
    private string search = string.Empty;

    private bool MatchesSearch(ReportLine line)
    {
        if (string.IsNullOrWhiteSpace(search)) return true;
        if (selectedCodes.Contains(line.Key) || selectedGroupIds.Contains(line.Key)) return true;
        var term = search.Trim();
        return line.Name.Contains(term, StringComparison.OrdinalIgnoreCase)
               || line.CostCodes.Any(entryCode => entryCode.Contains(term, StringComparison.OrdinalIgnoreCase));
    }

    // Codes and existing roll-ups ticked for the next roll-up. Selected roll-ups are
    // merged into the new group rather than nested.
    private readonly HashSet<string> selectedCodes = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> selectedGroupIds = new(StringComparer.OrdinalIgnoreCase);

    // The line whose Cost % Complete edit is currently in flight, if any.
    private string? savingKey;

    // Header sorting: null = the default alphabetical-by-name order. Text columns start
    // ascending; value columns start descending (biggest first — what the numbers are
    // usually sorted for). Clicking the active column flips the direction.
    private string? sortColumn;
    private bool sortDescending;

    private static readonly HashSet<string> TextSortColumns = new(StringComparer.Ordinal) { "code", "name" };

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortDescending = !sortDescending;
            return;
        }
        sortColumn = column;
        sortDescending = !TextSortColumns.Contains(column);
    }

    private RenderFragment SortHeader(string column, string label) => __builder =>
    {
        <button type="button"
                class="inline-flex items-center gap-1 uppercase tracking-wider font-semibold hover:text-content"
                title="Sort by @label"
                @onclick="() => SortBy(column)">
            @label
            @if (sortColumn == column)
            {
                <span aria-hidden="true">@(sortDescending ? "▼" : "▲")</span>
            }
        </button>
    };

    private decimal SortValue(ReportLine line, string column) => column switch
    {
        "sales" => ContractSalesFor(line.CostCodes),
        "complete" => SalesCompletionFor(line.CostCodes),
        "claim" => ClaimValueFor(line.CostCodes),
        "target" => TargetCostFor(line.CostCodes),
        "wo" => WoCommittedFor(line.CostCodes),
        "acos" => CostOfSalesFor(line.CostCodes),
        "nonwo" => NonWoCostOfSalesFor(line.CostCodes),
        "drawdown" => DrawdownFor(line.CostCodes),
        "pl" => ProfitLossFor(line.CostCodes),
        "costpct" => CostCompletionFor(line.CostCodes),
        _ => 0m
    };

    private IEnumerable<ReportLine> ApplySort(IEnumerable<ReportLine> lines) => sortColumn switch
    {
        null => lines.OrderBy(line => line.Name, StringComparer.OrdinalIgnoreCase),
        "code" => sortDescending
            ? lines.OrderByDescending(line => line.Code, StringComparer.OrdinalIgnoreCase)
            : lines.OrderBy(line => line.Code, StringComparer.OrdinalIgnoreCase),
        "name" => sortDescending
            ? lines.OrderByDescending(line => line.Name, StringComparer.OrdinalIgnoreCase)
            : lines.OrderBy(line => line.Name, StringComparer.OrdinalIgnoreCase),
        _ => (sortDescending
                ? lines.OrderByDescending(line => SortValue(line, sortColumn))
                : lines.OrderBy(line => SortValue(line, sortColumn)))
            .ThenBy(line => line.Name, StringComparer.OrdinalIgnoreCase)
    };

    protected override void OnParametersSet()
    {
        byCode = SummaryRows.ToDictionary(row => row.CostCode, StringComparer.OrdinalIgnoreCase);
        // New rows have arrived (or the parent re-rendered after the save): re-enable the input.
        savingKey = null;
        // Codes that have just been rolled up can no longer be individually selected,
        // and merged-away roll-ups can no longer be selected either.
        selectedCodes.RemoveWhere(selected => GroupedCodes.Contains(selected));
        selectedGroupIds.RemoveWhere(selected =>
            !Groups.Any(group => string.Equals(group.CostCentreGroupId, selected, StringComparison.OrdinalIgnoreCase)));
    }

    private HashSet<string> GroupedCodes =>
        Groups.SelectMany(group => group.CostCodes).ToHashSet(StringComparer.OrdinalIgnoreCase);

    private int SelectionCount => selectedCodes.Count + selectedGroupIds.Count;

    private void ToggleSelection(string costCode)
    {
        if (!selectedCodes.Remove(costCode)) selectedCodes.Add(costCode);
    }

    private void ToggleGroupSelection(string groupId)
    {
        if (!selectedGroupIds.Remove(groupId)) selectedGroupIds.Add(groupId);
    }

    private void ClearSelection()
    {
        selectedCodes.Clear();
        selectedGroupIds.Clear();
    }

    private Task RequestGroup() =>
        OnGroupRequested.InvokeAsync((
            (IReadOnlyList<string>)selectedCodes.OrderBy(selected => selected, StringComparer.OrdinalIgnoreCase).ToList(),
            (IReadOnlyList<string>)selectedGroupIds.OrderBy(selected => selected, StringComparer.OrdinalIgnoreCase).ToList()));

    private static string Heading(ReportLine line) =>
        line.IsGroup ? line.Name : $"{line.Code} — {(line.InMaster ? line.Name : "(not in cost-code master)")}";

    private decimal SumFor(IReadOnlyList<string> costCodes, Func<ProjectFinancialSummaryRow, decimal> value) =>
        costCodes.Sum(entryCode => byCode.TryGetValue(entryCode, out var row) ? value(row) : 0m);

    // With "Hide scope in packages" on (the default), every figure nets off what
    // reconciliation packages already account for — the packaged money's position lives
    // on the package row instead, so this table shows only unreconciled scope and its
    // drawdown stops being polluted by mismatches that a package has already resolved.
    private decimal RowSales(ProjectFinancialSummaryRow row) =>
        row.BudgetedSales - (hidePackagedScope ? row.PackagedSales : 0m);

    private decimal RowClaimed(ProjectFinancialSummaryRow row) =>
        row.ClaimedToDate - (hidePackagedScope ? row.PackagedClaimed : 0m);

    private decimal RowTarget(ProjectFinancialSummaryRow row) =>
        hidePackagedScope
            ? Math.Round((row.BudgetedSales - row.PackagedSales) * FinancialSummaryAssumptions.CostFactor, 2)
            : row.BudgetedCost;

    private decimal RowActual(ProjectFinancialSummaryRow row) =>
        row.ActualCost - (hidePackagedScope ? row.PackagedActualCost : 0m);

    private decimal PackagedWoFor(string costCode) =>
        hidePackagedScope && byCode.TryGetValue(costCode, out var row) ? row.PackagedWoCommitted : 0m;

    private decimal ContractSalesFor(IReadOnlyList<string> costCodes) => SumFor(costCodes, RowSales);

    private decimal ClaimValueFor(IReadOnlyList<string> costCodes) => SumFor(costCodes, RowClaimed);

    // Contract sales value with the markup backed out — what the line should cost us.
    private decimal TargetCostFor(IReadOnlyList<string> costCodes) => SumFor(costCodes, RowTarget);

    // Value-weighted across the line's centres: claimed £ over contract £.
    private decimal SalesCompletionFor(IReadOnlyList<string> costCodes)
    {
        var sales = ContractSalesFor(costCodes);
        return sales == 0m ? 0m : Math.Round(ClaimValueFor(costCodes) / sales * 100m, 1);
    }

    // Weighted by target cost; falls back to a simple average when the line carries no target.
    private decimal CostCompletionFor(IReadOnlyList<string> costCodes)
    {
        var target = TargetCostFor(costCodes);
        if (target != 0m)
            return Math.Round(SumFor(costCodes, row => row.CostCompletionPercent * RowTarget(row)) / target, 1);
        var percents = costCodes
            .Select(entryCode => byCode.TryGetValue(entryCode, out var row) ? row.CostCompletionPercent : 0m)
            .ToList();
        return percents.Count == 0 ? 0m : Math.Round(percents.Average(), 1);
    }

    private decimal WoCommittedFor(IReadOnlyList<string> costCodes) =>
        costCodes.Sum(entryCode =>
            (WorkOrderCommittedByCode.TryGetValue(entryCode, out var committed) ? committed : 0m)
            - PackagedWoFor(entryCode));

    // Allocated Xero purchase spend, net of credit notes.
    private decimal CostOfSalesFor(IReadOnlyList<string> costCodes) => SumFor(costCodes, RowActual);

    // The share of that spend not linked to any work order.
    private decimal NonWoCostOfSalesFor(IReadOnlyList<string> costCodes) => SumFor(costCodes, row => row.NonWorkOrderActualCost);

    private bool IsCentreFinalised(string costCode) =>
        byCode.TryGetValue(costCode, out var row) && row.IsFinalised;

    private bool AllFinalised(IReadOnlyList<string> costCodes) => costCodes.All(IsCentreFinalised);

    private bool AnyFinalised(IReadOnlyList<string> costCodes) => costCodes.Any(IsCentreFinalised);

    // What one centre has left of its target cost after work orders and unlinked spend
    // (all netted of packaged scope when the toggle is on).
    private decimal RemainderFor(string costCode) =>
        (byCode.TryGetValue(costCode, out var row) ? RowTarget(row) - row.NonWorkOrderActualCost : 0m)
        - (WorkOrderCommittedByCode.TryGetValue(costCode, out var committed) ? committed : 0m)
        + PackagedWoFor(costCode);

    // Unlocked centres' remainders: funds still available on the line.
    private decimal DrawdownFor(IReadOnlyList<string> costCodes) =>
        costCodes.Where(entryCode => !IsCentreFinalised(entryCode)).Sum(RemainderFor);

    // Locked centres' remainders: realised profit / loss.
    private decimal ProfitLossFor(IReadOnlyList<string> costCodes) =>
        costCodes.Where(IsCentreFinalised).Sum(RemainderFor);

    private static string LockTitle(ReportLine line, bool allLocked, bool anyLocked) =>
        allLocked
            ? "Unlock — the remainder returns to drawdown as available funds"
            : anyLocked
                ? "Some centres in this roll-up are already locked — lock the rest so the whole remainder reads as profit / loss"
                : line.IsGroup
                    ? "Lock every centre in this roll-up — no more spend expected; the remainder becomes profit / loss"
                    : "Lock this cost centre — no more spend expected; the remainder becomes profit / loss";

    private bool IsSaving(string key) => string.Equals(savingKey, key, StringComparison.OrdinalIgnoreCase);

    private async Task HandleCostCompletionChangedAsync(ReportLine line, ChangeEventArgs args)
    {
        if (!decimal.TryParse(Convert.ToString(args.Value),
                System.Globalization.NumberStyles.Number,
                System.Globalization.CultureInfo.InvariantCulture,
                out var percent)) { StateHasChanged(); return; }
        percent = Math.Clamp(percent, 0m, 100m);
        if (percent == CostCompletionFor(line.CostCodes)) return;
        savingKey = line.Key;
        await OnCostCompletionChanged.InvokeAsync((line.CostCodes, percent));
    }

    private bool HasAnyValue(IReadOnlyList<string> costCodes) =>
        costCodes.Any(entryCode =>
            (byCode.TryGetValue(entryCode, out var row) &&
             (row.BudgetedSales != 0m || row.CompletionPercent != 0m || row.ClaimedToDate != 0m ||
              row.BudgetedCost != 0m || row.CostCompletionPercent != 0m || row.ActualCost != 0m ||
              row.IsFinalised)) ||
            (WorkOrderCommittedByCode.TryGetValue(entryCode, out var committed) && committed != 0m));

    private IEnumerable<ReportLine> VisibleLines
    {
        get
        {
            var grouped = GroupedCodes;

            var individuals = CostCenters
                .Where(centre => !grouped.Contains(centre.Code))
                .Select(centre => new ReportLine(centre.Code, centre.Code, centre.Name, InMaster: true, IsGroup: false, new[] { centre.Code }))
                .Concat(UnmatchedCodes
                    .Where(unmatched => !grouped.Contains(unmatched))
                    .Select(unmatched => new ReportLine(unmatched, unmatched, "", InMaster: false, IsGroup: false, new[] { unmatched })));

            var rollUps = Groups.Select(group => new ReportLine(
                group.CostCentreGroupId, "", group.Name, InMaster: true, IsGroup: true, group.CostCodes));

            return ApplySort(individuals.Concat(rollUps))
                .Where(line => line.IsGroup || !hideZeroRows || HasAnyValue(line.CostCodes) || selectedCodes.Contains(line.Key))
                .Where(MatchesSearch);
        }
    }

    // Packages count in the table (rows + totals) only while the netting toggle is on —
    // with gross figures on the centres, package rows would double-count their scope.
    private IEnumerable<PackageReconciliationRow> IncludedPackages =>
        hidePackagedScope ? Packages : Array.Empty<PackageReconciliationRow>();

    // Rendered package rows follow the search like centre rows do; totals stay
    // project-wide, matching the hide-zero and search behaviour.
    private IEnumerable<PackageReconciliationRow> VisiblePackages =>
        IncludedPackages.Where(package =>
            string.IsNullOrWhiteSpace(search)
            || package.Name.Contains(search.Trim(), StringComparison.OrdinalIgnoreCase));

    private IEnumerable<string> UnmatchedCodes =>
        SummaryRows.Select(row => row.CostCode)
            .Union(WorkOrderCommittedByCode.Keys, StringComparer.OrdinalIgnoreCase)
            .Where(rowCode => !CostCenters.Any(centre => string.Equals(centre.Code, rowCode, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(rowCode => rowCode, StringComparer.OrdinalIgnoreCase);

    // Totals go through the same per-row accessors as the lines, so they respect the
    // hide-packaged-scope toggle and always equal the sum of what's on screen. Package
    // rows are added back in, so the total covers the whole project either way — with
    // the toggle on, the packaged scope simply arrives via the package rows instead of
    // the centres.
    private decimal TotalContractSales => SummaryRows.Sum(RowSales) + IncludedPackages.Sum(package => package.SalesValue);
    private decimal TotalClaimValue => SummaryRows.Sum(RowClaimed) + IncludedPackages.Sum(package => package.ClaimedToDate);
    private decimal TotalTargetCost => SummaryRows.Sum(RowTarget) + IncludedPackages.Sum(package => package.TargetCost);
    private decimal TotalWoCommitted =>
        WorkOrderCommittedByCode.Sum(entry => entry.Value - PackagedWoFor(entry.Key))
        + IncludedPackages.Sum(package => package.WoCommitted);
    private decimal TotalCostOfSales => SummaryRows.Sum(RowActual) + IncludedPackages.Sum(package => package.InvoicedToDate);
    private decimal TotalNonWoCostOfSales => SummaryRows.Sum(row => row.NonWorkOrderActualCost);

    // Every code with any figure — summary rows plus work-order-only codes.
    private IEnumerable<string> AllCodes =>
        byCode.Keys.Union(WorkOrderCommittedByCode.Keys, StringComparer.OrdinalIgnoreCase);

    private decimal TotalDrawdown =>
        AllCodes.Where(entryCode => !IsCentreFinalised(entryCode)).Sum(RemainderFor)
        + IncludedPackages.Where(package => !package.IsLocked).Sum(package => package.Drawdown);
    private decimal TotalProfitLoss =>
        AllCodes.Where(IsCentreFinalised).Sum(RemainderFor)
        + IncludedPackages.Where(package => package.IsLocked).Sum(package => package.ProfitLoss);

    // Matching the per-line calculation: claimed £ over contract £ (both netted of
    // packaged scope when the toggle is on).
    private decimal WeightedSalesCompletion =>
        TotalContractSales == 0m
            ? 0m
            : TotalClaimValue / TotalContractSales * 100m;

    // Weighted by target cost, the base the cost side draws down against. Weighted over
    // the centre rows only — packages carry no cost-side completion — so the weights
    // match the base they divide by.
    private decimal WeightedCostCompletion
    {
        get
        {
            var rowsTarget = SummaryRows.Sum(RowTarget);
            return rowsTarget == 0m
                ? 0m
                : SummaryRows.Sum(row => row.CostCompletionPercent * RowTarget(row)) / rowsTarget;
        }
    }

    private string MoneyClass(decimal value) => value == 0m ? "text-content-muted" : "text-content";

    // Negative drawdown = more committed to work orders than the target cost allows.
    private string DrawdownClass(decimal value) =>
        value == 0m ? "text-content-muted" : value < 0m ? "text-negative" : "text-content";

    private static string InputValue(decimal value) =>
        value.ToString(value == Math.Truncate(value) ? "0" : "0.#");

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string Percent(decimal value) =>
        $"{value.ToString(value == Math.Truncate(value) ? "0" : "0.#")}%";
}
