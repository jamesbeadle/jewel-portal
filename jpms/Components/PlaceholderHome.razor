@* Generic post-sign-in home for non-admin roles. Will be replaced by role-specific
   homepages as the corresponding journeys are signed off in /docs/user-journeys/. *@

<section class="max-w-3xl mx-auto px-4 py-8 md:py-12">

    <div class="mb-8 md:mb-10">
        <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-2">JPMS</p>
        <h1 class="text-3xl md:text-4xl font-semibold text-slate-900 leading-tight mb-3">
            Welcome, @FirstName.
        </h1>
        <p class="text-base md:text-lg text-slate-700 leading-relaxed">
            You're signed in as <span class="font-medium text-slate-900">@User.Email</span>.
            Your role on the platform is <RoleBadge Role="User.Role" />.
        </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-8">
        <Stat Label="Role"     Value="@User.Role.DisplayName()" />
        <Stat Label="Provider" Value="@ProviderName" />
        <Stat Label="Status"   Value="Approved" />
    </div>

    <section class="rounded-xl border border-slate-200 bg-white overflow-hidden mb-6">
        <header class="px-5 py-3 border-b border-slate-200 bg-slate-50">
            <h2 class="text-sm font-medium text-slate-700">Your home is being built</h2>
        </header>
        <div class="p-5 text-sm text-slate-700 leading-relaxed">
            <p class="mb-3">
                The @User.Role.DisplayName() homepage will land here once that journey is signed off
                in the scoping repo.
            </p>
            <p>
                Until then this is a placeholder so the sign-in and RBAC plumbing can be
                exercised end-to-end.
            </p>
        </div>
    </section>

</section>

@code {
    [Parameter, EditorRequired] public DirectoryUser User { get; set; } = default!;
    [Parameter, EditorRequired] public AuthProvider Provider { get; set; }

    private string FirstName => string.IsNullOrWhiteSpace(User.DisplayName)
        ? User.Role.DisplayName()
        : User.DisplayName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? User.DisplayName;

    private string ProviderName => Provider switch
    {
        AuthProvider.Microsoft => "Microsoft",
        AuthProvider.Google    => "Google",
        _ => "—"
    };
}
