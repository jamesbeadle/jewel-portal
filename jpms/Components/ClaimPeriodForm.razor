@using Jewel.JPMS.Cqrs
@using Jewel.JPMS.Contracts.Commercial
@inject ICommandSender Commands

<section class="rounded-xl border border-slate-200 bg-white p-5">
    <h3 class="text-sm font-medium text-slate-700 mb-3">Open a claim period</h3>
    <form @onsubmit="Add" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <FormField Label="Period number" InputType="number" Value="@periodNumber" OnChange="@(value => periodNumber = value)" />
            <FormField Label="Start date" InputType="date" Value="@startDate" OnChange="@(value => startDate = value)" />
            <FormField Label="End date" InputType="date" Value="@endDate" OnChange="@(value => endDate = value)" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-900 text-white font-medium text-sm px-4 py-2 hover:bg-slate-800 transition">
            Open period
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter] public EventCallback OnAdded { get; set; }

    private string periodNumber = "1";
    private string startDate = "";
    private string endDate = "";

    private async Task Add()
    {
        if (!DateTimeOffset.TryParse(startDate, out var start) || !DateTimeOffset.TryParse(endDate, out var end)) return;
        await Commands.SendAsync(
            new AddClaimPeriod(ProjectId, FormNumber.ParseCount(periodNumber), start, end),
            CancellationToken.None);
        startDate = "";
        endDate = "";
        await OnAdded.InvokeAsync();
    }
}
