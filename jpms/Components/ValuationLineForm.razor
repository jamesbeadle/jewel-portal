@using Jewel.JPMS.Commercial
@using Jewel.JPMS.Contracts.Commercial
@inject IValuationReportStore Store

<section class="rounded-xl border border-line bg-surface p-5">
    <h3 class="text-sm font-medium text-content-muted mb-3">@(IsEditing ? "Edit line" : "Add a line")</h3>
    <form @onsubmit="SaveAsync" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
            <div>
                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Element</label>
                <select @bind="elementType"
                        class="w-full rounded-lg border border-line-strong px-3 py-2 text-sm text-content focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent">
                    <option value="@ValuationElementType.ContractWorks">Contract works</option>
                    <option value="@ValuationElementType.PcSum">PC sum</option>
                    <option value="@ValuationElementType.Contingency">Contingency</option>
                    <option value="@ValuationElementType.Variation">Variation</option>
                </select>
            </div>
            <div>
                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Line type</label>
                <select @bind="lineType"
                        class="w-full rounded-lg border border-line-strong px-3 py-2 text-sm text-content focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent">
                    <option value="@ValuationLineType.Priced">Priced</option>
                    <option value="@ValuationLineType.ProvisionalSum">Provisional sum</option>
                    <option value="@ValuationLineType.Omit">Omit (negative)</option>
                    <option value="@ValuationLineType.Declined">Declined (excluded)</option>
                    <option value="@ValuationLineType.Tbc">TBC (excluded)</option>
                </select>
            </div>
            @if (elementType == ValuationElementType.Variation)
            {
                <FormField Label="Variation ref" Value="@variationRef" OnChange="@(v => variationRef = v)" />
                <FormField Label="Variation title" Value="@variationTitle" OnChange="@(v => variationTitle = v)" />
            }
            else
            {
                <FormField Label="Section code" Value="@sectionCode" OnChange="@(v => sectionCode = v)" />
                <FormField Label="Section name" Value="@sectionName" OnChange="@(v => sectionName = v)" />
            }
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-4 gap-3">
            <FormField Label="Cost code" Value="@costCode" OnChange="@(v => costCode = v)" />
            <div class="sm:col-span-3">
                <FormField Label="Description" Value="@description" OnChange="@(v => description = v)" />
            </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            <FormField Label="Unit" Value="@unit" OnChange="@(v => unit = v)" />
            <FormField Label="Quantity" InputType="number" Value="@quantity" OnChange="@(v => quantity = v)" />
            <FormField Label="Rate £" InputType="number" Value="@rate" OnChange="@(v => rate = v)" />
            <div>
                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Amount £</label>
                <div class="px-3 py-2 text-sm text-content font-mono">@PreviewAmount</div>
            </div>
        </div>

        <FormField Label="Comments" Value="@comments" OnChange="@(v => comments = v)" />

        <div class="flex items-center gap-2">
            <button type="submit" disabled="@busy"
                    class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover disabled:bg-surface-field transition">
                @(IsEditing ? "Save changes" : "Add line")
            </button>
            @if (IsEditing)
            {
                <button type="button" @onclick="@(() => OnCancel.InvokeAsync())"
                        class="rounded-lg border border-line bg-surface text-content-muted font-medium text-sm px-3 py-2 hover:border-line-strong transition">
                    Cancel
                </button>
            }
        </div>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter] public ValuationLineItem? Editing { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private static readonly System.Globalization.CultureInfo Gb = System.Globalization.CultureInfo.GetCultureInfo("en-GB");

    private ValuationElementType elementType = ValuationElementType.ContractWorks;
    private ValuationLineType lineType = ValuationLineType.Priced;
    private string sectionCode = "", sectionName = "", variationRef = "", variationTitle = "";
    private string costCode = "", description = "", unit = "", comments = "";
    private string quantity = "1", rate = "0";
    private bool busy;

    private bool IsEditing => Editing is not null;

    private ValuationLineItem? lastLoaded;

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(Editing, lastLoaded))
        {
            lastLoaded = Editing;
            if (Editing is { } e)
            {
                elementType = e.ElementType;
                lineType = e.LineType;
                sectionCode = e.SectionCode; sectionName = e.SectionName;
                variationRef = e.VariationRef; variationTitle = e.VariationTitle;
                costCode = e.CostCode; description = e.Description; unit = e.Unit; comments = e.Comments;
                quantity = e.Quantity.ToString(Gb); rate = e.Rate.ToString(Gb);
            }
        }
    }

    private string PreviewAmount =>
        ValuationCalculations.LineAmount(lineType, FormNumber.ParseAmount(quantity), FormNumber.ParseAmount(rate)).ToString("C2", Gb);

    private async Task SaveAsync()
    {
        busy = true;
        var qty = FormNumber.ParseAmount(quantity);
        var rt = FormNumber.ParseAmount(rate);

        if (Editing is { } e)
        {
            await Store.UpdateLineAsync(new UpdateValuationLineItem(
                e.ValuationLineItemId, elementType, sectionCode, sectionName, variationRef, variationTitle,
                lineType, costCode, description, unit, qty, rt, comments, e.DisplayOrder));
        }
        else
        {
            await Store.AddLineAsync(new AddValuationLineItem(
                ProjectId, elementType, sectionCode, sectionName, variationRef, variationTitle,
                lineType, costCode, description, unit, qty, rt, comments, NextOrder()));
            Reset();
        }

        busy = false;
        await OnSaved.InvokeAsync();
    }

    private int NextOrder()
    {
        var siblings = Store.LinesFor(ProjectId).Where(l => l.ElementType == elementType).ToList();
        return siblings.Count == 0 ? 1 : siblings.Max(l => l.DisplayOrder) + 1;
    }

    private void Reset()
    {
        sectionCode = sectionName = variationRef = variationTitle = "";
        costCode = description = unit = comments = "";
        quantity = "1"; rate = "0";
        lineType = ValuationLineType.Priced;
    }
}
