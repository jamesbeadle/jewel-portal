@using Jewel.JPMS.Contracts.Commercial
@using Jewel.JPMS.Contracts.Xero
@inject IQueryClient Queries
@inject IXeroLedgerStore Ledger
@inject ICostCenterStore CostCenters

@* Breakdown behind one cost centre's Under/Over Expected figure on the Financials
   tab: the budgeted sales → budgeted cost → expected actual cost calculation, then
   the allocated Xero purchase lines that make up the actual cost. *@
<Modal IsOpen="IsOpen"
       Title="@($"{CostCode} — {CostCentreName}")"
       ShowFooter="false"
       OnCancel="OnClose"
       Class="max-w-3xl">
    @if (Row is not null)
    {
        <div class="space-y-5">
            <section>
                <h3 class="text-xs uppercase tracking-wider text-content-subtle font-semibold mb-2">Budget</h3>
                <dl class="rounded-lg border border-line divide-y divide-line text-sm">
                    <div class="flex items-center justify-between gap-4 px-4 py-2.5">
                        <dt class="text-content-muted">Budgeted sales <span class="text-content-subtle">(valuation report)</span></dt>
                        <dd class="text-content font-medium">@Money(Row.BudgetedSales)</dd>
                    </div>
                    <div class="flex items-center justify-between gap-4 px-4 py-2.5">
                        <dt class="text-content-muted">
                            Budgeted cost
                            <span class="text-content-subtle">— sales less @MarginText margin: @Money(Row.BudgetedSales) × @CostFactorText</span>
                        </dt>
                        <dd class="text-content font-medium">@Money(Row.BudgetedCost)</dd>
                    </div>
                    <div class="flex items-center justify-between gap-4 px-4 py-2.5">
                        <dt class="text-content-muted">
                            Expected actual cost
                            <span class="text-content-subtle">— at @Percent(Row.CompletionPercent) complete: @Money(Row.BudgetedCost) × @Percent(Row.CompletionPercent)</span>
                        </dt>
                        <dd class="text-content font-medium">@Money(Row.ExpectedActualCost)</dd>
                    </div>
                </dl>
            </section>

            <section>
                <h3 class="text-xs uppercase tracking-wider text-content-subtle font-semibold mb-2">Actual costs</h3>
                @if (loading)
                {
                    <p class="text-sm text-content-subtle italic">Loading allocated costs…</p>
                }
                else if (lines is null || lines.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">
                        No Xero purchase lines have been allocated to this cost centre yet.
                    </p>
                }
                else
                {
                    <div class="rounded-lg border border-line overflow-x-auto">
                        <table class="w-full text-sm border-collapse">
                            <thead class="bg-surface-raised border-b border-line">
                                <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                    <th class="px-4 py-2.5 whitespace-nowrap">Date</th>
                                    <th class="px-4 py-2.5">Supplier</th>
                                    <th class="px-4 py-2.5 whitespace-nowrap">Invoice</th>
                                    <th class="px-4 py-2.5">Description</th>
                                    <th class="px-4 py-2.5 text-right whitespace-nowrap">Net £</th>
                                    <th class="px-4 py-2.5"><span class="sr-only">Move</span></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-line">
                                @foreach (var line in lines)
                                {
                                    <tr>
                                        <td class="px-4 py-2.5 whitespace-nowrap text-content-muted">@(line.Date?.ToString("dd MMM yyyy") ?? "—")</td>
                                        <td class="px-4 py-2.5 text-content">@line.Supplier</td>
                                        <td class="px-4 py-2.5 whitespace-nowrap text-content-muted">@line.InvoiceNumber</td>
                                        <td class="px-4 py-2.5 text-content-muted">
                                            @line.Description
                                            @if (line.IsSplit)
                                            {
                                                <span class="ml-1.5 text-[10px] uppercase tracking-wider font-semibold border border-line rounded px-1 py-0.5"
                                                      title="This centre's share of a line split across several cost centres">Split</span>
                                            }
                                        </td>
                                        <td class="px-4 py-2.5 text-right whitespace-nowrap @(line.Net < 0 ? "text-negative" : "text-content")">@MoneyExact(line.Net)</td>
                                        <td class="px-4 py-2.5 whitespace-nowrap text-right">
                                            @if (line.IsSplit)
                                            {
                                                @* Only a share of the line sits here — moving the whole line from this
                                                   modal would silently drag the other centres' shares with it. Splits
                                                   are re-cut on the cost allocation screen. *@
                                                <span class="text-xs text-content-subtle" title="Re-allocate split lines from the cost allocation screen">—</span>
                                            }
                                            else if (movingLineId == line.XeroLedgerLineId)
                                            {
                                                <span class="inline-flex items-center gap-1.5">
                                                    <select class="bg-surface border border-line rounded-lg px-2 py-1 text-content text-sm w-52"
                                                            disabled="@isMoving"
                                                            @onchange="e => MoveAsync(line.XeroLedgerLineId, e.Value?.ToString())">
                                                        <option value="" selected>Move to…</option>
                                                        @foreach (var centre in CostCenters.Active().Where(c => !string.Equals(c.Code, CostCode, StringComparison.OrdinalIgnoreCase)))
                                                        {
                                                            <option value="@centre.Code">@centre.Code @centre.Name</option>
                                                        }
                                                    </select>
                                                    <button type="button" aria-label="Cancel move" disabled="@isMoving"
                                                            class="inline-flex items-center justify-center w-7 h-7 rounded-md text-content-subtle hover:text-content hover:bg-surface-raised"
                                                            @onclick="CancelMove">
                                                        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                             stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
                                                    </button>
                                                </span>
                                            }
                                            else
                                            {
                                                <button type="button" disabled="@isMoving"
                                                        class="text-xs font-medium text-content-subtle hover:text-content underline underline-offset-4"
                                                        @onclick="() => movingLineId = line.XeroLedgerLineId">Move</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="border-t-2 border-line-strong bg-surface-raised">
                                <tr class="font-semibold text-content">
                                    <td class="px-4 py-2.5" colspan="4">Total actual cost</td>
                                    <td class="px-4 py-2.5 text-right whitespace-nowrap">@MoneyExact(lines.Sum(line => line.Net))</td>
                                    <td class="px-4 py-2.5"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                    @if (moveError is not null)
                    {
                        <p class="text-sm text-negative mt-2">@moveError</p>
                    }
                }
            </section>

            <section class="rounded-lg border border-line bg-surface-raised px-4 py-3 flex items-center justify-between gap-4 text-sm">
                <span class="text-content-muted">
                    Under/over expected — @Money(Row.ExpectedActualCost) expected − @Money(Row.ActualCost) actual
                </span>
                <span class="font-semibold @(Row.UnderOverExpected == 0m ? "text-content" : Row.UnderOverExpected > 0m ? "text-positive" : "text-negative")">
                    @Money(Row.UnderOverExpected) @(Row.UnderOverExpected == 0m ? "" : Row.UnderOverExpected > 0m ? "under" : "over")
                </span>
            </section>
        </div>
    }
</Modal>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string CostCode { get; set; } = "";
    [Parameter] public string CostCentreName { get; set; } = "";
    [Parameter] public ProjectFinancialSummaryRow? Row { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>Raised after a line has been reallocated to another cost centre,
    /// so the parent can close the modal and refresh the financial summary.</summary>
    [Parameter] public EventCallback OnInvoiceMoved { get; set; }

    private IReadOnlyList<CostCentreActualCostLine>? lines;
    private bool loading;
    private string? loadedKey;
    private string? movingLineId;
    private bool isMoving;
    private string? moveError;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen)
        {
            // Refetch on next open so the detail always matches the live table.
            loadedKey = null;
            movingLineId = null;
            moveError = null;
            return;
        }
        var key = $"{ProjectId}|{CostCode}";
        if (key == loadedKey) return;
        loadedKey = key;
        loading = true;
        lines = null;
        lines = await Queries.AskAsync(new ListCostCentreActualCosts(ProjectId, CostCode), CancellationToken.None);
        loading = false;
    }

    private void CancelMove()
    {
        movingLineId = null;
        moveError = null;
    }

    private async Task MoveAsync(string xeroLedgerLineId, string? newCostCode)
    {
        if (string.IsNullOrEmpty(newCostCode) || isMoving) return;
        isMoving = true;
        moveError = null;
        try
        {
            // Note: SetXeroAllocation replaces the line's Note, so record the move there.
            await Ledger.ApplyAsync(new SetXeroAllocation(
                new[] { xeroLedgerLineId },
                XeroAllocationAction.Allocate,
                ProjectId,
                newCostCode,
                Note: $"Moved from {CostCode} on the Financials tab"));
            movingLineId = null;
            await OnInvoiceMoved.InvokeAsync();
        }
        catch (Exception ex)
        {
            moveError = $"Couldn't move this line: {ex.Message}";
        }
        finally
        {
            isMoving = false;
        }
    }

    private static string MarginText =>
        $"{FinancialSummaryAssumptions.MarginPercent:0.#}%";

    private static string CostFactorText =>
        $"{100m - FinancialSummaryAssumptions.MarginPercent:0.#}%";

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string MoneyExact(decimal value) =>
        value.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string Percent(decimal value) =>
        $"{value.ToString(value == Math.Truncate(value) ? "0" : "0.#")}%";
}
