<nav class="border-b border-line mb-6 overflow-x-auto">
    <ul class="flex items-center gap-1 text-sm whitespace-nowrap">
        @foreach (var tab in Tabs)
        {
            <li>
                <a href="@HrefFor(tab.Slug)" class="@ClassFor(tab.Slug)">
                    @tab.Label
                </a>
            </li>
        }
    </ul>
</nav>

@code {
    [Parameter, EditorRequired] public string LeadId { get; set; } = "";
    [Parameter, EditorRequired] public string ActiveTab { get; set; } = "overview";

    private record TabItem(string Slug, string Label);

    private static readonly TabItem[] Tabs =
    {
        new("overview",     "Overview"),
        new("qualification","Qualification"),
        new("site-visits",  "Site visits"),
        new("info-chase",   "Info chase"),
        new("bid-decision", "Bid / no-bid"),
        new("proposal",     "Proposal"),
        new("outcome",      "Outcome")
    };

    private string HrefFor(string slug) =>
        slug == "overview" ? $"/leads/{LeadId}" : $"/leads/{LeadId}/{slug}";

    private string ClassFor(string slug)
    {
        var isActive = slug == ActiveTab;
        if (isActive)
        {
            return "inline-block px-3 py-2 border-b-2 border-accent text-content font-medium";
        }
        return "inline-block px-3 py-2 border-b-2 border-transparent text-content-subtle hover:text-content hover:border-line-strong";
    }
}
