@using Jewel.JPMS.Features.Projects
@inject ProjectListReadModel Projects

<div class="rounded-xl border border-line bg-surface overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-4 py-3">Valuation</th>
                <th class="px-4 py-3">Project</th>
                <th class="px-4 py-3 text-right">Gross</th>
                <th class="px-4 py-3 text-right hidden sm:table-cell">Retention</th>
                <th class="px-4 py-3 text-right">Net</th>
                <th class="px-4 py-3 hidden md:table-cell">Issued</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @foreach (var valuation in Valuations)
            {
                <tr>
                    <td class="px-4 py-3 font-mono text-xs text-content-muted">@valuation.ValuationId</td>
                    <td class="px-4 py-3 text-content font-medium">@ProjectReference(valuation.ProjectId)</td>
                    <td class="px-4 py-3 text-right text-content-muted">@Money(valuation.GrossValue)</td>
                    <td class="px-4 py-3 text-right text-content-muted hidden sm:table-cell">@valuation.RetentionPercent.ToString("0.#")%</td>
                    <td class="px-4 py-3 text-right text-content font-medium">@Money(valuation.NetValue)</td>
                    <td class="px-4 py-3 text-content-subtle hidden md:table-cell">@(valuation.IssuedAt?.LocalDateTime.ToString("d MMM yyyy") ?? "")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Valuation> Valuations { get; set; } = Array.Empty<Valuation>();

    private string ProjectReference(string projectId) =>
        Projects.Find(projectId)?.Reference ?? projectId;

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
