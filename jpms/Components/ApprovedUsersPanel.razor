@inject IUserDirectory UserDirectory

<section class="panel overflow-hidden mb-6">
    <header class="panel-header flex items-center justify-between">
        <h2 class="text-sm font-medium text-content">Users</h2>
        <div class="flex items-center gap-3">
            <span class="text-xs text-content-subtle">@ApprovedUsers.Count</span>
            <button type="button" disabled
                    title="Coming soon — invite a user by email"
                    class="text-xs font-medium text-content-faint cursor-not-allowed">
                + Add user
            </button>
        </div>
    </header>

    <ul class="divide-y divide-line">
        @foreach (var user in ApprovedUsers)
        {
            <ApprovedUserRow User="user" IsCurrentUser="@IsCurrentUser(user.Email)" />
        }
    </ul>
</section>

@code {
    [Parameter, EditorRequired] public string CurrentUserEmail { get; set; } = "";

    private IReadOnlyList<DirectoryUser> ApprovedUsers => UserDirectory.All();

    private bool IsCurrentUser(string email) =>
        string.Equals(email, CurrentUserEmail, StringComparison.OrdinalIgnoreCase);
}
