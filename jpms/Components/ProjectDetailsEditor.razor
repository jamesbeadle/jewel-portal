@using Jewel.JPMS.Contracts.Projects
@using Jewel.JPMS.Features.Projects
@inject SessionService Session
@inject ICommandSender Commands
@inject ProjectListReadModel Projects
@inject IClientStore ClientStore
@inject IArchitectStore ArchitectStore

@*
    "Edit details" button + modal for a project's core details (reference, name, client, entity,
    stage, project manager). Sends the existing UpdateProjectDetails command and refreshes the
    project list read model, so the page header, stage badge and Overview stats update in place.
    Server-side the command is gated to directors and project managers; the button mirrors that.
*@

@if (CanEdit)
{
    <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" @onclick="Open">Edit details</button>

    <Modal IsOpen="@open" Title="Edit project details" ConfirmLabel="@(busy ? "Saving…" : "Save changes")"
           CancelLabel="Cancel" OnConfirm="Save" OnCancel="Close">
        <div class="space-y-3">
            @if (error is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@error</p>
            }

            <FormField Label="Reference" Value="@reference" OnChange="v => reference = v" Required="true" />
            <FormField Label="Project name" Value="@name" OnChange="v => name = v" Required="true" />
            <FormField Label="Client" Value="@clientName" OnChange="v => clientName = v" Required="true" />

            <div>
                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Corresponds with</label>
                <select class="field" value="@partySelection" @onchange="OnPartyChanged">
                    <option value="">— Not assigned —</option>
                    @if (clients.Count > 0)
                    {
                        <optgroup label="Clients">
                            @foreach (var client in clients)
                            {
                                <option value="@($"{ClientPrefix}{client.ClientId}")">@client.Name</option>
                            }
                        </optgroup>
                    }
                    @if (architects.Count > 0)
                    {
                        <optgroup label="Architects">
                            @foreach (var architect in architects)
                            {
                                <option value="@($"{ArchitectPrefix}{architect.ArchitectId}")">@architect.Name</option>
                            }
                        </optgroup>
                    }
                </select>
                <p class="text-xs text-content-subtle mt-1">The party project emails are addressed to — a client account directly, or an architect acting on the client's behalf. The free-text client above stays the display name on documents.</p>
            </div>

            @if (partySelection.StartsWith(ArchitectPrefix, StringComparison.Ordinal))
            {
                <div>
                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">On behalf of client</label>
                    <select class="field" value="@onBehalfOfClientId" @onchange="OnOnBehalfOfClientChanged">
                        <option value="">— Not recorded —</option>
                        @foreach (var client in clients)
                        {
                            <option value="@client.ClientId">@client.Name</option>
                        }
                    </select>
                    <p class="text-xs text-content-subtle mt-1">Optional: the client this architect is acting for.</p>
                </div>
            }

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Entity *</label>
                    <select class="field" value="@organisation" @onchange="OnOrganisationChanged">
                        @foreach (var option in AllOrganisations)
                        {
                            <option value="@option">@option.DisplayName()</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Stage *</label>
                    <select class="field" value="@stage" @onchange="OnStageChanged">
                        @foreach (var option in AllStages)
                        {
                            <option value="@option">@option.DisplayName()</option>
                        }
                    </select>
                </div>
            </div>

            <FormField Label="Project manager email" Value="@projectManagerEmail" OnChange="v => projectManagerEmail = v" InputType="email" Required="true" />
        </div>
    </Modal>
}

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private static readonly Organisation[] AllOrganisations = Enum.GetValues<Organisation>();
    private static readonly ProjectStage[] AllStages = Enum.GetValues<ProjectStage>();

    private bool open;
    private bool busy;
    private string? error;

    private const string ClientPrefix = "client:";
    private const string ArchitectPrefix = "architect:";

    private string reference = "";
    private string name = "";
    private string clientName = "";
    private Organisation organisation = Organisation.JewelBespokeBuild;
    private ProjectStage stage = ProjectStage.LiveDelivery;
    private string projectManagerEmail = "";

    // The party this project corresponds with — "client:{id}" / "architect:{id}" / "" — plus the
    // optional client an architect acts for.
    private string partySelection = "";
    private string onBehalfOfClientId = "";
    private IReadOnlyList<Client> clients = Array.Empty<Client>();
    private IReadOnlyList<Architect> architects = Array.Empty<Architect>();

    // Mirrors UpdateProjectDetailsAuthorisation server-side (directors and project managers;
    // administrators carry every role).
    private bool CanEdit =>
        Session.AvailableRoles.Any(role => role is Role.Admin or Role.ManagingDirector or Role.ProjectManager);

    private void Open()
    {
        var project = Projects.Find(ProjectId);
        if (project is null) return;
        reference = project.Reference;
        name = project.Name;
        clientName = project.ClientName;
        organisation = project.Organisation;
        stage = project.Stage;
        projectManagerEmail = project.ProjectManagerEmail;
        partySelection = string.IsNullOrEmpty(project.PartyId)
            ? ""
            : (project.PartyKind == PartyKind.Architect ? ArchitectPrefix : ClientPrefix) + project.PartyId;
        onBehalfOfClientId = project.OnBehalfOfClientId ?? "";
        error = null;
        open = true;
        _ = LoadPartiesAsync();
    }

    private async Task LoadPartiesAsync()
    {
        try { clients = await ClientStore.ListAsync(); } catch { clients = Array.Empty<Client>(); }
        try { architects = await ArchitectStore.ListAsync(); } catch { architects = Array.Empty<Architect>(); }
        StateHasChanged();
    }

    private void OnPartyChanged(ChangeEventArgs e)
    {
        partySelection = e.Value?.ToString() ?? "";
        if (!partySelection.StartsWith(ArchitectPrefix, StringComparison.Ordinal)) onBehalfOfClientId = "";
    }

    private void OnOnBehalfOfClientChanged(ChangeEventArgs e) =>
        onBehalfOfClientId = e.Value?.ToString() ?? "";

    private void Close()
    {
        open = false;
        error = null;
    }

    private void OnOrganisationChanged(ChangeEventArgs e) =>
        organisation = Enum.Parse<Organisation>(e.Value?.ToString() ?? nameof(Organisation.JewelBespokeBuild));

    private void OnStageChanged(ChangeEventArgs e) =>
        stage = Enum.Parse<ProjectStage>(e.Value?.ToString() ?? nameof(ProjectStage.LiveDelivery));

    private async Task Save()
    {
        if (busy) return;
        if (string.IsNullOrWhiteSpace(reference) || string.IsNullOrWhiteSpace(name) ||
            string.IsNullOrWhiteSpace(clientName) || string.IsNullOrWhiteSpace(projectManagerEmail))
        {
            error = "Reference, name, client and project manager email are all required.";
            return;
        }

        error = null;
        busy = true;
        try
        {
            var partyKind = partySelection.StartsWith(ArchitectPrefix, StringComparison.Ordinal)
                ? PartyKind.Architect
                : PartyKind.Client;
            var partyId = partySelection.StartsWith(ArchitectPrefix, StringComparison.Ordinal)
                ? partySelection[ArchitectPrefix.Length..]
                : partySelection.StartsWith(ClientPrefix, StringComparison.Ordinal)
                    ? partySelection[ClientPrefix.Length..]
                    : null;

            await Commands.SendAsync(
                new UpdateProjectDetails(
                    ProjectId,
                    reference.Trim(),
                    name.Trim(),
                    clientName.Trim(),
                    organisation,
                    stage,
                    projectManagerEmail.Trim(),
                    partyKind,
                    partyId,
                    partyKind == PartyKind.Architect && !string.IsNullOrWhiteSpace(onBehalfOfClientId)
                        ? onBehalfOfClientId
                        : null),
                CancellationToken.None);
            await Projects.RefreshAsync(CancellationToken.None);
            Close();
        }
        catch (CommandFailedException ex) { error = ex.Message; }
        catch { error = "Couldn't save the changes. Please try again."; }
        finally { busy = false; }
    }
}
