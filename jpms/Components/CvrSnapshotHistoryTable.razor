<div class="rounded-xl border border-line bg-surface overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-right text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-4 py-3 text-left">Snapshot</th>
                <th class="px-4 py-3">Tender</th>
                <th class="px-4 py-3">Forecast cost</th>
                <th class="px-4 py-3">Forecast value</th>
                <th class="px-4 py-3">Margin £</th>
                <th class="px-4 py-3">Margin %</th>
                <th class="px-4 py-3">Weeks ±</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line text-right">
            @foreach (var snapshot in Snapshots)
            {
                <tr>
                    <td class="px-4 py-3 text-left text-content font-medium">@snapshot.SnapshotAt.LocalDateTime.ToString("d MMM yyyy")</td>
                    <td class="px-4 py-3 text-content-muted">@Money(snapshot.TenderValue)</td>
                    <td class="px-4 py-3 text-content-muted">@Money(snapshot.ForecastFinalCost)</td>
                    <td class="px-4 py-3 text-content-muted">@Money(snapshot.ForecastFinalValue)</td>
                    <td class="px-4 py-3 text-content font-medium">@Money(snapshot.MarginPounds)</td>
                    <td class="px-4 py-3 text-content-muted">@snapshot.MarginPercent.ToString("0.0")%</td>
                    <td class="px-4 py-3 font-medium @(snapshot.WeeksAheadOrBehind >= 0 ? "text-emerald-700" : "text-rose-700")">
                        @snapshot.WeeksAheadOrBehind
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<CvrSnapshot> Snapshots { get; set; } = Array.Empty<CvrSnapshot>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
