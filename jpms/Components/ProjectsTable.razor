@inject NavigationManager Nav

<div class="panel overflow-hidden">
    <div class="overflow-x-auto overflow-y-auto max-h-[85vh]">
        <table class="data-table">
            <thead>
                <tr>
                    <th class="sticky top-0 z-20 bg-surface-raised">Reference</th>
                    <th class="sticky top-0 z-20 bg-surface-raised">Name</th>
                    <th class="sticky top-0 z-20 bg-surface-raised hidden md:table-cell">Client</th>
                    <th class="sticky top-0 z-20 bg-surface-raised hidden lg:table-cell">Entity</th>
                    <th class="sticky top-0 z-20 bg-surface-raised">Stage</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var project in Projects)
                {
                    <tr class="is-clickable" @onclick="() => OpenProject(project.ProjectId)">
                        <td class="font-mono text-xs text-content-muted">@project.Reference</td>
                        <td class="text-content font-medium">@project.Name</td>
                        <td class="hidden md:table-cell">@project.ClientName</td>
                        <td class="hidden lg:table-cell">@project.Organisation.ShortCode()</td>
                        <td><ProjectStageBadge Stage="project.Stage" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Project> Projects { get; set; } = Array.Empty<Project>();

    private void OpenProject(string projectId) =>
        Nav.NavigateTo($"/projects/{projectId}");
}
