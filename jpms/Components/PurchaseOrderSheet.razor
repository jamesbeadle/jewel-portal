@using Jewel.JPMS.Models

@* The printable purchase order — the in-app successor to the Buildertrend "Bill/PO Print".
   Render-only: both hosts (the internal Work Orders tab and the subcontractor portal) resolve
   their own data and pass it in. Styled as a white A4 sheet with its own scoped CSS so it reads
   the same on screen, in print and against the app's dark theme. The standard scope text is
   baked in (insurances/RAMS and invoices go to projects@ / accounts@ — never a named person);
   the order's own Scope prints under "Works Order info", and the Programme section renders only
   when the order carries programme information. *@

<div class="po-sheet">
    <header class="po-head">
        <div>
            <div class="po-wordmark">JEWEL</div>
            <div class="po-wordmark-sub">Bespoke Build Ltd</div>
            <h1 class="po-title">Purchase Order</h1>
            <dl class="po-meta">
                <dt>Date Created</dt><dd>@Order.CreatedAt.LocalDateTime.ToString("d MMM yyyy")</dd>
                <dt>Date Released</dt><dd>@Order.AwardedAt.LocalDateTime.ToString("d MMM yyyy")</dd>
                <dt>Purchase Order #</dt><dd>@Reference</dd>
            </dl>
        </div>
        <div class="po-company">
            <p class="po-company-name">Jewel Bespoke Build Ltd</p>
            <p>Printed: @DateTime.Now.ToString("d MMM yyyy")</p>
            <p>Argent House, 175 Hook Rise South,</p>
            <p>Surbiton, Greater London, KT6 7LD</p>
            <p>Phone: 0208 109 1014</p>
        </div>
    </header>

    <div class="po-rule"></div>

    <div class="po-parties">
        <div>
            <p class="po-label">Sub/Vendor</p>
            <p class="po-strong">@SupplierName</p>
            @if (!string.IsNullOrWhiteSpace(SupplierContactName))
            {
                <p>@SupplierContactName</p>
            }
            @if (!string.IsNullOrWhiteSpace(SupplierAddress))
            {
                <p>@SupplierAddress</p>
            }
        </div>
        <div>
            <p class="po-label">Job</p>
            <p class="po-strong">@ProjectName</p>
        </div>
    </div>

    <table class="po-table po-summary">
        <thead>
            <tr><th>PO Title</th><th>Scheduled Completion</th><th class="po-right">Total Price</th></tr>
        </thead>
        <tbody>
            <tr>
                <td>@(string.IsNullOrWhiteSpace(Order.Title) ? SupplierName : Order.Title)</td>
                <td>@(Order.ScheduledCompletion is null ? "—" : Order.ScheduledCompletion.Value.LocalDateTime.ToString("d MMM yyyy"))</td>
                <td class="po-right">@Money(Order.Value)</td>
            </tr>
        </tbody>
    </table>

    <section class="po-box">
        <p class="po-box-title">Scope of Work</p>
        <div class="po-box-body">
            <p class="po-quote">“This Works Order is issued subject to the terms and conditions which are appended hereto”</p>

            <p class="po-heading">Special Instructions</p>
            <p>Every site requires full PPE, boots and Hi-Vis, please ensure these are worn at all times, with all RAMS adhered to.</p>
            <p>We expect all of your work areas to be clean and tidy and left safe at the end of each working day.</p>
            <p>Ensure you are representing Jewel Bespoke Build by being polite and courteous to all clients and neighbours at all times.</p>

            <p class="po-heading">Insurances &amp; RAMS</p>
            <p>Contractors to send all insurance documents and RAMS prior to starting works on site — <strong>projects@jewelbb.co.uk</strong></p>

            @if (!string.IsNullOrWhiteSpace(Order.Scope))
            {
                <p class="po-heading">Works Order info</p>
                <p class="po-prewrap">@Order.Scope</p>
            }

            @if (HasProgramme)
            {
                <p class="po-heading">Programme</p>
                @if (Order.ProgrammeStart is not null)
                {
                    <p>Start Date — @Order.ProgrammeStart.Value.LocalDateTime.ToString("d MMM yyyy")</p>
                }
                @if (Order.ScheduledCompletion is not null)
                {
                    <p>Completion Date — @Order.ScheduledCompletion.Value.LocalDateTime.ToString("d MMM yyyy")</p>
                }
                @if (!string.IsNullOrWhiteSpace(Order.ProgrammeNotes))
                {
                    <p class="po-prewrap">@Order.ProgrammeNotes</p>
                }
            }

            <p>
                All changes to the contract sum <strong><em>(variations)</em></strong> must be notified in writing, and written
                approval to be received prior to any additional works being completed. Any works completed without written
                authorisation cannot be charged.
            </p>

            <p class="po-heading">Invoice and Payment Requirements</p>
            <p>
                Please forward your invoice to <strong>accounts@jewelbb.co.uk</strong> and <strong>projects@jewelbb.co.uk</strong>
                by COB Friday's with a <strong><em>30 day terms</em></strong>
            </p>
            <p>Invoices to include <strong>CIS Breakdown</strong> (if necessary)</p>
            <p>Correct <strong>VAT breakdown</strong> (including Reverse Charge if necessary)</p>
            <p>
                In the event that your invoice does not contain the correct info or sent in on time, we will be unable to
                process it in a timely manner.
            </p>

            <p>We thank you for your business and look forward to working with you.</p>
            <p>Jewel Bespoke Build Ltd is Incorporated in England with Limited Liability. Registered Company Number: 13752749</p>
        </div>
    </section>

    @if (Lines.Count > 0)
    {
        <table class="po-table po-items">
            <thead>
                <tr>
                    <th>Items</th>
                    <th>Cost Types</th>
                    <th>Description</th>
                    <th class="po-right">Qty/Unit</th>
                    <th class="po-right">Unit Cost</th>
                    <th class="po-right">Price</th>
                    <th class="po-right">Paid</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in Lines.OrderBy(line => line.SortOrder))
                {
                    <tr>
                        <td>
                            @line.Title
                            @if (!string.IsNullOrWhiteSpace(line.CostCode))
                            {
                                <span class="po-dim"> · @line.CostCode</span>
                            }
                        </td>
                        <td>@line.CostType</td>
                        <td>@line.Description</td>
                        <td class="po-right">@line.Quantity.ToString("0.##") @line.Unit</td>
                        <td class="po-right">@Money(line.UnitCost)</td>
                        <td class="po-right">@Money(line.LineTotal)</td>
                        <td class="po-right">@(line.PaidToDate == 0m ? "–" : Money(line.PaidToDate))</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="po-totals">
                    <td colspan="5"></td>
                    <td class="po-right">@Money(Lines.Sum(line => line.LineTotal))</td>
                    <td class="po-right">@Money(TotalPaid)</td>
                </tr>
            </tfoot>
        </table>
        <p class="po-remaining"><strong>Remaining Balance:</strong> @Money(Order.Value - TotalPaid)</p>
    }

    @if (!string.IsNullOrWhiteSpace(SiteAddress))
    {
        <table class="po-table po-custom">
            <thead><tr><th>Custom fields</th></tr></thead>
            <tbody><tr><td><strong>Site Address:</strong> @SiteAddress</td></tr></tbody>
        </table>
    }

    <p class="po-legal">
        A signature of Approval or Electronic Acceptance is required before this purchase order is effective. This purchase
        order then becomes part of the existing contract and is binding and subject to our terms and conditions detailed in
        our Work Orders.
    </p>

    <div class="po-signatures">
        <div class="po-signature">
            <p class="po-sign-name">@(string.IsNullOrWhiteSpace(ApprovedByName) ? Order.AwardedByEmail : ApprovedByName)</p>
            <p class="po-sign-line">Approved by</p>
            <p class="po-sign-date">@Order.AwardedAt.LocalDateTime.ToString("d MMM yyyy, HH:mm")</p>
        </div>
        <div class="po-signature">
            @if (Order.IsAccepted)
            {
                <p class="po-sign-name">@(string.IsNullOrWhiteSpace(Order.AcceptedByName) ? Order.AcceptedByEmail : Order.AcceptedByName)</p>
                <p class="po-sign-line">Electronically accepted by</p>
                <p class="po-sign-date">@Order.AcceptedAt!.Value.LocalDateTime.ToString("d MMM yyyy, HH:mm")</p>
            }
            else
            {
                <p class="po-sign-name po-dim">&nbsp;</p>
                <p class="po-sign-line">Awaiting electronic acceptance</p>
                <p class="po-sign-date">&nbsp;</p>
            }
        </div>
    </div>
</div>

<style>
    .po-sheet {
        background: #ffffff;
        color: #1e293b;
        max-width: 820px;
        margin: 0 auto;
        padding: 40px 44px;
        font-size: 13px;
        line-height: 1.5;
        border-radius: 4px;
        box-shadow: 0 1px 3px rgba(0, 0, 0, .3);
    }
    .po-head { display: flex; justify-content: space-between; gap: 24px; }
    .po-wordmark { font-size: 30px; font-weight: 800; letter-spacing: .18em; color: #e8912a; }
    .po-wordmark-sub { font-size: 10px; letter-spacing: .32em; text-transform: uppercase; color: #b45309; margin-top: 2px; }
    .po-title { font-size: 19px; font-weight: 700; margin: 14px 0 10px; color: #0f172a; }
    .po-meta { margin: 0; }
    .po-meta dt { font-weight: 700; font-size: 12px; color: #0f172a; }
    .po-meta dd { margin: 0 0 6px; }
    .po-company { text-align: right; color: #334155; }
    .po-company p { margin: 0 0 2px; }
    .po-company-name { font-weight: 600; color: #0f172a; }
    .po-rule { border-top: 1px solid #cbd5e1; margin: 14px 0 16px; }
    .po-parties { display: flex; gap: 48px; margin-bottom: 18px; }
    .po-parties p { margin: 0 0 2px; }
    .po-label { font-weight: 700; font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: #475569; margin-bottom: 4px !important; }
    .po-strong { font-weight: 600; color: #0f172a; }
    .po-table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
    .po-table th, .po-table td { border: 1px solid #cbd5e1; padding: 7px 10px; text-align: left; vertical-align: top; }
    .po-table th { font-weight: 600; color: #0f172a; background: #f8fafc; }
    .po-right { text-align: right !important; white-space: nowrap; }
    .po-box { border: 1px solid #cbd5e1; border-radius: 2px; margin-bottom: 16px; }
    .po-box-title { text-align: center; font-weight: 600; color: #0f172a; border-bottom: 1px solid #cbd5e1; background: #f8fafc; padding: 6px 10px; margin: 0; }
    .po-box-body { padding: 12px 14px; }
    .po-box-body p { margin: 0 0 9px; }
    .po-quote { color: #334155; }
    .po-heading { font-weight: 700; text-decoration: underline; color: #0f172a; margin-top: 14px !important; }
    .po-prewrap { white-space: pre-wrap; }
    .po-totals td { font-weight: 700; color: #0f172a; }
    .po-remaining { text-align: right; margin: -6px 2px 16px; color: #0f172a; }
    .po-custom td strong { color: #0f172a; }
    .po-legal { color: #334155; margin-bottom: 14px; }
    .po-dim { color: #64748b; }
    .po-signatures { display: flex; gap: 32px; border: 1px solid #cbd5e1; border-radius: 2px; padding: 18px 16px 12px; }
    .po-signature { flex: 1; }
    .po-sign-name { font-family: "Segoe Script", "Bradley Hand", cursive; font-size: 17px; color: #0f172a; margin: 0 0 4px; min-height: 26px; }
    .po-sign-line { border-top: 1px solid #64748b; padding-top: 4px; margin: 0; font-size: 11px; text-transform: uppercase; letter-spacing: .05em; color: #475569; }
    .po-sign-date { margin: 2px 0 0; color: #334155; }

    @@media print {
        body * { visibility: hidden; }
        .po-sheet, .po-sheet * { visibility: visible; }
        .po-sheet { position: absolute; left: 0; top: 0; width: 100%; max-width: none; box-shadow: none; border-radius: 0; padding: 0; }
    }
</style>

@code {
    /// <summary>The order being printed.</summary>
    [Parameter, EditorRequired] public WorkOrder Order { get; set; } = default!;

    /// <summary>The order's priced lines (may be empty for orders without a breakdown).</summary>
    [Parameter] public IReadOnlyList<WorkOrderLine> Lines { get; set; } = Array.Empty<WorkOrderLine>();

    [Parameter] public string SupplierName { get; set; } = "";
    [Parameter] public string SupplierContactName { get; set; } = "";
    [Parameter] public string SupplierAddress { get; set; } = "";
    [Parameter] public string ProjectName { get; set; } = "";
    [Parameter] public string SiteAddress { get; set; } = "";

    /// <summary>Display name of whoever raised/approved the order in the system
    /// (falls back to the raw AwardedByEmail when blank).</summary>
    [Parameter] public string ApprovedByName { get; set; } = "";

    private string Reference => Order.Number > 0 ? $"WO-{Order.Number:0000}" : Order.WorkOrderId;

    private bool HasProgramme =>
        Order.ProgrammeStart is not null
        || Order.ScheduledCompletion is not null
        || !string.IsNullOrWhiteSpace(Order.ProgrammeNotes);

    private decimal TotalPaid => Lines.Sum(line => line.PaidToDate);

    private static string Money(decimal value) =>
        value.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
