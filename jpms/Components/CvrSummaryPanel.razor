<section class="rounded-xl border border-slate-200 bg-white p-5">
    <header class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-medium text-slate-700">Cost-Value Reconciliation</h2>
        @if (Snapshot is not null)
        {
            <span class="text-xs text-slate-500">@Snapshot.SnapshotAt.LocalDateTime.ToString("d MMM yyyy")</span>
        }
    </header>

    @if (Snapshot is null)
    {
        <p class="text-sm text-slate-500 italic">No CVR snapshot yet.</p>
    }
    else
    {
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <Stat Label="Tender value"      Value="@Money(Snapshot.TenderValue)" />
            <Stat Label="Forecast cost"     Value="@Money(Snapshot.ForecastFinalCost)" />
            <Stat Label="Forecast value"    Value="@Money(Snapshot.ForecastFinalValue)" />
            <Stat Label="Margin"            Value="@($"{Money(Snapshot.MarginPounds)} ({Snapshot.MarginPercent:0.0}%)")" />
        </div>

        <div class="mt-4 text-sm text-slate-600">
            <span class="font-medium @(Snapshot.WeeksAheadOrBehind >= 0 ? "text-emerald-700" : "text-rose-700")">
                @(Snapshot.WeeksAheadOrBehind == 0
                    ? "On programme"
                    : Snapshot.WeeksAheadOrBehind > 0
                        ? $"{Snapshot.WeeksAheadOrBehind} weeks ahead"
                        : $"{Math.Abs(Snapshot.WeeksAheadOrBehind)} weeks behind")
            </span>
        </div>
    }
</section>

@code {
    [Parameter] public CvrSnapshot? Snapshot { get; set; }

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
