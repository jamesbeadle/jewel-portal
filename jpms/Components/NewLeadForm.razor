@inject ILeadStore LeadStore

<form @onsubmit="HandleSubmit" @onsubmit:preventDefault="true"
      class="rounded-2xl border border-line bg-surface p-6 space-y-4">

    <FormField Label="Contact name" Value="@contactName" OnChange="value => contactName = value" Required="true" />
    <FormField Label="Contact email" Value="@contactEmail" OnChange="value => contactEmail = value" InputType="email" />
    <FormField Label="Contact phone" Value="@contactPhone" OnChange="value => contactPhone = value" />
    <FormField Label="Company / Trust (optional)" Value="@companyName" OnChange="value => companyName = value" />
    <FormField Label="Site address" Value="@siteAddress" OnChange="value => siteAddress = value" Required="true" />
    <FormField Label="Estimated value (GBP)" Value="@estimatedValue" OnChange="value => estimatedValue = value" InputType="number" />

    <div>
        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Source</label>
        <select @bind="source"
                class="field">
            @foreach (var option in Enum.GetValues<LeadSource>())
            {
                <option value="@option">@option.DisplayName()</option>
            }
        </select>
    </div>

    <button type="submit"
            class="w-full rounded-lg bg-accent text-accent-ink font-medium px-4 py-2.5 hover:bg-accent-hover disabled:bg-surface-field transition"
            disabled="@(!CanSubmit)">
        Capture lead
    </button>
</form>

@code {
    [Parameter, EditorRequired] public string CurrentUserEmail { get; set; } = "";
    [Parameter] public EventCallback<Lead> OnCreated { get; set; }

    private string contactName = "";
    private string contactEmail = "";
    private string contactPhone = "";
    private string companyName = "";
    private string siteAddress = "";
    private string estimatedValue = "";
    private LeadSource source = LeadSource.Manual;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(contactName) && !string.IsNullOrWhiteSpace(siteAddress);

    private async Task HandleSubmit()
    {
        if (!CanSubmit) return;
        var leadId = $"LD-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}";
        var reference = $"LD-{DateTime.UtcNow:yyyy}-{LeadStore.All().Count + 1:000}";
        var value = decimal.TryParse(estimatedValue, out var parsed) ? (decimal?)parsed : null;
        var lead = new Lead(leadId, reference, contactName, contactEmail, contactPhone,
            companyName, siteAddress, value, source, LeadStage.NewLead, CurrentUserEmail, DateTimeOffset.UtcNow);
        LeadStore.Upsert(lead);
        await OnCreated.InvokeAsync(lead);
    }
}
