@inject ICommercialStore CommercialStore
@inject ICvrStore CvrStore
@inject ICommercialInputsStore InputsStore

@switch (Section)
{
    case "pvr":
        <PvrSection ProjectId="@ProjectId" />
        break;
    case "cvr":
        <CvrSection ProjectId="@ProjectId" />
        break;
    case "accruals":
        <h2 class="text-lg font-semibold text-content mb-3">QS Accruals</h2>
        <QsAccrualForm ProjectId="@ProjectId" />
        <QsAccrualsTable Accruals="CvrStore.AccrualsFor(ProjectId)" />
        break;
    case "prelims":
        <h2 class="text-lg font-semibold text-content mb-3">Prelim forecast</h2>
        <PrelimForecastForm ProjectId="@ProjectId" />
        <PrelimForecastGrid Items="CvrStore.PrelimsFor(ProjectId)" />
        break;
    case "eots":
        <h2 class="text-lg font-semibold text-content mb-3">Extensions of Time</h2>
        <EotForm ProjectId="@ProjectId" />
        <EotTable Eots="CvrStore.EotsFor(ProjectId)" />
        break;
    case "budgets":
        <h2 class="text-lg font-semibold text-content mb-3">Cost code budgets</h2>
        <CostCodeBudgetForm ProjectId="@ProjectId" />
        <CostCodeBudgetTable Budgets="CommercialStore.BudgetsFor(ProjectId)" />
        break;
    case "timesheets":
        <h2 class="text-lg font-semibold text-content mb-3">Timesheets — weekly approval</h2>
        <TimesheetApprovalGrid Timesheets="CommercialStore.TimesheetsFor(ProjectId)" />
        break;
    case "inputs":
        <div class="space-y-8">
            <section>
                <h2 class="text-lg font-semibold text-content mb-3">Dayworks</h2>
                <DayworkForm ProjectId="@ProjectId" />
                <DayworkTable Dayworks="InputsStore.DayworksFor(ProjectId)" />
            </section>
            <section>
                <h2 class="text-lg font-semibold text-content mb-3">Contra charges</h2>
                <ContraChargeForm ProjectId="@ProjectId" />
                <ContraChargeTable ContraCharges="InputsStore.ContraChargesFor(ProjectId)" />
            </section>
            <section>
                <h2 class="text-lg font-semibold text-content mb-3">Subcontractor retention</h2>
                <RetentionForm ProjectId="@ProjectId" />
                <RetentionTable Retentions="InputsStore.RetentionsFor(ProjectId)" />
            </section>
        </div>
        break;
    default:
        <CommercialSummary ProjectId="@ProjectId" />
        break;
}

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter, EditorRequired] public string Section { get; set; } = "summary";
}
