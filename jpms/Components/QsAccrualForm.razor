@inject ICvrStore CvrStore
@inject AuthService Auth

<section class="rounded-xl border border-line bg-surface p-5 mb-4">
    <h3 class="text-sm font-medium text-content-muted mb-3">Add accrual</h3>
    <form @onsubmit="Save" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <FormField Label="Category" Value="@category" OnChange="@(value => category = value)" Required="true" />
            <FormField Label="Description" Value="@description" OnChange="@(value => description = value)" />
            <FormField Label="Add £" InputType="number" Value="@addAmount" OnChange="@(value => addAmount = value)" />
            <FormField Label="Omit £" InputType="number" Value="@omitAmount" OnChange="@(value => omitAmount = value)" />
            <FormField Label="Liability £" InputType="number" Value="@liabilityAmount" OnChange="@(value => liabilityAmount = value)" />
        </div>
        <button type="submit" class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
            Add accrual
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private string category = "";
    private string description = "";
    private string addAmount = "0";
    private string omitAmount = "0";
    private string liabilityAmount = "0";

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(category)) return;
        CvrStore.SaveAccrual(new QsAccrual(
            "", ProjectId, category, description,
            FormNumber.ParseAmount(addAmount), FormNumber.ParseAmount(omitAmount), FormNumber.ParseAmount(liabilityAmount),
            Auth.CurrentUser?.Email ?? "", DateTimeOffset.UtcNow));
        category = "";
        description = "";
        addAmount = "0";
        omitAmount = "0";
        liabilityAmount = "0";
    }
}
