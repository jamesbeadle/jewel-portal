@using Jewel.JPMS.Features.Projects
@inject ProjectListReadModel Projects

@if (Project is not null)
{
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-6">
        <Stat Label="Stage"           Value="@Project.Stage.DisplayName()" />
        <Stat Label="Entity"          Value="@Project.Organisation.ShortCode()" />
        <Stat Label="Project Manager" Value="@Project.ProjectManagerEmail" />
    </div>

    <ProjectTodoList ProjectId="@ProjectId" />
}

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private Project? Project => Projects.Find(ProjectId);
}
