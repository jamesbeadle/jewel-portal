<div class="rounded-xl border border-line bg-surface overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-4 py-3">Subcontractor</th>
                <th class="px-4 py-3">Category</th>
                <th class="px-4 py-3">Status</th>
                <th class="px-4 py-3 text-right">Amount</th>
                <th class="px-4 py-3 text-right">Recovered</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @foreach (var contraCharge in ContraCharges)
            {
                <tr>
                    <td class="px-4 py-3 text-content font-medium">@contraCharge.SubcontractorReference</td>
                    <td class="px-4 py-3 text-content-muted">@contraCharge.Category</td>
                    <td class="px-4 py-3 text-content-muted">@contraCharge.Status</td>
                    <td class="px-4 py-3 text-right text-content-muted">@Money(contraCharge.Amount)</td>
                    <td class="px-4 py-3 text-right text-content font-medium">@Money(contraCharge.RecoveredAmount)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ContraCharge> ContraCharges { get; set; } = Array.Empty<ContraCharge>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
