@inject ICvrStore CvrStore

<div class="rounded-xl border border-slate-200 bg-white overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-right text-[10px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-3 py-3 text-left">Prelim item</th>
                <th class="px-3 py-3">Total Tendered</th>
                <th class="px-3 py-3">Total Actual</th>
                <th class="px-3 py-3">Total Forecast</th>
                <th class="px-3 py-3 bg-slate-100">Difference</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 text-right">
            @foreach (var item in Items)
            {
                var entries = CvrStore.PrelimEntriesFor(item.PrelimItemId);
                <tr>
                    <td class="px-3 py-2 text-left text-slate-900 font-medium">@item.Description</td>
                    <td class="px-3 py-2 text-slate-700">@Money(entries.Sum(e => e.TenderedAmount))</td>
                    <td class="px-3 py-2 text-slate-700">@Money(entries.Sum(e => e.ActualAmount))</td>
                    <td class="px-3 py-2 text-slate-700">@Money(entries.Sum(e => e.ForecastAmount))</td>
                    <td class="px-3 py-2 font-medium bg-slate-50 @DifferenceColour(entries.Sum(e => e.DifferenceAmount))">
                        @Money(entries.Sum(e => e.DifferenceAmount))
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<PrelimItem> Items { get; set; } = Array.Empty<PrelimItem>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string DifferenceColour(decimal value)
    {
        if (value > 0) return "text-emerald-700";
        if (value < 0) return "text-rose-700";
        return "text-slate-700";
    }
}
