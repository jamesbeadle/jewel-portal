@inject ICvrStore CvrStore

<div class="rounded-xl border border-line bg-surface overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-right text-[10px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-3 py-3 text-left">Prelim item</th>
                <th class="px-3 py-3">Total Tendered</th>
                <th class="px-3 py-3">Total Actual</th>
                <th class="px-3 py-3">Total Forecast</th>
                <th class="px-3 py-3 bg-surface-raised">Difference</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line text-right">
            @foreach (var item in Items)
            {
                var entries = CvrStore.PrelimEntriesFor(item.PrelimItemId);
                <tr>
                    <td class="px-3 py-2 text-left text-content font-medium">@item.Description</td>
                    <td class="px-3 py-2 text-content-muted">@Money(entries.Sum(e => e.TenderedAmount))</td>
                    <td class="px-3 py-2 text-content-muted">@Money(entries.Sum(e => e.ActualAmount))</td>
                    <td class="px-3 py-2 text-content-muted">@Money(entries.Sum(e => e.ForecastAmount))</td>
                    <td class="px-3 py-2 font-medium bg-surface-raised @DifferenceColour(entries.Sum(e => e.DifferenceAmount))">
                        @Money(entries.Sum(e => e.DifferenceAmount))
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<PrelimItem> Items { get; set; } = Array.Empty<PrelimItem>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string DifferenceColour(decimal value)
    {
        if (value > 0) return "text-emerald-700";
        if (value < 0) return "text-rose-700";
        return "text-content-muted";
    }
}
