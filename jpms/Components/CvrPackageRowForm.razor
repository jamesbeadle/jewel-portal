@inject ICvrStore CvrStore

<section class="rounded-xl border border-slate-200 bg-white p-5 mb-4">
    <h3 class="text-sm font-medium text-slate-700 mb-3">Record a package row</h3>
    <form @onsubmit="Save" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            <FormField Label="Package" Value="@packageName" OnChange="@(value => packageName = value)" Required="true" />
            <FormField Label="Order cost £" InputType="number" Value="@orderCost" OnChange="@(value => orderCost = value)" />
            <FormField Label="Order value £" InputType="number" Value="@orderValue" OnChange="@(value => orderValue = value)" />
            <FormField Label="Variation cost £" InputType="number" Value="@variationCost" OnChange="@(value => variationCost = value)" />
            <FormField Label="Variation value £" InputType="number" Value="@variationValue" OnChange="@(value => variationValue = value)" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-900 text-white font-medium text-sm px-4 py-2 hover:bg-slate-800 transition">
            Save package row
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private string packageName = "";
    private string orderCost = "0";
    private string orderValue = "0";
    private string variationCost = "0";
    private string variationValue = "0";

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(packageName)) return;
        CvrStore.SavePackageRow(new CvrPackageRow(
            ProjectId, packageName,
            FormNumber.ParseAmount(orderCost), FormNumber.ParseAmount(orderValue),
            FormNumber.ParseAmount(variationCost), FormNumber.ParseAmount(variationValue), 0m));
        packageName = "";
        orderCost = "0";
        orderValue = "0";
        variationCost = "0";
        variationValue = "0";
    }
}
