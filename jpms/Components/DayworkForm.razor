@inject ICommercialInputsStore InputsStore

<section class="rounded-xl border border-line bg-surface p-5 mb-4">
    <h3 class="text-sm font-medium text-content-muted mb-3">Log a daywork sheet</h3>
    <form @onsubmit="Save" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            <FormField Label="Worked on" InputType="date" Value="@workedOn" OnChange="@(value => workedOn = value)" />
            <FormField Label="Subcontractor" Value="@subcontractorReference" OnChange="@(value => subcontractorReference = value)" Required="true" />
            <FormField Label="Instructed by" Value="@instructedBy" OnChange="@(value => instructedBy = value)" />
            <FormField Label="Description" Value="@description" OnChange="@(value => description = value)" />
            <FormField Label="Hours" InputType="number" Value="@hours" OnChange="@(value => hours = value)" />
            <FormField Label="Hourly rate £" InputType="number" Value="@hourlyRate" OnChange="@(value => hourlyRate = value)" />
            <FormField Label="Labour cost £" InputType="number" Value="@labourCost" OnChange="@(value => labourCost = value)" />
            <FormField Label="Plant cost £" InputType="number" Value="@plantCost" OnChange="@(value => plantCost = value)" />
            <FormField Label="Materials cost £" InputType="number" Value="@materialsCost" OnChange="@(value => materialsCost = value)" />
            <FormField Label="Uplift %" InputType="number" Value="@upliftPercent" OnChange="@(value => upliftPercent = value)" />
            <FormField Label="Chargeable £" InputType="number" Value="@chargeableAmount" OnChange="@(value => chargeableAmount = value)" />
        </div>
        <button type="submit" class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
            Log daywork
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private string workedOn = "";
    private string subcontractorReference = "";
    private string instructedBy = "";
    private string description = "";
    private string hours = "0";
    private string hourlyRate = "0";
    private string labourCost = "0";
    private string plantCost = "0";
    private string materialsCost = "0";
    private string upliftPercent = "0";
    private string chargeableAmount = "0";

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(subcontractorReference)) return;
        var workedOnDate = DateTimeOffset.TryParse(workedOn, out var parsed) ? parsed : DateTimeOffset.UtcNow;
        InputsStore.LogDaywork(new Daywork(
            "", ProjectId, workedOnDate, subcontractorReference, description, instructedBy,
            FormNumber.ParseAmount(hours), FormNumber.ParseAmount(hourlyRate), FormNumber.ParseAmount(labourCost),
            FormNumber.ParseAmount(plantCost), FormNumber.ParseAmount(materialsCost), FormNumber.ParseAmount(upliftPercent),
            FormNumber.ParseAmount(chargeableAmount)));
        subcontractorReference = "";
        description = "";
    }
}
