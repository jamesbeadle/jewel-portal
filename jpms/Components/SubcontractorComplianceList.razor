@inject ISubcontractorStore SubcontractorStore

<section class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <header class="px-5 py-3 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
        <h2 class="text-sm font-medium text-slate-700">Compliance documents</h2>
        <span class="text-xs text-slate-500">@Documents.Count documents</span>
    </header>
    @if (Documents.Count == 0)
    {
        <p class="p-5 text-sm text-slate-500 italic">No compliance documents on file.</p>
    }
    else
    {
        <ul class="divide-y divide-slate-200">
            @foreach (var document in Documents)
            {
                <li class="p-4 text-sm flex items-start justify-between gap-3">
                    <div>
                        <p class="font-medium text-slate-900">@document.Kind</p>
                        <p class="text-xs text-slate-500 mt-1">@document.FileName · uploaded @document.UploadedAt.LocalDateTime.ToString("d MMM yyyy")</p>
                        @if (document.ExpiresAt is not null)
                        {
                            <p class="text-xs text-slate-500">Expires @document.ExpiresAt.Value.LocalDateTime.ToString("d MMM yyyy")</p>
                        }
                    </div>
                    <ComplianceStatusPill Status="document.Status()" />
                </li>
            }
        </ul>
    }
</section>

@code {
    [Parameter, EditorRequired] public string SubcontractorId { get; set; } = "";

    private IReadOnlyList<ComplianceDocument> Documents =>
        SubcontractorStore.ComplianceFor(SubcontractorId);
}
