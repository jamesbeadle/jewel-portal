@using Jewel.JPMS.Cqrs
@using Jewel.JPMS.Contracts.Projects
@using Jewel.JPMS.Features.Projects
@inject AuthService Auth
@inject ICommandSender Commands
@inject ProjectListReadModel Projects

<div class="space-y-3">
    <div>
        <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Reference *</label>
        <input type="text" value="@reference"
               @oninput="e => { reference = e.Value?.ToString() ?? string.Empty; referenceTouched = true; }"
               class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-mono text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-slate-900" />
        <p class="text-xs text-slate-400 mt-1">Suggested automatically — edit it to match your existing reference.</p>
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Project name *</label>
        <input type="text" value="@name" @oninput="e => name = e.Value?.ToString() ?? string.Empty"
               class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-slate-900" />
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Client *</label>
        <input type="text" value="@clientName" @oninput="e => clientName = e.Value?.ToString() ?? string.Empty"
               class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-slate-900" />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <div>
            <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Entity *</label>
            <select value="@organisation" @onchange="OnOrganisationChanged"
                    class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-slate-900">
                @foreach (var org in AllOrganisations)
                {
                    <option value="@org">@org.DisplayName()</option>
                }
            </select>
        </div>
        <div>
            <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Stage *</label>
            <select value="@stage" @onchange="e => stage = Enum.Parse<ProjectStage>(e.Value?.ToString() ?? nameof(ProjectStage.PreConstruction))"
                    class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-slate-900">
                @foreach (var option in AllStages)
                {
                    <option value="@option">@option.DisplayName()</option>
                }
            </select>
        </div>
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Project manager email *</label>
        <input type="email" value="@projectManagerEmail" @oninput="e => projectManagerEmail = e.Value?.ToString() ?? string.Empty"
               class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-slate-900" />
    </div>

    @if (error is not null)
    {
        <p class="text-sm text-red-600">@error</p>
    }

    <div class="flex items-center gap-2 pt-1">
        <button type="button" @onclick="Submit" disabled="@(busy || !CanSubmit)"
                class="rounded-lg bg-slate-900 text-white font-medium text-sm px-3 py-2 hover:bg-slate-800 disabled:bg-slate-300 transition">
            @(busy ? "Creating…" : "Create project")
        </button>
        <button type="button" @onclick="Close"
                class="rounded-lg border border-slate-200 bg-white text-slate-700 font-medium text-sm px-3 py-2 hover:border-slate-300 transition">
            Cancel
        </button>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClosed { get; set; }
    [Parameter] public EventCallback<Project> OnCreated { get; set; }

    private static readonly Organisation[] AllOrganisations = Enum.GetValues<Organisation>();
    private static readonly ProjectStage[] AllStages = Enum.GetValues<ProjectStage>();

    private string reference = "";
    private bool referenceTouched;
    private string name = "";
    private string clientName = "";
    private Organisation organisation = Organisation.JewelBespokeBuild;
    private ProjectStage stage = ProjectStage.LiveDelivery;
    private string projectManagerEmail = "";
    private string? error;
    private bool busy;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(reference) &&
        !string.IsNullOrWhiteSpace(name) &&
        !string.IsNullOrWhiteSpace(clientName) &&
        !string.IsNullOrWhiteSpace(projectManagerEmail);

    protected override async Task OnInitializedAsync()
    {
        projectManagerEmail = Auth.CurrentUser?.Email ?? "";
        await Projects.RefreshAsync(CancellationToken.None);
        RegenerateReference();
    }

    private void OnOrganisationChanged(ChangeEventArgs e)
    {
        organisation = Enum.Parse<Organisation>(e.Value?.ToString() ?? nameof(Organisation.JewelBespokeBuild));
        if (!referenceTouched) RegenerateReference();
    }

    private void RegenerateReference()
    {
        var existingCount = Projects.Current?.Count ?? 0;
        reference = $"{organisation.ShortCode()}-{DateTime.UtcNow:yyyy}-{existingCount + 1:000}";
    }

    private async Task Submit()
    {
        if (!CanSubmit || busy) return;
        busy = true;
        error = null;
        try
        {
            var created = await Commands.SendAsync(
                new CreateProjectShell(
                    reference.Trim(),
                    name.Trim(),
                    clientName.Trim(),
                    organisation,
                    projectManagerEmail.Trim(),
                    stage),
                CancellationToken.None);
            await Projects.RefreshAsync(CancellationToken.None);
            await OnCreated.InvokeAsync(created);
        }
        catch (Exception)
        {
            error = "Couldn't create the project. Check the details and that you have permission, then try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private Task Close() => OnClosed.InvokeAsync();
}
