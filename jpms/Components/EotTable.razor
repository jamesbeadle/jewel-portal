<div class="rounded-xl border border-line bg-surface overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-4 py-3">Reason</th>
                <th class="px-4 py-3 text-right">Days granted</th>
                <th class="px-4 py-3 text-right">Commercial recovery</th>
                <th class="px-4 py-3 hidden md:table-cell">Granted</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @foreach (var eot in Eots)
            {
                <tr>
                    <td class="px-4 py-3 text-content font-medium">@eot.Reason</td>
                    <td class="px-4 py-3 text-right text-content-muted">@eot.DaysGranted</td>
                    <td class="px-4 py-3 text-right text-content-muted">@Money(eot.CommercialRecovery)</td>
                    <td class="px-4 py-3 text-content-subtle hidden md:table-cell">@eot.GrantedAt.LocalDateTime.ToString("d MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Eot> Eots { get; set; } = Array.Empty<Eot>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
