<div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-left text-[11px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-4 py-3">Reason</th>
                <th class="px-4 py-3 text-right">Days granted</th>
                <th class="px-4 py-3 text-right">Commercial recovery</th>
                <th class="px-4 py-3 hidden md:table-cell">Granted</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @foreach (var eot in Eots)
            {
                <tr>
                    <td class="px-4 py-3 text-slate-900 font-medium">@eot.Reason</td>
                    <td class="px-4 py-3 text-right text-slate-700">@eot.DaysGranted</td>
                    <td class="px-4 py-3 text-right text-slate-700">@Money(eot.CommercialRecovery)</td>
                    <td class="px-4 py-3 text-slate-500 hidden md:table-cell">@eot.GrantedAt.LocalDateTime.ToString("d MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Eot> Eots { get; set; } = Array.Empty<Eot>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
