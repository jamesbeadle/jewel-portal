@inject ICommercialStore CommercialStore

<section class="rounded-xl border border-slate-200 bg-white p-5">
    <h3 class="text-sm font-medium text-slate-700 mb-3">Draft a valuation</h3>
    @if (Periods.Count == 0)
    {
        <p class="text-sm text-slate-500">Open a claim period first.</p>
    }
    else
    {
        <form @onsubmit="Draft" @onsubmit:preventDefault="true" class="space-y-3">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                <div>
                    <label class="block text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Claim period</label>
                    <select @bind="claimPeriodId"
                            class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-slate-900 focus:border-slate-900">
                        @foreach (var period in Periods)
                        {
                            <option value="@period.ClaimPeriodId">Period @period.PeriodNumber</option>
                        }
                    </select>
                </div>
                <FormField Label="Gross value £" InputType="number" Value="@grossValue" OnChange="@(value => grossValue = value)" />
                <FormField Label="Retention %" InputType="number" Value="@retentionPercent" OnChange="@(value => retentionPercent = value)" />
            </div>
            <button type="submit" class="rounded-lg bg-slate-900 text-white font-medium text-sm px-4 py-2 hover:bg-slate-800 transition">
                Draft valuation
            </button>
        </form>
    }
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private string claimPeriodId = "";
    private string grossValue = "0";
    private string retentionPercent = "0";

    private IReadOnlyList<ClaimPeriod> Periods => CommercialStore.ClaimPeriodsFor(ProjectId);

    private void Draft()
    {
        var selected = string.IsNullOrEmpty(claimPeriodId) ? Periods.FirstOrDefault()?.ClaimPeriodId : claimPeriodId;
        if (string.IsNullOrEmpty(selected)) return;
        CommercialStore.SaveValuation(new Valuation(
            "", selected, ProjectId,
            FormNumber.ParseAmount(grossValue), FormNumber.ParseAmount(retentionPercent), 0m, false, null));
        grossValue = "0";
        retentionPercent = "0";
    }
}
