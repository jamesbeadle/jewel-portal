<nav class="border-b border-slate-200 mb-6 overflow-x-auto">
    <ul class="flex items-center gap-1 text-sm whitespace-nowrap">
        @foreach (var tab in Tabs)
        {
            <li>
                <a href="@HrefFor(tab.Slug)" class="@ClassFor(tab.Slug)">@tab.Label</a>
            </li>
        }
    </ul>
</nav>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter, EditorRequired] public string ActiveTab { get; set; } = "summary";

    private record Tab(string Slug, string Label);

    private static readonly Tab[] Tabs =
    {
        new("summary",    "Summary"),
        new("pvr",        "PVR"),
        new("cvr",        "CVR"),
        new("accruals",   "Accruals"),
        new("prelims",    "Prelims"),
        new("eots",       "EOTs"),
        new("budgets",    "Budgets"),
        new("timesheets", "Timesheets")
    };

    private string HrefFor(string slug) =>
        slug == "summary"
            ? $"/projects/{ProjectId}/commercial"
            : $"/projects/{ProjectId}/commercial/{slug}";

    private string ClassFor(string slug)
    {
        if (slug == ActiveTab) return "inline-block px-3 py-2 border-b-2 border-slate-900 text-slate-900 font-medium";
        return "inline-block px-3 py-2 border-b-2 border-transparent text-slate-500 hover:text-slate-900 hover:border-slate-300";
    }
}
