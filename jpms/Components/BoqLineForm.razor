@inject IBoqStore BoqStore

<form @onsubmit="HandleSave" @onsubmit:preventDefault="true"
      class="rounded-2xl border border-line bg-surface p-5 grid grid-cols-1 sm:grid-cols-2 gap-3">

    <div class="sm:col-span-2">
        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Description *</label>
        <input type="text" @bind="description" required
               class="field" />
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Cost code *</label>
        <input type="text" @bind="costCode" required placeholder="e.g. GW-100"
               class="field" />
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Discipline</label>
        <select @bind="discipline" class="field">
            @foreach (var option in Enum.GetValues<Discipline>())
            {
                <option value="@option">@option.DisplayName()</option>
            }
        </select>
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Quantity *</label>
        <input type="number" step="0.01" @bind="quantity" required
               class="field" />
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Unit *</label>
        <input type="text" @bind="unit" required placeholder="m² / nr / item"
               class="field" />
    </div>

    <div>
        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Rate (GBP) *</label>
        <input type="number" step="0.01" @bind="rateValue" required
               class="field" />
    </div>

    <div class="sm:col-span-2">
        <button type="submit"
                class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
            Add line item
        </button>
    </div>
</form>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter] public EventCallback OnAdded { get; set; }

    private string description = "";
    private string costCode = "";
    private string unit = "";
    private decimal quantity;
    private decimal rateValue;
    private Discipline discipline = Discipline.Architectural;

    private async Task HandleSave()
    {
        var line = new BoqLineItem(
            $"BL-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}",
            ProjectId, description, unit, quantity, rateValue, costCode, discipline);
        BoqStore.Upsert(line);
        description = ""; costCode = ""; unit = ""; quantity = 0; rateValue = 0;
        await OnAdded.InvokeAsync();
    }
}
