@inject ISubcontractorStore SubcontractorStore
@inject IProjectStore ProjectStore

<div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-left text-[11px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-4 py-3">Work order</th>
                @if (ShowProject)
                {
                    <th class="px-4 py-3 hidden sm:table-cell">Project</th>
                }
                <th class="px-4 py-3 hidden md:table-cell">Subcontractor</th>
                <th class="px-4 py-3 text-right">Value</th>
                <th class="px-4 py-3 hidden lg:table-cell">Awarded</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @foreach (var workOrder in WorkOrders)
            {
                <tr>
                    <td class="px-4 py-3 font-mono text-xs text-slate-700">@workOrder.WorkOrderId</td>
                    @if (ShowProject)
                    {
                        <td class="px-4 py-3 text-slate-700 hidden sm:table-cell">@ProjectReference(workOrder.ProjectId)</td>
                    }
                    <td class="px-4 py-3 text-slate-700 hidden md:table-cell">@SubcontractorName(workOrder.SubcontractorId)</td>
                    <td class="px-4 py-3 text-right text-slate-900 font-medium">@Money(workOrder.Value)</td>
                    <td class="px-4 py-3 text-slate-500 hidden lg:table-cell">@workOrder.AwardedAt.LocalDateTime.ToString("d MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<WorkOrder> WorkOrders { get; set; } = Array.Empty<WorkOrder>();
    [Parameter] public bool ShowProject { get; set; } = true;

    private string SubcontractorName(string subcontractorId) =>
        SubcontractorStore.Find(subcontractorId)?.CompanyName ?? subcontractorId;

    private string ProjectReference(string projectId) =>
        ProjectStore.Find(projectId)?.Reference ?? projectId;

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
