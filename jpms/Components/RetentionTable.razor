<div class="rounded-xl border border-line bg-surface overflow-x-auto">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-4 py-3">Subcontractor</th>
                <th class="px-4 py-3 text-right">Certified</th>
                <th class="px-4 py-3 text-right">Retention held</th>
                <th class="px-4 py-3 text-right">Balance held</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @foreach (var retention in Retentions)
            {
                <tr>
                    <td class="px-4 py-3 text-content font-medium">@retention.SubcontractorReference</td>
                    <td class="px-4 py-3 text-right text-content-muted">@Money(retention.CertifiedAmount)</td>
                    <td class="px-4 py-3 text-right text-content-muted">@Money(retention.RetentionAmount)</td>
                    <td class="px-4 py-3 text-right text-content font-medium">@Money(retention.BalanceHeld)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<SubcontractorRetention> Retentions { get; set; } = Array.Empty<SubcontractorRetention>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
