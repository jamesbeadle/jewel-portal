<nav class="mb-6 text-sm">
    <a href="/leads" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Leads</a>
    <span class="text-slate-400 mx-2">/</span>
    <span class="text-slate-700 font-medium">@Lead.Reference</span>
</nav>

<header class="mb-6">
    <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
        <div class="min-w-0">
            <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1 font-mono">@Lead.Reference</p>
            <h1 class="text-3xl md:text-4xl font-semibold text-slate-900 leading-tight">@Lead.ContactName</h1>
            <p class="text-sm text-slate-600 mt-2">
                @Lead.SiteAddress · @Lead.Source.DisplayName()
                @if (!string.IsNullOrWhiteSpace(Lead.CompanyName))
                {
                    <span> · @Lead.CompanyName</span>
                }
            </p>
        </div>
        <LeadStageBadge Stage="Lead.Stage" />
    </div>
</header>

@code {
    [Parameter, EditorRequired] public Lead Lead { get; set; } = default!;
}
