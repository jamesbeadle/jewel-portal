@using Jewel.JPMS.Cqrs
@using Jewel.JPMS.Contracts.Cashflow
@using Jewel.JPMS.Features.Cashflow
@inject ICommandSender Commands
@inject CashflowReadModel CashflowReadModel

<section class="rounded-xl border border-line bg-surface p-5 mb-6">
    <h2 class="text-sm font-medium text-content-muted mb-3">Capture 13-week position</h2>
    <form @onsubmit="Capture" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <FormField Label="Expected income (13w) £" InputType="number" Value="@expectedIncome" OnChange="@(value => expectedIncome = value)" />
            <FormField Label="Committed spend (13w) £" InputType="number" Value="@committedSpend" OnChange="@(value => committedSpend = value)" />
        </div>
        <button type="submit" class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
            Capture snapshot
        </button>
    </form>
</section>

@code {
    private string expectedIncome = "0";
    private string committedSpend = "0";

    private async Task Capture()
    {
        await Commands.SendAsync(
            new CaptureCashflowSnapshot(FormNumber.ParseAmount(expectedIncome), FormNumber.ParseAmount(committedSpend)),
            CancellationToken.None);
        await CashflowReadModel.RefreshAsync(CancellationToken.None);
        expectedIncome = "0";
        committedSpend = "0";
    }
}
