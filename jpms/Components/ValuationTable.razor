<div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-200">
            <tr class="text-left text-[11px] uppercase tracking-wider text-slate-500 font-semibold">
                <th class="px-4 py-3">Period</th>
                <th class="px-4 py-3 text-right">Gross</th>
                <th class="px-4 py-3 text-right hidden sm:table-cell">Retention</th>
                <th class="px-4 py-3 text-right">Net</th>
                <th class="px-4 py-3">Status</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
            @foreach (var (valuation, index) in Valuations.Select((value, i) => (value, i)))
            {
                <tr>
                    <td class="px-4 py-3 text-slate-900 font-medium">Period @(Valuations.Count - index)</td>
                    <td class="px-4 py-3 text-right text-slate-700">@Money(valuation.GrossValue)</td>
                    <td class="px-4 py-3 text-right text-slate-600 hidden sm:table-cell">@valuation.RetentionPercent.ToString("0.#")%</td>
                    <td class="px-4 py-3 text-right text-slate-900 font-medium">@Money(valuation.NetValue)</td>
                    <td class="px-4 py-3">
                        <span class="text-[11px] font-medium @(valuation.IsIssued ? "text-emerald-700" : "text-amber-700")">
                            @(valuation.IsIssued ? "Issued" : "Draft")
                        </span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Valuation> Valuations { get; set; } = Array.Empty<Valuation>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
