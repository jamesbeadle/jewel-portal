@inject ICvrStore CvrStore
@inject ICommercialStore CommercialStore

<div class="space-y-6">
    <CvrSummaryPanel Snapshot="CvrStore.LatestSnapshot(ProjectId)" />

    <section>
        <h2 class="text-lg font-semibold text-content mb-3">Forecast Final Cost — by package</h2>
        <p class="text-sm text-content-muted mb-3">
            Every FFC is the sum of explicit components — never a black-box number.
        </p>
        <ForecastComponentTable Rows="CvrStore.ForecastComponentsFor(ProjectId)" />
    </section>

    <section>
        <h2 class="text-lg font-semibold text-content mb-3">Programme Valuation Report — recent periods</h2>
        <ValuationTable Valuations="CommercialStore.ValuationsFor(ProjectId)" />
    </section>
</div>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
}
