@inject IMobilisationStore MobilisationStore

<section class="rounded-xl border border-slate-200 bg-white overflow-hidden">
    <header class="px-5 py-3 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
        <h2 class="text-sm font-medium text-slate-700">Mobilisation checklist</h2>
        <span class="text-xs @(Checklist.IsGateOpen ? "text-emerald-700" : "text-rose-700") font-semibold">
            @(Checklist.IsGateOpen ? "Gate open" : $"Gate closed — {Checklist.CompletedCount}/{Checklist.Items.Count}")
        </span>
    </header>
    <ul class="divide-y divide-slate-200">
        @foreach (var item in Checklist.Items)
        {
            <li class="px-5 py-3 flex items-center justify-between gap-3 text-sm">
                <div>
                    <p class="@(item.IsComplete ? "text-slate-500 line-through" : "text-slate-900 font-medium")">
                        @item.Description
                    </p>
                    @if (item.IsComplete && item.CompletedAt is not null)
                    {
                        <p class="text-xs text-slate-500 mt-1">Completed @item.CompletedAt.Value.LocalDateTime.ToString("d MMM yyyy")</p>
                    }
                </div>
                <button type="button" @onclick="() => MobilisationStore.ToggleItem(item.MobilisationItemId)"
                        class="text-xs font-medium text-slate-700 hover:text-slate-900 underline underline-offset-4">
                    @(item.IsComplete ? "Reopen" : "Mark done")
                </button>
            </li>
        }
    </ul>
</section>

@code {
    [Parameter, EditorRequired] public MobilisationChecklist Checklist { get; set; } = default!;
}
