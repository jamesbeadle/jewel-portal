<section class="rounded-xl border border-slate-200 bg-white p-5">
    @if (Settlement is null)
    {
        <p class="text-sm text-slate-500 italic">No settlement record yet. Created at Practical Completion.</p>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <Stat Label="Final value"  Value="@Money(Settlement.FinalContractValue)" />
            <Stat Label="Final cost"   Value="@Money(Settlement.FinalCost)" />
            <Stat Label="Final margin" Value="@Money(Settlement.FinalMargin)" />
        </div>
        <p class="text-xs text-slate-500 mt-3">
            Agreed @Settlement.AgreedAt.LocalDateTime.ToString("d MMM yyyy") ·
            <span class="@(Settlement.IsClientSigned ? "text-emerald-700" : "text-amber-700") font-medium">
                @(Settlement.IsClientSigned ? "Client signed" : "Pending client signature")
            </span>
        </p>
    }
</section>

@code {
    [Parameter] public SettlementRecord? Settlement { get; set; }

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
