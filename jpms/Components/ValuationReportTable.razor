@using Jewel.JPMS.Commercial
@using Jewel.JPMS.Contracts.Commercial
@inject IValuationReportStore Store
@inject ICostCenterStore CostCenters
@inject SessionService Session
@implements IDisposable

@if (lines.Count == 0)
{
    <div class="rounded-xl border border-line bg-surface px-3 py-6 text-center text-content-subtle italic">
        No lines yet. Add contract works, provisional sums, contingency and variation lines to build the report.
    </div>
}
else
{
    <div class="space-y-3">
        @if (CanRecodeCostCentres)
        {
            @* Toggle the first column into a searchable cost-centre picker for every line — a finance
               allocation the FD/PM can correct in place, independent of any claim's lock. *@
            <div class="flex items-center justify-end gap-2">
                @if (editCostCentres)
                {
                    <span class="text-[11px] text-content-subtle">Pick a cost centre for any line — changes save as you go.</span>
                }
                <button type="button" @onclick="ToggleEditCostCentres"
                        class="@(editCostCentres
                                  ? "rounded-lg bg-accent text-accent-ink font-medium text-sm px-3 py-2 hover:bg-accent-hover transition"
                                  : "rounded-lg border border-line bg-surface text-content-muted font-medium text-sm px-3 py-2 hover:border-line-strong transition")">
                    @(editCostCentres ? "Done editing cost centres" : "Edit cost centres")
                </button>
            </div>
        }
        @foreach (var section in Sections)
        {
            var isOpen = IsExpanded(section.Type);
            <div class="rounded-xl border border-line bg-surface overflow-hidden">
                <button type="button" @onclick="@(() => Toggle(section.Type))" aria-expanded="@isOpen"
                        class="w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-surface-raised/60 transition">
                    <svg class="@(isOpen ? "w-4 h-4 shrink-0 text-content-subtle rotate-90 transition-transform" : "w-4 h-4 shrink-0 text-content-subtle transition-transform")"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M9 6l6 6-6 6" />
                    </svg>
                    <span class="font-semibold text-content whitespace-nowrap">@section.Title</span>
                    <span class="text-xs text-content-subtle whitespace-nowrap">
                        @section.Lines.Count @(section.Lines.Count == 1 ? "line" : "lines")
                    </span>
                    <span class="ml-auto flex items-baseline gap-6 whitespace-nowrap">
                        @if (SelectedClaim is not null)
                        {
                            <span class="text-sm">
                                <span class="text-[11px] uppercase tracking-wider text-content-subtle mr-1.5">Claimed</span>
                                <span class="text-content-muted">@Money(ClaimedTotalFor(section)) (@Pct(PercentTotalFor(section)))</span>
                            </span>
                            <span class="text-sm">
                                <span class="text-[11px] uppercase tracking-wider text-content-subtle mr-1.5">This period</span>
                                <span class="text-content-muted">@Money(PeriodTotalFor(section))</span>
                            </span>
                        }
                        <span class="text-sm">
                            <span class="text-[11px] uppercase tracking-wider text-content-subtle mr-1.5">Total</span>
                            <span class="text-content font-medium">@Money(section.Amount)</span>
                        </span>
                    </span>
                </button>

                @if (isOpen)
                {
                    @if (section.Lines.Count == 0)
                    {
                        <div class="border-t border-line px-4 py-5 text-center text-content-subtle italic text-sm">
                            No @section.Title.ToLowerInvariant() lines yet.
                        </div>
                    }
                    else
                    {
                        @* `isolate` traps the sticky cells' z-10/20/30 in a local stacking context so they
                           never paint over the app header (sticky z-30 in MainLayout) when the page scrolls. *@
                        <div class="isolate border-t border-line overflow-x-auto overflow-y-auto max-h-[85vh]">
                            <table class="w-full text-sm border-collapse">
                                <thead class="bg-surface-raised border-b border-line">
                                    <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                        <th class="@CodeHeadClass">@(editCostCentres ? "Cost centre" : "Code")</th>
                                        <th class="@DescHeadClass">Description</th>
                                        @if (section.Type == ValuationElementType.Variation && !editCostCentres)
                                        {
                                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 whitespace-nowrap min-w-[220px]">Cost centre</th>
                                        }
                                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap">Qty</th>
                                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap">Rate £</th>
                                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap">Amount £</th>
                                        @if (SelectedClaim is not null)
                                        {
                                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap"
                                                title="@PrevColumnTitle">Prev. %</th>
                                        }
                                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap">% Complete</th>
                                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap">Claimed £</th>
                                        @if (SelectedClaim is not null)
                                        {
                                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap"
                                                title="Movement this period — cumulative claimed now less the previous claim's cumulative">Period £</th>
                                        }
                                        @if (CanEditLines)
                                        {
                                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right w-[80px]"></th>
                                        }
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-line">
                                    @foreach (var line in section.Lines)
                                    {
                                        <tr class="@(line.CountsTowardTotals ? "" : "opacity-60")">
                                            <td class="@CodeCellClass">
                                                @if (editCostCentres)
                                                {
                                                    @* Every section's value can be recoded here; variations also move their
                                                       mirrored VO's committed budget server-side (SetValuationLineCostCentreHandler). *@
                                                    <SearchSelect Options="@CostCentreOptionsFor(line)" WidthClass="w-full"
                                                                  Placeholder="Cost centre…"
                                                                  Value="@line.CostCode"
                                                                  Disabled="@(recodingLineId == line.ValuationLineItemId)"
                                                                  ValueChanged="value => SetCostCentreAsync(line, value)" />
                                                    @if (costCentreErrorLineId == line.ValuationLineItemId && costCentreError is not null)
                                                    {
                                                        <div class="text-[11px] text-negative mt-1">@costCentreError</div>
                                                    }
                                                }
                                                else
                                                {
                                                    @CodeFor(line)
                                                }
                                            </td>
                                            <td class="@DescCellClass">
                                                <div class="font-medium">@TitleFor(line)</div>
                                                @if (!string.IsNullOrWhiteSpace(line.Comments))
                                                {
                                                    <div class="text-[11px] text-content-subtle">@line.Comments</div>
                                                }
                                                @if (!line.CountsTowardTotals)
                                                {
                                                    <span class="inline-block mt-0.5 text-[10px] uppercase tracking-wide text-content-subtle">@line.LineType</span>
                                                }
                                            </td>
                                            @if (section.Type == ValuationElementType.Variation && !editCostCentres)
                                            {
                                                @* Where this variation's value is allocated in the cost-centre master.
                                                   Editable for Admin/MD/FD/PM (the API enforces the same gate); the
                                                   value itself stays locked — only the allocation moves. While the
                                                   "Edit cost centres" mode is on, the first column handles this instead. *@
                                                <td class="px-3 py-2 whitespace-nowrap">
                                                    @if (CanRecodeCostCentres)
                                                    {
                                                        <SearchSelect Options="@CostCentreOptionsFor(line)" WidthClass="w-52"
                                                                      Placeholder="Cost centre…"
                                                                      Value="@line.CostCode"
                                                                      Disabled="@(recodingLineId == line.ValuationLineItemId)"
                                                                      ValueChanged="value => SetCostCentreAsync(line, value)" />
                                                        @if (costCentreErrorLineId == line.ValuationLineItemId && costCentreError is not null)
                                                        {
                                                            <div class="text-[11px] text-negative mt-1">@costCentreError</div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-content-muted">@CostCentreLabel(line.CostCode)</span>
                                                    }
                                                </td>
                                            }
                                            <td class="px-3 py-2 text-right text-content-muted whitespace-nowrap">@Num(line.Quantity)</td>
                                            <td class="px-3 py-2 text-right text-content-muted whitespace-nowrap">@Num(line.Rate)</td>
                                            <td class="px-3 py-2 text-right text-content whitespace-nowrap">@Money(line.LineAmount)</td>
                                            @if (SelectedClaim is not null)
                                            {
                                                @* Cumulative % claimed on the previous claim — the baseline the current
                                                   claim moves off, so the client can see what changed this period. *@
                                                <td class="px-3 py-2 text-right text-content-subtle whitespace-nowrap">
                                                    @(line.CountsTowardTotals && HasPreviousClaim ? Pct(PreviousPercentFor(line)) : "—")
                                                </td>
                                            }
                                            <td class="px-3 py-2 text-right whitespace-nowrap">
                                                @if (CanEditEntries && line.CountsTowardTotals)
                                                {
                                                    @if (editingLineId == line.ValuationLineItemId)
                                                    {
                                                        @* Explicit commit only: Enter / tick saves, Esc / cross discards. *@
                                                        <span class="inline-flex items-center gap-1">
                                                            @if (HasPreviousClaim)
                                                            {
                                                                @* Old percentage stays visible while editing so it's clear what's being changed from. *@
                                                                <span class="text-[11px] text-content-subtle mr-1 whitespace-nowrap">was @Pct(PreviousPercentFor(line))</span>
                                                            }
                                                            <input @ref="editInput" type="text" inputmode="decimal"
                                                                   value="@editValue"
                                                                   @oninput="@(e => { editValue = e.Value?.ToString() ?? ""; editError = false; })"
                                                                   @onkeydown="@(e => OnEditKeyDownAsync(e, line))"
                                                                   aria-label="Percent complete"
                                                                   class="field w-16 text-right px-2 py-1 focus:outline-none focus:ring-2 @(editError ? "ring-2 ring-negative border-negative" : "focus:ring-accent focus:border-accent")" />
                                                            <button type="button" title="Save (Enter)" aria-label="Save percent complete"
                                                                    @onclick="() => CommitEditAsync(line)"
                                                                    class="inline-flex items-center justify-center w-6 h-6 rounded-md text-positive hover:bg-surface-raised">
                                                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                                                     stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7" /></svg>
                                                            </button>
                                                            <button type="button" title="Cancel (Esc)" aria-label="Cancel edit"
                                                                    @onclick="CancelEdit"
                                                                    class="inline-flex items-center justify-center w-6 h-6 rounded-md text-content-subtle hover:text-content hover:bg-surface-raised">
                                                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                                                     stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
                                                            </button>
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="inline-flex items-baseline gap-1.5 justify-end">
                                                            <button type="button" title="Edit % complete"
                                                                    @onclick="() => StartEdit(line)"
                                                                    class="underline decoration-dotted underline-offset-2 hover:decoration-solid @(PercentFor(line) == 0m ? "text-content-muted" : "text-content")">
                                                                @Pct(PercentFor(line))
                                                            </button>
                                                            @if (ShowDelta(line))
                                                            {
                                                                <span class="text-[11px] text-content-subtle whitespace-nowrap" title="Change from the previous claim">@SignedPct(DeltaFor(line))</span>
                                                            }
                                                        </span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-content-muted">@(line.CountsTowardTotals ? Pct(PercentFor(line)) : "—")</span>
                                                    @if (ShowDelta(line))
                                                    {
                                                        <span class="ml-1.5 text-[11px] text-content-subtle whitespace-nowrap" title="Change from the previous claim">@SignedPct(DeltaFor(line))</span>
                                                    }
                                                }
                                            </td>
                                            <td class="px-3 py-2 text-right text-content-muted whitespace-nowrap">
                                                @(line.CountsTowardTotals ? Money(ClaimedFor(line)) : "—")
                                            </td>
                                            @if (SelectedClaim is not null)
                                            {
                                                @* What this period moved in money. On Claim 1 (no previous claim)
                                                   everything claimed is movement, which is exactly right. *@
                                                <td class="px-3 py-2 text-right whitespace-nowrap @(PeriodFor(line) == 0m ? "text-content-subtle" : "text-content")">
                                                    @(line.CountsTowardTotals ? Money(PeriodFor(line)) : "—")
                                                </td>
                                            }
                                            @if (CanEditLines)
                                            {
                                                <td class="px-3 py-2 text-right whitespace-nowrap">
                                                    @if (line.ElementType == ValuationElementType.Variation)
                                                    {
                                                        @* Variation lines mirror approved VOs and can only change via the variation itself. *@
                                                        <span class="text-content-subtle text-xs" title="From an approved variation order — manage it on the Variations tab.">Locked</span>
                                                    }
                                                    else
                                                    {
                                                        <button @onclick="@(() => OnEditLine.InvokeAsync(line))"
                                                                class="text-content-subtle hover:text-content underline underline-offset-2 text-xs">Edit</button>
                                                        <button @onclick="@(() => RemoveLineAsync(line))"
                                                                class="ml-2 text-negative/80 hover:text-negative underline underline-offset-2 text-xs">Remove</button>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        }
    </div>
}

@* Extra accordion sections that live with the bill (e.g. valuation invoices) but are fed
   from their own store rather than the line items. *@
@if (ExtraSections is not null)
{
    <div class="mt-3">@ExtraSections</div>
}

@if (lines.Count > 0)
{
    <div class="mt-4 rounded-xl border border-line bg-surface-raised p-5">
        <h3 class="text-sm font-semibold text-content mb-3">Valuation summary@(SelectedClaim is null ? "" : $" — Claim {SelectedClaim.ClaimNumber}")</h3>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-1.5 text-sm max-w-2xl">
            <SummaryRow Label="Original contract sum" Value="@Money(contractSum)" />
            <SummaryRow Label="Net variations" Value="@Money(netVariations)" />
            <SummaryRow Label="Revised contract sum" Value="@Money(revisedContractSum)" Strong="true" />
            <SummaryRow Label="Total works complete" Value="@Money(totalWorksComplete)" />
            @if (SelectedClaim is not null)
            {
                <SummaryRow Label="Works claimed this period" Value="@Money(PeriodClaimedTotal)" />
            }
            <SummaryRow Label=@($"Retention held ({Pct(retentionPercent)})") Value="@Money(retentionHeld)" />
            <SummaryRow Label=@($"Retention released ({Pct(retentionReleasePercent)})") Value="@Money(retentionReleased)" />
            <SummaryRow Label="Certified to date" Value="@Money(certifiedToDate)" />
            <SummaryRow Label="Payment due (ex VAT)" Value="@Money(paymentDueExVat)" Strong="true" />
        </dl>
    </div>
}

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter] public ValuationClaim? SelectedClaim { get; set; }
    // The claim immediately before SelectedClaim, so each line can show its previously-claimed
    // cumulative % next to what's being claimed now. Null for Claim 1 or when no claim is selected.
    [Parameter] public ValuationClaim? PreviousClaim { get; set; }
    [Parameter] public EventCallback<ValuationLineItem> OnEditLine { get; set; }
    // Rendered between the bill sections and the summary (e.g. the valuation invoices accordion).
    [Parameter] public RenderFragment? ExtraSections { get; set; }
    // Total issued/paid valuation invoices — drives "Certified to date" for live (draft/no-claim) views.
    [Parameter] public decimal InvoicedToDate { get; set; }

    private static readonly System.Globalization.CultureInfo Gb = System.Globalization.CultureInfo.GetCultureInfo("en-GB");

    private IReadOnlyList<ValuationLineItem> lines = Array.Empty<ValuationLineItem>();
    private IReadOnlyList<ClaimLine> entries = Array.Empty<ClaimLine>();
    // Entries from the previous claim, keyed by line — the baseline for each line's "Prev. %".
    private IReadOnlyList<ClaimLine> previousEntries = Array.Empty<ClaimLine>();

    // Sections start collapsed so the four totals read at a glance; state survives re-renders.
    private readonly HashSet<ValuationElementType> expanded = new();

    private bool IsExpanded(ValuationElementType type) => expanded.Contains(type);

    private void Toggle(ValuationElementType type)
    {
        if (!expanded.Remove(type)) expanded.Add(type);
    }

    // Editable only while a Draft claim is selected.
    private bool CanEditEntries => SelectedClaim is { Status: ValuationClaimStatus.Draft };
    // Lines can be edited whenever no claim has locked them (no Preapproved/Confirmed claim selected is fine,
    // but bill edits are always allowed since they only affect future claims; keep simple: allow unless viewing a locked claim).
    private bool CanEditLines => SelectedClaim is null or { Status: ValuationClaimStatus.Draft };

    // Summary figures.
    private decimal contractSum, netVariations, revisedContractSum, totalWorksComplete;
    private decimal retentionHeld, retentionReleased, certifiedToDate, paymentDueExVat;
    private decimal retentionPercent, retentionReleasePercent;

    protected override void OnInitialized()
    {
        // The cost-centre master loads in the background on first read; re-render when it
        // lands so the Variations section's cost-centre cells fill in.
        CostCenters.OnChange += OnCostCentresChanged;
    }

    private void OnCostCentresChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => CostCenters.OnChange -= OnCostCentresChanged;

    protected override void OnParametersSet()
    {
        lines = Store.LinesFor(ProjectId);
        entries = SelectedClaim is null ? Array.Empty<ClaimLine>() : Store.EntriesFor(SelectedClaim.ValuationClaimId);
        // Fetch-once per claim id (revalidated by the store's Refresh); loads in the background and
        // re-renders via the parent's OnChange subscription, same as the current claim's entries.
        previousEntries = PreviousClaim is null ? Array.Empty<ClaimLine>() : Store.EntriesFor(PreviousClaim.ValuationClaimId);
        Recompute();
    }

    private void Recompute()
    {
        // Shared with the Cashflow tab (ValuationSummaryFigures) so the two tabs can't drift.
        var figures = ValuationSummaryFigures.For(lines, entries, SelectedClaim, InvoicedToDate);
        contractSum = figures.ContractSum;
        netVariations = figures.NetVariations;
        revisedContractSum = figures.RevisedContractSum;
        totalWorksComplete = figures.TotalWorksComplete;
        retentionPercent = figures.RetentionPercent;
        retentionHeld = figures.RetentionHeld;
        retentionReleasePercent = figures.RetentionReleasePercent;
        retentionReleased = figures.RetentionReleased;
        certifiedToDate = figures.CertifiedToDate;
        paymentDueExVat = figures.PaymentDueExVat;
    }

    private record Section(ValuationElementType Type, string Title, List<ValuationLineItem> Lines)
    {
        public decimal Amount => Lines.Where(l => l.CountsTowardTotals).Sum(l => l.LineAmount);
    }

    // Always render all four sections so the shape of the bill is visible even before
    // any lines exist in a given block.
    private IEnumerable<Section> Sections
    {
        get
        {
            Section Make(string title, ValuationElementType type) =>
                new(type, title, lines.Where(l => l.ElementType == type)
                                      .OrderBy(l => l.DisplayOrder)
                                      .ToList());

            return new[]
            {
                Make("Contract Works", ValuationElementType.ContractWorks),
                Make("Provisional Sums", ValuationElementType.PcSum),
                Make("Contingency Sums", ValuationElementType.Contingency),
                Make("Variations", ValuationElementType.Variation)
            };
        }
    }

    private decimal ClaimedTotalFor(Section section) =>
        section.Lines.Where(l => l.CountsTowardTotals).Sum(ClaimedFor);

    private decimal PercentTotalFor(Section section)
    {
        var amount = section.Amount;
        return amount == 0m ? 0m : Math.Round(ClaimedTotalFor(section) / amount * 100m, 2);
    }

    // Non-variation lines show the Jewel master cost code (00001..00137, per the
    // seeded CostCenters master); fall back to the NRM2 section ref only if a line
    // has no cost code mapped. Variation lines prefer their VariationRef but now
    // also carry a cost code for purchase-invoice reconciliation.
    private static string CodeFor(ValuationLineItem line) =>
        line.ElementType == ValuationElementType.Variation
            ? (string.IsNullOrWhiteSpace(line.VariationRef) ? line.CostCode : line.VariationRef)
            : (string.IsNullOrWhiteSpace(line.CostCode) ? line.SectionCode : line.CostCode);

    private static string TitleFor(ValuationLineItem line)
    {
        if (line.ElementType == ValuationElementType.Variation)
            return string.IsNullOrWhiteSpace(line.VariationTitle) ? line.Description : line.VariationTitle;
        if (!string.IsNullOrWhiteSpace(line.Description)) return line.Description;
        return line.SectionName;
    }

    private decimal PercentFor(ValuationLineItem line) =>
        entries.FirstOrDefault(e => e.ValuationLineItemId == line.ValuationLineItemId)?.PercentComplete ?? 0m;

    private decimal ClaimedFor(ValuationLineItem line) =>
        ValuationCalculations.CumulativeClaimed(PercentFor(line), line.LineAmount);

    // ---- Previous claim comparison -----------------------------------------
    // "Prev. %" is the cumulative % complete this line carried on the claim before the selected
    // one; the delta beside the current % is how much is being claimed this period.
    private bool HasPreviousClaim => PreviousClaim is not null;

    private decimal PreviousPercentFor(ValuationLineItem line) =>
        previousEntries.FirstOrDefault(e => e.ValuationLineItemId == line.ValuationLineItemId)?.PercentComplete ?? 0m;

    private decimal DeltaFor(ValuationLineItem line) => PercentFor(line) - PreviousPercentFor(line);

    // Only worth showing a delta when there's a prior claim to compare against, the line is priced
    // into totals, and the percentage actually moved.
    private bool ShowDelta(ValuationLineItem line) =>
        HasPreviousClaim && line.CountsTowardTotals && DeltaFor(line) != 0m;

    private string PrevColumnTitle => PreviousClaim is null
        ? "No earlier claim to compare against — this is the first claim"
        : $"Cumulative % complete claimed on {PreviousClaim.DisplayName}";

    // Movement in money this period: cumulative claimed now less the previous claim's
    // cumulative (both computed against the CURRENT line amount, so a re-priced line
    // doesn't produce a phantom movement). No previous claim → everything is movement.
    private decimal PreviousClaimedFor(ValuationLineItem line) =>
        ValuationCalculations.CumulativeClaimed(PreviousPercentFor(line), line.LineAmount);

    private decimal PeriodFor(ValuationLineItem line) => ClaimedFor(line) - PreviousClaimedFor(line);

    private decimal PeriodTotalFor(Section section) =>
        section.Lines.Where(l => l.CountsTowardTotals).Sum(PeriodFor);

    private decimal PeriodClaimedTotal =>
        lines.Where(l => l.CountsTowardTotals).Sum(PeriodFor);

    // ---- % complete click-to-edit -----------------------------------------
    // One cell edits at a time; nothing saves until the user confirms (Enter or
    // the tick). Esc or the cross discards. Clicking elsewhere leaves the editor
    // open rather than silently committing or discarding.
    private string? editingLineId;
    private string editValue = "";
    private bool editError;
    private bool focusPending;
    private ElementReference editInput;

    private void StartEdit(ValuationLineItem line)
    {
        editingLineId = line.ValuationLineItemId;
        editValue = PercentFor(line).ToString("0.##", Gb);
        editError = false;
        focusPending = true;
    }

    private void CancelEdit()
    {
        editingLineId = null;
        editError = false;
    }

    private async Task OnEditKeyDownAsync(KeyboardEventArgs e, ValuationLineItem line)
    {
        if (e.Key == "Enter") await CommitEditAsync(line);
        else if (e.Key == "Escape") CancelEdit();
    }

    private async Task CommitEditAsync(ValuationLineItem line)
    {
        if (SelectedClaim is null) { CancelEdit(); return; }
        if (!decimal.TryParse(editValue.Trim().TrimEnd('%'), System.Globalization.NumberStyles.Number, Gb, out var percent)
            || percent < 0m || percent > 100m)
        {
            editError = true;
            return;
        }
        await Store.RecordEntryAsync(ProjectId, new RecordClaimEntry(SelectedClaim.ValuationClaimId, line.ValuationLineItemId, percent));
        editingLineId = null;
        editError = false;
        OnParametersSet();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (focusPending && editingLineId is not null)
        {
            focusPending = false;
            await editInput.FocusAsync();
        }
    }

    private async Task RemoveLineAsync(ValuationLineItem line)
    {
        await Store.RemoveLineAsync(ProjectId, line.ValuationLineItemId);
        OnParametersSet();
    }

    // ---- Variation cost-centre recode --------------------------------------
    // Mirrors the API gate (ValuationReportAuthorisation.RolesThatMayRecodeCostCentres):
    // admins, the MD, the FD and project managers may move a variation's value between
    // cost centres; everyone else sees the allocation read-only.
    private bool CanRecodeCostCentres => Session.ActiveRole
        is Role.Admin or Role.ManagingDirector or Role.FinanceDirector or Role.ProjectManager;

    // "Edit cost centres" mode: the first column becomes a searchable cost-centre picker for every
    // line in every section. Off by default so the report reads as a normal bill.
    private bool editCostCentres;
    private void ToggleEditCostCentres() => editCostCentres = !editCostCentres;

    // The first column widens to hold the dropdown in edit mode; the sticky Description column's
    // left offset must track that width so the two frozen columns stay flush (w-64 == left-64).
    private string CodeHeadClass =>
        "sticky left-0 top-0 z-30 bg-surface-raised px-3 py-3 " + (editCostCentres ? "w-64" : "w-[72px]");
    private string DescHeadClass =>
        "sticky " + (editCostCentres ? "left-64" : "left-[72px]") + " top-0 z-30 bg-surface-raised px-3 py-3 min-w-[220px]";
    private string CodeCellClass => editCostCentres
        ? "sticky left-0 z-10 bg-surface px-3 py-2 align-top w-64"
        : "sticky left-0 z-10 bg-surface px-3 py-2 font-mono text-[11px] text-content-subtle whitespace-nowrap";
    private string DescCellClass =>
        "sticky " + (editCostCentres ? "left-64" : "left-[72px]") + " z-10 bg-surface px-3 py-2 text-content";

    private string? recodingLineId;
    private string? costCentreError;
    private string? costCentreErrorLineId;

    private async Task SetCostCentreAsync(ValuationLineItem line, string code)
    {
        // SearchSelect's leading blank entry clears — a variation's value always sits
        // somewhere, so ignore it rather than send an update the API would reject.
        if (string.IsNullOrWhiteSpace(code) || code == line.CostCode) return;
        recodingLineId = line.ValuationLineItemId;
        costCentreError = null;
        costCentreErrorLineId = null;
        try
        {
            await Store.SetLineCostCentreAsync(new SetValuationLineCostCentre(line.ValuationLineItemId, code));
            OnParametersSet();
        }
        catch (CommandFailedException failure)
        {
            costCentreError = failure.Message;
            costCentreErrorLineId = line.ValuationLineItemId;
        }
        finally
        {
            recodingLineId = null;
        }
    }

    // The label carries code + name so typing matches either (same as XeroAllocation).
    private IReadOnlyList<SearchSelect.Option>? costCentreOptionsCache;
    private object? costCentreOptionsCacheKey;

    private IReadOnlyList<SearchSelect.Option> CostCentreOptions
    {
        get
        {
            var centres = CostCenters.ActiveAlphabetical();
            if (costCentreOptionsCache is null || !ReferenceEquals(costCentreOptionsCacheKey, centres))
            {
                costCentreOptionsCache = centres
                    .Select(centre => new SearchSelect.Option(centre.Code, $"{centre.Code} {centre.Name}")).ToList();
                costCentreOptionsCacheKey = centres;
            }
            return costCentreOptionsCache;
        }
    }

    // A line coded to a retired centre still shows (and can be moved off) it.
    private IReadOnlyList<SearchSelect.Option> CostCentreOptionsFor(ValuationLineItem line)
    {
        var options = CostCentreOptions;
        if (string.IsNullOrWhiteSpace(line.CostCode) || options.Any(option => option.Value == line.CostCode))
            return options;
        var withCurrent = new List<SearchSelect.Option>(options.Count + 1)
        {
            new(line.CostCode, $"{line.CostCode} (retired)")
        };
        withCurrent.AddRange(options);
        return withCurrent;
    }

    private string CostCentreLabel(string code)
    {
        if (string.IsNullOrWhiteSpace(code)) return "—";
        var centre = CostCenters.All().FirstOrDefault(c => string.Equals(c.Code, code, StringComparison.OrdinalIgnoreCase));
        return centre is null ? code : $"{code} — {centre.Name}";
    }

    private static string Money(decimal v) => v.ToString("C2", Gb);
    private static string Num(decimal v) => v.ToString("0.##", Gb);
    private static string Pct(decimal v) => v.ToString("0.##", Gb) + "%";
    // Signed for the "what changed" delta: "+20%", "-5%" (negatives already carry their sign).
    private static string SignedPct(decimal v) => (v > 0m ? "+" : "") + v.ToString("0.##", Gb) + "%";
}
