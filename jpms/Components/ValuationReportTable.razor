@using Jewel.JPMS.Commercial
@using Jewel.JPMS.Contracts.Commercial
@inject IValuationReportStore Store

<div class="rounded-xl border border-line bg-surface overflow-x-auto">
    <table class="w-full text-sm border-collapse">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="sticky left-0 z-10 bg-surface-raised px-3 py-3 w-[72px]">Code</th>
                <th class="sticky left-[72px] z-10 bg-surface-raised px-3 py-3 min-w-[220px]">Description</th>
                <th class="px-3 py-3 text-right whitespace-nowrap">Qty</th>
                <th class="px-3 py-3 text-right whitespace-nowrap">Rate £</th>
                <th class="px-3 py-3 text-right whitespace-nowrap">Amount £</th>
                <th class="px-3 py-3 text-right whitespace-nowrap">% Complete</th>
                <th class="px-3 py-3 text-right whitespace-nowrap">Claimed £</th>
                @if (CanEditLines)
                {
                    <th class="px-3 py-3 text-right w-[80px]"></th>
                }
            </tr>
        </thead>
        <tbody class="divide-y divide-line">
            @if (lines.Count == 0)
            {
                <tr>
                    <td colspan="@ColumnCount" class="px-3 py-6 text-center text-content-subtle italic">
                        No lines yet. Add contract works, provisional sums, contingency and variation lines to build the report.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var block in Blocks)
                {
                    <tr class="bg-surface-raised/60">
                        <td colspan="@ColumnCount" class="px-3 py-2 text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                            @block.Title
                        </td>
                    </tr>
                    @foreach (var line in block.Lines)
                    {
                        <tr class="@(line.CountsTowardTotals ? "" : "opacity-60")">
                            <td class="sticky left-0 z-10 bg-surface px-3 py-2 font-mono text-[11px] text-content-subtle whitespace-nowrap">@CodeFor(line)</td>
                            <td class="sticky left-[72px] z-10 bg-surface px-3 py-2 text-content">
                                <div class="font-medium">@TitleFor(line)</div>
                                @if (!string.IsNullOrWhiteSpace(line.Comments))
                                {
                                    <div class="text-[11px] text-content-subtle">@line.Comments</div>
                                }
                                @if (!line.CountsTowardTotals)
                                {
                                    <span class="inline-block mt-0.5 text-[10px] uppercase tracking-wide text-content-subtle">@line.LineType</span>
                                }
                            </td>
                            <td class="px-3 py-2 text-right text-content-muted whitespace-nowrap">@Num(line.Quantity)</td>
                            <td class="px-3 py-2 text-right text-content-muted whitespace-nowrap">@Num(line.Rate)</td>
                            <td class="px-3 py-2 text-right text-content whitespace-nowrap">@Money(line.LineAmount)</td>
                            <td class="px-3 py-2 text-right whitespace-nowrap">
                                @if (CanEditEntries && line.CountsTowardTotals)
                                {
                                    <input type="number" step="any" min="0" max="100"
                                           value="@PercentText(line)"
                                           @onchange="@(e => SaveEntryAsync(line, e.Value?.ToString()))"
                                           class="w-20 text-right rounded-lg border border-line-strong px-2 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent" />
                                }
                                else
                                {
                                    <span class="text-content-muted">@(line.CountsTowardTotals ? Pct(PercentFor(line)) : "—")</span>
                                }
                            </td>
                            <td class="px-3 py-2 text-right text-content-muted whitespace-nowrap">
                                @(line.CountsTowardTotals ? Money(ClaimedFor(line)) : "—")
                            </td>
                            @if (CanEditLines)
                            {
                                <td class="px-3 py-2 text-right whitespace-nowrap">
                                    <button @onclick="@(() => OnEditLine.InvokeAsync(line))"
                                            class="text-content-subtle hover:text-content underline underline-offset-2 text-xs">Edit</button>
                                    <button @onclick="@(() => RemoveLineAsync(line))"
                                            class="ml-2 text-negative/80 hover:text-negative underline underline-offset-2 text-xs">Remove</button>
                                </td>
                            }
                        </tr>
                    }
                }
            }
        </tbody>
    </table>
</div>

@if (lines.Count > 0)
{
    <div class="mt-4 rounded-xl border border-line bg-surface-raised p-5">
        <h3 class="text-sm font-semibold text-content mb-3">Valuation summary@(SelectedClaim is null ? "" : $" — Claim {SelectedClaim.ClaimNumber}")</h3>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-1.5 text-sm max-w-2xl">
            <SummaryRow Label="Original contract sum" Value="@Money(contractSum)" />
            <SummaryRow Label="Net variations" Value="@Money(netVariations)" />
            <SummaryRow Label="Revised contract sum" Value="@Money(revisedContractSum)" Strong="true" />
            <SummaryRow Label="Total works complete" Value="@Money(totalWorksComplete)" />
            <SummaryRow Label=@($"Retention held ({Pct(retentionPercent)})") Value="@Money(retentionHeld)" />
            <SummaryRow Label=@($"Retention released ({Pct(retentionReleasePercent)})") Value="@Money(retentionReleased)" />
            <SummaryRow Label="Certified to date" Value="@Money(certifiedToDate)" />
            <SummaryRow Label="Payment due (ex VAT)" Value="@Money(paymentDueExVat)" Strong="true" />
        </dl>
    </div>
}

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter] public ValuationClaim? SelectedClaim { get; set; }
    [Parameter] public EventCallback<ValuationLineItem> OnEditLine { get; set; }

    private static readonly System.Globalization.CultureInfo Gb = System.Globalization.CultureInfo.GetCultureInfo("en-GB");

    private IReadOnlyList<ValuationLineItem> lines = Array.Empty<ValuationLineItem>();
    private IReadOnlyList<ClaimLine> entries = Array.Empty<ClaimLine>();

    // Editable only while a Draft claim is selected.
    private bool CanEditEntries => SelectedClaim is { Status: ValuationClaimStatus.Draft };
    // Lines can be edited whenever no claim has locked them (no Preapproved/Confirmed claim selected is fine,
    // but bill edits are always allowed since they only affect future claims; keep simple: allow unless viewing a locked claim).
    private bool CanEditLines => SelectedClaim is null or { Status: ValuationClaimStatus.Draft };

    private int ColumnCount => CanEditLines ? 8 : 7;

    // Summary figures.
    private decimal contractSum, netVariations, revisedContractSum, totalWorksComplete;
    private decimal retentionHeld, retentionReleased, certifiedToDate, paymentDueExVat;
    private decimal retentionPercent, retentionReleasePercent;

    protected override void OnParametersSet()
    {
        lines = Store.LinesFor(ProjectId);
        entries = SelectedClaim is null ? Array.Empty<ClaimLine>() : Store.EntriesFor(SelectedClaim.ValuationClaimId);
        Recompute();
    }

    private void Recompute()
    {
        contractSum = ValuationCalculations.ContractSum(lines);
        netVariations = ValuationCalculations.NetVariations(lines);
        revisedContractSum = ValuationCalculations.RevisedContractSum(contractSum, netVariations);

        retentionPercent = SelectedClaim?.RetentionPercent ?? 0m;
        retentionReleasePercent = SelectedClaim?.RetentionReleasePercent ?? 0m;

        if (SelectedClaim is { Status: ValuationClaimStatus.Draft })
        {
            // Live preview for an editable draft.
            var live = lines.Where(l => l.CountsTowardTotals)
                            .Select(l => ValuationCalculations.CumulativeClaimed(PercentFor(l), l.LineAmount));
            totalWorksComplete = live.Sum();
            retentionHeld = ValuationCalculations.RetentionHeld(totalWorksComplete, retentionPercent);
            retentionReleased = ValuationCalculations.RetentionReleased(revisedContractSum, retentionReleasePercent);
            certifiedToDate = SelectedClaim.CertifiedToDate;
            paymentDueExVat = ValuationCalculations.PaymentDueExVat(totalWorksComplete, retentionHeld, retentionReleased, certifiedToDate);
        }
        else if (SelectedClaim is not null)
        {
            // Frozen totals from the locked claim.
            totalWorksComplete = SelectedClaim.TotalWorksComplete;
            retentionHeld = SelectedClaim.RetentionHeld;
            retentionReleased = SelectedClaim.RetentionReleased;
            certifiedToDate = SelectedClaim.CertifiedToDate;
            paymentDueExVat = SelectedClaim.PaymentDueExVat;
        }
        else
        {
            totalWorksComplete = retentionHeld = retentionReleased = certifiedToDate = paymentDueExVat = 0m;
        }
    }

    private record Block(string Title, List<ValuationLineItem> Lines);

    private IEnumerable<Block> Blocks
    {
        get
        {
            Block? Make(string title, ValuationElementType type)
            {
                var rows = lines.Where(l => l.ElementType == type)
                                .OrderBy(l => l.DisplayOrder)
                                .ToList();
                return rows.Count == 0 ? null : new Block(title, rows);
            }

            return new[]
            {
                Make("Contract works", ValuationElementType.ContractWorks),
                Make("Provisional Sums", ValuationElementType.PcSum),
                Make("Contingency", ValuationElementType.Contingency),
                Make("Variations", ValuationElementType.Variation)
            }.Where(b => b is not null)!.Cast<Block>();
        }
    }

    // Non-variation lines show the Jewel cost-centre code (JBB-*); fall back to the
    // NRM2 section ref only if a line has no cost code mapped.
    private static string CodeFor(ValuationLineItem line) =>
        line.ElementType == ValuationElementType.Variation
            ? (string.IsNullOrWhiteSpace(line.VariationRef) ? line.CostCode : line.VariationRef)
            : (string.IsNullOrWhiteSpace(line.CostCode) ? line.SectionCode : line.CostCode);

    private static string TitleFor(ValuationLineItem line)
    {
        if (line.ElementType == ValuationElementType.Variation)
            return string.IsNullOrWhiteSpace(line.VariationTitle) ? line.Description : line.VariationTitle;
        if (!string.IsNullOrWhiteSpace(line.Description)) return line.Description;
        return line.SectionName;
    }

    private decimal PercentFor(ValuationLineItem line) =>
        entries.FirstOrDefault(e => e.ValuationLineItemId == line.ValuationLineItemId)?.PercentComplete ?? 0m;

    private string PercentText(ValuationLineItem line)
    {
        var p = PercentFor(line);
        return p == 0m ? "" : p.ToString("0.##", Gb);
    }

    private decimal ClaimedFor(ValuationLineItem line) =>
        ValuationCalculations.CumulativeClaimed(PercentFor(line), line.LineAmount);

    private async Task SaveEntryAsync(ValuationLineItem line, string? raw)
    {
        if (SelectedClaim is null) return;
        var percent = FormNumber.ParseAmount(raw ?? "0");
        await Store.RecordEntryAsync(ProjectId, new RecordClaimEntry(SelectedClaim.ValuationClaimId, line.ValuationLineItemId, percent));
        OnParametersSet();
    }

    private async Task RemoveLineAsync(ValuationLineItem line)
    {
        await Store.RemoveLineAsync(ProjectId, line.ValuationLineItemId);
        OnParametersSet();
    }

    private static string Money(decimal v) => v.ToString("C2", Gb);
    private static string Num(decimal v) => v.ToString("0.##", Gb);
    private static string Pct(decimal v) => v.ToString("0.##", Gb) + "%";
}
