@using Jewel.JPMS.Commercial
@using Jewel.JPMS.Contracts.Commercial
@inject IValuationReportStore Store

@if (lines.Count == 0)
{
    <div class="rounded-xl border border-line bg-surface px-3 py-6 text-center text-content-subtle italic">
        No lines yet. Add contract works, provisional sums, contingency and variation lines to build the report.
    </div>
}
else
{
    <div class="space-y-3">
        @foreach (var section in Sections)
        {
            var isOpen = IsExpanded(section.Type);
            <div class="rounded-xl border border-line bg-surface overflow-hidden">
                <button type="button" @onclick="@(() => Toggle(section.Type))" aria-expanded="@isOpen"
                        class="w-full flex items-center gap-3 px-4 py-3 text-left hover:bg-surface-raised/60 transition">
                    <svg class="@(isOpen ? "w-4 h-4 shrink-0 text-content-subtle rotate-90 transition-transform" : "w-4 h-4 shrink-0 text-content-subtle transition-transform")"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M9 6l6 6-6 6" />
                    </svg>
                    <span class="font-semibold text-content whitespace-nowrap">@section.Title</span>
                    <span class="text-xs text-content-subtle whitespace-nowrap">
                        @section.Lines.Count @(section.Lines.Count == 1 ? "line" : "lines")
                    </span>
                    <span class="ml-auto flex items-baseline gap-6 whitespace-nowrap">
                        @if (SelectedClaim is not null)
                        {
                            <span class="text-sm">
                                <span class="text-[11px] uppercase tracking-wider text-content-subtle mr-1.5">Claimed</span>
                                <span class="text-content-muted">@Money(ClaimedTotalFor(section)) (@Pct(PercentTotalFor(section)))</span>
                            </span>
                        }
                        <span class="text-sm">
                            <span class="text-[11px] uppercase tracking-wider text-content-subtle mr-1.5">Total</span>
                            <span class="text-content font-medium">@Money(section.Amount)</span>
                        </span>
                    </span>
                </button>

                @if (isOpen)
                {
                    @if (section.Lines.Count == 0)
                    {
                        <div class="border-t border-line px-4 py-5 text-center text-content-subtle italic text-sm">
                            No @section.Title.ToLowerInvariant() lines yet.
                        </div>
                    }
                    else
                    {
                        <div class="border-t border-line overflow-x-auto overflow-y-auto max-h-[85vh]">
                            <table class="w-full text-sm border-collapse">
                                <thead class="bg-surface-raised border-b border-line">
                                    <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                        <th class="sticky left-0 top-0 z-30 bg-surface-raised px-3 py-3 w-[72px]">Code</th>
                                        <th class="sticky left-[72px] top-0 z-30 bg-surface-raised px-3 py-3 min-w-[220px]">Description</th>
                                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap">Qty</th>
                                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap">Rate £</th>
                                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap">Amount £</th>
                                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap">% Complete</th>
                                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right whitespace-nowrap">Claimed £</th>
                                        @if (CanEditLines)
                                        {
                                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right w-[80px]"></th>
                                        }
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-line">
                                    @foreach (var line in section.Lines)
                                    {
                                        <tr class="@(line.CountsTowardTotals ? "" : "opacity-60")">
                                            <td class="sticky left-0 z-10 bg-surface px-3 py-2 font-mono text-[11px] text-content-subtle whitespace-nowrap">@CodeFor(line)</td>
                                            <td class="sticky left-[72px] z-10 bg-surface px-3 py-2 text-content">
                                                <div class="font-medium">@TitleFor(line)</div>
                                                @if (!string.IsNullOrWhiteSpace(line.Comments))
                                                {
                                                    <div class="text-[11px] text-content-subtle">@line.Comments</div>
                                                }
                                                @if (!line.CountsTowardTotals)
                                                {
                                                    <span class="inline-block mt-0.5 text-[10px] uppercase tracking-wide text-content-subtle">@line.LineType</span>
                                                }
                                            </td>
                                            <td class="px-3 py-2 text-right text-content-muted whitespace-nowrap">@Num(line.Quantity)</td>
                                            <td class="px-3 py-2 text-right text-content-muted whitespace-nowrap">@Num(line.Rate)</td>
                                            <td class="px-3 py-2 text-right text-content whitespace-nowrap">@Money(line.LineAmount)</td>
                                            <td class="px-3 py-2 text-right whitespace-nowrap">
                                                @if (CanEditEntries && line.CountsTowardTotals)
                                                {
                                                    @if (editingLineId == line.ValuationLineItemId)
                                                    {
                                                        @* Explicit commit only: Enter / tick saves, Esc / cross discards. *@
                                                        <span class="inline-flex items-center gap-1">
                                                            <input @ref="editInput" type="text" inputmode="decimal"
                                                                   value="@editValue"
                                                                   @oninput="@(e => { editValue = e.Value?.ToString() ?? ""; editError = false; })"
                                                                   @onkeydown="@(e => OnEditKeyDownAsync(e, line))"
                                                                   aria-label="Percent complete"
                                                                   class="field w-16 text-right px-2 py-1 focus:outline-none focus:ring-2 @(editError ? "ring-2 ring-negative border-negative" : "focus:ring-accent focus:border-accent")" />
                                                            <button type="button" title="Save (Enter)" aria-label="Save percent complete"
                                                                    @onclick="() => CommitEditAsync(line)"
                                                                    class="inline-flex items-center justify-center w-6 h-6 rounded-md text-positive hover:bg-surface-raised">
                                                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                                                     stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7" /></svg>
                                                            </button>
                                                            <button type="button" title="Cancel (Esc)" aria-label="Cancel edit"
                                                                    @onclick="CancelEdit"
                                                                    class="inline-flex items-center justify-center w-6 h-6 rounded-md text-content-subtle hover:text-content hover:bg-surface-raised">
                                                                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                                                                     stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
                                                            </button>
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <button type="button" title="Edit % complete"
                                                                @onclick="() => StartEdit(line)"
                                                                class="underline decoration-dotted underline-offset-2 hover:decoration-solid @(PercentFor(line) == 0m ? "text-content-muted" : "text-content")">
                                                            @Pct(PercentFor(line))
                                                        </button>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-content-muted">@(line.CountsTowardTotals ? Pct(PercentFor(line)) : "—")</span>
                                                }
                                            </td>
                                            <td class="px-3 py-2 text-right text-content-muted whitespace-nowrap">
                                                @(line.CountsTowardTotals ? Money(ClaimedFor(line)) : "—")
                                            </td>
                                            @if (CanEditLines)
                                            {
                                                <td class="px-3 py-2 text-right whitespace-nowrap">
                                                    @if (line.ElementType == ValuationElementType.Variation)
                                                    {
                                                        @* Variation lines mirror approved VOs and can only change via the variation itself. *@
                                                        <span class="text-content-subtle text-xs" title="From an approved variation order — manage it on the Variations tab.">Locked</span>
                                                    }
                                                    else
                                                    {
                                                        <button @onclick="@(() => OnEditLine.InvokeAsync(line))"
                                                                class="text-content-subtle hover:text-content underline underline-offset-2 text-xs">Edit</button>
                                                        <button @onclick="@(() => RemoveLineAsync(line))"
                                                                class="ml-2 text-negative/80 hover:text-negative underline underline-offset-2 text-xs">Remove</button>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        }
    </div>
}

@* Extra accordion sections that live with the bill (e.g. valuation invoices) but are fed
   from their own store rather than the line items. *@
@if (ExtraSections is not null)
{
    <div class="mt-3">@ExtraSections</div>
}

@if (lines.Count > 0)
{
    <div class="mt-4 rounded-xl border border-line bg-surface-raised p-5">
        <h3 class="text-sm font-semibold text-content mb-3">Valuation summary@(SelectedClaim is null ? "" : $" — Claim {SelectedClaim.ClaimNumber}")</h3>
        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-1.5 text-sm max-w-2xl">
            <SummaryRow Label="Original contract sum" Value="@Money(contractSum)" />
            <SummaryRow Label="Net variations" Value="@Money(netVariations)" />
            <SummaryRow Label="Revised contract sum" Value="@Money(revisedContractSum)" Strong="true" />
            <SummaryRow Label="Total works complete" Value="@Money(totalWorksComplete)" />
            <SummaryRow Label=@($"Retention held ({Pct(retentionPercent)})") Value="@Money(retentionHeld)" />
            <SummaryRow Label=@($"Retention released ({Pct(retentionReleasePercent)})") Value="@Money(retentionReleased)" />
            <SummaryRow Label="Certified to date" Value="@Money(certifiedToDate)" />
            <SummaryRow Label="Payment due (ex VAT)" Value="@Money(paymentDueExVat)" Strong="true" />
        </dl>
    </div>
}

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter] public ValuationClaim? SelectedClaim { get; set; }
    [Parameter] public EventCallback<ValuationLineItem> OnEditLine { get; set; }
    // Rendered between the bill sections and the summary (e.g. the valuation invoices accordion).
    [Parameter] public RenderFragment? ExtraSections { get; set; }
    // Total issued/paid valuation invoices — drives "Certified to date" for live (draft/no-claim) views.
    [Parameter] public decimal InvoicedToDate { get; set; }

    private static readonly System.Globalization.CultureInfo Gb = System.Globalization.CultureInfo.GetCultureInfo("en-GB");

    private IReadOnlyList<ValuationLineItem> lines = Array.Empty<ValuationLineItem>();
    private IReadOnlyList<ClaimLine> entries = Array.Empty<ClaimLine>();

    // Sections start collapsed so the four totals read at a glance; state survives re-renders.
    private readonly HashSet<ValuationElementType> expanded = new();

    private bool IsExpanded(ValuationElementType type) => expanded.Contains(type);

    private void Toggle(ValuationElementType type)
    {
        if (!expanded.Remove(type)) expanded.Add(type);
    }

    // Editable only while a Draft claim is selected.
    private bool CanEditEntries => SelectedClaim is { Status: ValuationClaimStatus.Draft };
    // Lines can be edited whenever no claim has locked them (no Preapproved/Confirmed claim selected is fine,
    // but bill edits are always allowed since they only affect future claims; keep simple: allow unless viewing a locked claim).
    private bool CanEditLines => SelectedClaim is null or { Status: ValuationClaimStatus.Draft };

    // Summary figures.
    private decimal contractSum, netVariations, revisedContractSum, totalWorksComplete;
    private decimal retentionHeld, retentionReleased, certifiedToDate, paymentDueExVat;
    private decimal retentionPercent, retentionReleasePercent;

    protected override void OnParametersSet()
    {
        lines = Store.LinesFor(ProjectId);
        entries = SelectedClaim is null ? Array.Empty<ClaimLine>() : Store.EntriesFor(SelectedClaim.ValuationClaimId);
        Recompute();
    }

    private void Recompute()
    {
        contractSum = ValuationCalculations.ContractSum(lines);
        netVariations = ValuationCalculations.NetVariations(lines);
        revisedContractSum = ValuationCalculations.RevisedContractSum(contractSum, netVariations);

        retentionPercent = SelectedClaim?.RetentionPercent ?? 0m;
        retentionReleasePercent = SelectedClaim?.RetentionReleasePercent ?? 0m;

        if (SelectedClaim is { Status: ValuationClaimStatus.Draft })
        {
            // Live preview for an editable draft. Certified to date tracks the valuation
            // invoices issued so far, so adding/issuing an invoice updates the payment due.
            var live = lines.Where(l => l.CountsTowardTotals)
                            .Select(l => ValuationCalculations.CumulativeClaimed(PercentFor(l), l.LineAmount));
            totalWorksComplete = live.Sum();
            retentionHeld = ValuationCalculations.RetentionHeld(totalWorksComplete, retentionPercent);
            retentionReleased = ValuationCalculations.RetentionReleased(revisedContractSum, retentionReleasePercent);
            certifiedToDate = InvoicedToDate;
            paymentDueExVat = ValuationCalculations.PaymentDueExVat(totalWorksComplete, retentionHeld, retentionReleased, certifiedToDate);
        }
        else if (SelectedClaim is not null)
        {
            // Frozen totals from the locked claim (its CertifiedToDate captured the invoiced
            // total at the moment it was locked).
            totalWorksComplete = SelectedClaim.TotalWorksComplete;
            retentionHeld = SelectedClaim.RetentionHeld;
            retentionReleased = SelectedClaim.RetentionReleased;
            certifiedToDate = SelectedClaim.CertifiedToDate;
            paymentDueExVat = SelectedClaim.PaymentDueExVat;
        }
        else
        {
            // No claim selected: nothing is being claimed, but what's been invoiced still reads.
            totalWorksComplete = retentionHeld = retentionReleased = paymentDueExVat = 0m;
            certifiedToDate = InvoicedToDate;
        }
    }

    private record Section(ValuationElementType Type, string Title, List<ValuationLineItem> Lines)
    {
        public decimal Amount => Lines.Where(l => l.CountsTowardTotals).Sum(l => l.LineAmount);
    }

    // Always render all four sections so the shape of the bill is visible even before
    // any lines exist in a given block.
    private IEnumerable<Section> Sections
    {
        get
        {
            Section Make(string title, ValuationElementType type) =>
                new(type, title, lines.Where(l => l.ElementType == type)
                                      .OrderBy(l => l.DisplayOrder)
                                      .ToList());

            return new[]
            {
                Make("Contract Works", ValuationElementType.ContractWorks),
                Make("Provisional Sums", ValuationElementType.PcSum),
                Make("Contingency Sums", ValuationElementType.Contingency),
                Make("Variations", ValuationElementType.Variation)
            };
        }
    }

    private decimal ClaimedTotalFor(Section section) =>
        section.Lines.Where(l => l.CountsTowardTotals).Sum(ClaimedFor);

    private decimal PercentTotalFor(Section section)
    {
        var amount = section.Amount;
        return amount == 0m ? 0m : Math.Round(ClaimedTotalFor(section) / amount * 100m, 2);
    }

    // Non-variation lines show the Jewel master cost code (00001..00137, per the
    // seeded CostCenters master); fall back to the NRM2 section ref only if a line
    // has no cost code mapped. Variation lines prefer their VariationRef but now
    // also carry a cost code for purchase-invoice reconciliation.
    private static string CodeFor(ValuationLineItem line) =>
        line.ElementType == ValuationElementType.Variation
            ? (string.IsNullOrWhiteSpace(line.VariationRef) ? line.CostCode : line.VariationRef)
            : (string.IsNullOrWhiteSpace(line.CostCode) ? line.SectionCode : line.CostCode);

    private static string TitleFor(ValuationLineItem line)
    {
        if (line.ElementType == ValuationElementType.Variation)
            return string.IsNullOrWhiteSpace(line.VariationTitle) ? line.Description : line.VariationTitle;
        if (!string.IsNullOrWhiteSpace(line.Description)) return line.Description;
        return line.SectionName;
    }

    private decimal PercentFor(ValuationLineItem line) =>
        entries.FirstOrDefault(e => e.ValuationLineItemId == line.ValuationLineItemId)?.PercentComplete ?? 0m;

    private decimal ClaimedFor(ValuationLineItem line) =>
        ValuationCalculations.CumulativeClaimed(PercentFor(line), line.LineAmount);

    // ---- % complete click-to-edit -----------------------------------------
    // One cell edits at a time; nothing saves until the user confirms (Enter or
    // the tick). Esc or the cross discards. Clicking elsewhere leaves the editor
    // open rather than silently committing or discarding.
    private string? editingLineId;
    private string editValue = "";
    private bool editError;
    private bool focusPending;
    private ElementReference editInput;

    private void StartEdit(ValuationLineItem line)
    {
        editingLineId = line.ValuationLineItemId;
        editValue = PercentFor(line).ToString("0.##", Gb);
        editError = false;
        focusPending = true;
    }

    private void CancelEdit()
    {
        editingLineId = null;
        editError = false;
    }

    private async Task OnEditKeyDownAsync(KeyboardEventArgs e, ValuationLineItem line)
    {
        if (e.Key == "Enter") await CommitEditAsync(line);
        else if (e.Key == "Escape") CancelEdit();
    }

    private async Task CommitEditAsync(ValuationLineItem line)
    {
        if (SelectedClaim is null) { CancelEdit(); return; }
        if (!decimal.TryParse(editValue.Trim().TrimEnd('%'), System.Globalization.NumberStyles.Number, Gb, out var percent)
            || percent < 0m || percent > 100m)
        {
            editError = true;
            return;
        }
        await Store.RecordEntryAsync(ProjectId, new RecordClaimEntry(SelectedClaim.ValuationClaimId, line.ValuationLineItemId, percent));
        editingLineId = null;
        editError = false;
        OnParametersSet();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (focusPending && editingLineId is not null)
        {
            focusPending = false;
            await editInput.FocusAsync();
        }
    }

    private async Task RemoveLineAsync(ValuationLineItem line)
    {
        await Store.RemoveLineAsync(ProjectId, line.ValuationLineItemId);
        OnParametersSet();
    }

    private static string Money(decimal v) => v.ToString("C2", Gb);
    private static string Num(decimal v) => v.ToString("0.##", Gb);
    private static string Pct(decimal v) => v.ToString("0.##", Gb) + "%";
}
