@inject ICvrStore CvrStore

<section class="rounded-xl border border-slate-200 bg-white p-5 mb-4">
    <h3 class="text-sm font-medium text-slate-700 mb-3">Capture this period's snapshot</h3>
    <form @onsubmit="Capture" @onsubmit:preventDefault="true" class="space-y-3">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
            <FormField Label="Tender value £" InputType="number" Value="@tenderValue" OnChange="@(value => tenderValue = value)" />
            <FormField Label="Forecast final cost £" InputType="number" Value="@forecastFinalCost" OnChange="@(value => forecastFinalCost = value)" />
            <FormField Label="Forecast final value £" InputType="number" Value="@forecastFinalValue" OnChange="@(value => forecastFinalValue = value)" />
            <FormField Label="Weeks ahead / behind" InputType="number" Value="@weeksAheadOrBehind" OnChange="@(value => weeksAheadOrBehind = value)" />
        </div>
        <button type="submit" class="rounded-lg bg-slate-900 text-white font-medium text-sm px-4 py-2 hover:bg-slate-800 transition">
            Capture snapshot
        </button>
    </form>
</section>

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";

    private string tenderValue = "0";
    private string forecastFinalCost = "0";
    private string forecastFinalValue = "0";
    private string weeksAheadOrBehind = "0";

    private void Capture()
    {
        CvrStore.CaptureSnapshot(new CvrSnapshot(
            "", ProjectId, DateTimeOffset.UtcNow,
            FormNumber.ParseAmount(tenderValue), FormNumber.ParseAmount(forecastFinalCost), FormNumber.ParseAmount(forecastFinalValue),
            0m, 0m, FormNumber.ParseCount(weeksAheadOrBehind)));
    }
}
