@inject ICommercialStore CommercialStore

<div class="rounded-xl border border-line bg-surface overflow-hidden">
    <table class="w-full text-sm">
        <thead class="bg-surface-raised border-b border-line">
            <tr class="text-right text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                <th class="px-4 py-3 text-left">Reference</th>
                <th class="px-4 py-3 text-left">Name</th>
                <th class="px-4 py-3 hidden md:table-cell">Stage</th>
                <th class="px-4 py-3">Issued to date</th>
                <th class="px-4 py-3">Forward income</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-line text-right">
            @foreach (var project in Projects)
            {
                var valuations = CommercialStore.ValuationsFor(project.ProjectId);
                var issued = valuations.Where(v => v.IsIssued).Sum(v => v.NetValue);
                var forward = valuations.Where(v => !v.IsIssued).Sum(v => v.NetValue);
                <tr>
                    <td class="px-4 py-3 text-left font-mono text-xs text-content-muted">@project.Reference</td>
                    <td class="px-4 py-3 text-left text-content font-medium">@project.Name</td>
                    <td class="px-4 py-3 text-left hidden md:table-cell"><ProjectStageBadge Stage="project.Stage" /></td>
                    <td class="px-4 py-3 text-content-muted">@Money(issued)</td>
                    <td class="px-4 py-3 text-content font-medium">@Money(forward)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Project> Projects { get; set; } = Array.Empty<Project>();

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
