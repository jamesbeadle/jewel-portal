@page "/portal/client/project/{ProjectId}/valuations"
@layout PortalLayout
@inject IProjectStore ProjectStore
@inject ICommercialStore CommercialStore

<PageTitle>Valuations · Client portal</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <nav class="mb-4 text-sm">
        <a href="/portal/client" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Client portal</a>
        <span class="text-slate-400 mx-2">/</span>
        <span class="text-slate-700 font-medium">Valuations</span>
    </nav>

    <header class="mb-6">
        <h1 class="text-2xl md:text-3xl font-semibold text-slate-900">Programme Valuation Reports</h1>
        <p class="text-sm text-slate-600 mt-1">Each report covers the work completed in a Claim Period.</p>
    </header>

    @if (project is null)
    {
        <p class="text-sm text-slate-500 italic">Project not found.</p>
    }
    else
    {
        <ValuationTable Valuations="CommercialStore.ValuationsFor(ProjectId)" />
    }
</section>

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private Project? project;

    protected override void OnParametersSet() => project = ProjectStore.Find(ProjectId);
}
