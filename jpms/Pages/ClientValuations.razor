@page "/portal/client/project/{ProjectId}/valuations"
@layout PortalLayout
@using Jewel.JPMS.Features.Projects
@inject ProjectListReadModel Projects
@inject ICommercialStore CommercialStore

<PageTitle>Valuations · Client portal</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <nav class="mb-4 text-sm">
        <a href="/portal/client" class="text-content-subtle hover:text-content underline underline-offset-4">Client portal</a>
        <span class="text-content-subtle mx-2">/</span>
        <span class="text-content-muted font-medium">Valuations</span>
    </nav>

    <header class="mb-6">
        <h1 class="text-2xl md:text-3xl font-semibold text-content">Programme Valuation Reports</h1>
        <p class="text-sm text-content-muted mt-1">Each report covers the work completed in a Claim Period.</p>
    </header>

    @if (project is null)
    {
        <p class="text-sm text-content-subtle italic">Project not found.</p>
    }
    else
    {
        <ValuationTable Valuations="CommercialStore.ValuationsFor(ProjectId)" />
    }
</section>

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private Project? project;

    protected override async Task OnInitializedAsync()
    {
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
    }

    protected override void OnParametersSet() => project = Projects.Find(ProjectId);
}
