@page "/portal/client/project/{ProjectId}/defects"
@layout PortalLayout
@using Jewel.JPMS.Features.Projects
@inject ProjectListReadModel Projects
@inject ICloseoutStore CloseoutStore
@implements IDisposable

<PageTitle>Defects · Client portal</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <nav class="mb-4 text-sm">
        <a href="/portal/client" class="text-content-subtle hover:text-content underline underline-offset-4">Client portal</a>
        <span class="text-content-subtle mx-2">/</span>
        <span class="text-content-muted font-medium">Defects</span>
    </nav>

    <header class="mb-6">
        <h1 class="text-2xl md:text-3xl font-semibold text-content">Defects</h1>
        <p class="text-sm text-content-muted mt-1">Raise new defects or track existing ones during the defects period.</p>
    </header>

    @if (project is null)
    {
        <p class="text-sm text-content-subtle italic">Project not found.</p>
    }
    else
    {
        <ClientDefectForm ProjectId="@ProjectId" />

        <h2 class="text-lg font-semibold text-content mt-6 mb-3">Open defects</h2>
        @if (Defects.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">No defects raised.</p>
        }
        else
        {
            <DefectTable Defects="Defects" />
        }
    }
</section>

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private Project? project;
    private IReadOnlyList<Defect> Defects => CloseoutStore.DefectsFor(ProjectId);

    protected override async Task OnInitializedAsync()
    {
        CloseoutStore.OnChange += StateHasChanged;
        Projects.OnChanged += StateHasChanged;
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
    }

    protected override void OnParametersSet() => project = Projects.Find(ProjectId);

    public void Dispose()
    {
        CloseoutStore.OnChange -= StateHasChanged;
        Projects.OnChanged -= StateHasChanged;
    }
}
