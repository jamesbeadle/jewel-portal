@page "/portfolio/project-health"
@using Jewel.JPMS.Features.Projects
@inject AuthService Auth
@inject SessionService Session
@inject ProjectListReadModel Projects
@inject IChangeRegister ChangeRegister
@inject ICommercialStore CommercialStore
@inject NavigationManager Nav

<PageTitle>Project health · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/portfolio" class="text-content-subtle hover:text-content underline underline-offset-4">Portfolio</a>
            <span class="text-content-subtle mx-2">/</span>
            <span class="text-content-muted font-medium">Project health</span>
        </nav>

        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-content">Project health</h1>
            <p class="text-sm text-content-muted mt-1">Overdue RFIs, open variations, unvalued WIP across all projects.</p>
        </header>

        <ProjectHealthTable Rows="HealthRows" />
    </section>
}

@code {
    private bool isLoaded;

    private IReadOnlyList<HealthRow> HealthRows =>
        (Projects.Current ?? Array.Empty<Project>()).Select(project => new HealthRow(
            project.Reference, project.Name,
            ChangeRegister.ForProject(project.ProjectId, ChangeKind.Rfi).Count(c => c.Status != ChangeStatus.Closed),
            ChangeRegister.ForProject(project.ProjectId, ChangeKind.Variation).Count(c => c.Status is ChangeStatus.Open or ChangeStatus.AwaitingResponse),
            CommercialStore.ValuationsFor(project.ProjectId).Count(v => !v.IsIssued)
        )).ToList().AsReadOnly();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
        isLoaded = true;
    }
}
