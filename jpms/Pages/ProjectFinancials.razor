@page "/projects/{ProjectId}/financials"
@using Jewel.JPMS.Features.CostCenters
@using Jewel.JPMS.Features.Commercial
@using Jewel.JPMS.Features.Procurement
@using Jewel.JPMS.Contracts.Commercial
@inject AuthService Auth
@inject SessionService Session
@inject CostCentersReadModel CostCenters
@inject ProjectFinancialSummaryReadModel Summary
@inject ProjectWorkOrdersReadModel WorkOrders
@inject ICommandSender Commands
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Financials · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="financials">
        <h2 class="text-lg font-semibold text-content mb-3">Financial summary</h2>

        @if (CostCenters.Current.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">
                No cost centres found. Run the cost-centre seed script against the database to populate the master list.
            </p>
        }
        else
        {
            @if (Summary.LastRefreshFailed(ProjectId))
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">
                    The financial summary could not be loaded — the figures below only show work-order data.
                    <button type="button" class="underline underline-offset-2 ml-1" @onclick="RetrySummaryAsync">Retry</button>
                </p>
            }
            @if (costCompletionError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">
                    @costCompletionError
                </p>
            }
            <FinancialsTable CostCenters="CostCenters.Current"
                             SummaryRows="Summary.Current(ProjectId)"
                             WorkOrderCommittedByCode="WoCommittedByCode"
                             OnWorkOrderCommittedSelected="OpenWorkOrdersModal"
                             OnCostCompletionChanged="HandleCostCompletionChangedAsync" />
            <p class="text-xs text-content-subtle mt-3">
                Contract sales value is the valuation report's contract value per cost centre — initial
                contract plus variation lines, declined/TBC excluded. % complete is the sales-side
                completion from the latest claim (edit it on the valuation report); claim value is the
                cumulative claimed amount at that completion. WO committed is the value committed to
                work orders — click a figure for the cost centre's orders. Drawdown is the expected cost
                (contract sales value less our assumed
                @($"{FinancialSummaryAssumptions.MarginPercent:0.#}%") margin) not yet committed to work
                orders; negative means the centre is committed beyond its expected cost. Cost % complete
                is the cost-side completion — edit it directly in the table.
            </p>

            <CostCentreWorkOrdersModal IsOpen="@(selectedWoCostCode is not null)"
                                       ProjectId="@ProjectId"
                                       CostCode="@(selectedWoCostCode ?? "")"
                                       CostCentreName="@SelectedWoCostCentreName"
                                       Orders="WorkOrders.Current(ProjectId)"
                                       OnClose="CloseWorkOrdersModal" />
        }
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;
    private string? selectedWoCostCode;
    private string? costCompletionError;

    // Committed work-order value per cost code — order line totals, from the same store the
    // Work Orders tab renders. Lines without a cost code can't land on a Financials row, so
    // they're excluded here (they surface on the Work Orders tab instead).
    private IReadOnlyDictionary<string, decimal> WoCommittedByCode =>
        WorkOrders.Current(ProjectId)
            .SelectMany(detail => detail.Lines)
            .Where(line => !string.IsNullOrWhiteSpace(line.CostCode))
            .GroupBy(line => line.CostCode, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key,
                          group => group.Sum(line => line.LineTotal),
                          StringComparer.OrdinalIgnoreCase);

    private string SelectedWoCostCentreName =>
        selectedWoCostCode is null
            ? ""
            : CostCenters.Current.FirstOrDefault(centre =>
                  string.Equals(centre.Code, selectedWoCostCode, StringComparison.OrdinalIgnoreCase))?.Name
              ?? "(not in cost-code master)";

    private Task RetrySummaryAsync() => Summary.RefreshAsync(ProjectId, CancellationToken.None);

    private void OpenWorkOrdersModal(string costCode) => selectedWoCostCode = costCode;

    private void CloseWorkOrdersModal() => selectedWoCostCode = null;

    // A row's Cost % Complete was edited: persist it, then re-pull the summary so the
    // table (and its weighted total) reflects the saved value.
    private async Task HandleCostCompletionChangedAsync((string CostCode, decimal Percent) edit)
    {
        costCompletionError = null;
        try
        {
            await Commands.SendAsync(
                new SetCostCentreCostCompletion(ProjectId, edit.CostCode, edit.Percent), CancellationToken.None);
        }
        catch (CommandFailedException)
        {
            costCompletionError = $"Could not save the cost % complete for {edit.CostCode} — please try again.";
        }
        await Summary.RefreshAsync(ProjectId, CancellationToken.None);
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        CostCenters.OnChanged += StateHasChanged;
        Summary.OnChanged += StateHasChanged;
        WorkOrders.OnChanged += StateHasChanged;
        // Refresh once per tab entry (stale-while-revalidate, per the front-end
        // data-loading convention) — cached figures render immediately, then update.
        _ = Summary.RefreshAsync(ProjectId, CancellationToken.None);
        _ = WorkOrders.RefreshAsync(ProjectId, CancellationToken.None);
        await CostCenters.RefreshAsync(CancellationToken.None);
        isLoaded = true;
    }

    public void Dispose()
    {
        CostCenters.OnChanged -= StateHasChanged;
        Summary.OnChanged -= StateHasChanged;
        WorkOrders.OnChanged -= StateHasChanged;
    }
}
