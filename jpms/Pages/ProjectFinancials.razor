@page "/projects/{ProjectId}/financials"
@using Jewel.JPMS.Features.CostCenters
@using Jewel.JPMS.Features.Commercial
@using Jewel.JPMS.Contracts.Commercial
@inject AuthService Auth
@inject SessionService Session
@inject CostCentersReadModel CostCenters
@inject ProjectFinancialSummaryReadModel Summary
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Financials · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="financials">
        <h2 class="text-lg font-semibold text-content mb-3">Financial summary</h2>

        @if (CostCenters.Current.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">
                No cost centres found. Run the cost-centre seed script against the database to populate the master list.
            </p>
        }
        else
        {
            <FinancialsTable CostCenters="CostCenters.Current"
                             SummaryRows="Summary.Current(ProjectId)"
                             OnUnderOverSelected="OpenCostCentreModal" />
            <p class="text-xs text-content-subtle mt-3">
                Budgeted sales is the valuation report's contract value per cost centre (declined/TBC lines
                excluded); budgeted cost is that figure less an assumed
                @($"{FinancialSummaryAssumptions.MarginPercent:0.#}%") margin. Completion comes from the
                latest claim, and expected actual cost applies it to the budgeted cost. Actual cost is Xero
                purchase spend allocated to this project on the Allocation page, net of credit notes. Click
                an under/over figure for the breakdown.
            </p>

            <CostCentreFinancialsModal IsOpen="@(selectedCostCode is not null)"
                                       ProjectId="@ProjectId"
                                       CostCode="@(selectedCostCode ?? "")"
                                       CostCentreName="@SelectedCostCentreName"
                                       Row="SelectedRow"
                                       OnClose="CloseCostCentreModal" />
        }
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;
    private string? selectedCostCode;

    private ProjectFinancialSummaryRow? SelectedRow =>
        selectedCostCode is null
            ? null
            : Summary.Current(ProjectId).FirstOrDefault(row =>
                string.Equals(row.CostCode, selectedCostCode, StringComparison.OrdinalIgnoreCase));

    private string SelectedCostCentreName =>
        selectedCostCode is null
            ? ""
            : CostCenters.Current.FirstOrDefault(centre =>
                  string.Equals(centre.Code, selectedCostCode, StringComparison.OrdinalIgnoreCase))?.Name
              ?? "(not in cost-code master)";

    private void OpenCostCentreModal(string costCode) => selectedCostCode = costCode;

    private void CloseCostCentreModal() => selectedCostCode = null;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        CostCenters.OnChanged += StateHasChanged;
        Summary.OnChanged += StateHasChanged;
        // Refresh once per tab entry (stale-while-revalidate, per the front-end
        // data-loading convention) — cached figures render immediately, then update.
        _ = Summary.RefreshAsync(ProjectId, CancellationToken.None);
        await CostCenters.RefreshAsync(CancellationToken.None);
        isLoaded = true;
    }

    public void Dispose()
    {
        CostCenters.OnChanged -= StateHasChanged;
        Summary.OnChanged -= StateHasChanged;
    }
}
