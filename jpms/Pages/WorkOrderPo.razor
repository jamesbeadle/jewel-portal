@page "/projects/{ProjectId}/work-orders/{WorkOrderId}/po"
@using Jewel.JPMS.Contracts.Procurement
@using Jewel.JPMS.Features.Procurement
@using Jewel.JPMS.Features.Projects
@using Jewel.JPMS.Features.Subcontractors
@using Jewel.JPMS.Models
@inject AuthService Auth
@inject SessionService Session
@inject ProjectWorkOrdersReadModel WorkOrders
@inject ProjectListReadModel Projects
@inject SubcontractorsReadModel Subcontractors
@inject IUserDirectory Users
@inject ICommandSender Commands
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

@* The printable purchase order for one work order — opened from the Work Orders tab. The sheet
   itself is the shared PurchaseOrderSheet; this page resolves the internal-side data (supplier
   record, project, approver display name) and offers Print (browser print → paper or PDF). *@

<PageTitle>@Title · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-4 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (Detail is null)
{
    <section class="px-4 md:px-8 py-12">
        <h1 class="text-2xl font-semibold text-content mb-2">Work order not found</h1>
        <p class="text-content-muted">
            This work order doesn't exist on this project.
            <a class="underline underline-offset-4" href="@($"/projects/{ProjectId}/work-orders")">Back to the Work Orders tab</a>
        </p>
    </section>
}
else
{
    <section class="px-4 md:px-8 py-6">
        <div class="po-toolbar flex items-center justify-between gap-3 mb-5 max-w-[820px] mx-auto">
            <a class="text-sm text-content-subtle hover:text-content underline underline-offset-4"
               href="@($"/projects/{ProjectId}/work-orders")">← Work orders</a>
            <div class="flex items-center gap-3">
                @if (Detail.Order.IsAccepted)
                {
                    <span class="rounded-full border border-emerald-200 bg-emerald-50 text-emerald-800 px-2.5 py-0.5 text-xs font-medium"
                          title="@($"Electronically accepted by {Detail.Order.AcceptedByName} on {Detail.Order.AcceptedAt!.Value.LocalDateTime:d MMM yyyy, HH:mm}")">
                        Accepted by supplier
                    </span>
                }
                else if (Detail.Order.Status == WorkOrderStatus.Released)
                {
                    <span class="rounded-full border border-amber-200 bg-amber-50 text-amber-800 px-2.5 py-0.5 text-xs font-medium">
                        Awaiting supplier acceptance
                    </span>
                }
                <button type="button" class="btn-secondary text-sm" @onclick="OpenEmailModal"
                        title="Draft the covering email to the supplier in the shared mailbox — nothing sends until you review it in Outlook">
                    Draft email to supplier…
                </button>
                <button type="button" class="btn-secondary text-sm" @onclick="PrintAsync"
                        title="Print the purchase order, or save it as a PDF from the print dialog">
                    Print / save PDF
                </button>
            </div>
        </div>

        @if (emailNote is not null)
        {
            <p class="po-toolbar rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-sm text-content mb-4 max-w-[820px] mx-auto">
                @emailNote
                @if (emailLink is not null)
                {
                    <a class="text-accent underline ml-1" href="@emailLink" target="_blank" rel="noopener">Open the draft in Outlook</a>
                }
            </p>
        }
        @if (emailError is not null)
        {
            <p class="po-toolbar rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4 max-w-[820px] mx-auto">@emailError</p>
        }

        <PurchaseOrderSheet Order="Detail.Order"
                            Lines="Detail.Lines"
                            SupplierName="@Detail.SubcontractorName"
                            SupplierContactName="@(Supplier?.ContactName ?? "")"
                            SupplierAddress="@SupplierAddress"
                            ProjectName="@(Project?.Name ?? "")"
                            SiteAddress="@SiteAddress"
                            ApprovedByName="@ApprovedByName" />

        <Modal IsOpen="showEmailModal" Title="@($"Email work order {Title2} to {Detail.SubcontractorName}")" ShowFooter="true"
               ConfirmLabel="@(emailBusy ? "Drafting…" : "Create draft in mailbox")" ConfirmDisabled="@emailBusy" CancelLabel="Cancel"
               OnCancel="CloseEmailModal" OnConfirm="ConfirmEmailDraftAsync" Class="max-w-3xl w-full">
            <p class="rounded-lg bg-surface-raised border border-line px-3 py-2 text-xs text-content-muted mb-3">
                Nothing sends from here — this creates a draft in the shared mailbox, addressed to the supplier's
                directory email, for you to review and send from Outlook. Print the purchase order to PDF first if
                you want to attach it before sending.
            </p>

            <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Subject</label>
            <input class="field mb-3" @bind="emailSubject" />

            <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Body (HTML)</label>
            <textarea class="field font-mono text-xs" rows="14" @bind="emailBody"></textarea>
        </Modal>
    </section>
}

<style>
    @@media print {
        .po-toolbar { display: none; }
    }
</style>

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string WorkOrderId { get; set; } = "";

    private bool isLoaded;

    private ProjectWorkOrderDetail? Detail =>
        WorkOrders.Current(ProjectId).FirstOrDefault(detail =>
            string.Equals(detail.Order.WorkOrderId, WorkOrderId, StringComparison.OrdinalIgnoreCase));

    private Project? Project => Projects.Find(ProjectId);

    private Subcontractor? Supplier =>
        Detail is null
            ? null
            : (Subcontractors.Current ?? Array.Empty<Subcontractor>()).FirstOrDefault(sub =>
                string.Equals(sub.SubcontractorId, Detail.Order.SubcontractorId, StringComparison.OrdinalIgnoreCase));

    private string SupplierAddress =>
        Supplier is null
            ? ""
            : string.Join(", ", new[] { Supplier.Town, Supplier.County }.Where(part => !string.IsNullOrWhiteSpace(part)));

    private string SiteAddress =>
        Project is null
            ? ""
            : string.Join(", ", new[] { Project.AddressLine, Project.Town, Project.Postcode }.Where(part => !string.IsNullOrWhiteSpace(part)));

    // Whoever raised/approved the order in the system, by display name (falls back to the email
    // inside the sheet when the directory has no entry).
    private string ApprovedByName =>
        Detail is null ? "" : Users.Find(Detail.Order.AwardedByEmail)?.DisplayName ?? "";

    private string Title => Detail is null ? "Purchase order" : $"WO-{Detail.Order.Number:0000} purchase order";

    private async Task PrintAsync() => await JS.InvokeVoidAsync("window.print");

    // ---- Draft the covering email in the shared mailbox (review + send from Outlook) ----

    private bool showEmailModal;
    private bool emailBusy;
    private string emailSubject = "";
    private string emailBody = "";
    private string? emailNote;
    private string? emailError;
    private string? emailLink;

    private string Title2 => Detail is null ? "" : $"WO-{Detail.Order.Number:0000}";

    private void OpenEmailModal()
    {
        if (Detail is null) return;
        emailSubject = $"Work order WO-{Detail.Order.Number:0000} — {Detail.Order.Title} — {Project?.Name ?? ProjectId}";
        emailBody = DefaultEmailBody(Detail);
        emailNote = null;
        emailError = null;
        showEmailModal = true;
    }

    private void CloseEmailModal() => showEmailModal = false;

    // The pre-filled covering email: the order summary (priced lines, or value + scope for orders
    // without a breakdown), programme dates when set, the portal link for electronic acceptance,
    // and the standard pre-start paperwork line (RAMS/insurances to projects@ — never a named person).
    private string DefaultEmailBody(ProjectWorkOrderDetail detail)
    {
        var order = detail.Order;
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"<p>Hello {detail.SubcontractorName},</p>");
        sb.AppendLine($"<p>Please find below the details of our work order <strong>WO-{order.Number:0000}</strong> for <strong>{Project?.Name ?? "the project"}</strong>.</p>");
        if (detail.Lines.Count > 0)
        {
            sb.AppendLine("<table border=\"1\" cellpadding=\"6\" cellspacing=\"0\" style=\"border-collapse:collapse\">");
            sb.AppendLine("<tr><th align=\"left\">Item</th><th align=\"left\">Qty</th><th align=\"left\">Unit</th><th align=\"right\">Total</th></tr>");
            foreach (var line in detail.Lines.OrderBy(l => l.SortOrder))
                sb.AppendLine($"<tr><td>{line.Title}</td><td>{line.Quantity}</td><td>{line.Unit}</td><td align=\"right\">{line.LineTotal:£#,##0.00}</td></tr>");
            sb.AppendLine($"<tr><td colspan=\"3\"><strong>Order total</strong></td><td align=\"right\"><strong>{order.Value:£#,##0.00}</strong></td></tr>");
            sb.AppendLine("</table>");
        }
        else
        {
            sb.AppendLine($"<p><strong>Order value:</strong> {order.Value:£#,##0.00}</p>");
            if (!string.IsNullOrWhiteSpace(order.Scope))
                sb.AppendLine($"<p><strong>Scope:</strong> {order.Scope}</p>");
        }
        if (order.ProgrammeStart is { } start)
            sb.AppendLine($"<p><strong>Programme start:</strong> {start.LocalDateTime:d MMM yyyy}</p>");
        if (order.ScheduledCompletion is { } completion)
            sb.AppendLine($"<p><strong>Scheduled completion:</strong> {completion.LocalDateTime:d MMM yyyy}</p>");
        sb.AppendLine($"<p>You can view and electronically accept this work order in our portal: <a href=\"{Nav.BaseUri}portal/work-orders/{order.WorkOrderId}\">{Nav.BaseUri}portal/work-orders/{order.WorkOrderId}</a></p>");
        sb.AppendLine("<p>Before starting on site, please send your RAMS documentation and current insurance certificates to projects@jewelbb.co.uk.</p>");
        sb.AppendLine("<p>Kind regards,<br/>Jewel Bespoke Build</p>");
        return sb.ToString();
    }

    private async Task ConfirmEmailDraftAsync()
    {
        if (emailBusy || Detail is null) return;
        emailError = null;
        try
        {
            emailBusy = true;
            var draft = await Commands.SendAsync(
                new PrepareWorkOrderEmailDraft(Detail.Order.WorkOrderId, emailSubject.Trim(), emailBody), CancellationToken.None);
            showEmailModal = false;
            emailNote = $"Draft created in the shared mailbox to {draft.RecipientEmail}. Review it (attach the printed PDF if you like) and send from the mailbox's Drafts folder.";
            emailLink = draft.WebLink;
        }
        catch (CommandFailedException ex) { emailError = $"Couldn't create the draft: {ex.Message}"; }
        catch { emailError = "Couldn't create the draft. Check the supplier has an email address in the directory and the mailbox connection, then try again."; }
        finally { emailBusy = false; }
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        WorkOrders.OnChanged += StateHasChanged;
        Projects.OnChanged += StateHasChanged;
        Subcontractors.OnChanged += StateHasChanged;
        // Refresh once per entry (stale-while-revalidate, per the front-end data-loading convention).
        _ = WorkOrders.RefreshAsync(ProjectId, CancellationToken.None);
        _ = Projects.RefreshAsync(CancellationToken.None);
        await Subcontractors.RefreshAsync(CancellationToken.None);
        isLoaded = true;
    }

    public void Dispose()
    {
        WorkOrders.OnChanged -= StateHasChanged;
        Projects.OnChanged -= StateHasChanged;
        Subcontractors.OnChanged -= StateHasChanged;
    }
}
