@page "/projects/{ProjectId}/closeout"
@inject AuthService Auth
@inject SessionService Session
@inject ICloseoutStore CloseoutStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Close-out · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="closeout">
        <div class="space-y-6">
            <section>
                <h2 class="text-lg font-semibold text-content mb-3">Defect register</h2>
                @if (Defects.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">No defects raised.</p>
                }
                else
                {
                    <DefectTable Defects="Defects" />
                }
            </section>

            <section>
                <h2 class="text-lg font-semibold text-content mb-3">Settlement</h2>
                <SettlementCard Settlement="CloseoutStore.SettlementFor(ProjectId)" />
            </section>

            <section>
                <h2 class="text-lg font-semibold text-content mb-3">VAT analysis</h2>
                <VatAnalysisCard Vat="CloseoutStore.VatFor(ProjectId)" />
            </section>

            <section>
                <h2 class="text-lg font-semibold text-content mb-3">Retention release</h2>
                <RetentionReleaseCard Release="CloseoutStore.RetentionFor(ProjectId)" />
            </section>
        </div>
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;
    private IReadOnlyList<Defect> Defects => CloseoutStore.DefectsFor(ProjectId);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        CloseoutStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => CloseoutStore.OnChange -= StateHasChanged;
}
