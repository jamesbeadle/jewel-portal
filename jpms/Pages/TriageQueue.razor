    private async Task LoadUnassignedAsync()
    {
        unassignedError = null;
        try { unassigned = await RequestRegister.ListUnassignedAsync(); }
        catch { unassigned = Array.Empty<Request>(); }
    }

    private async Task ReturnUnassigned(Request request)
    {
        if (busy) return;
        unassignedError = null;
        try
        {
            busy = true;
            await RequestRegister.ReturnToTriageAsync(request.RequestId, request.ProjectId);
            await LoadAsync();
            await LoadUnassignedAsync();
        }
        catch
        {
            unassignedError = "Couldn't return that request to triage. Please try again.";
        }
        finally { busy = false; }
    }

    // Point the detail pane at an email: set the selection and reset the create forms. Loading
    // the body and thread is the caller's job — Select does both; the jump-to-latest inside
    // LoadThreadAsync reuses this directly so it doesn't re-fetch the thread it already has.
    private void ApplySelection(MailboxMessage item)
    {
        selected = item;
        // Pathway-first: pre-select the thread's own pathway when it already carries one (rendered as
        // a fixed badge); otherwise the triager chooses before any action beyond Discard is offered.
        pathway = PathwayFromBucket(item.Bucket);
        mode = TriageMode.None;
        actionError = null;
        crossFileMessage = null;
        crossFilePicks.Clear();
        previewAttachment = null;
        threadNote = null;
        ResetLinkState();
        replyOutcome = null;
        linkNote = null;
        replyProjectId = "";
        replyBody = "";
        createProjectId = "";
        // Deliberately blank rather than copied from the email — the subject/body of the email is
        // rarely the right subject/detail for the record, so the triager writes their own.
        createTitle = "";
        createDescription = "";
        createRaisedTo = createDrawingRef = createResponseDue = "";
        createAddToProgramme = false;
        createTrade = "";
        createTodoRows = new List<TodoDraftRow> { new() };
        createTodoLinkRequestId = "";
        createTodoLinkRequests = Array.Empty<LinkableRecord>();
    }

    // jumpToLatest: clicking an email in the QUEUE list triages its thread from the newest member —
    // if later replies exist, the selection moves onto the latest one (the reply that says what to
    // do with the rest; every action applies thread-wide anyway). Clicks inside the thread panel
    // pass false so any member can still be read without being bounced back to the latest.
    private async Task Select(MailboxMessage item, bool jumpToLatest = true)
    {
        ApplySelection(item);
        // Body and thread are independent live reads — fetch them side by side.
        await Task.WhenAll(LoadDetailAsync(item), LoadThreadAsync(item, jumpToLatest));
    }

    // Fetch the full body + attachment names on demand when an email is opened. Cancels any in-flight
    // fetch so rapid clicking can't race a stale result onto the newly selected email.
    private async Task LoadDetailAsync(MailboxMessage item)
    {
        detailCts?.Cancel();
        var cts = new CancellationTokenSource();
        detailCts = cts;

        detail = null;
        detailLoading = true;
        try
        {
            var loaded = await Intake.GetMessageDetailAsync(item.Id, item.InternetMessageId, cts.Token);
            if (!cts.IsCancellationRequested && selected?.Id == item.Id)
                detail = loaded;
        }
        catch (OperationCanceledException) { /* superseded by a newer selection */ }
        catch { /* leave detail null so the view falls back to the preview */ }
        finally
        {
            if (selected?.Id == item.Id)
                detailLoading = false;
        }
    }

    // Fetch the selected email's whole conversation for the thread panel. Same cancellation shape as
    // LoadDetailAsync: rapid clicking can't race a stale thread onto the newly selected email. The
    // list is cleared up front so a previous selection's thread never flashes against this one.
    private async Task LoadThreadAsync(MailboxMessage item, bool jumpToLatest = false)
    {
        threadCts?.Cancel();
        var cts = new CancellationTokenSource();
        threadCts = cts;

        thread = Array.Empty<MailboxMessage>();
        if (string.IsNullOrEmpty(item.ConversationId)) { threadLoading = false; return; }

        threadLoading = true;
        var jumped = false;
        try
        {
            var page = await Intake.ListConversationLiveAsync(item.ConversationId, cts.Token);
            if (cts.IsCancellationRequested || selected?.Id != item.Id)
                return;
            thread = page.Items;

            // Triage the thread from its newest member: when the clicked email has later replies,
            // move the selection onto the latest one and note where the user came from. Queue view
            // only — the Discarded/Tagged panes are management surfaces where the clicked email is
            // the one being managed.
            if (jumpToLatest && view == QueueView.Active && thread.Count > 1 && thread[^1].Id != item.Id)
            {
                var latest = thread[^1];
                jumped = true;
                threadLoading = false;
                ApplySelection(latest);
                threadNote = $"This email has newer replies, so the latest ({Date(latest.ReceivedAt)}) is shown — triage from here. "
                    + $"The one you clicked ({Date(item.ReceivedAt)}) is in the thread below.";
                await LoadDetailAsync(latest);
            }
        }
        catch (OperationCanceledException) { /* superseded by a newer selection */ }
        catch { /* leave empty: the panel simply doesn't render */ }
        finally
        {
            if (jumped || selected?.Id == item.Id)
                threadLoading = false;
        }
    }

    private static string ThreadRowClass(bool current)
    {
        var baseClass = "w-full text-left rounded-lg border px-3 py-2 transition";
        return current
            ? $"{baseClass} border-accent bg-surface"
            : $"{baseClass} border-line hover:border-line-strong hover:bg-surface";
    }

    private static string FormatSize(long bytes)
    {
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576.0:0.#} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes} B";
    }

    private async Task SetMode(TriageMode next)
    {
        mode = next;
        actionError = null;
        crossFileMessage = null;
        crossFilePicks.Clear();
        // Entering the to-do form with a project already chosen loads its open requests for the
        // optional request link; leaving it clears the pick (the loader guards on the mode).
        await LoadCreateTodoLinkRequestsAsync();
    }

    // Choose the pathway for a not-yet-filed thread. Resets the action state so nothing chosen under
    // one pathway (a record type, picked records) can leak into another; a thread that already
    // carries a pathway ignores this — its routing decision is fixed at first filing.
    private void SetPathway(TriagePathway next)
    {
        if (FixedPathway is not null || pathway == next) return;
        pathway = next;
        mode = TriageMode.None;
        actionError = null;
        crossFileMessage = null;
        crossFilePicks.Clear();
        ResetLinkState();
    }

    // Segmented-selector styling, mirroring the sort toggle's active/inactive treatment.
    private string PathwaySegmentClass(TriagePathway p) =>
        pathway == p
            ? "rounded-md text-xs px-2.5 py-1.5 transition bg-accent text-accent-ink font-medium"
            : "rounded-md text-xs px-2.5 py-1.5 transition text-content-muted hover:bg-surface-raised";

    private async Task OnLinkRecordTypeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<RecordType>(e.Value?.ToString(), out var type)) linkRecordType = type;
        linkRecordId = "";
        linkRecordIds.Clear();
        await LoadLinkRecordsAsync();
    }

    private async Task OnLinkProjectChanged(ChangeEventArgs e)
    {
        linkProjectId = e.Value?.ToString() ?? "";
        linkRecordId = "";
        linkRecordIds.Clear();
        await LoadLinkRecordsAsync();
    }

    // Load the chosen project's records of the chosen type for the picker. Record-agnostic: the same
    // call backs both the Link panel and the Tagged tab's "link to another record" control.
    private async Task LoadLinkRecordsAsync()
    {
        if (string.IsNullOrWhiteSpace(linkProjectId))
        {
            linkRecords = Array.Empty<LinkableRecord>();
            return;
        }
        try
        {
            linkRecordsLoading = true;
            linkRecordId = "";
            linkRecordIds.Clear();
            StateHasChanged(); // show the loading state while the fetch is in flight
            linkRecords = await Intake.ListLinkableRecordsAsync(linkProjectId, linkRecordType);
        }
        catch
        {
            linkRecords = Array.Empty<LinkableRecord>();
        }
        finally
        {
            linkRecordsLoading = false;
        }
    }

    // The first record type the current context offers (the chosen pathway on the queue, the thread's
    // bucket on the Tagged tab) — what the link picker resets to, so a type from another pathway can
    // never survive a pathway or selection change.
    private RecordType DefaultLinkRecordType => view == QueueView.Tagged
        ? TaggedLinkTypeOptions[0]
        : (QueueLinkTypeOptions.Count > 0 ? QueueLinkTypeOptions[0] : RecordType.Request);

    // Clear the link picker back to the current context's defaults after a selection or pathway
    // changes, or a link action completes.
    private void ResetLinkState()
    {
        linkRecordType = DefaultLinkRecordType;
        linkProjectId = "";
        linkRecordId = "";
        linkRecordIds.Clear();
        linkRecords = Array.Empty<LinkableRecord>();
    }

    private async Task OnCreateProjectChanged(ChangeEventArgs e)
