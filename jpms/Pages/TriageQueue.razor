    private IReadOnlyList<MailboxMessage> thread = Array.Empty<MailboxMessage>();
    private bool threadLoading;
    private CancellationTokenSource? threadCts;
    // Set when the selection was auto-moved onto a thread's latest reply, telling the triager what
    // happened and where the email they actually clicked sits. Cleared on every new selection.
    private string? threadNote;

    // AI suggestion state: Claude's recommendation for the selected email (null until asked for or
    // after dismissal), the in-flight flag, and the same cancellation shape as the detail/thread
    // loads so rapid clicking can't race a stale suggestion onto a newly selected email.
    private TriageRecommendation? recommendation;
    private bool recommendLoading;
    private string? recommendError;
    private CancellationTokenSource? recommendCts;

    private IReadOnlyList<Request> unassigned = Array.Empty<Request>();
    private string? unassignedError;

    // Triage is restricted to administrators, project managers, and the finance director.
    // Administrators are granted every role server-side, so they always carry Role.ProjectManager too.
    private bool CanTriage =>
