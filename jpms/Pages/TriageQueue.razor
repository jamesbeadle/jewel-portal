    private RecordType linkRecordType = RecordType.Request;
    private string linkProjectId = "";
    private string linkRecordId = "";
    private IReadOnlyList<LinkableRecord> linkRecords = Array.Empty<LinkableRecord>();
    private bool linkRecordsLoading;

    // Create-new state. A request created from an email always starts as a General container
    // (auto-numbered REQ-#### server-side); it's promoted to an RFI later from the request page.
    private RecordType createRecordType = RecordType.Request;
    private string createProjectId = "";
    private const RequestType createKind = RequestType.General;
    private string createTitle = "";
    private string createDescription = "";
    private string createRaisedTo = "";
    private string createDrawingRef = "";
    private string createResponseDue = "";
    // "Also add to Programme": as well as tagging the email to the new request, the server tags it
    // to the project's scheduling bucket (the same tag "Tag email to programme" applies) so the
