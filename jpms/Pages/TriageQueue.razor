    // requests are filtered server-side), reloaded whenever the To-do form gains a project. Project
    // to-dos only — the General to-do mode has no project, so no request link.
    private string createTodoLinkRequestId = "";
    private IReadOnlyList<LinkableRecord> createTodoLinkRequests = Array.Empty<LinkableRecord>();
    private bool createTodoLinkRequestsLoading;

    // The assignee picker's option pool: the ROLES a to-do can be assigned to
    // (TodoRoles.AssignableAsTodoAssignee, served by ListTodoAssignableRoles), fetched once when
    // the page loads and shared by every to-do draft row. Items are assigned to a role, not a
