@page "/requests/triage"
@using Jewel.JPMS.Contracts.Drawings
@using Jewel.JPMS.Contracts.Procurement
@using Jewel.JPMS.Contracts.Requests
@using Jewel.JPMS.Contracts.Todos
@inject AuthService Auth
@inject SessionService Session
@inject NavigationManager Nav
@inject IIntakeQueue Intake
@inject ITodoStore Todos
@inject IRequestRegister RequestRegister
@inject IDrawingStore DrawingStore
@inject ICommandSender Commands
@inject Jewel.JPMS.Features.Projects.ProjectListReadModel Projects
@implements IDisposable

<PageTitle>Triage · JPMS</PageTitle>

@*
    Live-read triage. The mailbox is the single source of truth and nothing ever moves — triage just
    adds/removes category tags on the email. The Queue is Inbox messages with no JPMS tag (read live);
    the Discarded tab is messages tagged "JPMS/Discarded". Discard/restore/assign add or remove tags,
    each verified by reading the categories back. Nothing about un-triaged mail is stored in the database.
*@

@*
    Shared message body + attachments, used by both the Queue and Discarded detail panes. Declared
    before first use; reads the live `detail` / `selected` fields each time it is rendered.
*@
@{
    // Small paperclip glyph flagging an email as carrying attachments — shown on list rows
    // (queue / discarded / tagged) and thread panel rows. Inherits the row's text colour.
    RenderFragment PaperclipIcon =
        @<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              class="w-3 h-3 shrink-0" aria-hidden="true">
            <path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48" />
        </svg>;

    RenderFragment MessageBody =@<text>
        @if (threadNote is not null)
        {
            <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-xs text-content">@threadNote</p>
        }
        <div class="rounded-lg bg-surface-raised border border-line p-3 max-h-[28rem] overflow-y-auto">
            @if (detailLoading)
            {
                <p class="text-sm text-content-subtle italic">Loading message…</p>
            }
            else if (detail is not null && !string.IsNullOrWhiteSpace(detail.BodyHtml) && detail.BodyIsHtml)
            {
                <div class="rounded bg-white text-gray-900 p-3 text-sm overflow-x-auto">@((MarkupString)detail.BodyHtml)</div>
            }
            else if (detail is not null && !string.IsNullOrWhiteSpace(detail.BodyHtml))
            {
                <p class="text-sm text-content whitespace-pre-wrap">@detail.BodyHtml</p>
            }
            else
            {
                <p class="text-sm text-content-subtle italic">@(selected is null ? "" : Dash(selected.BodyPreview))</p>
            }
        </div>

        @*
            Attachments: names, preview, download and save-to-drawings for the open email.
            Rendered directly under the body — above the thread panel — so a long thread
            never pushes the attachment names out of sight.
        *@
        @if (detail is not null && detail.Attachments.Count > 0)
        {
            <div class="rounded-lg bg-surface-raised border border-line p-3">
                <p class="text-xs uppercase tracking-wider text-content-subtle font-semibold mb-2">
                    @detail.Attachments.Count attachment@(detail.Attachments.Count == 1 ? "" : "s")
                </p>
                <ul class="space-y-1">
                    @foreach (var att in detail.Attachments)
                    {
                        <li class="flex items-center justify-between gap-3 text-sm text-content">
                            <span class="truncate">@att.Name</span>
                            <span class="flex items-center gap-3 whitespace-nowrap">
                                @if (att.Size > 0)
                                {
                                    <span class="text-xs text-content-subtle">@FormatSize(att.Size)</span>
                                }
                                @if (!string.IsNullOrEmpty(att.Id))
                                {
                                    @if (IsPreviewable(att))
                                    {
                                        <button type="button" class="text-xs text-accent hover:underline"
                                                @onclick="() => ToggleAttachmentPreview(att)">
                                            @(previewAttachment == att ? "Hide preview" : "Preview")
                                        </button>
                                    }
                                    <a href="@AttachmentUrl(att, inline: false)" target="_blank" rel="noopener"
                                       class="text-xs text-accent hover:underline">Download</a>
                                    <button type="button" class="text-xs text-accent hover:underline" disabled="@busy"
                                            @onclick="() => OpenDrawingImport(att)">Save to drawings</button>
                                }
                            </span>
                        </li>
                    }
                </ul>

                @* Inline preview: check a PDF/image without leaving triage. The iframe hits the same
                   endpoint the Download link does, with ?inline=1 so the browser renders it in place. *@
                @if (previewAttachment is not null)
                {
                    <div class="mt-3 rounded-lg border border-line bg-surface overflow-hidden">
                        <header class="px-3 py-2 border-b border-line bg-surface-raised flex items-center justify-between gap-3">
                            <span class="text-xs text-content-muted font-medium truncate">@previewAttachment.Name</span>
                            <span class="flex items-center gap-3 shrink-0">
                                <a href="@AttachmentUrl(previewAttachment, inline: false)" target="_blank" rel="noopener"
                                   class="text-xs text-accent hover:underline underline-offset-2">Open / download</a>
                                <button type="button" class="text-xs text-content-muted hover:text-content"
                                        @onclick="() => previewAttachment = null">Close</button>
                            </span>
                        </header>
                        <iframe src="@AttachmentUrl(previewAttachment, inline: true)"
                                class="w-full h-[60vh] bg-white" title="Attachment preview"></iframe>
                    </div>
                }

                @if (importNote is not null)
                {
                    <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-xs text-content mt-3">@importNote</p>
                }
                @if (importError is not null)
                {
                    <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-xs text-negative mt-3">@importError</p>
                }

                @* Inline import form: any email's attachment can become a drawing revision on a project. *@
                @if (importAttachment is not null)
                {
                    <div class="mt-3 rounded-lg border border-line bg-surface p-3 space-y-3">
                        <p class="text-xs text-content-muted">
                            Save <span class="font-medium text-content">@importAttachment.Name</span> into a project's drawings.
                            The file lands as an <span class="font-medium text-content">unapproved revision</span>.
                        </p>
                        <div class="inline-flex rounded-lg border border-line-strong p-0.5 gap-0.5">
                            <button type="button" @onclick="() => SetImportMode(isRevision: false)"
                                    class="rounded-md text-xs px-2.5 py-1.5 transition @(!importIsRevision ? "bg-accent text-accent-ink font-medium" : "text-content-muted hover:bg-surface-raised")">
                                New drawing
                            </button>
                            <button type="button" @onclick="() => SetImportMode(isRevision: true)"
                                    class="rounded-md text-xs px-2.5 py-1.5 transition @(importIsRevision ? "bg-accent text-accent-ink font-medium" : "text-content-muted hover:bg-surface-raised")">
                                Revision of existing drawing
                            </button>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            <div>
                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Project *</label>
                                <select class="field" value="@importProjectId" @onchange="OnImportProjectChanged">
                                    <option value="">Select a project…</option>
                                    @foreach (var project in ProjectOptions)
                                    {
                                        <option value="@project.ProjectId">@project.Reference — @project.Name</option>
                                    }
                                </select>
                            </div>
                            @if (importIsRevision)
                            {
                                <div>
                                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Existing drawing *</label>
                                    <select class="field" @bind="importDrawingId" disabled="@string.IsNullOrWhiteSpace(importProjectId)">
                                        @if (string.IsNullOrWhiteSpace(importProjectId))
                                        {
                                            <option value="">Select a project first…</option>
                                        }
                                        else if (!DrawingStore.DrawingsLoadedFor(importProjectId))
                                        {
                                            <option value="">Loading drawings…</option>
                                        }
                                        else if (ImportDrawingOptions.Count == 0)
                                        {
                                            <option value="">No drawings on this project yet</option>
                                        }
                                        else
                                        {
                                            <option value="">Select a drawing…</option>
                                            @foreach (var drawing in ImportDrawingOptions)
                                            {
                                                <option value="@drawing.DrawingId">@drawing.DrawingCode — @drawing.Title</option>
                                            }
                                        }
                                    </select>
                                </div>
                            }
                            else
                            {
                                <FormField Label="Drawing code" Value="@importCode" OnChange="v => importCode = v" Required="true" />
                            }
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            @if (!importIsRevision)
                            {
                                <FormField Label="Title" Value="@importTitle" OnChange="v => importTitle = v" />
                            }
                            <FormField Label="Revision label" Value="@importRevision" OnChange="v => importRevision = v" />
                        </div>
                        <div class="flex items-center gap-3">
                            <button type="button" class="btn-primary"
                                    disabled="@(busy || string.IsNullOrWhiteSpace(importProjectId) || (importIsRevision ? string.IsNullOrWhiteSpace(importDrawingId) : string.IsNullOrWhiteSpace(importCode)))"
                                    @onclick="DoImportDrawing">@(busy ? "Saving…" : "Save to drawings")</button>
                            <button type="button" class="text-sm text-content-muted hover:text-content" @onclick="() => importAttachment = null">Cancel</button>
                        </div>
                    </div>
                }
            </div>
        }
        else if (selected is not null && selected.HasAttachments && detail is not null)
        {
            <p class="text-xs text-content-subtle italic">This email has attachments, but their names couldn't be retrieved.</p>
        }

        @*
            Thread panel: the rest of this email's conversation, read live and regardless of tags.
            Later replies often say how the older messages should be triaged (e.g. "ignore my last —
            resolved on site"), so triaging oldest-first still shows the newest context. Click a
            member to open it. Linking or discarding already applies to the whole thread server-side.
        *@
        @if (selected is not null && !string.IsNullOrEmpty(selected.ConversationId))
        {
            @if (threadLoading)
            {
                <p class="text-xs text-content-subtle italic">Checking the thread for replies…</p>
            }
            else if (thread.Count > 1)
            {
                <div class="rounded-lg bg-surface-raised border border-line p-3">
                    <p class="text-xs uppercase tracking-wider text-content-subtle font-semibold mb-2">
                        Thread · @thread.Count emails
                    </p>
                    <div class="space-y-1">
                        @foreach (var member in thread)
                        {
                            var isCurrent = member.Id == selected.Id;
                            var isLatest = member.Id == thread[^1].Id;
                            <button type="button" @key="member.Id" disabled="@isCurrent"
                                    @onclick="() => Select(member, jumpToLatest: false)" class="@ThreadRowClass(isCurrent)">
                                <div class="flex items-center justify-between gap-2">
                                    <span class="text-xs font-medium text-content truncate">@DisplayFrom(member)</span>
                                    <span class="flex items-center gap-1.5 whitespace-nowrap">
                                        @if (member.HasAttachments)
                                        {
                                            <span title="Has attachments" class="inline-flex items-center text-content-subtle">@PaperclipIcon</span>
                                        }
                                        @if (isLatest)
                                        {
                                            <span class="inline-flex items-center rounded-full bg-accent/10 text-accent text-[10px] font-medium px-2 py-0.5">Latest</span>
                                        }
                                        @if (isCurrent)
                                        {
                                            <span class="inline-flex items-center rounded-full border border-accent text-accent text-[10px] font-medium px-2 py-0.5">Viewing</span>
                                        }
                                        else if (member.Categories.Count == 0)
                                        {
                                            <span class="inline-flex items-center rounded-full border border-line text-content-subtle text-[10px] font-medium px-2 py-0.5">In queue</span>
                                        }
                                        @foreach (var tag in member.Categories)
                                        {
                                            <span class="inline-flex items-center rounded-full bg-accent/10 text-accent text-[10px] font-medium px-2 py-0.5">@TagLabel(tag)</span>
                                        }
                                    </span>
                                </div>
                                <p class="text-xs text-content-muted truncate mt-0.5">@Dash(member.BodyPreview)</p>
                                <p class="text-[11px] text-content-subtle mt-0.5">@Date(member.ReceivedAt)</p>
                            </button>
                        }
                    </div>
                    <p class="text-[11px] text-content-subtle mt-2">
                        Read the latest reply before triaging the oldest — linking or discarding any email here applies to the whole thread.
                    </p>
                </div>
            }
        }

    </text>;
}

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (!CanTriage)
{
    <section class="px-6 md:px-8 py-12">
        <div class="panel p-8 text-center">
            <p class="text-sm text-content">You don't have access to mailbox triage.</p>
            <p class="text-xs text-content-subtle mt-1">Triage is available to administrators and project managers.</p>
        </div>
    </section>
}
else
{
    <section class="px-6 md:px-8 py-8 md:py-12">
        <header class="mb-6">
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · projects@@jewelbb.co.uk</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Mailbox triage</h1>
            @if (view == QueueView.Active)
            {
                <p class="text-sm text-content-muted mt-2">
                    @total email@(total == 1 ? "" : "s") in the inbox waiting to be assigned to a request.
                </p>
            }
            else if (view == QueueView.Discarded)
            {
                <p class="text-sm text-content-muted mt-2">
                    @discardedTotal discarded email@(discardedTotal == 1 ? "" : "s") — restore one to put it back in the queue.
                </p>
            }
            else
            {
                <p class="text-sm text-content-muted mt-2">
                    @taggedTotal tagged email@(taggedTotal == 1 ? "" : "s") — add or remove tags to manage which processes use them.
                </p>
            }
        </header>

        <div class="flex gap-2 mb-6 border-b border-line">
            <button type="button" class="@ViewTabClass(QueueView.Active)" @onclick="() => SwitchView(QueueView.Active)">Queue</button>
            <button type="button" class="@ViewTabClass(QueueView.Tagged)" @onclick="() => SwitchView(QueueView.Tagged)">Tagged</button>
        </div>

        @if (loadError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4">@loadError</p>
        }

        @if (view == QueueView.Active)
        {
        @if (unassigned.Count > 0)
        {
            <div class="panel p-5 mb-6 border-amber-500/40">
                <div class="flex items-start gap-2 mb-1">
                    <h2 class="text-sm font-semibold text-amber-700">Unassigned requests</h2>
                    <span class="inline-flex items-center rounded-full bg-amber-500/10 px-2 py-0.5 text-[11px] font-medium text-amber-600">@unassigned.Count</span>
                </div>
                <p class="text-xs text-content-subtle mb-3">
                    These requests aren't tied to a live project, so they don't appear in any register. Return one to triage to process its emails again and pick the right project.
                </p>
                @if (unassignedError is not null)
                {
                    <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@unassignedError</p>
                }
                <div class="space-y-2">
                    @foreach (var request in unassigned)
                    {
                        <div @key="request.RequestId" class="flex items-center justify-between gap-3 rounded-lg border border-line px-3 py-2">
                            <div class="min-w-0">
                                <p class="text-sm text-content truncate">
                                    <span class="font-mono text-xs text-content-muted mr-2">@Dash(request.Reference)</span>@Dash(request.Title)
                                </p>
                                <p class="text-[11px] text-content-subtle mt-0.5">Issued @Date(request.IssuedAt ?? request.RaisedAt) · @Dash(request.RaisedByEmail)</p>
                            </div>
                            <button type="button" class="btn-secondary text-xs whitespace-nowrap"
                                    disabled="@busy" @onclick="() => ReturnUnassigned(request)">
                                Return to triage
                            </button>
                        </div>
                    }
                </div>
            </div>
        }

        @if (listLoading && items.Count == 0)
        {
            <JewelSpinner Class="py-16" Label="Loading" />
        }
        else if (total == 0)
        {
            <div class="panel p-8 text-center">
                <p class="text-sm text-content">Nothing in the queue.</p>
                <p class="text-xs text-content-subtle mt-1">Every email in the requests mailbox has been dealt with.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
                <div class="relative space-y-2 lg:col-span-1">
                    @if (listLoading)
                    {
                        <JewelSpinner Overlay="true" Label="Loading" />
                    }
                    @foreach (var item in items)
                    {
                        <button type="button" @key="item.Id" @onclick="() => Select(item)"
                                class="@RowClass(item)">
                            <div class="flex items-center justify-between gap-2">
                                <span class="text-sm font-medium text-content truncate">@DisplayFrom(item)</span>
                            </div>
                            <p class="text-sm text-content-muted truncate mt-0.5">@Dash(item.Subject)</p>
                            <div class="flex items-center gap-2 mt-1 text-[11px] text-content-subtle">
                                <span>@Date(item.ReceivedAt)</span>
                                @if (item.HasAttachments)
                                {
                                    <span title="Has attachments" class="inline-flex items-center">@PaperclipIcon</span>
                                }
                            </div>
                        </button>
                    }

                    @if (QueuePageCount > 1)
                    {
                        <div class="flex items-center justify-between gap-2 pt-2">
                            @if (queueIndex > 0)
                            {
                                <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" @onclick="PreviousPage">Previous</button>
                            }
                            else
                            {
                                <span></span>
                            }
                            <span class="text-[11px] text-content-subtle">Page @(queueIndex + 1) / @QueuePageCount</span>
                            @if (queueNext is not null)
                            {
                                <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" @onclick="NextPage">Next</button>
                            }
                            else
                            {
                                <span></span>
                            }
                        </div>
                    }
                </div>

                <div class="lg:col-span-2">
                    @if (selected is null)
                    {
                        @if (replyOutcome is { } outcome)
                        {
                            <div class="panel p-5 mb-4 border-accent/40 space-y-2">
                                <div class="flex items-center justify-between gap-2">
                                    <p class="text-xs uppercase tracking-wider text-accent font-semibold">Reply draft staged</p>
                                    <button type="button" class="text-content-subtle hover:text-content text-xs" title="Dismiss"
                                            @onclick="() => replyOutcome = null">✕</button>
                                </div>
                                <p class="text-sm text-content">
                                    <span class="font-mono text-xs text-content-muted mr-1">@outcome.Request.Reference</span>
                                    was created from the email, and your reply is waiting as a draft in the projects mailbox
                                    (to @(string.Join("; ", outcome.Draft.Recipients))) — review and send it from Outlook.
                                </p>
                                @if (!string.IsNullOrWhiteSpace(outcome.Draft.WebLink))
                                {
                                    <a class="text-accent underline text-sm" href="@outcome.Draft.WebLink" target="_blank" rel="noopener">Open the draft in Outlook</a>
                                }
                            </div>
                        }
                        <div class="panel p-8 text-center text-sm text-content-subtle">
                            Select an email to triage it.
                        </div>
                    }
                    else
                    {
                        <div class="panel p-5 space-y-4 relative">
                            @if (busy)
                            {
                                <JewelSpinner Overlay="true" Label="@busyLabel" />
                            }
                            @if (actionError is not null)
                            {
                                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@actionError</p>
                            }

                            <div>
                                <h2 class="text-lg font-semibold text-content">@Dash(selected.Subject)</h2>
                                <p class="text-sm text-content-muted mt-1">
                                    From @DisplayFrom(selected) · @Date(selected.ReceivedAt)
                                </p>
                            </div>

                            @MessageBody

                            @*
                                AI-assisted triage: Claude reads the whole thread server-side and suggests the
                                next action. Advisory only — "Set this up" just pre-fills the normal link/create/
                                discard controls below; nothing is actioned until the triager submits as usual.
                            *@
                            <div class="pt-3 border-t border-line">
                                @if (recommendLoading)
                                {
                                    <p class="text-xs text-content-subtle italic">Reading the thread and suggesting an action…</p>
                                }
                                else if (recommendation is null)
                                {
                                    <button type="button" class="btn-secondary text-xs" disabled="@busy" @onclick="DoRecommend">
                                        ✦ Suggest an action
                                    </button>
                                    @if (recommendError is not null)
                                    {
                                        <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-xs text-negative mt-2">@recommendError</p>
                                    }
                                }
                                else
                                {
                                    <div class="rounded-lg border border-accent/40 bg-accent/5 p-4 space-y-3">
                                        <div class="flex items-center justify-between gap-2">
                                            <p class="text-xs uppercase tracking-wider text-accent font-semibold">✦ Suggested action</p>
                                            <button type="button" class="text-content-subtle hover:text-content text-xs" title="Dismiss suggestion"
                                                    @onclick="() => recommendation = null">✕</button>
                                        </div>

                                        <div class="flex flex-wrap items-center gap-2">
                                            <span class="inline-flex items-center rounded-full bg-accent/10 text-accent text-xs font-medium px-2.5 py-1">
                                                @RecommendationActionLabel(recommendation.RecommendedAction)
                                            </span>
                                            @if (RecommendedProject is { } suggestedProject)
                                            {
                                                <span class="inline-flex items-center rounded-full border border-line text-content-muted text-xs px-2.5 py-1">
                                                    @suggestedProject.Reference — @suggestedProject.Name
                                                </span>
                                            }
                                            @if (recommendation.Urgency == "high")
                                            {
                                                <span class="inline-flex items-center rounded-full bg-negative/10 text-negative text-xs font-medium px-2.5 py-1">High urgency</span>
                                            }
                                            <span class="text-[11px] text-content-subtle">@recommendation.Confidence confidence</span>
                                        </div>

                                        <p class="text-sm text-content">@recommendation.Summary</p>

                                        @if (recommendation.KeyDates.Count > 0)
                                        {
                                            <ul class="space-y-0.5">
                                                @foreach (var keyDate in recommendation.KeyDates)
                                                {
                                                    <li class="text-xs text-content-muted"><span class="font-medium text-content">@keyDate.Date</span> — @keyDate.Meaning</li>
                                                }
                                            </ul>
                                        }

                                        @if (recommendation.RecommendedAction == "create_todos" && recommendation.TodoItems.Count > 0)
                                        {
                                            <ul class="list-disc pl-4 space-y-0.5">
                                                @foreach (var todoTitle in recommendation.TodoItems)
                                                {
                                                    <li class="text-xs text-content-muted">@todoTitle</li>
                                                }
                                            </ul>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(recommendation.Reasoning))
                                        {
                                            <p class="text-xs text-content-subtle">@recommendation.Reasoning</p>
                                        }

                                        @if (recommendation.SecondaryActions.Count > 0)
                                        {
                                            <p class="text-xs text-content-subtle">
                                                Also consider: @string.Join(", ", recommendation.SecondaryActions.Select(RecommendationActionLabel)).
                                            </p>
                                        }

                                        @if (recommendation.RecommendedAction != "none")
                                        {
                                            <button type="button" class="btn-primary text-xs" disabled="@busy" @onclick="ApplyRecommendation">
                                                Set this up below
                                            </button>
                                        }
                                    </div>
                                }
                            </div>

                            <div class="pt-3 border-t border-line">
                                <div class="flex flex-wrap gap-2 mb-4">
                                    <button type="button" class="@ModeTabClass(TriageMode.Link)" @onclick="() => SetMode(TriageMode.Link)">Link to existing</button>
                                    <button type="button" class="@ModeTabClass(TriageMode.Create)" @onclick="() => SetMode(TriageMode.Create)">Create new</button>
                                    <button type="button" class="@ModeTabClass(TriageMode.GeneralTodo)" @onclick="() => SetMode(TriageMode.GeneralTodo)">General to-do</button>
                                    <button type="button" class="@ModeTabClass(TriageMode.Reply)" @onclick="() => SetMode(TriageMode.Reply)">Reply in thread</button>
                                    <button type="button" class="@ModeTabClass(TriageMode.Discard)" @onclick="() => SetMode(TriageMode.Discard)">Discard</button>
                                </div>

                                @if (mode == TriageMode.Link)
                                {
                                    <div class="space-y-3">
                                        <div>
                                            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Record type</label>
                                            <select class="field" value="@((int)linkRecordType)" @onchange="OnLinkRecordTypeChanged">
                                                @foreach (var recordType in RecordTypeOptions)
                                                {
                                                    <option value="@((int)recordType)">@RecordTypeLabel(recordType)</option>
                                                }
                                            </select>
                                        </div>

                                        <div>
                                            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Project</label>
                                            <select class="field" value="@linkProjectId" @onchange="OnLinkProjectChanged">
                                                <option value="">Select a project…</option>
                                                @foreach (var project in ProjectOptions)
                                                {
                                                    <option value="@project.ProjectId">@project.Reference — @project.Name</option>
                                                }
                                            </select>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(linkProjectId))
                                        {
                                            if (linkRecordsLoading)
                                            {
                                                <p class="text-sm text-content-subtle italic">Loading @(RecordTypeLabelPlural(linkRecordType))…</p>
                                            }
                                            else
                                            {
                                                var candidates = DuplicateCandidates();
                                                var others = ProjectRecords().Except(candidates).ToList();

                                                @if (candidates.Count > 0)
                                                {
                                                    <div>
                                                        <p class="text-xs font-semibold text-amber-600 mb-1">Possible matches for this email</p>
                                                        <div class="space-y-1">
                                                            @foreach (var record in candidates)
                                                            {
                                                                <button type="button" @onclick="() => linkRecordId = record.RecordId" class="@RecordPickClass(record, true)">
                                                                    <span class="flex items-center gap-2">
                                                                        <span class="font-mono text-xs text-content-muted">@record.Reference</span>
                                                                        @if (!string.IsNullOrWhiteSpace(record.StatusLabel))
                                                                        {
                                                                            <span class="text-[10px] uppercase tracking-wider text-content-subtle">@record.StatusLabel</span>
                                                                        }
                                                                    </span>
                                                                    <span class="text-sm text-content">@record.Title</span>
                                                                    @if (!string.IsNullOrWhiteSpace(record.Summary))
                                                                    {
                                                                        <span class="text-xs text-content-subtle line-clamp-2">@record.Summary</span>
                                                                    }
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                }

                                                @if (others.Count > 0)
                                                {
                                                    <div>
                                                        <p class="text-xs font-semibold text-content-subtle mb-1">Other @(RecordTypeLabelPlural(linkRecordType)) on this project</p>
                                                        <div class="space-y-1 max-h-56 overflow-y-auto">
                                                            @foreach (var record in others)
                                                            {
                                                                <button type="button" @onclick="() => linkRecordId = record.RecordId" class="@RecordPickClass(record, false)">
                                                                    <span class="flex items-center gap-2">
                                                                        <span class="font-mono text-xs text-content-muted">@record.Reference</span>
                                                                        @if (!string.IsNullOrWhiteSpace(record.StatusLabel))
                                                                        {
                                                                            <span class="text-[10px] uppercase tracking-wider text-content-subtle">@record.StatusLabel</span>
                                                                        }
                                                                    </span>
                                                                    <span class="text-sm text-content">@record.Title</span>
                                                                    @if (!string.IsNullOrWhiteSpace(record.Summary))
                                                                    {
                                                                        <span class="text-xs text-content-subtle line-clamp-2">@record.Summary</span>
                                                                    }
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                }

                                                @if (candidates.Count == 0 && others.Count == 0)
                                                {
                                                    <p class="text-sm text-content-subtle italic">No @(RecordTypeLabelPlural(linkRecordType)) on this project yet.</p>
                                                }
                                            }
                                        }

                                        <button type="button" class="btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(linkRecordId))" @onclick="DoLink">
                                            Link email to selected record
                                        </button>
                                    </div>
                                }
                                else if (mode == TriageMode.Create)
                                {
                                    <div class="space-y-4">
                                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Record type *</label>
                                                <select class="field" value="@((int)createRecordType)" @onchange="OnCreateRecordTypeChanged">
                                                    @foreach (var recordType in CreateRecordTypeOptions)
                                                    {
                                                        <option value="@((int)recordType)">@RecordTypeLabel(recordType)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Project *</label>
                                                <select class="field" value="@createProjectId" @onchange="OnCreateProjectChanged">
                                                    <option value="">Select a project…</option>
                                                    @foreach (var project in ProjectOptions)
                                                    {
                                                        <option value="@project.ProjectId">@project.Reference — @project.Name</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>

                                        @if (createRecordType == RecordType.Request)
                                        {
                                            <p class="rounded-lg bg-surface-raised border border-line px-3 py-2 text-xs text-content-subtle">
                                                Created as a <span class="font-medium text-content">General</span> request and auto-numbered REQ-####. Promote it to an official RFI from the request page.
                                            </p>

                                            <FormField Label="Raised to" Value="@createRaisedTo" OnChange="v => createRaisedTo = v" />

                                            <FormField Label="Subject" Value="@createTitle" OnChange="v => createTitle = v" Required="true" />

                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Detail</label>
                                                <textarea class="field" rows="4" value="@createDescription" @oninput="OnCreateDescriptionInput"></textarea>
                                            </div>

                                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                <FormField Label="Drawing / detail ref" Value="@createDrawingRef" OnChange="v => createDrawingRef = v" />
                                                <FormField Label="Response due" Value="@createResponseDue" OnChange="v => createResponseDue = v" InputType="date" />
                                            </div>

                                            <label class="flex items-start gap-2 cursor-pointer">
                                                <input type="checkbox" class="mt-0.5" @bind="createAddToProgramme" />
                                                <span class="text-sm text-content">
                                                    Also add to Programme
                                                    <span class="block text-xs text-content-subtle">The email (and its thread) is also tagged to the project's <span class="font-medium">programme communications</span>, so it appears under the Programme tab as well as on the new request.</span>
                                                </span>
                                            </label>

                                            <button type="button" class="btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(createProjectId))" @onclick="DoCreate">Create request from email</button>
                                        }
                                        else if (createRecordType == RecordType.BidPackageInvite)
                                        {
                                            <FormField Label="Title" Value="@createTitle" OnChange="v => createTitle = v" Required="true" />
                                            <FormField Label="Trade" Value="@createTrade" OnChange="v => createTrade = v" />

                                            <p class="text-xs text-content-subtle">A draft bid package is created and this email is linked to it. Invite subcontractors and add line items from the bid package page.</p>

                                            <button type="button" class="btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(createProjectId) || string.IsNullOrWhiteSpace(createTitle))" @onclick="DoCreateBidPackage">Create bid package from email</button>
                                        }
                                        else if (createRecordType == RecordType.Scheduling)
                                        {
                                            <p class="rounded-lg bg-surface-raised border border-line px-3 py-2 text-xs text-content-subtle">
                                                This email (and its whole thread) is tagged to the project's <span class="font-medium text-content">programme communications</span> and appears under the project's Programme tab. You can add further tags later from the Tagged view — the same email can also feed a request or bid package.
                                            </p>

                                            <button type="button" class="btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(createProjectId))" @onclick="DoTagScheduling">Tag email to programme</button>
                                        }
                                        else if (createRecordType == RecordType.Todo)
                                        {
                                            <p class="rounded-lg bg-surface-raised border border-line px-3 py-2 text-xs text-content-subtle">
                                                Each item is numbered TODO-#### and this email is tagged to <span class="font-medium text-content">every item</span> you add here, so one email can feed several to-dos. The items appear on the project's To-do tab.
                                            </p>

                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Link to an open request (optional)</label>
                                                @if (string.IsNullOrWhiteSpace(createProjectId))
                                                {
                                                    <p class="text-xs text-content-subtle italic">Choose a project to see its open requests.</p>
                                                }
                                                else if (createTodoLinkRequestsLoading)
                                                {
                                                    <p class="text-sm text-content-subtle italic">Loading requests…</p>
                                                }
                                                else if (createTodoLinkRequests.Count == 0)
                                                {
                                                    <p class="text-xs text-content-subtle italic">No open requests on this project.</p>
                                                }
                                                else
                                                {
                                                    <select class="field" value="@createTodoLinkRequestId" @onchange="OnCreateTodoLinkRequestChanged">
                                                        <option value="">No request link</option>
                                                        @foreach (var record in createTodoLinkRequests)
                                                        {
                                                            <option value="@record.RecordId">@record.Reference — @record.Title</option>
                                                        }
                                                    </select>
                                                    @if (!string.IsNullOrWhiteSpace(createTodoLinkRequestId))
                                                    {
                                                        <p class="text-xs text-content-subtle mt-1">
                                                            This email is tagged to the request as well as to every item below, so it appears in the request's conversation too — exactly as if you'd also used "Link to existing".
                                                        </p>
                                                    }
                                                }
                                            </div>

                                            @for (var i = 0; i < createTodoRows.Count; i++)
                                            {
                                                var row = createTodoRows[i];
                                                var rowNumber = i + 1;
                                                <div @key="row" class="rounded-lg border border-line p-3 space-y-3">
                                                    <div class="flex items-center justify-between">
                                                        <p class="text-xs uppercase tracking-wider text-content-subtle font-semibold">Item @rowNumber</p>
                                                        @if (createTodoRows.Count > 1)
                                                        {
                                                            <button type="button" class="text-xs text-content-subtle hover:text-negative" @onclick="() => RemoveTodoRow(row)">Remove</button>
                                                        }
                                                    </div>

                                                    <FormField Label="Title" Value="@row.Title" OnChange="v => row.Title = v" Required="true" />

                                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                        <div>
                                                            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Assigned role</label>
                                                            <SearchSelect Options="@todoAssigneeOptions" Value="@row.AssigneeRole" ValueChanged="v => row.AssigneeRole = v"
                                                                          Placeholder="Unassigned" WidthClass="w-full" />
                                                        </div>
                                                        <FormField Label="Due" Value="@row.Due" OnChange="v => row.Due = v" InputType="date" />
                                                    </div>

                                                    <div>
                                                        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Detail</label>
                                                        <textarea class="field" rows="6" value="@row.Notes" @oninput="e => OnTodoNotesInput(row, e)"></textarea>
                                                    </div>
                                                </div>
                                            }

                                            <button type="button" class="btn-secondary text-xs" @onclick="AddTodoRow">+ Add another item</button>

                                            <button type="button" class="btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(createProjectId) || !createTodoRows.Any(r => !string.IsNullOrWhiteSpace(r.Title)))" @onclick="DoCreateTodos">
                                                Create @(TodoRowCountLabel) from email
                                            </button>
                                        }
                                    </div>
                                }
                                else if (mode == TriageMode.GeneralTodo)
                                {
                                    @* Company-wide emails that don't belong to any project: capture them straight onto
                                       the GENERAL to-do list. Same row editor as "Create new → To-do item", but no
                                       project is chosen — items are created with no project and live on the To-dos
                                       browser page (and the dashboards of everyone holding the assigned role). *@
                                    <div class="space-y-4">
                                        <p class="rounded-lg bg-surface-raised border border-line px-3 py-2 text-xs text-content-subtle">
                                            For <span class="font-medium text-content">company-wide</span> emails that don't belong to a project. Each item is numbered TODO-#### and this email is tagged to <span class="font-medium text-content">every item</span> you add here. The items appear on the To-dos page and on the dashboard of everyone holding the assigned role — not on any project.
                                        </p>

                                        @for (var i = 0; i < createTodoRows.Count; i++)
                                        {
                                            var row = createTodoRows[i];
                                            var rowNumber = i + 1;
                                            <div @key="row" class="rounded-lg border border-line p-3 space-y-3">
                                                <div class="flex items-center justify-between">
                                                    <p class="text-xs uppercase tracking-wider text-content-subtle font-semibold">Item @rowNumber</p>
                                                    @if (createTodoRows.Count > 1)
                                                    {
                                                        <button type="button" class="text-xs text-content-subtle hover:text-negative" @onclick="() => RemoveTodoRow(row)">Remove</button>
                                                    }
                                                </div>

                                                <FormField Label="Title" Value="@row.Title" OnChange="v => row.Title = v" Required="true" />

                                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                    <div>
                                                        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Assigned role</label>
                                                        <SearchSelect Options="@todoAssigneeOptions" Value="@row.AssigneeRole" ValueChanged="v => row.AssigneeRole = v"
                                                                      Placeholder="Unassigned" WidthClass="w-full" />
                                                    </div>
                                                    <FormField Label="Due" Value="@row.Due" OnChange="v => row.Due = v" InputType="date" />
                                                </div>

                                                <div>
                                                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Detail</label>
                                                    <textarea class="field" rows="6" value="@row.Notes" @oninput="e => OnTodoNotesInput(row, e)"></textarea>
                                                </div>
                                            </div>
                                        }

                                        <button type="button" class="btn-secondary text-xs" @onclick="AddTodoRow">+ Add another item</button>

                                        <button type="button" class="btn-primary" disabled="@(busy || !createTodoRows.Any(r => !string.IsNullOrWhiteSpace(r.Title)))" @onclick="DoCreateGeneralTodos">
                                            Create @(TodoRowCountLabel) from email
                                        </button>
                                    </div>
                                }
                                else if (mode == TriageMode.Reply)
                                {
                                    <div class="space-y-3">
                                        <p class="rounded-lg bg-surface-raised border border-line px-3 py-2 text-xs text-content-subtle">
                                            Write your reply here. It's staged as a draft in the <span class="font-medium text-content">projects mailbox</span> with the whole thread quoted behind it — review and send it from Outlook. In the background a <span class="font-medium text-content">General</span> request (auto-numbered REQ-####) is created on the chosen project carrying the same reply as its description, so replying triages the thread. Nothing is sent from here.
                                        </p>

                                        <div>
                                            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Project *</label>
                                            <select class="field" value="@replyProjectId" @onchange="OnReplyProjectChanged">
                                                <option value="">Select a project…</option>
                                                @foreach (var project in ProjectOptions)
                                                {
                                                    <option value="@project.ProjectId">@project.Reference — @project.Name</option>
                                                }
                                            </select>
                                        </div>

                                        <div>
                                            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Your reply *</label>
                                            <textarea class="field" rows="6" placeholder="Write the reply that will go above the quoted thread…"
                                                      value="@replyBody" @oninput="OnReplyBodyInput"></textarea>
                                        </div>

                                        <button type="button" class="btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(replyProjectId) || string.IsNullOrWhiteSpace(replyBody))" @onclick="DoReplyInThread">
                                            Create reply draft and request
                                        </button>
                                    </div>
                                }
                                else if (mode == TriageMode.Discard)
                                {
                                    <div class="space-y-3">
                                        <p class="text-sm text-content-muted">Discard this email if it isn’t a request (spam, an auto-reply, or sent to the wrong place). This adds a “discarded” category tag to it — the email stays put in the mailbox — and removes it from the queue. You can restore it from the Discarded tab.</p>
                                        <button type="button" class="btn-secondary border-negative/40 text-negative hover:border-negative" disabled="@busy" @onclick="DoDiscard">Discard email</button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        }
        else if (view == QueueView.Discarded)
        {
            @if (listLoading && discardedItems.Count == 0)
            {
                <JewelSpinner Class="py-16" Label="Loading" />
            }
            else if (discardedTotal == 0)
            {
                <div class="panel p-8 text-center">
                    <p class="text-sm text-content">No discarded emails.</p>
                    <p class="text-xs text-content-subtle mt-1">Emails you discard from the queue show up here, and can be restored.</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
                    <div class="relative space-y-2 lg:col-span-1">
                        @if (listLoading)
                        {
                            <JewelSpinner Overlay="true" Label="Loading" />
                        }
                        @foreach (var item in discardedItems)
                        {
                            <button type="button" @key="item.Id" @onclick="() => Select(item)" class="@RowClass(item)">
                                <div class="flex items-center justify-between gap-2">
                                    <span class="text-sm font-medium text-content truncate">@DisplayFrom(item)</span>
                                </div>
                                <p class="text-sm text-content-muted truncate mt-0.5">@Dash(item.Subject)</p>
                                <div class="flex items-center gap-2 mt-1 text-[11px] text-content-subtle">
                                    <span>@Date(item.ReceivedAt)</span>
                                    @if (item.HasAttachments)
                                    {
                                        <span title="Has attachments" class="inline-flex items-center">@PaperclipIcon</span>
                                    }
                                </div>
                            </button>
                        }

                        @if (DiscardedPageCount > 1)
                        {
                            <div class="flex items-center justify-between gap-2 pt-2">
                                @if (discardedIndex > 0)
                                {
                                    <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" @onclick="PreviousDiscarded">Previous</button>
                                }
                                else
                                {
                                    <span></span>
                                }
                                <span class="text-[11px] text-content-subtle">Page @(discardedIndex + 1) / @DiscardedPageCount</span>
                                @if (discardedNext is not null)
                                {
                                    <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" @onclick="NextDiscarded">Next</button>
                                }
                                else
                                {
                                    <span></span>
                                }
                            </div>
                        }
                    </div>

                    <div class="lg:col-span-2">
                        @if (selected is null)
                        {
                            <div class="panel p-8 text-center text-sm text-content-subtle">
                                Select a discarded email to view it.
                            </div>
                        }
                        else
                        {
                            <div class="panel p-5 space-y-4 relative">
                                @if (busy)
                                {
                                    <JewelSpinner Overlay="true" Label="@busyLabel" />
                                }
                                @if (actionError is not null)
                                {
                                    <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@actionError</p>
                                }

                                <div>
                                    <h2 class="text-lg font-semibold text-content">@Dash(selected.Subject)</h2>
                                    <p class="text-sm text-content-muted mt-1">
                                        From @DisplayFrom(selected) · @Date(selected.ReceivedAt)
                                    </p>
                                </div>

                                @MessageBody

                                <div class="pt-3 border-t border-line">
                                    <p class="text-sm text-content-muted mb-3">
                                        This email was discarded. Restore it to remove the “discarded” tag and put it back in the triage queue.
                                    </p>
                                    <button type="button" class="btn-primary" disabled="@busy" @onclick="DoRestore">Restore to triage</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="flex flex-wrap items-center gap-2 mb-5">
                <span class="text-xs uppercase tracking-wider text-content-subtle font-semibold mr-1">Filter</span>
                <div class="relative">
                    <button type="button"
                            class="rounded-full border border-line px-3 py-1 text-xs font-medium text-content-muted hover:text-content hover:border-line-strong transition inline-flex items-center gap-1.5"
                            @onclick="ToggleFilterMenu">
                        @FilterButtonLabel
                        <span class="text-[9px] leading-none">▾</span>
                    </button>
                    @if (filterOpen)
                    {
                        <div class="absolute z-20 mt-1 w-60 max-h-72 overflow-y-auto rounded-lg border border-line bg-surface-raised shadow-lg p-1">
                            <button type="button"
                                    class="w-full text-left rounded px-3 py-1.5 text-sm text-content-muted hover:bg-surface hover:text-content"
                                    @onclick="ClearTagFilters">
                                All tags
                            </button>
                            <div class="my-1 border-t border-line"></div>
                            @foreach (var tag in knownTags)
                            {
                                <label class="flex items-center gap-2 rounded px-3 py-1.5 text-sm text-content hover:bg-surface cursor-pointer">
                                    <input type="checkbox" checked="@selectedTags.Contains(tag)" @onchange="() => ToggleTag(tag)" />
                                    <span>@TagLabel(tag)</span>
                                </label>
                            }
                        </div>
                    }
                </div>
                @foreach (var tag in selectedTags)
                {
                    <span class="inline-flex items-center gap-1.5 rounded-full border border-accent bg-surface-raised px-2.5 py-1 text-xs text-content">
                        @TagLabel(tag)
                        <button type="button" class="text-content-subtle hover:text-negative" @onclick="() => ToggleTag(tag)" title="Remove filter">✕</button>
                    </span>
                }
            </div>

            @if (listLoading && taggedItems.Count == 0)
            {
                <JewelSpinner Class="py-16" Label="Loading" />
            }
            else if (taggedTotal == 0)
            {
                <div class="panel p-8 text-center">
                    <p class="text-sm text-content">@(selectedTags.Count == 0 ? "No tagged emails." : "No emails with the selected tags.")</p>
                    <p class="text-xs text-content-subtle mt-1">Emails linked to a request (or discarded) appear here. Open one to add it to another request or remove a tag.</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
                    <div class="relative space-y-2 lg:col-span-1">
                        @if (listLoading)
                        {
                            <JewelSpinner Overlay="true" Label="Loading" />
                        }
                        @foreach (var item in taggedItems)
                        {
                            <button type="button" @key="item.Id" @onclick="() => Select(item)" class="@RowClass(item)">
                                <div class="flex items-center justify-between gap-2">
                                    <span class="text-sm font-medium text-content truncate">@DisplayFrom(item)</span>
                                </div>
