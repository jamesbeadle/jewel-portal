    private void OnCreateTodoLinkRequestChanged(ChangeEventArgs e) => createTodoLinkRequestId = e.Value?.ToString() ?? "";

    // Load the chosen project's open requests for the To-do form's optional request link. A failed
    // load leaves the picker empty rather than blocking triage — the to-dos can still be created,
    // the email just isn't linked to a request. Any change of project or record type clears the
    // current pick: a request selected against one project must never survive into another.
    private async Task LoadCreateTodoLinkRequestsAsync()
    {
        createTodoLinkRequestId = "";
        if (mode != TriageMode.GeneralTodo || string.IsNullOrWhiteSpace(createProjectId))
        {
            createTodoLinkRequests = Array.Empty<LinkableRecord>();
            return;
        }
        try
        {
            createTodoLinkRequestsLoading = true;
            StateHasChanged(); // show the loading state while the fetch is in flight
            createTodoLinkRequests = await Intake.ListLinkableRecordsAsync(createProjectId, RecordType.Request);
        }
        catch
        {
            createTodoLinkRequests = Array.Empty<LinkableRecord>();
        }
        finally
        {
            createTodoLinkRequestsLoading = false;
        }
    }

    private void OnCreateDescriptionInput(ChangeEventArgs e) => createDescription = e.Value?.ToString() ?? "";

    // Toggle a record in the queue panel's multi-pick — clicking a picked record unpicks it.
    private void ToggleLinkRecord(string recordId)
    {
        if (!linkRecordIds.Add(recordId)) linkRecordIds.Remove(recordId);
    }

    // Link the email to EVERY picked record — one LinkMessageToRecord per pick, applied sequentially
    // (each tags the whole conversation, verified server-side; the mailbox message never moves, so
    // the same message id keeps working for the second and later tags). Not routed through RunAction
    // because partial failure needs its own handling: once the first tag sticks the email has left
    // the queue, so the queue must refresh regardless, and any picks that didn't take are reported
    // via linkNote with a pointer to the Tagged view, where "add another tag" finishes the job.
    private async Task DoLink() => await DoLinkCore(allowCrossPathway: false);

    // "File under both anyway": retry just the picks the server asked to confirm, consenting to the
    // Subcontractor↔Internal dual filing (the lane, never the wall — see crossFileMessage).
    private async Task DoLinkConfirmCross() => await DoLinkCore(allowCrossPathway: true);

    private async Task DoLinkCore(bool allowCrossPathway)
    {
        if (selected is null || busy) return;
        var picks = allowCrossPathway
            ? crossFilePicks.ToList()
            : linkRecords.Where(r => linkRecordIds.Contains(r.RecordId)).ToList();
        if (picks.Count == 0) return;

        actionError = null;
        linkNote = null;
        crossFileMessage = null;
        busyLabel = "Linking";
        busy = true;
        var succeeded = new List<LinkableRecord>();
        var failed = new List<LinkableRecord>();
        var needsConfirm = new List<LinkableRecord>();
        string? confirmMessage = null;
        string? firstFailure = null;
        try
        {
            foreach (var record in picks)
            {
                try
                {
                    // The type to link as is the picked RECORD's own type, not the dropdown's: the
                    // Scheduling picker lists the bucket alongside the programme's claims documents
                    // (NOD/EOT requests, LADs claims), and each of those must link through its owning
                    // provider so the tag stem resolves correctly. Cost-centre links carry the
                    // triager's pathway choice — the record type alone can't say which side of the
                    // wall a cost centre's mail belongs to.
                    await Intake.LinkMessageToRecordAsync(
                        selected.Id, selected.InternetMessageId, record.Type, record.RecordId,
                        pathway: CostCentrePathwayFor(record),
                        allowCrossPathway: allowCrossPathway);
                    succeeded.Add(record);
                }
                catch (CommandFailedException ex) when (!allowCrossPathway && IsCrossFilePrompt(ex.Message))
                {
                    // The lane, not the wall: the server wants explicit consent to file the thread
                    // under both non-client pathways. Held back for the inline confirm button.
                    needsConfirm.Add(record);
                    confirmMessage ??= ex.Message;
                }
                catch (CommandFailedException ex)
                {
                    failed.Add(record);
                    firstFailure ??= ex.Message;
                }
                catch
                {
                    failed.Add(record);
                    firstFailure ??= "That action didn't complete. Please try again.";
                }
            }

            if (succeeded.Count == 0)
            {
                // Nothing stuck — the email is still in the queue, so keep the selection and the
                // picks. Confirmable rejections surface as the inline confirm; anything else shows
                // the first error in place, exactly like a single-link failure.
                if (needsConfirm.Count > 0)
                {
                    crossFilePicks.Clear();
                    crossFilePicks.AddRange(needsConfirm);
                    crossFileMessage = confirmMessage;
                }
                actionError = firstFailure;
                return;
            }

            var unfinished = failed.Concat(needsConfirm).ToList();
            if (unfinished.Count > 0)
            {
                linkNote = $"The email was linked to {References(succeeded)}, but couldn't be linked to {References(unfinished)}. "
                    + "It has left the queue — open it on the Tagged tab and use “add another tag” to finish.";
            }

            // At least one tag stuck, so the email (thread) has left the Inbox queue: refresh and
            // clear the selection, mirroring RunAction's success path.
            ResetQueuePaging();
            await LoadAsync();
            selected = null;
            detail = null;
            detailLoading = false;
            mode = TriageMode.None;
        }
        finally { busy = false; }
    }

    private static string References(IReadOnlyList<LinkableRecord> records) =>
        string.Join(", ", records.Select(r => r.Reference));

    // The pathway label sent with a link command. Only pathway-neutral COST-CENTRE links carry one —
    // the record type implies the pathway everywhere else, and a Todo link must stay neutral (sending
    // a pathway with it would file the thread, which a to-do never does). On the queue it is the
    // triager's selection; on the Tagged tab it is the thread's own side. Internal never applies —
    // cost-centre mail is valuation-side (Client) or subcontract-side (Subcontractor) only.
    private string? CostCentrePathwayFor(LinkableRecord record)
    {
        if (record.Type != RecordType.CostCentre) return null;
        var side = view == QueueView.Tagged ? FixedPathway : pathway;
        return side is TriagePathway.Client or TriagePathway.Subcontractor ? PathwayLabel(side.Value) : null;
    }

    private async Task DoCreate()
    {
        if (selected is null || busy) return;
        if (string.IsNullOrWhiteSpace(createProjectId)) { actionError = "Choose a project."; return; }
        if (string.IsNullOrWhiteSpace(createTitle)) { actionError = "A subject is required."; return; }

        // Blank reference: a General request is auto-numbered REQ-#### server-side.
        var command = new CreateRequestFromMessage(
            selected.Id,
            createProjectId,
            createKind,
            "",
            createTitle.Trim(),
            createDescription?.Trim() ?? "",
            RaisedTo: NullIfBlank(createRaisedTo),
            DrawingRef: NullIfBlank(createDrawingRef),
            ResponseDue: ParseDate(createResponseDue),
            InternetMessageId: selected.InternetMessageId,
            AddToProgramme: createAddToProgramme);

        await RunAction("Creating request", async () => await Intake.CreateRequestFromMessageAsync(command));
    }

    private async Task DoCreateBidPackage()
    {
        if (selected is null || busy) return;
        if (string.IsNullOrWhiteSpace(createProjectId)) { actionError = "Choose a project."; return; }
        if (string.IsNullOrWhiteSpace(createTitle)) { actionError = "A title is required."; return; }

        var command = new CreateBidPackageFromMessage(
            selected.Id,
            createProjectId,
            createTitle.Trim(),
            createTrade?.Trim() ?? "",
            InternetMessageId: selected.InternetMessageId);

        await RunAction("Creating bid package", async () => await Intake.CreateBidPackageFromMessageAsync(command));
    }

    // Internal → "To-dos": create every row with a title in one command. With a project chosen the
    // items land on that project's To-do tab — and an open request on it can optionally be tagged too
    // (server-verified before anything is created), so one action feeds the request's conversation
    // AND captures its follow-up to-dos. With no project the items are GENERAL (company-wide)
    // entries for mail that belongs to no project, surfacing on the /todos browser and the assigned
    // roles' dashboards. Either way the email is tagged "JPMS/TODO-####" once per created item, so
    // each item reads this email back live by its own tag — one email can feed several to-dos.
    //
    // Pathway: "Internal" rides along so the server files a not-yet-filed thread under Internal —
    // EXCEPT when a request link is picked: the request tag makes the thread feed a client-side
    // record, so the pathway is withheld and the thread's filing follows the request instead.
    private async Task DoCreateInternalTodos()
    {
        if (selected is null || busy) return;

        var drafts = createTodoRows
            .Where(row => !string.IsNullOrWhiteSpace(row.Title))
            .Select(row => new TodoItemDraft(
                row.Title.Trim(),
                NullIfBlank(row.Notes),
                ParseTodoRole(row.AssigneeRole),
                ParseDate(row.Due)))
            .ToList();
        if (drafts.Count == 0) { actionError = "At least one to-do item needs a title."; return; }

        var linkRequestId = string.IsNullOrWhiteSpace(createProjectId) ? null : NullIfBlank(createTodoLinkRequestId);
        var command = new CreateTodoItemsFromMessage(
            selected.Id,
            NullIfBlank(createProjectId),
            drafts,
            LinkRequestId: linkRequestId,
            InternetMessageId: selected.InternetMessageId,
            Pathway: linkRequestId is null ? "Internal" : null);

        await RunAction("Creating to-dos", async () => await Intake.CreateTodoItemsFromMessageAsync(command));
    }

    // "Reply in thread": the reply written here is staged as an Outlook draft on the email
    // (projects mailbox, thread quoted behind it) AND becomes the description of a General request
    // created from it in the background — one write-up answers the email and papers the request, so
    // the email is triaged by the act of replying. The outcome (request + draft weblink) is kept
    // for the success banner; the pre-filled draft is reviewed and sent from Outlook itself.
    private async Task DoReplyInThread()
    {
        if (selected is null || busy) return;
        if (string.IsNullOrWhiteSpace(replyProjectId)) { actionError = "Choose a project."; return; }
        if (string.IsNullOrWhiteSpace(replyBody)) { actionError = "Write the reply first."; return; }

        var command = new ReplyInThreadFromMessage(selected.Id, replyProjectId, replyBody.Trim(), selected.InternetMessageId);
        await RunAction("Preparing reply draft", async () =>
        {
            replyOutcome = await Intake.ReplyInThreadFromMessageAsync(command);
            replyProjectId = "";
            replyBody = "";
        });
    }

    private void OnReplyProjectChanged(ChangeEventArgs e) => replyProjectId = e.Value?.ToString() ?? "";

    private void OnReplyBodyInput(ChangeEventArgs e) => replyBody = e.Value?.ToString() ?? "";

    private async Task DoDiscard()
    {
        if (selected is null || busy) return;
        await RunAction("Discarding", async () => await Intake.DiscardMessageAsync(selected.Id, selected.InternetMessageId));
    }

    private async Task DoRestore()
    {
        if (selected is null || busy) return;
        actionError = null;
        try
        {
            busyLabel = "Restoring";
            busy = true;
            await Intake.RestoreMessageAsync(selected.Id, selected.InternetMessageId);
            selected = null;
            detail = null;
            detailLoading = false;
            ResetDiscardedPaging();
            await LoadDiscardedAsync();
        }
        catch
        {
            actionError = "Couldn't restore that email. Please try again.";
        }
        finally { busy = false; }
    }

    // ---- Preview / open an attachment without leaving triage ----
    // Same previewable set as the drawing viewer: browsers render PDFs and images natively in an
    // iframe; everything else gets a Download link only. Bytes are proxied through the API on
    // demand (mailbox/message/attachment) — nothing is stored in JPMS by previewing.

    private IntakeAttachment? previewAttachment;

    private static bool IsPreviewable(IntakeAttachment attachment)
    {
        var type = attachment.ContentType ?? "";
        return type.Contains("pdf", StringComparison.OrdinalIgnoreCase)
            || type.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
    }

    // Ids go in the query string, never the path — Graph ids don't survive a URL path segment.
    private string AttachmentUrl(IntakeAttachment attachment, bool inline) =>
        $"/api/mailbox/message/attachment?id={Uri.EscapeDataString(selected?.Id ?? "")}"
        + $"&aid={Uri.EscapeDataString(attachment.Id)}{(inline ? "&inline=1" : "")}";

    private void ToggleAttachmentPreview(IntakeAttachment attachment) =>
        previewAttachment = previewAttachment == attachment ? null : attachment;

    // ---- Save an attachment into a project's drawings ----
    // Unlike the record actions this does NOT consume the email: the message keeps its place in
    // triage (it may still become a request or bid package) — only the file is copied out.

    private IntakeAttachment? importAttachment;
    private bool importIsRevision;
    private string importDrawingId = "";
    private string importProjectId = "";
    private string importCode = "";
    private string importTitle = "";
    private string importRevision = "";
    private string? importNote;
    private string? importError;

    private IReadOnlyList<Drawing> ImportDrawingOptions =>
        string.IsNullOrWhiteSpace(importProjectId) ? Array.Empty<Drawing>() : DrawingStore.DrawingsFor(importProjectId);

    private void OpenDrawingImport(IntakeAttachment attachment)
    {
        importAttachment = attachment;
        importNote = null;
        importError = null;
        // Keep whichever project the triager already picked in the link/create forms.
        if (string.IsNullOrWhiteSpace(importProjectId))
            importProjectId = !string.IsNullOrWhiteSpace(createProjectId) ? createProjectId : linkProjectId;
        if (!string.IsNullOrWhiteSpace(importProjectId))
            DrawingStore.Refresh(importProjectId);
        PrefillFromFileName(attachment.Name);
    }

    private void SetImportMode(bool isRevision)
    {
        importIsRevision = isRevision;
        importError = null;
        if (isRevision && !string.IsNullOrWhiteSpace(importProjectId))
            DrawingStore.Refresh(importProjectId);
    }

    private void OnImportProjectChanged(ChangeEventArgs e)
    {
        importProjectId = e.Value?.ToString() ?? "";
        importDrawingId = "";
        if (!string.IsNullOrWhiteSpace(importProjectId))
            DrawingStore.Refresh(importProjectId);
    }

    // "PRO-064-(WD)-P-800 Rev I Site set out.pdf" → code "PRO-064-(WD)-P-800", revision "I",
    // title "Site set out". Falls back to the bare file name as the code when no "Rev X" is found.
    private void PrefillFromFileName(string fileName)
    {
        var name = System.IO.Path.GetFileNameWithoutExtension(fileName ?? "").Trim();
        var match = System.Text.RegularExpressions.Regex.Match(
            name, @"^(?<code>.+?)[\s\-–—]+Rev(?:ision)?\.?\s*(?<rev>[A-Za-z0-9]{1,3})\b[\s\-–—]*(?<title>.*)$",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (match.Success)
        {
            importCode = match.Groups["code"].Value.Trim();
            importRevision = match.Groups["rev"].Value.Trim().ToUpperInvariant();
            importTitle = match.Groups["title"].Value.Trim();
        }
        else
        {
            importCode = name;
            importRevision = "";
            importTitle = "";
        }
    }

    private async Task DoImportDrawing()
    {
        if (selected is null || importAttachment is null || busy) return;
        importError = null;
        importNote = null;

        // In revision mode the target drawing is picked explicitly; send its code so the
        // import lands as a new unapproved revision of that drawing rather than a new one.
        var code = importCode.Trim();
        var title = importTitle.Trim();
        if (importIsRevision)
        {
            var target = ImportDrawingOptions.FirstOrDefault(d => d.DrawingId == importDrawingId);
            if (target is null) { importError = "Select the drawing this revision belongs to."; return; }
            code = target.DrawingCode;
            title = target.Title;
        }

        try
        {
            busyLabel = "Saving drawing";
            busy = true;
            var drawing = await Commands.SendAsync(
                new ImportDrawingFromMessage(
                    importProjectId, selected.Id, importAttachment.Id,
                    code, title, importRevision.Trim()),
                CancellationToken.None);
            var project = ProjectOptions.FirstOrDefault(p => p.ProjectId == importProjectId);
            importNote = $"Saved as {drawing.DrawingCode} (unapproved revision) under {(project is null ? "the project" : project.Name)}'s drawings.";
            importAttachment = null;
            importDrawingId = "";
        }
        catch (CommandFailedException ex) { importError = ex.Message; }
        catch { importError = "Couldn't save that attachment to drawings. Please try again."; }
        finally { busy = false; }
    }

    // Runs a Queue-tab action (assign / create / discard), then refreshes the inbox and clears the
    // selection — the message has left the Inbox, so it drops out of the live read. `label` captions
    // the detail-pane spinner while the action is in flight.
    private async Task RunAction(string label, Func<Task> action)
    {
        actionError = null;
        try
        {
            busyLabel = label;
            busy = true;
            await action();
            ResetQueuePaging();
            await LoadAsync();
            selected = null;
            detail = null;
            detailLoading = false;
            mode = TriageMode.None;
        }
        catch (CommandFailedException ex)
        {
            // e.g. the reference is already in use on this project.
            actionError = ex.Message;
        }
        catch
        {
            actionError = "That action didn't complete. Please try again.";
        }
        finally { busy = false; }
    }

    // Runs a Tagged-tab action (add a tag, remove a tag), then refreshes the tagged list and clears the
    // selection — the email's tag set has changed, so re-read it live.
    private async Task RunTaggedAction(string label, Func<Task> action)
    {
        actionError = null;
        try
        {
            busyLabel = label;
            busy = true;
            await action();
            ResetTaggedPaging();
            await LoadTaggedAsync();
            selected = null;
            detail = null;
            detailLoading = false;
            ResetLinkState();
        }
        catch
        {
            actionError = "That action didn't complete. Please try again.";
        }
        finally { busy = false; }
    }

    // Add another workflow tag by linking this already-tagged email to a second record (so it feeds
    // more than one record). Reuses the same generic link command as the queue's "Link to existing",
    // but NOT RunTaggedAction — the pathway guards need their own error handling: the server's
    // cross-filing prompt becomes an inline confirm (retry with consent), while a client-wall
    // rejection is shown verbatim with no retry (the wall has no override).
    private async Task DoAddTagLink() => await DoAddTagLinkCore(allowCrossPathway: false);

    private async Task DoAddTagLinkConfirmCross() => await DoAddTagLinkCore(allowCrossPathway: true);

    private async Task DoAddTagLinkCore(bool allowCrossPathway)
    {
        if (selected is null || busy || string.IsNullOrWhiteSpace(linkRecordId)) return;
        // The type to link as is the picked RECORD's own type, not the dropdown's (the Scheduling
        // picker lists NOD/EOT/LAD claims documents alongside the bucket — see DoLinkCore).
        var record = linkRecords.FirstOrDefault(r => r.RecordId == linkRecordId);
        var recordType = record?.Type ?? linkRecordType;
        actionError = null;
        try
        {
            busyLabel = "Linking";
            busy = true;
            await Intake.LinkMessageToRecordAsync(
                selected.Id, selected.InternetMessageId, recordType, linkRecordId,
                pathway: record is null ? null : CostCentrePathwayFor(record),
                allowCrossPathway: allowCrossPathway);
            crossFileMessage = null;
            ResetTaggedPaging();
            await LoadTaggedAsync();
            selected = null;
            detail = null;
            detailLoading = false;
            ResetLinkState();
        }
        catch (CommandFailedException ex) when (!allowCrossPathway && IsCrossFilePrompt(ex.Message))
        {
            crossFileMessage = ex.Message;
        }
        catch (CommandFailedException ex)
        {
            crossFileMessage = null;
            actionError = ex.Message;
        }
        catch
        {
            crossFileMessage = null;
            actionError = "That action didn't complete. Please try again.";
        }
        finally { busy = false; }
    }

    private async Task DoRemoveTag(string tag)
    {
        if (selected is null || busy) return;
        await RunTaggedAction("Removing tag", async () => await Intake.RemoveTagFromMessageAsync(selected.Id, selected.InternetMessageId, tag));
    }

    private void OnTaggedRecordChanged(ChangeEventArgs e) => linkRecordId = e.Value?.ToString() ?? "";

    // Display label for a workflow tag chip: drop the "JPMS/" prefix (e.g. "JPMS/RFI-001" -> "RFI-001").
    private static string TagLabel(string tag) =>
        tag.StartsWith("JPMS/", StringComparison.OrdinalIgnoreCase) ? tag["JPMS/".Length..] : tag;

    private IReadOnlyList<Project> ProjectOptions =>
        Projects.Current ?? (IReadOnlyList<Project>)Array.Empty<Project>();

    // The loaded records for the chosen type + project (empty until both are chosen and the load runs).
    private IReadOnlyList<LinkableRecord> ProjectRecords() => linkRecords;

    // Records on the chosen project whose reference or title overlaps the email subject — surfaced
    // first so a duplicate record isn't created for something already being tracked. Type-agnostic.
    private List<LinkableRecord> DuplicateCandidates()
    {
        var subject = selected?.Subject ?? "";
        var tokens = Tokenise(subject);
        return ProjectRecords()
            .Select(r => (r, score: Overlap(r, subject, tokens)))
            .Where(x => x.score > 0)
            .OrderByDescending(x => x.score)
            .Select(x => x.r)
            .ToList();
    }

    private static int Overlap(LinkableRecord record, string subject, HashSet<string> subjectTokens)
    {
        var score = 0;
        if (!string.IsNullOrWhiteSpace(record.Reference) &&
            subject.Contains(record.Reference, StringComparison.OrdinalIgnoreCase))
            score += 10;
        foreach (var token in Tokenise(record.Title))
            if (subjectTokens.Contains(token)) score++;
        return score;
    }

    private static HashSet<string> Tokenise(string text) =>
        text.Split(new[] { ' ', '\t', '\n', '\r', '-', '_', '.', ',', ':', ';', '[', ']', '(', ')', '/' },
                   StringSplitOptions.RemoveEmptyEntries)
            .Select(w => w.ToLowerInvariant())
            .Where(w => w.Length > 3)
            .ToHashSet();

    private string RowClass(MailboxMessage item)
    {
        var baseClass = "w-full text-left rounded-lg border px-3 py-2 transition";
        return selected?.Id == item.Id
            ? $"{baseClass} border-accent bg-surface-raised"
            : $"{baseClass} border-line hover:border-line-strong hover:bg-surface-raised";
    }

    private string ViewTabClass(QueueView tab)
    {
        var baseClass = "px-3 py-2 text-sm font-medium border-b-2 -mb-px transition";
        return view == tab
            ? $"{baseClass} border-accent text-content"
            : $"{baseClass} border-transparent text-content-muted hover:text-content";
    }

    private string ModeTabClass(TriageMode tab)
    {
        var baseClass = "rounded-lg px-3 py-1.5 text-sm font-medium border transition";
        return mode == tab
            ? $"{baseClass} border-accent text-content bg-surface-raised"
            : $"{baseClass} border-line text-content-muted hover:text-content hover:border-line-strong";
    }

    private string RecordPickClass(LinkableRecord record, bool candidate)
    {
        var baseClass = "w-full text-left rounded-lg border px-3 py-2 flex flex-col gap-0.5 transition";
        if (linkRecordIds.Contains(record.RecordId)) return $"{baseClass} border-accent bg-surface-raised";
        return candidate
            ? $"{baseClass} border-amber-500/40 hover:border-amber-500"
            : $"{baseClass} border-line hover:border-line-strong";
    }

    private static string DisplayFrom(MailboxMessage item) =>
        string.IsNullOrWhiteSpace(item.FromName) ? item.FromEmail : item.FromName;

    private static string Dash(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string Date(DateTimeOffset value) => value.LocalDateTime.ToString("d MMM yyyy, HH:mm");

    private static string? NullIfBlank(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    // The to-do rows' SearchSelect holds the assigned role as its int-in-a-string value ("" = unassigned).
    private static Role? ParseTodoRole(string value) =>
        int.TryParse(value, out var parsed) ? (Role)parsed : null;

    private static DateTimeOffset? ParseDate(string value) =>
        DateTimeOffset.TryParse(value, out var parsed) ? parsed : null;

    public void Dispose()
    {
        RequestRegister.OnChange -= StateHasChanged;
        DrawingStore.OnChange -= StateHasChanged;
    }
}
