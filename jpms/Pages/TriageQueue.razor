@page "/requests/triage"
@using Jewel.JPMS.Contracts.Procurement
@using Jewel.JPMS.Contracts.Requests
@inject AuthService Auth
@inject SessionService Session
@inject NavigationManager Nav
@inject IIntakeQueue Intake
@inject IRequestRegister RequestRegister
@inject Jewel.JPMS.Features.Projects.ProjectListReadModel Projects
@implements IDisposable

<PageTitle>Triage · JPMS</PageTitle>

@*
    Live-read triage. The mailbox is the single source of truth and nothing ever moves — triage just
    adds/removes category tags on the email. The Queue is Inbox messages with no JPMS tag (read live);
    the Discarded tab is messages tagged "JPMS/Discarded". Discard/restore/assign add or remove tags,
    each verified by reading the categories back. Nothing about un-triaged mail is stored in the database.
*@

@*
    Shared message body + attachments, used by both the Queue and Discarded detail panes. Declared
    before first use; reads the live `detail` / `selected` fields each time it is rendered.
*@
@{
    RenderFragment MessageBody =@<text>
        <div class="rounded-lg bg-surface-raised border border-line p-3 max-h-[28rem] overflow-y-auto">
            @if (detailLoading)
            {
                <p class="text-sm text-content-subtle italic">Loading message…</p>
            }
            else if (detail is not null && !string.IsNullOrWhiteSpace(detail.BodyHtml) && detail.BodyIsHtml)
            {
                <div class="rounded bg-white text-gray-900 p-3 text-sm overflow-x-auto">@((MarkupString)detail.BodyHtml)</div>
            }
            else if (detail is not null && !string.IsNullOrWhiteSpace(detail.BodyHtml))
            {
                <p class="text-sm text-content whitespace-pre-wrap">@detail.BodyHtml</p>
            }
            else
            {
                <p class="text-sm text-content-subtle italic">@(selected is null ? "" : Dash(selected.BodyPreview))</p>
            }
        </div>

        @if (detail is not null && detail.Attachments.Count > 0)
        {
            <div class="rounded-lg bg-surface-raised border border-line p-3">
                <p class="text-xs uppercase tracking-wider text-content-subtle font-semibold mb-2">
                    @detail.Attachments.Count attachment@(detail.Attachments.Count == 1 ? "" : "s")
                </p>
                <ul class="space-y-1">
                    @foreach (var att in detail.Attachments)
                    {
                        <li class="flex items-center justify-between gap-3 text-sm text-content">
                            <span class="truncate">@att.Name</span>
                            @if (att.Size > 0)
                            {
                                <span class="text-xs text-content-subtle whitespace-nowrap">@FormatSize(att.Size)</span>
                            }
                        </li>
                    }
                </ul>
            </div>
        }
        else if (selected is not null && selected.HasAttachments && detail is not null)
        {
            <p class="text-xs text-content-subtle italic">This email has attachments, but their names couldn't be retrieved.</p>
        }
    </text>;
}

@if (!isLoaded)
{
    <section class="max-w-6xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (!CanTriage)
{
    <section class="max-w-6xl mx-auto px-4 py-12">
        <div class="panel p-8 text-center">
            <p class="text-sm text-content">You don't have access to mailbox triage.</p>
            <p class="text-xs text-content-subtle mt-1">Triage is available to administrators and project managers.</p>
        </div>
    </section>
}
else
{
    <section class="max-w-6xl mx-auto px-4 py-8 md:py-12">
        <header class="mb-6">
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · projects@@jewelbb.co.uk</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Mailbox triage</h1>
            @if (view == QueueView.Active)
            {
                <p class="text-sm text-content-muted mt-2">
                    @total email@(total == 1 ? "" : "s") in the inbox waiting to be assigned to a request.
                </p>
            }
            else if (view == QueueView.Discarded)
            {
                <p class="text-sm text-content-muted mt-2">
                    @discardedTotal discarded email@(discardedTotal == 1 ? "" : "s") — restore one to put it back in the queue.
                </p>
            }
            else
            {
                <p class="text-sm text-content-muted mt-2">
                    @taggedTotal tagged email@(taggedTotal == 1 ? "" : "s") — add or remove tags to manage which processes use them.
                </p>
            }
        </header>

        <div class="flex gap-2 mb-6 border-b border-line">
            <button type="button" class="@ViewTabClass(QueueView.Active)" @onclick="() => SwitchView(QueueView.Active)">Queue</button>
            <button type="button" class="@ViewTabClass(QueueView.Tagged)" @onclick="() => SwitchView(QueueView.Tagged)">Tagged</button>
        </div>

        @if (loadError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4">@loadError</p>
        }

        @if (view == QueueView.Active)
        {
        @if (unassigned.Count > 0)
        {
            <div class="panel p-5 mb-6 border-amber-500/40">
                <div class="flex items-start gap-2 mb-1">
                    <h2 class="text-sm font-semibold text-amber-700">Unassigned requests</h2>
                    <span class="inline-flex items-center rounded-full bg-amber-500/10 px-2 py-0.5 text-[11px] font-medium text-amber-600">@unassigned.Count</span>
                </div>
                <p class="text-xs text-content-subtle mb-3">
                    These requests aren't tied to a live project, so they don't appear in any register. Return one to triage to process its emails again and pick the right project.
                </p>
                @if (unassignedError is not null)
                {
                    <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@unassignedError</p>
                }
                <div class="space-y-2">
                    @foreach (var request in unassigned)
                    {
                        <div @key="request.RequestId" class="flex items-center justify-between gap-3 rounded-lg border border-line px-3 py-2">
                            <div class="min-w-0">
                                <p class="text-sm text-content truncate">
                                    <span class="font-mono text-xs text-content-muted mr-2">@Dash(request.Reference)</span>@Dash(request.Title)
                                </p>
                                <p class="text-[11px] text-content-subtle mt-0.5">Raised @Date(request.RaisedAt) · @Dash(request.RaisedByEmail)</p>
                            </div>
                            <button type="button" class="btn-secondary text-xs whitespace-nowrap"
                                    disabled="@busy" @onclick="() => ReturnUnassigned(request)">
                                Return to triage
                            </button>
                        </div>
                    }
                </div>
            </div>
        }

        @if (total == 0)
        {
            <div class="panel p-8 text-center">
                <p class="text-sm text-content">Nothing in the queue.</p>
                <p class="text-xs text-content-subtle mt-1">Every email in the requests mailbox has been dealt with.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
                <div class="space-y-2 lg:col-span-1">
                    @foreach (var item in items)
                    {
                        <button type="button" @key="item.Id" @onclick="() => Select(item)"
                                class="@RowClass(item)">
                            <div class="flex items-center justify-between gap-2">
                                <span class="text-sm font-medium text-content truncate">@DisplayFrom(item)</span>
                            </div>
                            <p class="text-sm text-content-muted truncate mt-0.5">@Dash(item.Subject)</p>
                            <div class="flex items-center gap-2 mt-1 text-[11px] text-content-subtle">
                                <span>@Date(item.ReceivedAt)</span>
                                @if (item.HasAttachments)
                                {
                                    <span title="Has attachments">· attachment</span>
                                }
                            </div>
                        </button>
                    }

                    @if (QueuePageCount > 1)
                    {
                        <div class="flex items-center justify-between gap-2 pt-2">
                            @if (queueIndex > 0)
                            {
                                <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" @onclick="PreviousPage">Previous</button>
                            }
                            else
                            {
                                <span></span>
                            }
                            <span class="text-[11px] text-content-subtle">Page @(queueIndex + 1) / @QueuePageCount</span>
                            @if (queueNext is not null)
                            {
                                <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" @onclick="NextPage">Next</button>
                            }
                            else
                            {
                                <span></span>
                            }
                        </div>
                    }
                </div>

                <div class="lg:col-span-2">
                    @if (selected is null)
                    {
                        <div class="panel p-8 text-center text-sm text-content-subtle">
                            Select an email to triage it.
                        </div>
                    }
                    else
                    {
                        <div class="panel p-5 space-y-4">
                            @if (actionError is not null)
                            {
                                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@actionError</p>
                            }

                            <div>
                                <h2 class="text-lg font-semibold text-content">@Dash(selected.Subject)</h2>
                                <p class="text-sm text-content-muted mt-1">
                                    From @DisplayFrom(selected) · @Date(selected.ReceivedAt)
                                </p>
                            </div>

                            @MessageBody

                            <div class="pt-3 border-t border-line">
                                <div class="flex flex-wrap gap-2 mb-4">
                                    <button type="button" class="@ModeTabClass(TriageMode.Link)" @onclick="() => SetMode(TriageMode.Link)">Link to existing</button>
                                    <button type="button" class="@ModeTabClass(TriageMode.Create)" @onclick="() => SetMode(TriageMode.Create)">Create new</button>
                                    <button type="button" class="@ModeTabClass(TriageMode.Discard)" @onclick="() => SetMode(TriageMode.Discard)">Discard</button>
                                </div>

                                @if (mode == TriageMode.Link)
                                {
                                    <div class="space-y-3">
                                        <div>
                                            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Record type</label>
                                            <select class="field" value="@((int)linkRecordType)" @onchange="OnLinkRecordTypeChanged">
                                                @foreach (var recordType in RecordTypeOptions)
                                                {
                                                    <option value="@((int)recordType)">@RecordTypeLabel(recordType)</option>
                                                }
                                            </select>
                                        </div>

                                        <div>
                                            <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Project</label>
                                            <select class="field" value="@linkProjectId" @onchange="OnLinkProjectChanged">
                                                <option value="">Select a project…</option>
                                                @foreach (var project in ProjectOptions)
                                                {
                                                    <option value="@project.ProjectId">@project.Reference — @project.Name</option>
                                                }
                                            </select>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(linkProjectId))
                                        {
                                            if (linkRecordsLoading)
                                            {
                                                <p class="text-sm text-content-subtle italic">Loading @(RecordTypeLabel(linkRecordType).ToLowerInvariant())s…</p>
                                            }
                                            else
                                            {
                                                var candidates = DuplicateCandidates();
                                                var others = ProjectRecords().Except(candidates).ToList();

                                                @if (candidates.Count > 0)
                                                {
                                                    <div>
                                                        <p class="text-xs font-semibold text-amber-600 mb-1">Possible matches for this email</p>
                                                        <div class="space-y-1">
                                                            @foreach (var record in candidates)
                                                            {
                                                                <button type="button" @onclick="() => linkRecordId = record.RecordId" class="@RecordPickClass(record, true)">
                                                                    <span class="font-mono text-xs text-content-muted">@record.Reference</span>
                                                                    <span class="text-sm text-content">@record.Title</span>
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                }

                                                @if (others.Count > 0)
                                                {
                                                    <div>
                                                        <p class="text-xs font-semibold text-content-subtle mb-1">Other @(RecordTypeLabel(linkRecordType).ToLowerInvariant())s on this project</p>
                                                        <div class="space-y-1 max-h-56 overflow-y-auto">
                                                            @foreach (var record in others)
                                                            {
                                                                <button type="button" @onclick="() => linkRecordId = record.RecordId" class="@RecordPickClass(record, false)">
                                                                    <span class="font-mono text-xs text-content-muted">@record.Reference</span>
                                                                    <span class="text-sm text-content">@record.Title</span>
                                                                </button>
                                                            }
                                                        </div>
                                                    </div>
                                                }

                                                @if (candidates.Count == 0 && others.Count == 0)
                                                {
                                                    <p class="text-sm text-content-subtle italic">No @(RecordTypeLabel(linkRecordType).ToLowerInvariant())s on this project yet.</p>
                                                }
                                            }
                                        }

                                        <button type="button" class="btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(linkRecordId))" @onclick="DoLink">
                                            Link email to selected record
                                        </button>
                                    </div>
                                }
                                else if (mode == TriageMode.Create)
                                {
                                    <div class="space-y-4">
                                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Record type *</label>
                                                <select class="field" value="@((int)createRecordType)" @onchange="OnCreateRecordTypeChanged">
                                                    @foreach (var recordType in RecordTypeOptions)
                                                    {
                                                        <option value="@((int)recordType)">@RecordTypeLabel(recordType)</option>
                                                    }
                                                </select>
                                            </div>
                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Project *</label>
                                                <select class="field" value="@createProjectId" @onchange="OnCreateProjectChanged">
                                                    <option value="">Select a project…</option>
                                                    @foreach (var project in ProjectOptions)
                                                    {
                                                        <option value="@project.ProjectId">@project.Reference — @project.Name</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>

                                        @if (createRecordType == RecordType.Request)
                                        {
                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Type *</label>
                                                <select class="field" value="@((int)createKind)" @onchange="OnCreateKindChanged">
                                                    @foreach (var option in KindOptions)
                                                    {
                                                        <option value="@((int)option)">@option.DisplayName() — @option.LongName()</option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                <FormField Label="Reference" Value="@createReference" OnChange="v => createReference = v" Required="true" />
                                                <FormField Label="Raised to" Value="@createRaisedTo" OnChange="v => createRaisedTo = v" />
                                            </div>

                                            <FormField Label="Subject" Value="@createTitle" OnChange="v => createTitle = v" Required="true" />

                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Detail</label>
                                                <textarea class="field" rows="4" value="@createDescription" @oninput="OnCreateDescriptionInput"></textarea>
                                            </div>

                                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                <FormField Label="Drawing / detail ref" Value="@createDrawingRef" OnChange="v => createDrawingRef = v" />
                                                <FormField Label="Response due" Value="@createResponseDue" OnChange="v => createResponseDue = v" InputType="date" />
                                            </div>

                                            <button type="button" class="btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(createProjectId))" @onclick="DoCreate">Create request from email</button>
                                        }
                                        else if (createRecordType == RecordType.BidPackageInvite)
                                        {
                                            <FormField Label="Title" Value="@createTitle" OnChange="v => createTitle = v" Required="true" />
                                            <FormField Label="Trade" Value="@createTrade" OnChange="v => createTrade = v" />

                                            <p class="text-xs text-content-subtle">A draft bid package is created and this email is linked to it. Invite subcontractors and add line items from the bid package page.</p>

                                            <button type="button" class="btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(createProjectId) || string.IsNullOrWhiteSpace(createTitle))" @onclick="DoCreateBidPackage">Create bid package from email</button>
                                        }
                                    </div>
                                }
                                else if (mode == TriageMode.Discard)
                                {
                                    <div class="space-y-3">
                                        <p class="text-sm text-content-muted">Discard this email if it isn’t a request (spam, an auto-reply, or sent to the wrong place). This adds a “discarded” category tag to it — the email stays put in the mailbox — and removes it from the queue. You can restore it from the Discarded tab.</p>
                                        <button type="button" class="btn-secondary border-negative/40 text-negative hover:border-negative" disabled="@busy" @onclick="DoDiscard">Discard email</button>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        }
        else if (view == QueueView.Discarded)
        {
            @if (discardedTotal == 0)
            {
                <div class="panel p-8 text-center">
                    <p class="text-sm text-content">No discarded emails.</p>
                    <p class="text-xs text-content-subtle mt-1">Emails you discard from the queue show up here, and can be restored.</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
                    <div class="space-y-2 lg:col-span-1">
                        @foreach (var item in discardedItems)
                        {
                            <button type="button" @key="item.Id" @onclick="() => Select(item)" class="@RowClass(item)">
                                <div class="flex items-center justify-between gap-2">
                                    <span class="text-sm font-medium text-content truncate">@DisplayFrom(item)</span>
                                </div>
                                <p class="text-sm text-content-muted truncate mt-0.5">@Dash(item.Subject)</p>
                                <div class="flex items-center gap-2 mt-1 text-[11px] text-content-subtle">
                                    <span>@Date(item.ReceivedAt)</span>
                                    @if (item.HasAttachments)
                                    {
                                        <span title="Has attachments">· attachment</span>
                                    }
                                </div>
                            </button>
                        }

                        @if (DiscardedPageCount > 1)
                        {
                            <div class="flex items-center justify-between gap-2 pt-2">
                                @if (discardedIndex > 0)
                                {
                                    <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" @onclick="PreviousDiscarded">Previous</button>
                                }
                                else
                                {
                                    <span></span>
                                }
                                <span class="text-[11px] text-content-subtle">Page @(discardedIndex + 1) / @DiscardedPageCount</span>
                                @if (discardedNext is not null)
                                {
                                    <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" @onclick="NextDiscarded">Next</button>
                                }
                                else
                                {
                                    <span></span>
                                }
                            </div>
                        }
                    </div>

                    <div class="lg:col-span-2">
                        @if (selected is null)
                        {
                            <div class="panel p-8 text-center text-sm text-content-subtle">
                                Select a discarded email to view it.
                            </div>
                        }
                        else
                        {
                            <div class="panel p-5 space-y-4">
                                @if (actionError is not null)
                                {
                                    <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@actionError</p>
                                }

                                <div>
                                    <h2 class="text-lg font-semibold text-content">@Dash(selected.Subject)</h2>
                                    <p class="text-sm text-content-muted mt-1">
                                        From @DisplayFrom(selected) · @Date(selected.ReceivedAt)
                                    </p>
                                </div>

                                @MessageBody

                                <div class="pt-3 border-t border-line">
                                    <p class="text-sm text-content-muted mb-3">
                                        This email was discarded. Restore it to remove the “discarded” tag and put it back in the triage queue.
                                    </p>
                                    <button type="button" class="btn-primary" disabled="@busy" @onclick="DoRestore">Restore to triage</button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="flex flex-wrap items-center gap-2 mb-5">
                <span class="text-xs uppercase tracking-wider text-content-subtle font-semibold mr-1">Filter</span>
                <div class="relative">
                    <button type="button"
                            class="rounded-full border border-line px-3 py-1 text-xs font-medium text-content-muted hover:text-content hover:border-line-strong transition inline-flex items-center gap-1.5"
                            @onclick="ToggleFilterMenu">
                        @FilterButtonLabel
                        <span class="text-[9px] leading-none">▾</span>
                    </button>
                    @if (filterOpen)
                    {
                        <div class="absolute z-20 mt-1 w-60 max-h-72 overflow-y-auto rounded-lg border border-line bg-surface-raised shadow-lg p-1">
                            <button type="button"
                                    class="w-full text-left rounded px-3 py-1.5 text-sm text-content-muted hover:bg-surface hover:text-content"
                                    @onclick="ClearTagFilters">
                                All tags
                            </button>
                            <div class="my-1 border-t border-line"></div>
                            @foreach (var tag in knownTags)
                            {
                                <label class="flex items-center gap-2 rounded px-3 py-1.5 text-sm text-content hover:bg-surface cursor-pointer">
                                    <input type="checkbox" checked="@selectedTags.Contains(tag)" @onchange="() => ToggleTag(tag)" />
                                    <span>@TagLabel(tag)</span>
                                </label>
                            }
                        </div>
                    }
                </div>
                @foreach (var tag in selectedTags)
                {
                    <span class="inline-flex items-center gap-1.5 rounded-full border border-accent bg-surface-raised px-2.5 py-1 text-xs text-content">
                        @TagLabel(tag)
                        <button type="button" class="text-content-subtle hover:text-negative" @onclick="() => ToggleTag(tag)" title="Remove filter">✕</button>
                    </span>
                }
            </div>

            @if (taggedTotal == 0)
            {
                <div class="panel p-8 text-center">
                    <p class="text-sm text-content">@(selectedTags.Count == 0 ? "No tagged emails." : "No emails with the selected tags.")</p>
                    <p class="text-xs text-content-subtle mt-1">Emails linked to a request (or discarded) appear here. Open one to add it to another request or remove a tag.</p>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
                    <div class="space-y-2 lg:col-span-1">
                        @foreach (var item in taggedItems)
                        {
                            <button type="button" @key="item.Id" @onclick="() => Select(item)" class="@RowClass(item)">
                                <div class="flex items-center justify-between gap-2">
                                    <span class="text-sm font-medium text-content truncate">@DisplayFrom(item)</span>
                                </div>
                                <p class="text-sm text-content-muted truncate mt-0.5">@Dash(item.Subject)</p>
                                @if (item.Categories.Count > 0)
                                {
                                    <div class="flex flex-wrap items-center gap-1 mt-1">
                                        @foreach (var tag in item.Categories)
                                        {
                                            <span class="inline-flex items-center rounded-full bg-accent/10 text-accent text-[10px] font-medium px-2 py-0.5">@TagLabel(tag)</span>
                                        }
                                    </div>
                                }
                                <div class="flex items-center gap-2 mt-1 text-[11px] text-content-subtle">
                                    <span>@Date(item.ReceivedAt)</span>
                                    @if (item.HasAttachments)
                                    {
                                        <span title="Has attachments">· attachment</span>
                                    }
                                </div>
                            </button>
                        }

                        @if (TaggedPageCount > 1)
                        {
                            <div class="flex items-center justify-between gap-2 pt-2">
                                @if (taggedIndex > 0)
                                {
                                    <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" @onclick="PreviousTagged">Previous</button>
                                }
                                else
                                {
                                    <span></span>
                                }
                                <span class="text-[11px] text-content-subtle">Page @(taggedIndex + 1) / @TaggedPageCount</span>
                                @if (taggedNext is not null)
                                {
                                    <button type="button" class="btn-secondary text-xs px-2.5 py-1.5" @onclick="NextTagged">Next</button>
                                }
                                else
                                {
                                    <span></span>
                                }
                            </div>
                        }
                    </div>

                    <div class="lg:col-span-2">
                        @if (selected is null)
                        {
                            <div class="panel p-8 text-center text-sm text-content-subtle">
                                Select a tagged email to manage its tags.
                            </div>
                        }
                        else
                        {
                            <div class="panel p-5 space-y-4">
                                @if (actionError is not null)
                                {
                                    <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@actionError</p>
                                }

                                <div>
                                    <h2 class="text-lg font-semibold text-content">@Dash(selected.Subject)</h2>
                                    <p class="text-sm text-content-muted mt-1">
                                        From @DisplayFrom(selected) · @Date(selected.ReceivedAt)
                                    </p>
                                </div>

                                @MessageBody

                                <div class="pt-3 border-t border-line space-y-4">
                                    <div>
                                        <p class="text-xs uppercase tracking-wider text-content-subtle font-semibold mb-2">Tags on this email</p>
                                        @if (selected.Categories.Count == 0)
                                        {
                                            <p class="text-sm text-content-subtle italic">No workflow tags. (Refresh if you just changed them.)</p>
                                        }
                                        else
                                        {
                                            <div class="flex flex-wrap gap-2">
                                                @foreach (var tag in selected.Categories)
                                                {
                                                    <span class="inline-flex items-center gap-1.5 rounded-full border border-line bg-surface-raised px-2.5 py-1 text-xs text-content">
                                                        @TagLabel(tag)
                                                        <button type="button" class="text-content-subtle hover:text-negative" disabled="@busy" @onclick="() => DoRemoveTag(tag)" title="Remove this tag">✕</button>
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </div>

                                    <div>
                                        <p class="text-xs uppercase tracking-wider text-content-subtle font-semibold mb-2">Link to another record</p>
                                        <div class="space-y-3">
                                            <select class="field" value="@((int)linkRecordType)" @onchange="OnLinkRecordTypeChanged">
                                                @foreach (var recordType in RecordTypeOptions)
                                                {
                                                    <option value="@((int)recordType)">@RecordTypeLabel(recordType)</option>
                                                }
                                            </select>

                                            <select class="field" value="@linkProjectId" @onchange="OnLinkProjectChanged">
                                                <option value="">Select a project…</option>
                                                @foreach (var project in ProjectOptions)
                                                {
                                                    <option value="@project.ProjectId">@project.Reference — @project.Name</option>
                                                }
                                            </select>

                                            @if (!string.IsNullOrWhiteSpace(linkProjectId))
                                            {
                                                @if (linkRecordsLoading)
                                                {
                                                    <p class="text-sm text-content-subtle italic">Loading @(RecordTypeLabel(linkRecordType).ToLowerInvariant())s…</p>
                                                }
                                                else
                                                {
                                                    <select class="field" value="@linkRecordId" @onchange="OnTaggedRecordChanged">
                                                        <option value="">Select a @(RecordTypeLabel(linkRecordType).ToLowerInvariant())…</option>
                                                        @foreach (var record in ProjectRecords())
                                                        {
                                                            <option value="@record.RecordId">@record.Reference — @record.Title</option>
                                                        }
                                                    </select>
                                                }
                                            }

                                            <button type="button" class="btn-primary" disabled="@(busy || string.IsNullOrWhiteSpace(linkRecordId))" @onclick="DoAddTagLink">
                                                Link to selected record
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </section>
}

@code {
    private enum TriageMode { None, Link, Create, Discard }

    // The page shows the live queue (untagged Inbox), the discarded pile, or every tagged email (the
    // management surface for adding/removing workflow tags). The detail pane is shared.
    private enum QueueView { Active, Discarded, Tagged }
    private QueueView view = QueueView.Active;

    private static readonly RequestType[] KindOptions =
    {
        RequestType.Rfi, RequestType.Rfq, RequestType.Rfp, RequestType.Rfc, RequestType.Rfa
    };

    // The record types an email can be linked to, in the order shown in the category picker. Driven by
    // the providers registered server-side; adding a type here surfaces it once its provider exists.
    private static readonly RecordType[] RecordTypeOptions =
    {
        RecordType.Request, RecordType.BidPackageInvite
    };

    private static string RecordTypeLabel(RecordType type) => type switch
    {
        RecordType.Request          => "Request",
        RecordType.BidPackageInvite => "Bid Package Invite",
        _                           => type.ToString()
    };

    private const int PageSize = 25;

    private bool isLoaded;
    private string? loadError;

    // The current page only. Graph pages with an opaque cursor, so we keep a small stack of the
    // cursors we've walked (index 0 = first page, cursor null) to support Previous/Next.
    private IReadOnlyList<MailboxMessage> items = Array.Empty<MailboxMessage>();
    private int total;
    private List<string?> queueCursors = new() { null };
    private int queueIndex;
    private string? queueNext;

    private IReadOnlyList<MailboxMessage> discardedItems = Array.Empty<MailboxMessage>();
    private int discardedTotal;
    private List<string?> discardedCursors = new() { null };
    private int discardedIndex;
    private string? discardedNext;

    private IReadOnlyList<MailboxMessage> taggedItems = Array.Empty<MailboxMessage>();
    private int taggedTotal;
    private List<string?> taggedCursors = new() { null };
    private int taggedIndex;
    private string? taggedNext;
    // The Tagged tab's multi-select filter: the set of tags currently ticked (empty = every tagged
    // email), whether the dropdown is open, and the set of tags we've seen (offered in the dropdown).
    // "Discarded" is always offered; the rest accrue as tagged emails load.
    private readonly HashSet<string> selectedTags = new(StringComparer.OrdinalIgnoreCase);
    private bool filterOpen;
    private readonly SortedSet<string> knownTags = new(StringComparer.OrdinalIgnoreCase) { "JPMS/Discarded" };

    private MailboxMessage? selected;
    private MailboxMessageDetail? detail;
    private bool detailLoading;
    private CancellationTokenSource? detailCts;

    private IReadOnlyList<Request> unassigned = Array.Empty<Request>();
    private string? unassignedError;

    // Triage is restricted to administrators and project managers. Administrators are granted every
    // role server-side, so they always carry Role.ProjectManager too.
    private bool CanTriage =>
        Session.AvailableRoles.Any(role => role is Role.Admin or Role.ProjectManager);

    // Total pages for each list, derived from the server-reported total count.
    private int QueuePageCount => Math.Max(1, (int)Math.Ceiling(total / (double)PageSize));
    private int DiscardedPageCount => Math.Max(1, (int)Math.Ceiling(discardedTotal / (double)PageSize));
    private int TaggedPageCount => Math.Max(1, (int)Math.Ceiling(taggedTotal / (double)PageSize));

    private bool busy;
    private string? actionError;
    private TriageMode mode = TriageMode.None;

    // Link-to-existing state. The record type is chosen first (Request, Bid Package Invite, …), then a
    // project, then a record of that type — linking is record-agnostic (tags "JPMS/<ref>" either way).
    private RecordType linkRecordType = RecordType.Request;
    private string linkProjectId = "";
    private string linkRecordId = "";
    private IReadOnlyList<LinkableRecord> linkRecords = Array.Empty<LinkableRecord>();
    private bool linkRecordsLoading;

    // Create-new state
    private RecordType createRecordType = RecordType.Request;
    private string createProjectId = "";
    private RequestType createKind = RequestType.Rfi;
    private string createReference = "";
    private string createTitle = "";
    private string createDescription = "";
    private string createRaisedTo = "";
    private string createDrawingRef = "";
    private string createResponseDue = "";
    // Bid Package Invite create fields (shares createProjectId + createTitle with the Request form).
    private string createTrade = "";

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        RequestRegister.OnChange += StateHasChanged;
        await Projects.RefreshAsync(CancellationToken.None);
        await LoadAsync();
        await LoadUnassignedAsync();
        isLoaded = true;
    }

    private async Task SwitchView(QueueView next)
    {
        if (view == next) return;
        view = next;
        selected = null;
        detail = null;
        detailLoading = false;
        mode = TriageMode.None;
        actionError = null;
        if (next == QueueView.Discarded) { ResetDiscardedPaging(); await LoadDiscardedAsync(); }
        else if (next == QueueView.Tagged) { selectedTags.Clear(); filterOpen = false; ResetTaggedPaging(); await LoadTaggedAsync(); }
        else { ResetQueuePaging(); await LoadAsync(); }
    }

    private void ResetQueuePaging() { queueCursors = new() { null }; queueIndex = 0; queueNext = null; }
    private void ResetDiscardedPaging() { discardedCursors = new() { null }; discardedIndex = 0; discardedNext = null; }
    private void ResetTaggedPaging() { taggedCursors = new() { null }; taggedIndex = 0; taggedNext = null; }

    private async Task LoadAsync()
    {
        loadError = null;
        try
        {
            var result = await Intake.ListInboxLiveAsync(queueCursors[queueIndex], PageSize);
            items = result.Items;
            total = result.Total;
            queueNext = result.NextCursor;
            // Record the cursor for the next page so Next can advance to it.
            if (queueNext is not null && queueIndex == queueCursors.Count - 1)
                queueCursors.Add(queueNext);
        }
        catch
        {
            loadError = "Couldn't load the inbox. Please try again.";
            items = Array.Empty<MailboxMessage>();
            total = 0;
            queueNext = null;
        }
    }

    private async Task LoadDiscardedAsync()
    {
        loadError = null;
        try
        {
            var result = await Intake.ListDiscardedLiveAsync(discardedCursors[discardedIndex], PageSize);
            discardedItems = result.Items;
            discardedTotal = result.Total;
            discardedNext = result.NextCursor;
            if (discardedNext is not null && discardedIndex == discardedCursors.Count - 1)
                discardedCursors.Add(discardedNext);
        }
        catch
        {
            loadError = "Couldn't load discarded emails. Please try again.";
            discardedItems = Array.Empty<MailboxMessage>();
            discardedTotal = 0;
            discardedNext = null;
        }
    }

    private async Task PreviousPage()
    {
        if (queueIndex <= 0) return;
        queueIndex--;
        await LoadAsync();
    }

    private async Task NextPage()
    {
        if (queueNext is null) return;
        queueIndex++;
        await LoadAsync();
    }

    private async Task PreviousDiscarded()
    {
        if (discardedIndex <= 0) return;
        discardedIndex--;
        await LoadDiscardedAsync();
    }

    private async Task NextDiscarded()
    {
        if (discardedNext is null) return;
        discardedIndex++;
        await LoadDiscardedAsync();
    }

    private async Task LoadTaggedAsync()
    {
        loadError = null;
        try
        {
            var filter = selectedTags.Count == 0 ? null : selectedTags.ToList();
            var result = await Intake.ListTaggedLiveAsync(taggedCursors[taggedIndex], PageSize, filter);
            taggedItems = result.Items;
            taggedTotal = result.Total;
            taggedNext = result.NextCursor;
            if (taggedNext is not null && taggedIndex == taggedCursors.Count - 1)
                taggedCursors.Add(taggedNext);
            // Remember every tag we see so the filter dropdown can offer them.
            foreach (var message in taggedItems)
                foreach (var tag in message.Categories)
                    knownTags.Add(tag);
        }
        catch
        {
            loadError = "Couldn't load tagged emails. Please try again.";
            taggedItems = Array.Empty<MailboxMessage>();
            taggedTotal = 0;
            taggedNext = null;
        }
    }

    private void ToggleFilterMenu() => filterOpen = !filterOpen;

    private string FilterButtonLabel => selectedTags.Count == 0 ? "All tags" : $"{selectedTags.Count} selected";

    // Tick/untick a tag in the multi-select filter, then re-read the (OR-filtered) list from page one.
    private async Task ToggleTag(string tag)
    {
        if (!selectedTags.Add(tag)) selectedTags.Remove(tag);
        selected = null;
        detail = null;
        detailLoading = false;
        ResetTaggedPaging();
        await LoadTaggedAsync();
    }

    private async Task ClearTagFilters()
    {
        selectedTags.Clear();
        filterOpen = false;
        selected = null;
        detail = null;
        detailLoading = false;
        ResetTaggedPaging();
        await LoadTaggedAsync();
    }

    private async Task PreviousTagged()
    {
        if (taggedIndex <= 0) return;
        taggedIndex--;
        await LoadTaggedAsync();
    }

    private async Task NextTagged()
    {
        if (taggedNext is null) return;
        taggedIndex++;
        await LoadTaggedAsync();
    }

    private async Task LoadUnassignedAsync()
    {
        unassignedError = null;
        try { unassigned = await RequestRegister.ListUnassignedAsync(); }
        catch { unassigned = Array.Empty<Request>(); }
    }

    private async Task ReturnUnassigned(Request request)
    {
        if (busy) return;
        unassignedError = null;
        try
        {
            busy = true;
            await RequestRegister.ReturnToTriageAsync(request.RequestId, request.ProjectId);
            await LoadAsync();
            await LoadUnassignedAsync();
        }
        catch
        {
            unassignedError = "Couldn't return that request to triage. Please try again.";
        }
        finally { busy = false; }
    }

    private async Task Select(MailboxMessage item)
    {
        selected = item;
        mode = TriageMode.None;
        actionError = null;
        ResetLinkState();
        createRecordType = RecordType.Request;
        createProjectId = "";
        createKind = RequestType.Rfi;
        createReference = "";
        createTitle = item.Subject;
        createDescription = item.BodyPreview;
        createRaisedTo = createDrawingRef = createResponseDue = "";
        createTrade = "";
        await LoadDetailAsync(item);
    }

    // Fetch the full body + attachment names on demand when an email is opened. Cancels any in-flight
    // fetch so rapid clicking can't race a stale result onto the newly selected email.
    private async Task LoadDetailAsync(MailboxMessage item)
    {
        detailCts?.Cancel();
        var cts = new CancellationTokenSource();
        detailCts = cts;

        detail = null;
        detailLoading = true;
        try
        {
            var loaded = await Intake.GetMessageDetailAsync(item.Id, item.InternetMessageId, cts.Token);
            if (!cts.IsCancellationRequested && selected?.Id == item.Id)
                detail = loaded;
        }
        catch (OperationCanceledException) { /* superseded by a newer selection */ }
        catch { /* leave detail null so the view falls back to the preview */ }
        finally
        {
            if (selected?.Id == item.Id)
                detailLoading = false;
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576.0:0.#} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes} B";
    }

    private void SetMode(TriageMode next)
    {
        mode = next;
        actionError = null;
    }

    private async Task OnLinkRecordTypeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<RecordType>(e.Value?.ToString(), out var type)) linkRecordType = type;
        linkRecordId = "";
        await LoadLinkRecordsAsync();
    }

    private async Task OnLinkProjectChanged(ChangeEventArgs e)
    {
        linkProjectId = e.Value?.ToString() ?? "";
        linkRecordId = "";
        await LoadLinkRecordsAsync();
    }

    // Load the chosen project's records of the chosen type for the picker. Record-agnostic: the same
    // call backs both the Link panel and the Tagged tab's "link to another record" control.
    private async Task LoadLinkRecordsAsync()
    {
        if (string.IsNullOrWhiteSpace(linkProjectId))
        {
            linkRecords = Array.Empty<LinkableRecord>();
            return;
        }
        try
        {
            linkRecordsLoading = true;
            linkRecordId = "";
            StateHasChanged(); // show the loading state while the fetch is in flight
            linkRecords = await Intake.ListLinkableRecordsAsync(linkProjectId, linkRecordType);
        }
        catch
        {
            linkRecords = Array.Empty<LinkableRecord>();
        }
        finally
        {
            linkRecordsLoading = false;
        }
    }

    // Clear the link picker back to its defaults (type resets to Request) after a selection changes or
    // a link action completes.
    private void ResetLinkState()
    {
        linkRecordType = RecordType.Request;
        linkProjectId = "";
        linkRecordId = "";
        linkRecords = Array.Empty<LinkableRecord>();
    }

    private void OnCreateProjectChanged(ChangeEventArgs e)
    {
        createProjectId = e.Value?.ToString() ?? "";
        createReference = SuggestReference();
    }

    private void OnCreateKindChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var raw)) createKind = (RequestType)raw;
        createReference = SuggestReference();
    }

    private void OnCreateDescriptionInput(ChangeEventArgs e) => createDescription = e.Value?.ToString() ?? "";

    private string SuggestReference()
    {
        if (string.IsNullOrWhiteSpace(createProjectId)) return $"{createKind.DisplayName()}-001";
        var existing = RequestRegister.ForProject(createProjectId, createKind).Count;
        return $"{createKind.DisplayName()}-{existing + 1:000}";
    }

    private async Task DoLink()
    {
        if (selected is null || busy || string.IsNullOrWhiteSpace(linkRecordId)) return;
        await RunAction(async () => await Intake.LinkMessageToRecordAsync(selected.Id, selected.InternetMessageId, linkRecordType, linkRecordId));
    }

    private async Task DoCreate()
    {
        if (selected is null || busy) return;
        if (string.IsNullOrWhiteSpace(createProjectId)) { actionError = "Choose a project."; return; }
        if (string.IsNullOrWhiteSpace(createReference)) { actionError = "A reference is required."; return; }
        if (string.IsNullOrWhiteSpace(createTitle)) { actionError = "A subject is required."; return; }

        var command = new CreateRequestFromMessage(
            selected.Id,
            createProjectId,
            createKind,
            createReference.Trim(),
            createTitle.Trim(),
            createDescription?.Trim() ?? "",
            RaisedTo: NullIfBlank(createRaisedTo),
            DrawingRef: NullIfBlank(createDrawingRef),
            ResponseDue: ParseDate(createResponseDue),
            InternetMessageId: selected.InternetMessageId);

        await RunAction(async () => await Intake.CreateRequestFromMessageAsync(command));
    }

    private void OnCreateRecordTypeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<RecordType>(e.Value?.ToString(), out var type)) createRecordType = type;
    }

    private async Task DoCreateBidPackage()
    {
        if (selected is null || busy) return;
        if (string.IsNullOrWhiteSpace(createProjectId)) { actionError = "Choose a project."; return; }
        if (string.IsNullOrWhiteSpace(createTitle)) { actionError = "A title is required."; return; }

        var command = new CreateBidPackageFromMessage(
            selected.Id,
            createProjectId,
            createTitle.Trim(),
            createTrade?.Trim() ?? "",
            InternetMessageId: selected.InternetMessageId);

        await RunAction(async () => await Intake.CreateBidPackageFromMessageAsync(command));
    }

    private async Task DoDiscard()
    {
        if (selected is null || busy) return;
        await RunAction(async () => await Intake.DiscardMessageAsync(selected.Id, selected.InternetMessageId));
    }

    private async Task DoRestore()
    {
        if (selected is null || busy) return;
        actionError = null;
        try
        {
            busy = true;
            await Intake.RestoreMessageAsync(selected.Id, selected.InternetMessageId);
            selected = null;
            detail = null;
            detailLoading = false;
            ResetDiscardedPaging();
            await LoadDiscardedAsync();
        }
        catch
        {
            actionError = "Couldn't restore that email. Please try again.";
        }
        finally { busy = false; }
    }

    // Runs a Queue-tab action (assign / create / discard), then refreshes the inbox and clears the
    // selection — the message has left the Inbox, so it drops out of the live read.
    private async Task RunAction(Func<Task> action)
    {
        actionError = null;
        try
        {
            busy = true;
            await action();
            ResetQueuePaging();
            await LoadAsync();
            selected = null;
            detail = null;
            detailLoading = false;
            mode = TriageMode.None;
        }
        catch
        {
            actionError = "That action didn't complete. Please try again.";
        }
        finally { busy = false; }
    }

    // Runs a Tagged-tab action (add a tag, remove a tag), then refreshes the tagged list and clears the
    // selection — the email's tag set has changed, so re-read it live.
    private async Task RunTaggedAction(Func<Task> action)
    {
        actionError = null;
        try
        {
            busy = true;
            await action();
            ResetTaggedPaging();
            await LoadTaggedAsync();
            selected = null;
            detail = null;
            detailLoading = false;
            ResetLinkState();
        }
        catch
        {
            actionError = "That action didn't complete. Please try again.";
        }
        finally { busy = false; }
    }

    // Add another workflow tag by linking this already-tagged email to a second record of any type (so
    // it feeds more than one record). Reuses the same generic link command as the queue's "Link to existing".
    private async Task DoAddTagLink()
    {
        if (selected is null || busy || string.IsNullOrWhiteSpace(linkRecordId)) return;
        await RunTaggedAction(async () => await Intake.LinkMessageToRecordAsync(selected.Id, selected.InternetMessageId, linkRecordType, linkRecordId));
    }

    private async Task DoRemoveTag(string tag)
    {
        if (selected is null || busy) return;
        await RunTaggedAction(async () => await Intake.RemoveTagFromMessageAsync(selected.Id, selected.InternetMessageId, tag));
    }

    private void OnTaggedRecordChanged(ChangeEventArgs e) => linkRecordId = e.Value?.ToString() ?? "";

    // Display label for a workflow tag chip: drop the "JPMS/" prefix (e.g. "JPMS/RFI-001" -> "RFI-001").
    private static string TagLabel(string tag) =>
        tag.StartsWith("JPMS/", StringComparison.OrdinalIgnoreCase) ? tag["JPMS/".Length..] : tag;

    private IReadOnlyList<Project> ProjectOptions =>
        Projects.Current ?? (IReadOnlyList<Project>)Array.Empty<Project>();

    // The loaded records for the chosen type + project (empty until both are chosen and the load runs).
    private IReadOnlyList<LinkableRecord> ProjectRecords() => linkRecords;

    // Records on the chosen project whose reference or title overlaps the email subject — surfaced
    // first so a duplicate record isn't created for something already being tracked. Type-agnostic.
    private List<LinkableRecord> DuplicateCandidates()
    {
        var subject = selected?.Subject ?? "";
        var tokens = Tokenise(subject);
        return ProjectRecords()
            .Select(r => (r, score: Overlap(r, subject, tokens)))
            .Where(x => x.score > 0)
            .OrderByDescending(x => x.score)
            .Select(x => x.r)
            .ToList();
    }

    private static int Overlap(LinkableRecord record, string subject, HashSet<string> subjectTokens)
    {
        var score = 0;
        if (!string.IsNullOrWhiteSpace(record.Reference) &&
            subject.Contains(record.Reference, StringComparison.OrdinalIgnoreCase))
            score += 10;
        foreach (var token in Tokenise(record.Title))
            if (subjectTokens.Contains(token)) score++;
        return score;
    }

    private static HashSet<string> Tokenise(string text) =>
        text.Split(new[] { ' ', '\t', '\n', '\r', '-', '_', '.', ',', ':', ';', '[', ']', '(', ')', '/' },
                   StringSplitOptions.RemoveEmptyEntries)
            .Select(w => w.ToLowerInvariant())
            .Where(w => w.Length > 3)
            .ToHashSet();

    private string RowClass(MailboxMessage item)
    {
        var baseClass = "w-full text-left rounded-lg border px-3 py-2 transition";
        return selected?.Id == item.Id
            ? $"{baseClass} border-accent bg-surface-raised"
            : $"{baseClass} border-line hover:border-line-strong hover:bg-surface-raised";
    }

    private string ViewTabClass(QueueView tab)
    {
        var baseClass = "px-3 py-2 text-sm font-medium border-b-2 -mb-px transition";
        return view == tab
            ? $"{baseClass} border-accent text-content"
            : $"{baseClass} border-transparent text-content-muted hover:text-content";
    }

    private string ModeTabClass(TriageMode tab)
    {
        var baseClass = "rounded-lg px-3 py-1.5 text-sm font-medium border transition";
        return mode == tab
            ? $"{baseClass} border-accent text-content bg-surface-raised"
            : $"{baseClass} border-line text-content-muted hover:text-content hover:border-line-strong";
    }

    private string RecordPickClass(LinkableRecord record, bool candidate)
    {
        var baseClass = "w-full text-left rounded-lg border px-3 py-2 flex flex-col gap-0.5 transition";
        if (linkRecordId == record.RecordId) return $"{baseClass} border-accent bg-surface-raised";
        return candidate
            ? $"{baseClass} border-amber-500/40 hover:border-amber-500"
            : $"{baseClass} border-line hover:border-line-strong";
    }

    private static string DisplayFrom(MailboxMessage item) =>
        string.IsNullOrWhiteSpace(item.FromName) ? item.FromEmail : item.FromName;

    private static string Dash(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string Date(DateTimeOffset value) => value.LocalDateTime.ToString("d MMM yyyy, HH:mm");

    private static string? NullIfBlank(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static DateTimeOffset? ParseDate(string value) =>
        DateTimeOffset.TryParse(value, out var parsed) ? parsed : null;

    public void Dispose() => RequestRegister.OnChange -= StateHasChanged;
}
