    private async Task PreviousTagged()
    {
        if (taggedIndex <= 0) return;
        taggedIndex--;
        await LoadTaggedAsync();
    }

    private async Task NextTagged()
    {
        if (taggedNext is null) return;
        taggedIndex++;
        await LoadTaggedAsync();
    }

    private async Task LoadUnassignedAsync()
    {
        unassignedError = null;
        try { unassigned = await RequestRegister.ListUnassignedAsync(); }
        catch { unassigned = Array.Empty<Request>(); }
    }

    private async Task ReturnUnassigned(Request request)
    {
        if (busy) return;
        unassignedError = null;
        try
        {
            busy = true;
            await RequestRegister.ReturnToTriageAsync(request.RequestId, request.ProjectId);
            await LoadAsync();
            await LoadUnassignedAsync();
        }
        catch
        {
            unassignedError = "Couldn't return that request to triage. Please try again.";
        }
        finally { busy = false; }
    }

    // Point the detail pane at an email: set the selection and reset the create forms. Loading
    // the body and thread is the caller's job — Select does both; the jump-to-latest inside
    // LoadThreadAsync reuses this directly so it doesn't re-fetch the thread it already has.
    private void ApplySelection(MailboxMessage item)
    {
        selected = item;
        mode = TriageMode.None;
        actionError = null;
        previewAttachment = null;
        threadNote = null;
        recommendCts?.Cancel();
        recommendation = null;
        recommendError = null;
        recommendLoading = false;
        ResetLinkState();
        replyOutcome = null;
        replyProjectId = "";
        replyBody = "";
        createRecordType = RecordType.Request;
        createProjectId = "";
        // Deliberately blank rather than copied from the email — the subject/body of the email is
        // rarely the right subject/detail for the record, so the triager writes their own (the
        // "Suggest an action" flow can still fill these, but only on an explicit click).
        createTitle = "";
        createDescription = "";
        createRaisedTo = createDrawingRef = createResponseDue = "";
        createAddToProgramme = false;
        createTrade = "";
        createTodoRows = new List<TodoDraftRow> { new() };
        createTodoLinkRequestId = "";
        createTodoLinkRequests = Array.Empty<LinkableRecord>();
    }

    // jumpToLatest: clicking an email in the QUEUE list triages its thread from the newest member —
    // if later replies exist, the selection moves onto the latest one (the reply that says what to
    // do with the rest; every action applies thread-wide anyway). Clicks inside the thread panel
    // pass false so any member can still be read without being bounced back to the latest.
    private async Task Select(MailboxMessage item, bool jumpToLatest = true)
    {
        ApplySelection(item);
        // Body and thread are independent live reads — fetch them side by side.
        await Task.WhenAll(LoadDetailAsync(item), LoadThreadAsync(item, jumpToLatest));
    }

    // Fetch the full body + attachment names on demand when an email is opened. Cancels any in-flight
    // fetch so rapid clicking can't race a stale result onto the newly selected email.
    private async Task LoadDetailAsync(MailboxMessage item)
    {
        detailCts?.Cancel();
        var cts = new CancellationTokenSource();
        detailCts = cts;

        detail = null;
        detailLoading = true;
        try
        {
            var loaded = await Intake.GetMessageDetailAsync(item.Id, item.InternetMessageId, cts.Token);
            if (!cts.IsCancellationRequested && selected?.Id == item.Id)
                detail = loaded;
        }
        catch (OperationCanceledException) { /* superseded by a newer selection */ }
        catch { /* leave detail null so the view falls back to the preview */ }
        finally
        {
            if (selected?.Id == item.Id)
                detailLoading = false;
        }
    }

    // Fetch the selected email's whole conversation for the thread panel. Same cancellation shape as
    // LoadDetailAsync: rapid clicking can't race a stale thread onto the newly selected email. The
    // list is cleared up front so a previous selection's thread never flashes against this one.
    private async Task LoadThreadAsync(MailboxMessage item, bool jumpToLatest = false)
    {
        threadCts?.Cancel();
        var cts = new CancellationTokenSource();
        threadCts = cts;

        thread = Array.Empty<MailboxMessage>();
        if (string.IsNullOrEmpty(item.ConversationId)) { threadLoading = false; return; }

        threadLoading = true;
        var jumped = false;
        try
        {
            var page = await Intake.ListConversationLiveAsync(item.ConversationId, cts.Token);
            if (cts.IsCancellationRequested || selected?.Id != item.Id)
                return;
            thread = page.Items;

            // Triage the thread from its newest member: when the clicked email has later replies,
            // move the selection onto the latest one and note where the user came from. Queue view
            // only — the Discarded/Tagged panes are management surfaces where the clicked email is
            // the one being managed.
            if (jumpToLatest && view == QueueView.Active && thread.Count > 1 && thread[^1].Id != item.Id)
            {
                var latest = thread[^1];
                jumped = true;
                threadLoading = false;
                ApplySelection(latest);
                threadNote = $"This email has newer replies, so the latest ({Date(latest.ReceivedAt)}) is shown — triage from here. "
                    + $"The one you clicked ({Date(item.ReceivedAt)}) is in the thread below.";
                await LoadDetailAsync(latest);
            }
        }
        catch (OperationCanceledException) { /* superseded by a newer selection */ }
        catch { /* leave empty: the panel simply doesn't render */ }
        finally
        {
            if (jumped || selected?.Id == item.Id)
                threadLoading = false;
        }
    }

    private static string ThreadRowClass(bool current)
    {
        var baseClass = "w-full text-left rounded-lg border px-3 py-2 transition";
        return current
            ? $"{baseClass} border-accent bg-surface"
            : $"{baseClass} border-line hover:border-line-strong hover:bg-surface";
    }

    private static string FormatSize(long bytes)
    {
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576.0:0.#} MB";
        if (bytes >= 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes} B";
    }

    private void SetMode(TriageMode next)
    {
        mode = next;
        actionError = null;
    }

    // ---- AI-assisted triage suggestion ----

    // Ask Claude (server-side) to read the selected email's whole thread and recommend the next
    // action. Advisory only; a failed or unconfigured call shows a soft error, never blocks triage.
    private async Task DoRecommend()
    {
        if (selected is null || recommendLoading) return;
        recommendCts?.Cancel();
        var cts = new CancellationTokenSource();
        recommendCts = cts;

        var item = selected;
        recommendation = null;
        recommendError = null;
        recommendLoading = true;
        try
        {
            var result = await Intake.RecommendActionAsync(item, cts.Token);
            if (cts.IsCancellationRequested || selected?.Id != item.Id) return;
            if (result.Available) recommendation = result;
            else recommendError = "Suggestions aren't available right now — triage the email as usual.";
        }
        catch (OperationCanceledException) { /* superseded by a newer selection */ }
        catch
        {
            if (selected?.Id == item.Id)
                recommendError = "Couldn't get a suggestion. Please try again.";
        }
        finally
        {
            if (selected?.Id == item.Id)
                recommendLoading = false;
        }
    }

    // Pre-fill the normal triage controls from the suggestion. Nothing is submitted here — the
    // triager reviews the pre-filled form and confirms through the same buttons as always.
    private async Task ApplyRecommendation()
    {
        if (recommendation is null || selected is null) return;
        var suggestion = recommendation;

        switch (suggestion.RecommendedAction)
        {
            case "link_to_existing":
                SetMode(TriageMode.Link);
                if (suggestion.ProjectId is not null)
                {
                    linkProjectId = suggestion.ProjectId;
                    linkRecordId = "";
                    await LoadLinkRecordsAsync();
                }
                break;

            case "create_request":
                SetMode(TriageMode.Create);
                createRecordType = RecordType.Request;
                PrefillCreate(suggestion);
                break;

            case "create_bid_package":
                SetMode(TriageMode.Create);
                createRecordType = RecordType.BidPackageInvite;
                PrefillCreate(suggestion);
                break;

            case "tag_scheduling":
                SetMode(TriageMode.Create);
                createRecordType = RecordType.Scheduling;
                PrefillCreate(suggestion);
                break;

            case "create_todos":
                SetMode(TriageMode.Create);
                createRecordType = RecordType.Todo;
                PrefillCreate(suggestion);
                if (suggestion.TodoItems.Count > 0)
                    createTodoRows = suggestion.TodoItems.Select(title => new TodoDraftRow { Title = title }).ToList();
                // The suggestion may have set the project, so offer its open requests for the
                // optional request link straight away.
                await LoadCreateTodoLinkRequestsAsync();
                break;

            case "discard":
                SetMode(TriageMode.Discard);
                break;
        }
    }

    // Pre-fill the create form from Claude's drafted record — its own title, description, raised-to
    // and trade, written from the whole thread rather than copied from the email. The triager can
    // still edit every field before submitting.
    private void PrefillCreate(TriageRecommendation suggestion)
    {
        if (suggestion.ProjectId is not null) createProjectId = suggestion.ProjectId;
        if (!string.IsNullOrWhiteSpace(suggestion.SuggestedTitle)) createTitle = suggestion.SuggestedTitle;
        if (!string.IsNullOrWhiteSpace(suggestion.SuggestedDescription)) createDescription = suggestion.SuggestedDescription;
        if (!string.IsNullOrWhiteSpace(suggestion.SuggestedRaisedTo)) createRaisedTo = suggestion.SuggestedRaisedTo;
        if (!string.IsNullOrWhiteSpace(suggestion.SuggestedTrade)) createTrade = suggestion.SuggestedTrade;
        if (!string.IsNullOrWhiteSpace(suggestion.SuggestedResponseDue)
            && DateTimeOffset.TryParse(suggestion.SuggestedResponseDue, out var due))
            createResponseDue = due.ToString("yyyy-MM-dd");
    }

    private Project? RecommendedProject =>
        recommendation?.ProjectId is { } projectId
            ? ProjectOptions.FirstOrDefault(p => p.ProjectId == projectId)
            : null;

