@page "/projects/{ProjectId}/valuation"
@using Jewel.JPMS.Commercial
@using Jewel.JPMS.Contracts.Commercial
@inject AuthService Auth
@inject SessionService Session
@inject IValuationReportStore Store
@inject IValuationInvoiceStore Invoices
@inject IProjectRetentionStore Retention
@inject ICostCenterStore CostCenters
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Valuation Report · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="valuation">
        <div class="flex items-center justify-between gap-4 mb-4 flex-wrap">
            <h2 class="text-lg font-semibold text-content">Valuation Report</h2>
            <div class="flex items-center gap-2 flex-wrap">
                @if (Claims.Count > 0)
                {
                    <select @bind="selectedClaimId"
                            class="rounded-lg border border-line-strong bg-surface-field px-3 py-2 text-sm text-content focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent">
                        @foreach (var claim in Claims)
                        {
                            <option value="@claim.ValuationClaimId">@claim.DisplayName — @claim.Status (@claim.ClaimDate.ToString("dd MMM yyyy"))</option>
                        }
                    </select>
                }
                @if (Selected is not null)
                {
                    <button @onclick="OpenRename" title="Name this claim's period, e.g. June 2026"
                            class="rounded-lg border border-line bg-surface text-content-muted font-medium text-sm px-3 py-2 hover:border-line-strong transition">
                        Rename
                    </button>
                    <button @onclick="@(() => showDeleteClaim = true)" title="Delete this claim and its entries — invoices and snapshots survive with the link cleared"
                            class="rounded-lg border border-line bg-surface text-negative/80 font-medium text-sm px-3 py-2 hover:text-negative hover:border-line-strong transition">
                        Delete
                    </button>
                }
                <button @onclick="ToggleStartClaim"
                        class="rounded-lg border border-line bg-surface text-content-muted font-medium text-sm px-3 py-2 hover:border-line-strong transition">
                    New claim
                </button>
                @if (Selected is { Status: ValuationClaimStatus.Draft })
                {
                    <button @onclick="PreapproveAsync" disabled="@busy"
                            class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-3 py-2 hover:bg-accent-hover disabled:bg-surface-field transition">
                        We're claiming this
                    </button>
                }
                else if (Selected is { Status: ValuationClaimStatus.Preapproved })
                {
                    <button @onclick="ReopenAsync" disabled="@busy"
                            title="Undo the preapproval — back to Draft, % complete editable again"
                            class="rounded-lg border border-line bg-surface text-content-muted font-medium text-sm px-3 py-2 hover:border-line-strong transition">
                        Reopen as draft
                    </button>
                    <button @onclick="RaiseInvoiceAsync" disabled="@(busy || PaymentDueNow <= 0m)"
                            title="@(PaymentDueNow > 0m
                                      ? "Raise a valuation invoice for the payment due, drawn against this claim. Submit or issue it below to freeze the report snapshot."
                                      : "Nothing is currently due — issue or amend invoices below")"
                            class="rounded-lg border border-line bg-surface text-content-muted font-medium text-sm px-3 py-2 hover:border-line-strong disabled:opacity-50 transition">
                        Raise invoice (@Money(PaymentDueNow))
                    </button>
                    <button @onclick="ConfirmClickedAsync" disabled="@busy"
                            class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-3 py-2 hover:bg-accent-hover disabled:bg-surface-field transition">
                        Confirm payment received
                    </button>
                }
            </div>
        </div>

        @if (Selected is { } s)
        {
            <p class="text-sm text-content-muted mb-4">
                @switch (s.Status)
                {
                    case ValuationClaimStatus.Draft:
                        <span>Draft — edit % complete per line, then mark <em>We're claiming this</em> to lock the claim.</span>
                        break;
                    case ValuationClaimStatus.Preapproved:
                        <span>Preapproved on @(s.PreapprovedAt?.ToString("dd MMM yyyy")) — awaiting the client. Confirm once payment is received, or reopen as draft if this was preapproved by mistake.</span>
                        break;
                    case ValuationClaimStatus.Confirmed:
                        <span>Confirmed on @(s.ConfirmedAt?.ToString("dd MMM yyyy")) — amounts are final and carried into the next claim.</span>
                        break;
                }
            </p>
        }
        else
        {
            <p class="text-sm text-content-subtle italic mb-4">No claim selected. Build the bill below, then start a claim to value works complete.</p>
        }

        @if (showStartClaim)
        {
            <section class="rounded-xl border border-line bg-surface p-5 mb-4">
                <h3 class="text-sm font-medium text-content-muted mb-3">Start claim @NextClaimNumber</h3>
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                    <div>
                        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Period name</label>
                        <input type="text" @bind="newClaimName" placeholder="e.g. June 2026"
                               class="w-full rounded-lg border border-line-strong bg-surface-field px-3 py-2 text-sm text-content focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent" />
                    </div>
                    <div>
                        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Claim date</label>
                        <input type="date" @bind="newClaimDate"
                               class="w-full rounded-lg border border-line-strong bg-surface-field px-3 py-2 text-sm text-content focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent" />
                    </div>
                    <FormField Label="Retention %" InputType="number" Value="@newRetentionPercent" OnChange="@(v => newRetentionPercent = v)" />
                    <FormField Label="Retention release %" InputType="number" Value="@newRetentionReleasePercent" OnChange="@(v => newRetentionReleasePercent = v)" />
                </div>
                @if (LatestClaim is not null)
                {
                    <label class="flex items-center gap-2 mt-3 text-sm text-content-muted cursor-pointer select-none"
                           title="Copies each line's cumulative % complete from @LatestClaim.DisplayName, so this period starts where the last one left off and only movement needs entering.">
                        <input type="checkbox" class="cursor-pointer align-middle" @bind="newSeedFromLatest" />
                        Start from @(LatestClaim.DisplayName)'s percentages
                    </label>
                }
                <div class="flex items-center gap-2 mt-3">
                    <button @onclick="StartClaimAsync" disabled="@busy"
                            class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover disabled:bg-surface-field transition">
                        Start claim
                    </button>
                    <button @onclick="@(() => showStartClaim = false)"
                            class="rounded-lg border border-line bg-surface text-content-muted font-medium text-sm px-3 py-2 hover:border-line-strong transition">
                        Cancel
                    </button>
                </div>
            </section>
        }

        @if (Selected is null or { Status: ValuationClaimStatus.Draft })
        {
            <div class="flex justify-end mb-2">
                <button @onclick="OpenAddLine"
                        class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-3 py-2 hover:bg-accent-hover transition">
                    Add line
                </button>
            </div>
        }

        <ValuationReportTable ProjectId="@ProjectId" SelectedClaim="@Selected" PreviousClaim="@PreviousClaim"
                              OnEditLine="StartEditLine" InvoicedToDate="@invoicedToDate">
            <ExtraSections>
                @* The old Cash Calls tab, folded into the report: issued invoices feed
                   "Certified to date" and therefore the payment due. *@
                <ValuationInvoicesSection @ref="invoicesSection"
                                          ProjectId="@ProjectId"
                                          ValuationClaimId="@Selected?.ValuationClaimId"
                                          OnInvoicedToDateChanged="OnInvoicedToDateChanged"
                                          OnCertifiedChanged="OnCertifiedChanged"
                                          OnViewSnapshot="OpenSnapshot" />
                @* Snapshot register: the frozen report behind each invoice submission,
                   plus on-demand period-end captures. *@
                <div class="mt-3">
                    <ValuationSnapshotsSection ProjectId="@ProjectId" OnView="OpenSnapshot" OnDeleted="OnSnapshotDeleted" />
                </div>
            </ExtraSections>
        </ValuationReportTable>

        <Modal IsOpen="@(showLineForm || editingLine is not null)"
               Title="@(editingLine is null ? "Add a line" : "Edit line")"
               ShowFooter="false" Class="max-w-3xl" OnCancel="CloseLineForm">
            <ValuationLineForm ProjectId="@ProjectId" Editing="@editingLine" OnSaved="OnLineSaved" OnCancel="CloseLineForm" />
        </Modal>

        <Modal IsOpen="@(viewingSnapshotId is not null)"
               Title="Valuation report snapshot"
               ShowFooter="false" Class="max-w-6xl" OnCancel="CloseSnapshot">
            @if (viewingSnapshotId is not null)
            {
                <ValuationSnapshotViewer SnapshotId="@viewingSnapshotId" />
            }
        </Modal>

        <Modal IsOpen="@showRename"
               Title="Rename claim"
               ConfirmLabel="@(busy ? "Saving…" : "Save name")"
               OnCancel="@(() => showRename = false)"
               OnConfirm="SaveRenameAsync"
               Class="max-w-md">
            <div class="space-y-3">
                <p class="text-sm text-content">
                    Name the period this claim values — it shows everywhere the claim does.
                    Leave blank to fall back to "Claim @(Selected?.ClaimNumber)".
                </p>
                <FormField Label="Period name" Value="@renameValue" OnChange="@(v => renameValue = v)" />
            </div>
        </Modal>

        <Modal IsOpen="@showDeleteClaim"
               Title="Delete claim"
               ConfirmLabel="@(busy ? "Deleting…" : "Delete claim")"
               OnCancel="@(() => showDeleteClaim = false)"
               OnConfirm="DeleteClaimAsync"
               Class="max-w-md">
            <div class="space-y-2 text-sm text-content">
                <p>
                    Delete <span class="font-medium">@(Selected?.DisplayName)</span> and its per-line
                    % complete entries? This can't be undone.
                </p>
                <p class="text-content-subtle">
                    Valuation invoices and report snapshots keep their amounts and history — only
                    their link to this claim is cleared. Certified to date does not move.
                </p>
            </div>
        </Modal>

        <Modal IsOpen="@showConfirmNudge"
               Title="No invoice issued yet"
               ConfirmLabel="@(busy ? "Confirming…" : "Confirm anyway")"
               OnCancel="@(() => showConfirmNudge = false)"
               OnConfirm="ConfirmAsync"
               Class="max-w-md">
            <div class="space-y-2 text-sm text-content">
                <p>
                    No valuation invoice drawn against <span class="font-medium">@(Selected?.DisplayName)</span>
                    has been issued yet, so certified to date won't reflect this claim.
                </p>
                <p class="text-content-subtle">
                    The usual order is: raise the invoice, submit or issue it (freezing the report
                    snapshot), then confirm the claim once the client pays. You can still confirm
                    now and sort the invoice out afterwards.
                </p>
            </div>
        </Modal>
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;
    private bool busy;
    private bool showStartClaim;
    private bool showLineForm;
    private string selectedClaimId = "";
    private ValuationLineItem? editingLine;
    private decimal invoicedToDate;

    private void OnInvoicedToDateChanged(decimal total)
    {
        invoicedToDate = total;
        StateHasChanged();
    }

    // Certified to date moved (invoice issued / deleted / added as paid): the server has
    // re-frozen any Preapproved claim's totals, so re-pull claims to show them.
    private void OnCertifiedChanged() => Store.Refresh(ProjectId);

    // Read-only viewer for a frozen report snapshot ("show me the report behind VI-0007").
    private string? viewingSnapshotId;
    private void OpenSnapshot(string snapshotId) => viewingSnapshotId = snapshotId;
    private void CloseSnapshot() => viewingSnapshotId = null;

    // Deleting a snapshot clears any invoice's link to it server-side — reload the
    // invoice section so a dead "View report" link doesn't linger.
    private ValuationInvoicesSection? invoicesSection;
    private async Task OnSnapshotDeleted()
    {
        if (invoicesSection is not null) await invoicesSection.ReloadAsync();
    }

    private DateTime newClaimDate = DateTime.Today;
    private string newClaimName = "";
    private string newRetentionPercent = "5";
    private string newRetentionReleasePercent = "0";
    // Rollover default: copy the latest claim's percentages into the new one.
    private bool newSeedFromLatest;

    private bool showRename;
    private string renameValue = "";
    private bool showDeleteClaim;
    // Nudge (not a gate): confirming a claim with no issued/paid linked invoice asks first.
    private bool showConfirmNudge;

    private static readonly System.Globalization.CultureInfo Gb = System.Globalization.CultureInfo.GetCultureInfo("en-GB");
    private static string Money(decimal v) => v.ToString("C2", Gb);

    private IReadOnlyList<ValuationClaim> Claims => Store.ClaimsFor(ProjectId);
    private ValuationClaim? Selected => Claims.FirstOrDefault(c => c.ValuationClaimId == selectedClaimId);
    private int NextClaimNumber => Claims.Count == 0 ? 1 : Claims.Max(c => c.ClaimNumber) + 1;
    private ValuationClaim? LatestClaim => Claims.OrderByDescending(c => c.ClaimNumber).FirstOrDefault();

    // The claim's payment due as the report currently computes it (frozen for a locked claim,
    // live for a draft) — the figure the "Raise invoice" button offers to bill.
    private decimal PaymentDueNow => Selected is null
        ? 0m
        : ValuationSummaryFigures.For(
            Store.LinesFor(ProjectId),
            Store.EntriesFor(Selected.ValuationClaimId),
            Selected, invoicedToDate).PaymentDueExVat;

    // The claim immediately before the selected one (highest ClaimNumber below it), so the
    // report table can show each line's previously-claimed % against what's being claimed now.
    // Null for Claim 1 (nothing came before) or when no claim is selected.
    private ValuationClaim? PreviousClaim => Selected is null
        ? null
        : Claims.Where(c => c.ClaimNumber < Selected.ClaimNumber)
                .OrderByDescending(c => c.ClaimNumber)
                .FirstOrDefault();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        Store.OnChange += OnStoreChanged;
        // Refresh on entry: cached lines/claims render immediately, then update when the
        // background reload lands — so navigating back to this tab never shows stale data.
        Store.Refresh(ProjectId);
        // Warm the retention terms so the new-claim form can default its percentages.
        Retention.Refresh(ProjectId);
        // Revalidate the cost-centre master (stale-while-revalidate) — the report table's
        // "Edit cost centres" mode and the line form both offer it as a dropdown.
        _ = CostCenters.ListAllAsync();
        isLoaded = true;
    }

    private void OnStoreChanged()
    {
        if (string.IsNullOrEmpty(selectedClaimId) && Claims.Count > 0)
            selectedClaimId = Claims[0].ValuationClaimId;
        StateHasChanged();
    }

    private void ToggleStartClaim()
    {
        showStartClaim = !showStartClaim;
        if (!showStartClaim) return;
        // Rolling over is the norm once a claim exists — default the seed on.
        newSeedFromLatest = LatestClaim is not null;
        // Default the percentages from the project's retention terms (Setup tab) when recorded.
        if (Retention.RetentionFor(ProjectId) is { } terms)
            newRetentionPercent = terms.RetentionPercent.ToString("0.##", Gb);
    }

    private async Task StartClaimAsync()
    {
        busy = true;
        var date = new DateTimeOffset(newClaimDate.Date, TimeSpan.Zero);
        var claim = await Store.StartClaimAsync(new StartValuationClaim(
            ProjectId, NextClaimNumber, date,
            FormNumber.ParseAmount(newRetentionPercent), FormNumber.ParseAmount(newRetentionReleasePercent),
            newClaimName.Trim(),
            newSeedFromLatest ? LatestClaim?.ValuationClaimId : null));
        selectedClaimId = claim.ValuationClaimId;
        showStartClaim = false;
        newClaimName = "";
        busy = false;
    }

    // ---- Rename / delete ----------------------------------------------------
    private void OpenRename()
    {
        if (Selected is null) return;
        renameValue = Selected.Name;
        showRename = true;
    }

    private async Task SaveRenameAsync()
    {
        if (Selected is null || busy) return;
        busy = true;
        await Store.RenameClaimAsync(ProjectId, Selected.ValuationClaimId, renameValue.Trim());
        showRename = false;
        busy = false;
    }

    private async Task DeleteClaimAsync()
    {
        if (Selected is null || busy) return;
        busy = true;
        await Store.DeleteClaimAsync(ProjectId, Selected.ValuationClaimId);
        selectedClaimId = "";        // OnStoreChanged re-picks the first remaining claim
        showDeleteClaim = false;
        busy = false;
        // Any invoice that pointed at this claim had its link cleared server-side.
        if (invoicesSection is not null) await invoicesSection.ReloadAsync();
    }

    // ---- Raise invoice from the claim --------------------------------------
    // Creates a Raised invoice for the claim's payment due, drawn against the claim, first
    // day of the claim date's month as its period. Submitting/issuing it below freezes the
    // report snapshot — the guaranteed-snapshot path (unlike a manual/historic entry).
    private async Task RaiseInvoiceAsync()
    {
        if (Selected is null || busy) return;
        var amount = PaymentDueNow;
        if (amount <= 0m) return;
        busy = true;
        try
        {
            var period = new DateTimeOffset(
                new DateTime(Selected.ClaimDate.Year, Selected.ClaimDate.Month, 1), TimeSpan.Zero);
            await Invoices.CreateAsync(ProjectId, period, amount, Selected.ValuationClaimId);
            if (invoicesSection is not null) await invoicesSection.ReloadAsync();
        }
        finally { busy = false; }
    }

    private async Task PreapproveAsync()
    {
        if (Selected is null) return;
        busy = true;
        await Store.PreapproveClaimAsync(ProjectId, Selected.ValuationClaimId);
        busy = false;
    }

    // Nudge, don't enforce: if nothing drawn against this claim has been issued or paid,
    // ask before confirming — certified to date won't include this claim otherwise. If
    // the invoice list can't be checked, don't block the confirm on it.
    private async Task ConfirmClickedAsync()
    {
        if (Selected is null || busy) return;
        bool hasIssuedInvoice;
        try
        {
            var invoices = await Invoices.ListAsync(ProjectId);
            hasIssuedInvoice = invoices.Any(invoice =>
                invoice.ValuationClaimId == Selected.ValuationClaimId
                && invoice.Status is ValuationInvoiceStatus.Issued or ValuationInvoiceStatus.Paid);
        }
        catch { hasIssuedInvoice = true; }
        if (!hasIssuedInvoice) { showConfirmNudge = true; return; }
        await ConfirmAsync();
    }

    private async Task ConfirmAsync()
    {
        if (Selected is null) return;
        showConfirmNudge = false;
        busy = true;
        var confirmed = Selected;
        await Store.ConfirmClaimAsync(ProjectId, confirmed.ValuationClaimId);
        busy = false;
        // Roll straight over: offer the next period seeded from the claim just confirmed,
        // with the following month suggested as its name.
        newSeedFromLatest = true;
        newClaimName = confirmed.ClaimDate.AddMonths(1).ToString("MMMM yyyy", Gb);
        newClaimDate = DateTime.Today;
        showStartClaim = true;
    }

    // Undo an unintended "We're claiming this": Preapproved → Draft.
    private async Task ReopenAsync()
    {
        if (Selected is null) return;
        busy = true;
        await Store.ReopenClaimAsync(ProjectId, Selected.ValuationClaimId);
        busy = false;
    }

    private void OpenAddLine()
    {
        editingLine = null;
        showLineForm = true;
    }

    private void StartEditLine(ValuationLineItem line)
    {
        showLineForm = false;
        editingLine = line;
    }

    private void CloseLineForm()
    {
        showLineForm = false;
        editingLine = null;
    }

    // After an edit, close the modal. After an add, keep it open so several lines can be entered in a row.
    private void OnLineSaved()
    {
        if (editingLine is not null) editingLine = null;
    }

    public void Dispose() => Store.OnChange -= OnStoreChanged;
}
