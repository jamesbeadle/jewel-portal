@page "/projects/{ProjectId}/bid-package-invites"
@inject AuthService Auth
@inject SessionService Session
@inject IProcurementStore ProcurementStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Bid Package Invites · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="bid-package-invites">
        <div class="mb-5">
            <h2 class="text-lg font-semibold text-content">Bid package invites</h2>
            <p class="text-sm text-content-muted">
                Bid packages issued to subcontractors to tender. @Packages.Count package@(Packages.Count == 1 ? "" : "s") on this project.
            </p>
        </div>

        @if (Packages.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">
                No bid package invites yet. They'll appear here once a bid package is created for this project.
            </p>
        }
        else
        {
            <div class="rounded-xl border border-line bg-surface overflow-hidden">
                <table class="w-full text-sm">
                    <thead class="bg-surface-raised border-b border-line">
                        <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                            <th class="px-4 py-3">Package</th>
                            <th class="px-4 py-3 hidden sm:table-cell">Trade</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3 hidden lg:table-cell">Created</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-line">
                        @foreach (var package in Packages)
                        {
                            <tr class="hover:bg-surface-raised">
                                <td class="px-4 py-3">
                                    <a class="text-content font-medium hover:underline underline-offset-4"
                                       href="@($"/projects/{ProjectId}/bid-package-invites/{package.BidPackageId}")">@package.Title</a>
                                </td>
                                <td class="px-4 py-3 text-content-muted hidden sm:table-cell">@package.Trade</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center rounded-full bg-surface-raised border border-line px-2 py-0.5 text-[11px] font-medium text-content-muted">@package.Status</span>
                                </td>
                                <td class="px-4 py-3 text-content-subtle hidden lg:table-cell">@package.CreatedAt.LocalDateTime.ToString("d MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;
    private IReadOnlyList<BidPackage> Packages => ProcurementStore.PackagesFor(ProjectId);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        ProcurementStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => ProcurementStore.OnChange -= StateHasChanged;
}
