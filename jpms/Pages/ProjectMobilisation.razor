@page "/projects/{ProjectId}/mobilisation"
@inject AuthService Auth
@inject SessionService Session
@inject IMobilisationStore MobilisationStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Mobilisation · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="mobilisation">
        <h2 class="text-lg font-semibold text-slate-900 mb-1">Mobilisation</h2>
        <p class="text-sm text-slate-600 mb-5">
            All items must be complete before the project can pass into Live Delivery.
        </p>
        <MobilisationChecklistView Checklist="MobilisationStore.For(ProjectId)" />
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        MobilisationStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => MobilisationStore.OnChange -= StateHasChanged;
}
