@page "/nurture"
@inject AuthService Auth
@inject SessionService Session
@inject ILeadStore LeadStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Nurture · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <header class="mb-6 md:mb-8">
            <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1">JPMS · CRM</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900 leading-tight">Nurture</h1>
            <p class="text-sm text-slate-600 mt-2">
                Lost leads kept warm for future opportunities. Lifecycle re-opens when contacted.
            </p>
        </header>

        @if (Nurturing.Count == 0)
        {
            <p class="text-sm text-slate-500 italic">No leads currently in nurture.</p>
        }
        else
        {
            <LeadsTable Leads="Nurturing" />
        }
    </section>
}

@code {
    private bool isLoaded;

    private IReadOnlyList<Lead> Nurturing =>
        LeadStore.All()
            .Where(lead => lead.Stage is LeadStage.Lost or LeadStage.Nurture)
            .OrderByDescending(lead => lead.CapturedAt)
            .ToList()
            .AsReadOnly();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        LeadStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => LeadStore.OnChange -= StateHasChanged;
}
