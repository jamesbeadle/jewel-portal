@page "/nurture"
@inject AuthService Auth
@inject SessionService Session
@inject ILeadStore LeadStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Nurture · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="px-6 md:px-8 py-8 md:py-12">
        <header class="mb-6 md:mb-8">
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · CRM</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Nurture</h1>
            <p class="text-sm text-content-muted mt-2">
                Lost leads kept warm for future opportunities. Lifecycle re-opens when contacted.
            </p>
        </header>

        <div class="mb-3 flex items-center justify-end">
            <ExportToExcelButton FileName="Nurture leads"
                                 Disabled="@(Nurturing.Count == 0)"
                                 BuildWorkbook="BuildExportWorkbook" />
        </div>

        @if (Nurturing.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">No leads currently in nurture.</p>
        }
        else
        {
            <LeadsTable Leads="Nurturing" />
        }
    </section>
}

@code {
    private bool isLoaded;

    private IReadOnlyList<Lead> Nurturing =>
        LeadStore.All()
            .Where(lead => lead.Stage is LeadStage.Lost or LeadStage.Nurture)
            .OrderByDescending(lead => lead.CapturedAt)
            .ToList()
            .AsReadOnly();

    private ExcelWorkbook? BuildExportWorkbook(bool _)
    {
        var leads = Nurturing;
        if (leads.Count == 0) return null;

        var workbook = new ExcelWorkbook();
        var sheet = workbook.AddSheet("Nurture leads",
            new ExcelColumn("Reference"),
            new ExcelColumn("Contact"),
            new ExcelColumn("Site"),
            new ExcelColumn("Source"),
            new ExcelColumn("Value", ExcelFormat.Currency),
            new ExcelColumn("Stage"));

        foreach (var lead in leads)
        {
            sheet.AddRow(
                lead.Reference,
                lead.ContactName,
                lead.SiteAddress,
                lead.Source.DisplayName(),
                lead.EstimatedValue,
                lead.Stage.DisplayName());
        }
        return workbook;
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        LeadStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => LeadStore.OnChange -= StateHasChanged;
}
