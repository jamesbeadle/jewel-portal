@page "/projects/{ProjectId}/requests"
@page "/projects/{ProjectId}/requests/{Kind}"
@inject AuthService Auth
@inject SessionService Session
@inject IRequestRegister RequestRegister
@inject IVariationStore Variations
@inject IProcurementStore Procurement
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Requests · JPMS</PageTitle>

@*
    The project's document register — Requests, RFIs and Variations (VOQ & VO) in one place,
    because they are one lifecycle: a Request captured at mailbox triage, promoted to an RFI when
    information is formally sought, costed into a VOQ once the scope is identified, approved as a
    VO whose value is written onto the valuation report. The old separate Variations tab is folded
    in here so selecting an RFI from a variation (or a variation from an RFI) never jumps tabs.
    Each document type gets an explainer panel — with its red warnings — that follows the filter.
*@

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="requests">
        <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
            <div>
                <h2 class="text-lg font-semibold text-content">Document register</h2>
                <p class="text-sm text-content-subtle mt-0.5">
                    @AllRecords.Count request@(AllRecords.Count == 1 ? "" : "s") · @OpenCount open · @OverdueCount overdue
                    · @quotes.Count variation@(quotes.Count == 1 ? "" : "s")
                </p>
            </div>
            <div class="flex items-center gap-3">
                <ExportToExcelButton FileName="Requests register"
                                     Disabled="@(!HasExportableRows)"
                                     ShowIncludeAllRows="@(statusView != StatusView.All || ActiveSlug != "all")"
                                     IncludeAllLabel="Include entire register"
                                     BuildWorkbook="BuildExportWorkbook" />
                <button type="button" class="btn-primary" @onclick="OpenRaiseDialog">Raise request</button>
            </div>
        </div>

        <div class="flex flex-wrap items-center gap-2 mb-3 text-sm">
            @foreach (var filter in Filters)
            {
                <a href="@HrefFor(filter.Slug)" class="@FilterClass(filter.Slug)">
                    @filter.Label
                </a>
            }
        </div>

        @* ---- Document-type explainer — follows the active filter ------------------------------
           Each type says what it is; red is reserved for things that can genuinely hurt:
           unanswered RFIs (programme impact) and VOQ money treated as approved. *@
        <div class="rounded-xl border border-line bg-surface px-4 py-3 mb-4">
            <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mb-1.5">
                <p class="eyebrow">Document type</p>
                <span class="text-xs text-content-subtle">·</span>
                <p class="text-xs text-content-subtle">
                    Request @GeneralCount · RFI @RfiCount · VOQ @OpenVoqCount · VO @LiveOrders.Count
                </p>
            </div>
            @switch (ActiveSlug)
            {
                case "general":
                    <p class="text-sm font-medium text-content mb-1">Request — the general document type</p>
                    <p class="text-sm text-content-muted">
                        The most general type. Triaging the projects mailbox creates a Request for any email that
                        needs something doing — each one is tracked as its own record, carrying its conversation,
                        itemised queries and linked emails, until it's resolved, merged into another request, or
                        promoted to an RFI.
                    </p>
                    break;
                case "rfis":
                    <p class="text-sm font-medium text-content mb-1">RFI — Request for Information</p>
                    <p class="text-sm text-content-muted">
                        An official ask of an external party — architect, client or consultant — for information the
                        project needs. An RFI carries an issue date, a contractual response-due date and the
                        ball-in-court party, and its official document can be drafted to the projects mailbox from here.
                    </p>
                    <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mt-2">
                        While an RFI is unanswered the project may be waiting on information — that wait can have a
                        material impact on the programme.
                        @if (OverdueRfiCount > 0)
                        {
                            <span class="font-semibold">@OverdueRfiCount RFI@(OverdueRfiCount == 1 ? " is" : "s are") past
                            @(OverdueRfiCount == 1 ? "its" : "their") response-due date — chase before the programme slips.</span>
                        }
                    </p>
                    break;
                case "variations":
                    <p class="text-sm font-medium text-content mb-1">Variation — VOQ, then VO</p>
                    <p class="text-sm text-content-muted">
                        When every requirement of a specific group has been identified and costed, the request becomes a
                        <span class="text-content font-medium">Variation Order Quote (VOQ)</span> — the priced scope put to
                        the client for approval. Approval raises a <span class="text-content font-medium">Variation Order
                        (VO)</span>: the monetary amount of the work, which is added to the project valuation report.
                    </p>
                    <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mt-2">
                        A VOQ is not approved money — nothing on it appears on the valuation report or can be billed
                        until the client approves it as a VO.
                    </p>
                    @if (UnlinkedRows.Count > 0)
                    {
                        <p class="rounded-lg bg-surface-raised border border-line px-3 py-2 text-sm text-content-muted mt-2">
                            @UnlinkedRows.Count historic variation@(UnlinkedRows.Count == 1 ? " isn't" : "s aren't") linked back
                            to a request yet — open a variation and attach the RFI it was raised from in its
                            <span class="font-medium text-content">Originating request</span> panel.
                        </p>
                    }
                    break;
                default:
                    <p class="text-sm font-medium text-content mb-1">One register, one lifecycle</p>
                    <p class="text-sm text-content-muted">
                        Everything the project is asking of someone lives here and moves through one lifecycle:
                        a <span class="text-content font-medium">Request</span> captured at mailbox triage, promoted to an
                        <span class="text-content font-medium">RFI</span> when information is formally sought, costed into a
                        <span class="text-content font-medium">VOQ</span> once the scope is fully identified, and approved as a
                        <span class="text-content font-medium">VO</span> whose value is written onto the valuation report.
                        Pick a type above for its detail and warnings.
                    </p>
                    break;
            }
        </div>

        @if (ShowsRequestRows)
        {
            <div class="flex flex-wrap items-center gap-2 mb-5 text-sm">
                @foreach (var option in StatusViews)
                {
                    <button type="button" class="@StatusViewClass(option)" @onclick="() => statusView = option">
                        @StatusViewLabel(option) · @StatusViewCount(option)
                    </button>
                }
            </div>
        }

        @if (ShowsRequestRows && CanDraftEmail && SelectedRfis.Count > 0)
        {
            <div class="rounded-xl border border-line bg-surface px-4 py-3 mb-4">
                <div class="flex flex-wrap items-center gap-3">
                    <span class="text-sm font-medium text-content">@SelectedRfis.Count RFI@(SelectedRfis.Count == 1 ? "" : "s") selected</span>
                    <button type="button" class="btn-primary" disabled="@preparingDrafts" @onclick="PrepareSelectedDrafts">
                        @(preparingDrafts ? "Preparing drafts…" : $"Prepare email drafts ({SelectedRfis.Count})")
                    </button>
                    <button type="button" class="btn-secondary" disabled="@preparingDrafts" @onclick="ClearSelection">Clear selection</button>
                </div>
                <p class="text-xs text-content-subtle mt-2">Creates one draft per RFI in the projects mailbox — PDF attached, To/CC/BCC pre-filled from the correspondence profile. Review and send each from Outlook; nothing is sent from here.</p>
            </div>
        }

        @if (ShowsRequestRows && CanMerge && SelectedGenerals.Count > 0)
        {
            <div class="rounded-xl border border-line bg-surface px-4 py-3 mb-4">
                @if (SelectedGenerals.Count == 2)
                {
                    <div class="flex flex-wrap items-center gap-3">
                        <span class="text-sm font-medium text-content">Merge 2 general requests — keep:</span>
                        @foreach (var record in SelectedGenerals)
                        {
                            <label class="flex items-center gap-1.5 text-sm text-content cursor-pointer">
                                <input type="radio" name="merge-survivor" class="cursor-pointer"
                                       checked="@(SurvivorId == record.RequestId)"
                                       @onchange="() => mergeSurvivorId = record.RequestId" />
                                <span class="font-mono text-xs text-content-muted">@RefLabel(record)</span>
                                <span>@record.Title</span>
                            </label>
                        }
                        <button type="button" class="btn-primary" disabled="@merging" @onclick="MergeSelected">
                            @(merging ? "Merging…" : "Merge")
                        </button>
                    </div>
                    <p class="text-xs text-content-subtle mt-2">The kept request absorbs the other's description, conversation, itemised queries and linked emails. The other request closes with a "merged into" link — it stays under Closed for the audit trail and is never counted as open.</p>
                }
                else
                {
                    <p class="text-sm text-content">@SelectedGenerals.Count general request@(SelectedGenerals.Count == 1 ? "" : "s") selected — select exactly 2 to merge them.</p>
                }
            </div>
        }

        @if (mergeError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4">@mergeError</p>
        }
        @if (mergeResult is not null)
        {
            <p class="rounded-lg border border-line bg-surface px-3 py-2 text-sm text-emerald-600 mb-4">@mergeResult</p>
        }

        @if (draftBatchError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4">@draftBatchError</p>
        }
        @if (draftBatch is not null)
        {
            <div class="rounded-xl border border-line bg-surface px-4 py-3 mb-4 space-y-2">
                <p class="text-sm font-medium @(draftBatch.FailedCount == 0 ? "text-emerald-600" : "text-content")">
                    @draftBatch.PreparedCount of @draftBatch.Outcomes.Count draft@(draftBatch.Outcomes.Count == 1 ? "" : "s") created in the projects mailbox.
                    @if (draftBatch.FailedCount > 0)
                    {
                        <span class="text-content-muted font-normal">Failed RFIs stay selected so you can fix and retry.</span>
                    }
                </p>
                <ul class="space-y-1.5 text-sm">
                    @foreach (var outcome in draftBatch.Outcomes)
                    {
                        <li class="flex flex-wrap items-baseline gap-x-2">
                            <span class="font-mono text-xs text-content-muted">@LabelFor(outcome)</span>
                            @if (outcome.Succeeded)
                            {
                                <span class="text-emerald-600">Draft created</span>
                                <span class="text-xs text-content-subtle">To: @string.Join(", ", outcome.Draft!.Recipients)</span>
                                @if (!string.IsNullOrWhiteSpace(outcome.Draft.WebLink))
                                {
                                    <a href="@outcome.Draft.WebLink" target="_blank" rel="noopener"
                                       class="text-xs text-accent hover:underline underline-offset-2">Open in Outlook</a>
                                }
                            }
                            else
                            {
                                <span class="text-negative">@outcome.Error</span>
                            }
                        </li>
                    }
                </ul>
            </div>
        }

        @if (ShowsRequestRows)
        {
            @if (ActiveSlug == "all")
            {
                <h3 class="text-sm font-medium text-content-muted mb-2">Requests &amp; RFIs</h3>
            }
            @if (FilteredRecords.Count == 0)
            {
                <p class="text-sm text-content-subtle italic mb-6">No requests recorded.</p>
            }
            else
            {
                <div class="mb-6">
                    <RequestTable Records="FilteredRecords" ProjectId="@ProjectId"
                                  SelectionEnabled="@(CanDraftEmail || CanMerge)"
                                  RowSelectable="IsSelectableRow"
                                  SelectedIds="selectedIds"
                                  OnToggleSelect="ToggleSelect"
                                  OnToggleSelectAll="ToggleSelectAll"
                                  LinkedVoqs="LinkedVoqsByRequestId" />
                </div>
            }
        }

        @if (ShowsVariationRows)
        {
            @if (ActiveSlug == "all")
            {
                <h3 class="text-sm font-medium text-content-muted mb-2">Variations (VOQ &amp; VO)</h3>
            }

            @if (variationsError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4">@variationsError</p>
            }

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
                <div class="panel p-4">
                    <p class="eyebrow mb-1">Open quotes (VOQ)</p>
                    <p class="text-xl font-semibold text-content">@OpenVoqCount</p>
                </div>
                <div class="panel p-4">
                    <p class="eyebrow mb-1">Approved orders (VO)</p>
                    <p class="text-xl font-semibold text-content">@LiveOrders.Count</p>
                </div>
                <div class="panel p-4">
                    <p class="eyebrow mb-1">Approved value</p>
                    <p class="text-xl font-semibold text-content">@Money(LiveOrders.Sum(vo => vo.Value))</p>
                </div>
            </div>

            @* Subcontractor-raised variation requests: the portal-side entry to this register. Accepting
               creates a Selected VOQ carrying the sub's price (it appears in the table below); the
               normal approve step then writes the VO to the valuation and CVR. *@
            @if (OpenRequests.Count > 0 || ReviewedRequests.Count > 0)
            {
                <div class="rounded-xl border border-line bg-surface overflow-hidden mb-6">
                    <header class="px-5 py-3 border-b border-line bg-surface-raised flex items-center justify-between">
                        <h3 class="text-sm font-medium text-content-muted">Subcontractor variation requests</h3>
                        <span class="text-xs text-content-subtle">@OpenRequests.Count awaiting review</span>
                    </header>
                    @if (requestError is not null)
                    {
                        <p class="mx-5 mt-3 rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@requestError</p>
                    }
                    @if (OpenRequests.Count == 0)
                    {
                        <p class="p-5 text-sm text-content-subtle italic">Nothing awaiting review.</p>
                    }
                    else
                    {
                        <ul class="divide-y divide-line">
                            @foreach (var variationRequest in OpenRequests)
                            {
                                <li class="p-4 text-sm">
                                    <div class="flex items-start justify-between gap-3">
                                        <div>
                                            <p class="font-medium text-content">@variationRequest.Title</p>
                                            <p class="text-xs text-content-subtle mt-1">
                                                @variationRequest.SubcontractorName · against WO-@variationRequest.WorkOrderNumber.ToString("0000") · raised @variationRequest.SubmittedAt.LocalDateTime.ToString("d MMM yyyy")
                                            </p>
                                            <p class="text-sm text-content-muted mt-2 whitespace-pre-line">@variationRequest.Description</p>
                                        </div>
                                        <div class="text-right shrink-0">
                                            <p class="font-medium text-content">@Money(variationRequest.ProposedValue)</p>
                                            @if (CanManageVariations)
                                            {
                                                <div class="flex gap-2 mt-2 justify-end">
                                                    <button type="button" class="rounded-lg bg-accent text-accent-ink text-xs font-medium px-2.5 py-1 hover:bg-accent-hover transition disabled:opacity-60"
                                                            disabled="@requestBusy" @onclick="() => AcceptRequest(variationRequest.VariationRequestId)">
                                                        Accept → VOQ
                                                    </button>
                                                    <button type="button" class="rounded-lg border border-line text-xs font-medium px-2.5 py-1 text-content-muted hover:text-content transition disabled:opacity-60"
                                                            disabled="@requestBusy" @onclick="() => StartReject(variationRequest.VariationRequestId)">
                                                        Reject
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    @if (rejectingRequestId == variationRequest.VariationRequestId)
                                    {
                                        <div class="mt-3 flex flex-wrap gap-2 items-center">
                                            <input class="field w-72" placeholder="Reason (the subcontractor sees this)"
                                                   @bind="rejectReason" @bind:event="oninput" />
                                            <button type="button" class="btn-secondary" disabled="@(requestBusy || string.IsNullOrWhiteSpace(rejectReason))"
                                                    @onclick="() => ConfirmReject(variationRequest.VariationRequestId)">
                                                @(requestBusy ? "Rejecting…" : "Confirm reject")
                                            </button>
                                            <button type="button" class="text-xs text-content-subtle underline underline-offset-2"
                                                    @onclick="() => rejectingRequestId = null">Cancel</button>
                                        </div>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    @if (ReviewedRequests.Count > 0)
                    {
                        <details class="border-t border-line px-5 py-3">
                            <summary class="text-xs text-content-subtle cursor-pointer">Reviewed (@ReviewedRequests.Count)</summary>
                            <ul class="mt-2 space-y-1">
                                @foreach (var reviewed in ReviewedRequests)
                                {
                                    <li class="text-xs text-content-subtle">
                                        @reviewed.Title — @reviewed.Status.ToString().ToLowerInvariant()
                                        @(reviewed.Status == VariationRequestStatus.Rejected && !string.IsNullOrWhiteSpace(reviewed.RejectionReason) ? $" ({reviewed.RejectionReason})" : "")
                                        · @reviewed.SubcontractorName · @Money(reviewed.ProposedValue)
                                    </li>
                                }
                            </ul>
                        </details>
                    }
                </div>
            }

            @* Issue-WO / accept-reject errors need a home even when the review section above is not rendered. *@
            @if (requestError is not null && OpenRequests.Count == 0 && ReviewedRequests.Count == 0)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4">@requestError</p>
            }

            @if (Rows.Count == 0)
            {
                <p class="text-sm text-content-subtle italic">
                    No variations yet. Raise a VOQ from an RFQ on one of the requests above, or accept a
                    subcontractor's variation request.
                </p>
            }
            else
            {
                <div class="rounded-xl border border-line bg-surface overflow-x-auto overflow-y-auto max-h-[85vh]">
                    <table class="w-full text-sm">
                        <thead class="bg-surface-raised border-b border-line">
                            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Ref</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Title</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Request</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Status</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right">Value</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden lg:table-cell">Raised</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden lg:table-cell">Approved</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Work order</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-line">
                            @foreach (var row in Rows)
                            {
                                <tr class="hover:bg-surface-raised">
                                    <td class="px-4 py-3 font-mono text-[12px] whitespace-nowrap">
                                        <a class="text-content hover:underline underline-offset-4"
                                           href="@($"/projects/{ProjectId}/voq/{row.Voq.VariationOrderQuoteId}")">@row.Reference</a>
                                    </td>
                                    <td class="px-4 py-3">
                                        <a class="text-content font-medium hover:underline underline-offset-4"
                                           href="@($"/projects/{ProjectId}/voq/{row.Voq.VariationOrderQuoteId}")">@row.Voq.Title</a>
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        @{ var sourceRequest = RequestFor(row.Voq); }
                                        @if (sourceRequest is not null)
                                        {
                                            @* The trace back up the lifecycle: VOQ → the RFI/request it prices. *@
                                            <a class="font-mono text-xs text-content-muted hover:text-content hover:underline underline-offset-4"
                                               title="@sourceRequest.Title"
                                               href="@($"/projects/{ProjectId}/requests/view/{sourceRequest.RequestId}")">@RefLabel(sourceRequest)</a>
                                        }
                                        else
                                        {
                                            @* Seeded rows predate the VOQ→request link. Kept quiet here — repairing
                                               the link is done deliberately on the variation itself, so the badge
                                               links through to the VOQ page's Originating-request panel. *@
                                            <a class="inline-flex items-center rounded border border-line bg-surface-raised px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-content-subtle hover:text-content hover:border-content-subtle transition-colors"
                                               title="No request behind this variation yet — open it to link the RFI it was raised from"
                                               href="@($"/projects/{ProjectId}/voq/{row.Voq.VariationOrderQuoteId}")">No request</a>
                                        }
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        <span class="@BadgeClass(row)">@VariationStatusLabel(row)</span>
                                    </td>
                                    <td class="px-4 py-3 text-right whitespace-nowrap @(row.IsCancelled ? "text-content-subtle line-through" : "text-content")">
                                        @(row.Value is { } v ? Money(v) : "—")
                                    </td>
                                    <td class="px-4 py-3 text-content-subtle hidden lg:table-cell whitespace-nowrap">@row.Voq.CreatedAt.LocalDateTime.ToString("d MMM yyyy")</td>
                                    <td class="px-4 py-3 text-content-subtle hidden lg:table-cell whitespace-nowrap">
                                        @(row.Order?.ApprovedAt.LocalDateTime.ToString("d MMM yyyy") ?? "—")
                                    </td>
                                    <td class="px-4 py-3 whitespace-nowrap">
                                        @{ var issued = IssuedWorkOrdersFor(row.Order); }
                                        @if (issued.Count > 0)
                                        {
                                            <span class="text-xs text-content-muted">@string.Join(", ", issued.Select(order => $"WO-{order.Number:0000}"))</span>
                                        }
                                        @if (CanIssueWorkOrder(row.Order))
                                        {
                                            <button type="button" class="@(issued.Count > 0 ? "block " : "")text-xs text-accent underline underline-offset-2 disabled:opacity-60"
                                                    title="@(issued.Count > 0 ? "Issue a further work order for this variation" : "Issue the work order instructing this variation")"
                                                    disabled="@requestBusy" @onclick="() => IssueWorkOrder(row.Order!.VariationOrderId)">
                                                @(issued.Count > 0 ? "Issue another" : "Issue WO")
                                            </button>
                                        }
                                        else if (issued.Count == 0)
                                        {
                                            <span class="text-content-subtle">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <p class="text-xs text-content-subtle mt-3">
                    Only approved VOs are included on the valuation report; VOQs stay here until they're approved.
                </p>
            }
        }
    </ProjectPageShell>

    <RaiseRequestDialog ProjectId="@ProjectId"
                        IsOpen="raiseDialogOpen"
                        OnClose="CloseRaiseDialog"
                        OnRaised="OnRaised" />
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string? Kind { get; set; }

    private bool isLoaded;
    private bool raiseDialogOpen;

    private IReadOnlyList<Request> AllRecords => RequestRegister.ForProject(ProjectId);
    private int OpenCount => AllRecords.Count(r => r.Status is not RequestStatus.Closed);
    private int OverdueCount => AllRecords.Count(r => r.IsOverdue);
    private int GeneralCount => AllRecords.Count(r => r.Kind == RequestType.General);
    private int RfiCount => AllRecords.Count(r => r.Kind == RequestType.Rfi);
    private int OverdueRfiCount => AllRecords.Count(r => r.Kind == RequestType.Rfi && r.IsOverdue);

    private void OpenRaiseDialog() => raiseDialogOpen = true;
    private void CloseRaiseDialog() => raiseDialogOpen = false;

    // ---- Bulk selection ----------------------------------------------------------------------
    // One selection set serves two bulk actions: email drafts (RFIs — a General request has no
    // official document to send yet) and pre-RFI merging (open General requests). Selection
    // survives filter/tab switches within the page, so someone can tick rows across views.

    private readonly HashSet<string> selectedIds = new();
    private bool preparingDrafts;
    private string? draftBatchError;
    private RequestEmailDraftBatch? draftBatch;

    // Mirrors PrepareRequestEmailDraftsAuthorisation server-side (directors, project managers,
    // site managers and architects; admins carry every role server-side).
    private bool CanDraftEmail => Session.AvailableRoles.Any(role =>
        role is Role.Admin or Role.ManagingDirector or Role.ProjectManager or Role.SiteManager or Role.Architect);

    // Mirrors MergeRequestsAuthorisation server-side (admins, directors and project managers).
    private bool CanMerge => Session.AvailableRoles.Any(role =>
        role is Role.Admin or Role.ManagingDirector or Role.ProjectManager);

    private static bool IsRfi(Request record) => record.Kind == RequestType.Rfi;

    // Open General requests that haven't already been merged away — the merge candidates.
    private static bool IsMergeableGeneral(Request record) =>
        record.Kind == RequestType.General
        && record.MergedIntoRequestId is null
        && record.Status is not RequestStatus.Closed;

    private bool IsSelectableRow(Request record) =>
        (CanDraftEmail && IsRfi(record)) || (CanMerge && IsMergeableGeneral(record));

    private List<Request> SelectedRfis =>
        AllRecords.Where(r => selectedIds.Contains(r.RequestId) && IsRfi(r)).ToList();

    private List<Request> SelectedGenerals =>
        AllRecords.Where(r => selectedIds.Contains(r.RequestId) && IsMergeableGeneral(r)).ToList();

    private void ToggleSelect(Request record)
    {
        if (!IsSelectableRow(record)) return;
        if (!selectedIds.Remove(record.RequestId)) selectedIds.Add(record.RequestId);
    }

    // The header checkbox acts on the selectable rows currently shown: ticking it adds them all,
    // unticking removes them — without touching selections made under other filters.
    private void ToggleSelectAll(bool select)
    {
        var visible = FilteredRecords.Where(IsSelectableRow).Select(r => r.RequestId).ToList();
        if (select) selectedIds.UnionWith(visible);
        else selectedIds.ExceptWith(visible);
    }

    private void ClearSelection()
    {
        selectedIds.Clear();
        draftBatch = null;
        draftBatchError = null;
        mergeSurvivorId = null;
        mergeError = null;
        mergeResult = null;
    }

    // ---- Pre-RFI merge -----------------------------------------------------------------------
    // Exactly two selected General requests can be combined: the chosen survivor keeps its
    // reference/title and absorbs the other's description, conversation, items and emails; the
    // other closes with a "merged into" audit link (visible under Closed, never counted as open).

    private string? mergeSurvivorId;
    private bool merging;
    private string? mergeError;
    private string? mergeResult;

    private string? SurvivorId =>
        SelectedGenerals.Any(r => r.RequestId == mergeSurvivorId)
            ? mergeSurvivorId
            : SelectedGenerals.FirstOrDefault()?.RequestId;

    private static string RefLabel(Request record) =>
        !string.IsNullOrWhiteSpace(record.Reference) ? record.Reference
        : record.DisplayNumber.Length > 0 ? record.DisplayNumber
        : "(no ref)";

    private async Task MergeSelected()
    {
        var generals = SelectedGenerals;
        if (merging || generals.Count != 2) return;

        var survivor = generals.FirstOrDefault(r => r.RequestId == SurvivorId) ?? generals[0];
        var mergedAway = generals.First(r => r.RequestId != survivor.RequestId);

        merging = true;
        mergeError = null;
        mergeResult = null;
        try
        {
            await RequestRegister.MergeAsync(survivor.RequestId, mergedAway.RequestId, ProjectId);
            mergeResult = $"{RefLabel(mergedAway)} merged into {RefLabel(survivor)} — its conversation, queries and emails now live there.";
            selectedIds.Remove(survivor.RequestId);
            selectedIds.Remove(mergedAway.RequestId);
            mergeSurvivorId = null;
        }
        catch (Exception ex)
        {
            mergeError = ex.Message;
        }
        finally
        {
            merging = false;
        }
    }

    private string LabelFor(RequestEmailDraftOutcome outcome) =>
        !string.IsNullOrWhiteSpace(outcome.Reference)
            ? outcome.Reference!
            : AllRecords.FirstOrDefault(r => r.RequestId == outcome.RequestId)?.Reference ?? outcome.RequestId;

    private async Task PrepareSelectedDrafts()
    {
        var rfiIds = SelectedRfis.Select(r => r.RequestId).ToList();
        if (preparingDrafts || rfiIds.Count == 0) return;
        preparingDrafts = true;
        draftBatch = null;
        draftBatchError = null;
        try
        {
            var batch = await RequestRegister.PrepareEmailDraftsAsync(rfiIds);
            draftBatch = batch;
            // Drafted RFIs come off the selection; failures stay ticked for a fix-and-retry.
            foreach (var outcome in batch.Outcomes.Where(o => o.Succeeded))
                selectedIds.Remove(outcome.RequestId);
            // Drafting moved each Open RFI to Awaiting Response server-side (manually set back to
            // Open if a send is cancelled) — revalidate the register so the table shows it.
            if (batch.Outcomes.Any(o => o.Succeeded))
                RequestRegister.Refresh(ProjectId);
        }
        catch (Exception ex)
        {
            draftBatchError = ex.Message;
        }
        finally
        {
            preparingDrafts = false;
        }
    }

    private void OnRaised(Request raised)
    {
        raiseDialogOpen = false;
        Nav.NavigateTo($"/projects/{ProjectId}/requests/view/{raised.RequestId}");
    }

    // ---- Document-type filters -----------------------------------------------------------------

    private record Filter(string Slug, string Label, RequestType? Kind);

    // The register's document types, in lifecycle order: a Request is the general container from
    // mailbox triage; an RFI is a request promoted to an official ask for information; Variations
    // (VOQ → VO) are the costed-and-approved end of the same lifecycle, folded in from the retired
    // Variations tab. RFQs and the other instruments happen *inside* a request, so they aren't
    // top-level filters. "All" shows the whole register.
    private static readonly Filter[] Filters =
    {
        new("all",        "All",  null),
        new("general",    "Requests", RequestType.General),
        new("rfis",       "RFIs", RequestType.Rfi),
        new("variations", "Variations", null)
    };

    private string ActiveSlug => string.IsNullOrWhiteSpace(Kind) ? "all" : Kind.ToLowerInvariant();

    private bool ShowsRequestRows => ActiveSlug is "all" or "general" or "rfis";
    private bool ShowsVariationRows => ActiveSlug is "all" or "variations";

    private enum StatusView { Open, Closed, All }

    private static readonly StatusView[] StatusViews = { StatusView.Open, StatusView.Closed, StatusView.All };

    // Status filter defaults to Open so the register opens on outstanding work.
    private StatusView statusView = StatusView.Open;

    // Records for the active kind tab, before the open/closed filter is applied.
    private IReadOnlyList<Request> KindRecords
    {
        get
        {
            var filter = Filters.FirstOrDefault(f => f.Slug == ActiveSlug);
            if (filter?.Kind is null) return RequestRegister.ForProject(ProjectId);
            return RequestRegister.ForProject(ProjectId, filter.Kind.Value);
        }
    }

    private IReadOnlyList<Request> FilteredRecords
    {
        get
        {
            IEnumerable<Request> records = statusView switch
            {
                StatusView.Open   => KindRecords.Where(r => r.Status is not RequestStatus.Closed),
                StatusView.Closed => KindRecords.Where(r => r.Status is RequestStatus.Closed),
                _                 => KindRecords
            };
            return InRegisterOrder(records);
        }
    }

    // Register reads in reference order, ascending (RFI-001 at the top). The number is
    // parsed rather than string-compared so unpadded or suffixed references (RFI-49,
    // RFI-049A, RFI-1000) still land in numeric order; free-text or blank references
    // sort after the numbered run within their prefix.
    private static IReadOnlyList<Request> InRegisterOrder(IEnumerable<Request> records) =>
        records
            .OrderBy(r => ReferenceKey(r.Reference).Prefix, StringComparer.OrdinalIgnoreCase)
            .ThenBy(r => ReferenceKey(r.Reference).Number)
            .ThenBy(r => r.Reference, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private static (string Prefix, int Number) ReferenceKey(string? reference)
    {
        var raw = (reference ?? "").Trim();
        if (raw.Length == 0) return ("\uFFFF", int.MaxValue); // blanks last

        var dash = raw.IndexOf('-');
        if (dash > 0)
        {
            var digits = new string(raw[(dash + 1)..].TakeWhile(char.IsDigit).ToArray());
            if (int.TryParse(digits, out var number))
                return (raw[..dash], number);
        }
        return (raw, int.MaxValue); // unnumbered free text after numbered refs
    }

    private int StatusViewCount(StatusView view) => view switch
    {
        StatusView.Open   => KindRecords.Count(r => r.Status is not RequestStatus.Closed),
        StatusView.Closed => KindRecords.Count(r => r.Status is RequestStatus.Closed),
        _                 => KindRecords.Count
    };

    private static string StatusViewLabel(StatusView view) => view switch
    {
        StatusView.Open   => "Open",
        StatusView.Closed => "Closed",
        _                 => "All"
    };

    private string StatusViewClass(StatusView view) =>
        view == statusView
            ? "px-3 py-1.5 rounded-md bg-accent text-accent-ink font-medium"
            : "px-3 py-1.5 rounded-md text-content-muted hover:text-content hover:bg-surface-raised";

    private string HrefFor(string slug) =>
        slug == "all" ? $"/projects/{ProjectId}/requests" : $"/projects/{ProjectId}/requests/{slug}";

    private string FilterClass(string slug)
    {
        if (slug == ActiveSlug) return "px-3 py-1.5 rounded-md bg-accent text-accent-ink font-medium";
        return "px-3 py-1.5 rounded-md text-content-muted hover:text-content hover:bg-surface-raised";
    }

    // ---- Variations (VOQ & VO) — folded in from the retired Variations tab ---------------------

    private string? variationsError;
    private IReadOnlyList<VariationOrderQuote> quotes = Array.Empty<VariationOrderQuote>();
    private IReadOnlyList<VariationOrder> orders = Array.Empty<VariationOrder>();

    // One row per VOQ; once approved, the VO carries the ref, value and status.
    private sealed record VariationRow(VariationOrderQuote Voq, VariationOrder? Order)
    {
        public string Reference => Order?.VariationRef ?? Voq.Reference;
        public decimal? Value => Order?.Value ?? Voq.EstimatedValue;
        public bool IsCancelled => Order?.Status == VariationOrderStatus.Cancelled;
    }

    private List<VariationRow> Rows { get; set; } = new();

    private List<VariationOrder> LiveOrders =>
        orders.Where(vo => vo.Status != VariationOrderStatus.Cancelled).ToList();

    private int OpenVoqCount => quotes.Count(q =>
        q.Status is not (VariationOrderQuoteStatus.Approved or VariationOrderQuoteStatus.Rejected));

    // The trace back up the lifecycle: the register's request this VOQ prices, if its RequestId
    // resolves. Seeded variations predate the link, so a null here renders the red "Not linked".
    private Request? RequestFor(VariationOrderQuote voq) =>
        string.IsNullOrWhiteSpace(voq.RequestId)
            ? null
            : AllRecords.FirstOrDefault(r => string.Equals(r.RequestId, voq.RequestId, StringComparison.OrdinalIgnoreCase));

    private List<VariationRow> UnlinkedRows => Rows.Where(row => RequestFor(row.Voq) is null).ToList();

    // RFI rows get a chip through to their VOQ/VO — the same trace, walked downwards.
    private IReadOnlyDictionary<string, RequestTable.LinkedVoq> LinkedVoqsByRequestId =>
        Rows.Where(row => !string.IsNullOrWhiteSpace(row.Voq.RequestId))
            .GroupBy(row => row.Voq.RequestId, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(
                group => group.Key,
                group => new RequestTable.LinkedVoq(group.First().Voq.VariationOrderQuoteId, group.First().Reference),
                StringComparer.OrdinalIgnoreCase);

    // VOQ → request linking now lives on the VOQ page's "Originating request" panel — the
    // register only signposts it (the quiet "No request" badge links through), keeping the
    // dashboard view clean.

    // ---- Subcontractor variation requests ----

    private IReadOnlyList<SubcontractorVariationRequest> variationRequests = Array.Empty<SubcontractorVariationRequest>();
    private bool requestBusy;
    private string? requestError;
    private string? rejectingRequestId;
    private string rejectReason = "";

    private List<SubcontractorVariationRequest> OpenRequests =>
        variationRequests.Where(r => r.IsOpen).ToList();

    private List<SubcontractorVariationRequest> ReviewedRequests =>
        variationRequests.Where(r => !r.IsOpen).ToList();

    // Mirrors the API's VariationRoles.AllowedToManageVariations.
    private bool CanManageVariations => Session.AvailableRoles.Any(role =>
        role is Role.Admin or Role.ManagingDirector or Role.ProjectManager or Role.QuantitySurveyor);

    // Mirrors the API's issue gate (Director/PM, like awarding a bid package).
    private bool CanIssueWorkOrders => Session.AvailableRoles.Any(role =>
        role is Role.Admin or Role.ManagingDirector or Role.ProjectManager);

    private async Task AcceptRequest(string variationRequestId)
    {
        if (requestBusy) return;
        requestError = null;
        try
        {
            requestBusy = true;
            await Variations.AcceptVariationRequestAsync(variationRequestId);
            await LoadVariationsAsync(); // The new Selected VOQ appears in the register below.
        }
        catch (CommandFailedException ex) { requestError = ex.Message; }
        catch { requestError = "Couldn't accept the request. Please try again."; }
        finally { requestBusy = false; }
    }

    private void StartReject(string variationRequestId)
    {
        rejectingRequestId = variationRequestId;
        rejectReason = "";
        requestError = null;
    }

    private async Task ConfirmReject(string variationRequestId)
    {
        if (requestBusy || string.IsNullOrWhiteSpace(rejectReason)) return;
        requestError = null;
        try
        {
            requestBusy = true;
            await Variations.RejectVariationRequestAsync(variationRequestId, rejectReason.Trim());
            rejectingRequestId = null;
            await LoadVariationsAsync();
        }
        catch (CommandFailedException ex) { requestError = ex.Message; }
        catch { requestError = "Couldn't reject the request. Please try again."; }
        finally { requestBusy = false; }
    }

    // ---- Issue work order for a VO ----

    private IReadOnlyList<WorkOrder> IssuedWorkOrdersFor(VariationOrder? order) =>
        order is null
            ? Array.Empty<WorkOrder>()
            : Procurement.WorkOrdersFor(ProjectId)
                .Where(wo => string.Equals(wo.VariationOrderId, order.VariationOrderId, StringComparison.OrdinalIgnoreCase))
                .ToList();

    private bool CanIssueWorkOrder(VariationOrder? order) =>
        CanIssueWorkOrders
        && order is { Status: VariationOrderStatus.Approved or VariationOrderStatus.Issued }
        && !string.IsNullOrWhiteSpace(order.SubcontractorId);

    private async Task IssueWorkOrder(string variationOrderId)
    {
        if (requestBusy) return;
        requestError = null;
        try
        {
            requestBusy = true;
            await Variations.IssueWorkOrderForVariationOrderAsync(variationOrderId);
            Procurement.Refresh(ProjectId); // Show the new order in the issued-WO column.
            await LoadVariationsAsync();    // VO may have moved Approved → Issued.
        }
        catch (CommandFailedException ex) { requestError = ex.Message; }
        catch { requestError = "Couldn't issue the work order. Please try again."; }
        finally { requestBusy = false; }
    }

    private static string VariationStatusLabel(VariationRow row)
    {
        if (row.Order is { } vo)
        {
            return vo.Status switch
            {
                VariationOrderStatus.Approved => "VO — Approved",
                VariationOrderStatus.Issued => "VO — Issued",
                VariationOrderStatus.Cancelled => "VO — Cancelled",
                _ => "VO"
            };
        }
        return row.Voq.Status switch
        {
            VariationOrderQuoteStatus.Draft => "VOQ — Draft",
            VariationOrderQuoteStatus.Inviting => "VOQ — Inviting",
            VariationOrderQuoteStatus.Tendering => "VOQ — Tendering",
            VariationOrderQuoteStatus.Selected => "VOQ — Selected",
            VariationOrderQuoteStatus.Rejected => "VOQ — Rejected",
            _ => "VOQ"
        };
    }

    private static string BadgeClass(VariationRow row)
    {
        const string baseClass = "inline-flex items-center rounded-full border px-2 py-0.5 text-[11px] font-medium ";
        if (row.Order is { } vo)
        {
            return vo.Status switch
            {
                VariationOrderStatus.Cancelled => baseClass + "bg-negative/10 border-negative/30 text-negative",
                _ => baseClass + "bg-accent/10 border-accent/30 text-accent"
            };
        }
        return row.Voq.Status == VariationOrderQuoteStatus.Rejected
            ? baseClass + "bg-negative/10 border-negative/30 text-negative"
            : baseClass + "bg-surface-raised border-line text-content-muted";
    }

    private static string Money(decimal value) =>
        value.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    // ---- Excel export ----------------------------------------------------------------------
    // One workbook, one sheet per register currently shown — following the active document-type
    // filter (ShowsRequestRows / ShowsVariationRows), same as the register's on-screen sections.
    // Ticking "Include entire register" overrides both the document-type and status filters:
    // every request (all kinds, open and closed) plus the full Variations sheet — the Kind and
    // Status columns carry the distinctions the on-screen filters make.

    private bool HasExportableRows => AllRecords.Count > 0 || Rows.Count > 0;

    private ExcelWorkbook? BuildExportWorkbook(bool includeEntireRegister)
    {
        var workbook = new ExcelWorkbook();

        var requestRecords = includeEntireRegister ? InRegisterOrder(AllRecords) : FilteredRecords;
        if ((includeEntireRegister || ShowsRequestRows) && requestRecords.Count > 0)
        {
            var sheet = workbook.AddSheet("Requests & RFIs",
                new ExcelColumn("Ref"),
                new ExcelColumn("Kind"),
                new ExcelColumn("Subject"),
                new ExcelColumn("Raised to"),
                new ExcelColumn("Drawing / detail"),
                new ExcelColumn("Issued", ExcelFormat.Date),
                new ExcelColumn("Response due", ExcelFormat.Date),
                new ExcelColumn("Days out", ExcelFormat.Integer),
                new ExcelColumn("Value", ExcelFormat.Currency),
                new ExcelColumn("Status"));

            foreach (var record in requestRecords)
            {
                sheet.AddRow(
                    record.Reference,
                    record.Kind.DisplayName(),
                    record.Title,
                    record.RaisedTo,
                    record.DrawingRef,
                    (record.IssuedAt ?? record.RaisedAt).LocalDateTime,
                    record.ResponseDue?.LocalDateTime,
                    record.DaysOutstanding,
                    record.Value,
                    RequestStatusLabel(record.Status));
            }
        }

        if ((includeEntireRegister || ShowsVariationRows) && Rows.Count > 0)
        {
            var sheet = workbook.AddSheet("Variations",
                new ExcelColumn("Ref"),
                new ExcelColumn("Title"),
                new ExcelColumn("Request"),
                new ExcelColumn("Status"),
                new ExcelColumn("Value", ExcelFormat.Currency),
                new ExcelColumn("Raised", ExcelFormat.Date),
                new ExcelColumn("Approved", ExcelFormat.Date),
                new ExcelColumn("Work order"));

            foreach (var row in Rows)
            {
                var sourceRequest = RequestFor(row.Voq);
                var issued = IssuedWorkOrdersFor(row.Order);
                sheet.AddRow(
                    row.Reference,
                    row.Voq.Title,
                    sourceRequest is null ? null : RefLabel(sourceRequest),
                    VariationStatusLabel(row),
                    row.Value,
                    row.Voq.CreatedAt.LocalDateTime,
                    row.Order?.ApprovedAt.LocalDateTime,
                    issued.Count == 0 ? null : string.Join(", ", issued.Select(order => $"WO-{order.Number:0000}")));
            }
        }

        return workbook.Sheets.Count == 0 ? null : workbook;
    }

    // Matches RequestTable's Status cell text.
    private static string RequestStatusLabel(RequestStatus status) => status switch
    {
        RequestStatus.AwaitingResponse => "Awaiting response",
        _ => status.ToString()
    };

    private async Task LoadVariationsAsync()
    {
        try
        {
            quotes = await Variations.ListForProjectAsync(ProjectId);
            orders = await Variations.ListVariationOrdersForProjectAsync(ProjectId);
            variationRequests = await Variations.ListVariationRequestsForProjectAsync(ProjectId);
            var byVoq = orders.ToDictionary(vo => vo.VariationOrderQuoteId);
            Rows = quotes
                .Select(q => new VariationRow(q, byVoq.GetValueOrDefault(q.VariationOrderQuoteId)))
                .OrderByDescending(r => r.Voq.Number)
                .ToList();
            variationsError = null;
        }
        catch { variationsError = "Couldn't load variations. Please try again."; }
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        RequestRegister.OnChange += StateHasChanged;
        // Refresh on entry: cached requests render immediately, then update when the
        // background reload lands — so navigating back to this tab never shows stale data.
        RequestRegister.Refresh(ProjectId);
        Procurement.Refresh(ProjectId); // Background revalidation of work orders (issued-WO column).
        await LoadVariationsAsync();
        isLoaded = true;
    }

    public void Dispose() => RequestRegister.OnChange -= StateHasChanged;
}
