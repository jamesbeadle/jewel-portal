@page "/projects/{ProjectId}/setup"
@using Jewel.JPMS.Features.Projects
@inject AuthService Auth
@inject SessionService Session
@inject ProjectListReadModel Projects
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Setup · JPMS</PageTitle>

@*
    The project's Setup tab — the configuration pieces of the retired Overview tab. Deliberately
    last in the tab nav: project details (stage / entity / project manager, plus the Edit details
    editor) and the correspondence profile that routes every document the project issues.
*@

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="setup">
        @if (Project is not null)
        {
            <div class="flex items-center justify-end mb-3">
                <ProjectDetailsEditor ProjectId="@ProjectId" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-6">
                <Stat Label="Stage"           Value="@Project.Stage.DisplayName()" />
                <Stat Label="Entity"          Value="@Project.Organisation.ShortCode()" />
                <Stat Label="Project Manager" Value="@Project.ProjectManagerEmail" />
            </div>

            <ProjectCorrespondencePanel ProjectId="@ProjectId" />
        }
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;

    private Project? Project => Projects.Find(ProjectId);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        // Re-render when the project list refreshes (e.g. after "Edit details" saves) so the stats
        // pick up the new stage / entity / project manager without a page reload.
        Projects.OnChanged += StateHasChanged;
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
        isLoaded = true;
    }

    public void Dispose() => Projects.OnChanged -= StateHasChanged;
}
