@page "/portal/client/project/{ProjectId}/dashboard"
@layout PortalLayout
@using Jewel.JPMS.Features.Projects
@inject ProjectListReadModel Projects
@inject ISiteStore SiteStore
@inject IRequestRegister RequestRegister

<PageTitle>Progress · Client portal</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <nav class="mb-4 text-sm">
        <a href="/portal/client" class="text-content-subtle hover:text-content underline underline-offset-4">Client portal</a>
        <span class="text-content-subtle mx-2">/</span>
        <span class="text-content-muted font-medium">Progress</span>
    </nav>

    @if (project is null)
    {
        <p class="text-sm text-content-subtle italic">Project not found.</p>
    }
    else
    {
        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-content">@project.Name</h1>
            <p class="text-sm text-content-muted mt-1">Current stage: @project.Stage.DisplayName()</p>
        </header>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4 mb-6">
            <Stat Label="Overall progress" Value="@($"{LatestProgress:0.#}%")" />
            <Stat Label="Open changes"     Value="@OpenChangeCount.ToString()" />
            <Stat Label="Reports issued"   Value="@ReportCount.ToString()" />
        </div>

        <h2 class="text-lg font-semibold text-content mb-3">Recent updates</h2>
        <SiteReportList Reports="SiteStore.ReportsFor(ProjectId)" />
    }
</section>

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private Project? project;

    private decimal LatestProgress =>
        SiteStore.ReportsFor(ProjectId).FirstOrDefault()?.ProgressPercent ?? 0;
    private int OpenChangeCount =>
        RequestRegister.ForProject(ProjectId).Count(c => c.Status != RequestStatus.Closed);
    private int ReportCount => SiteStore.ReportsFor(ProjectId).Count;

    protected override async Task OnInitializedAsync()
    {
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
    }

    protected override void OnParametersSet() => project = Projects.Find(ProjectId);
}
