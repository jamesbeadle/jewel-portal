@page "/projects/{ProjectId}/settings"
@using Jewel.JPMS.Features.Projects
@inject AuthService Auth
@inject SessionService Session
@inject ProjectListReadModel Projects
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Project settings · JPMS</PageTitle>

@*
    The project's ONE settings page — the three per-section Setup tabs recombined so "Setup" means
    a single place: Details (identity and stage banner), Retention & valuation (the money-side
    profile), and Correspondence (the profile that routes every document the project issues). The
    old /setup, /financials-setup and /operations-setup routes redirect here.
*@

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="settings">
        @if (Project is not null)
        {
            <div class="flex flex-wrap items-center gap-2 mb-5 text-sm">
                @foreach (var pane in Panes)
                {
                    <button type="button" class="@PaneClass(pane)" @onclick="() => activePane = pane">@pane</button>
                }
            </div>

            @switch (activePane)
            {
                case DetailsPane:
                    <div class="flex items-center justify-end mb-3">
                        <ProjectDetailsEditor ProjectId="@ProjectId" />
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-4 mb-6">
                        <Stat Label="Stage"           Value="@Project.Stage.DisplayName()" />
                        <Stat Label="Entity"          Value="@Project.Organisation.ShortCode()" />
                        <Stat Label="Project Manager" Value="@Project.ProjectManagerEmail" />
                    </div>
                    break;
                case RetentionPane:
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 mb-6">
                        <NextValuationDateEditor ProjectId="@ProjectId" />
                    </div>
                    <ProjectRetentionPanel ProjectId="@ProjectId" />
                    break;
                default:
                    <ProjectCorrespondencePanel ProjectId="@ProjectId" />
                    break;
            }
        }
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private const string DetailsPane = "Details";
    private const string RetentionPane = "Retention & valuation";
    private const string CorrespondencePane = "Correspondence";
    private static readonly string[] Panes = { DetailsPane, RetentionPane, CorrespondencePane };

    private bool isLoaded;
    private string activePane = DetailsPane;

    private Project? Project => Projects.Find(ProjectId);

    private string PaneClass(string pane) =>
        pane == activePane
            ? "px-3 py-1.5 rounded-md bg-accent text-accent-ink font-medium"
            : "px-3 py-1.5 rounded-md text-content-muted hover:text-content hover:bg-surface-raised";

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        // Re-render when the project list refreshes (e.g. after "Edit details" saves) so the stats
        // pick up the new stage / entity / project manager without a page reload.
        Projects.OnChanged += StateHasChanged;
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
        isLoaded = true;
    }

    public void Dispose() => Projects.OnChanged -= StateHasChanged;
}
