@page "/directory/{SubcontractorId}"
@inject AuthService Auth
@inject SessionService Session
@inject ISubcontractorStore SubcontractorStore
@inject UserInviteService Invites
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@PageTitleText · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (!CanAccess)
{
    <section class="px-6 md:px-8 py-12">
        <h1 class="text-2xl font-semibold text-content mb-2">Not available</h1>
        <p class="text-content-muted">The company directory is restricted to administrators and the managing director.</p>
    </section>
}
else if (!SubcontractorStore.IsLoaded)
{
    @* Directory fetch still in flight — don't flash "not found" before it lands. *@
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (subcontractor is null)
{
    <section class="px-6 md:px-8 py-12">
        <h1 class="text-2xl font-semibold text-content mb-2">Subcontractor not found</h1>
        <p class="text-content-muted">
            <a class="text-content underline" href="/directory">Back to directory</a>.
        </p>
    </section>
}
else
{
    <section class="px-6 md:px-8 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/directory" class="text-content-subtle hover:text-content underline underline-offset-4">Subcontractors</a>
            <span class="text-content-subtle mx-2">/</span>
            <span class="text-content-muted font-medium">@subcontractor.CompanyName</span>
        </nav>

        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-content">@subcontractor.CompanyName</h1>
            <p class="text-sm text-content-muted mt-1">@ContactLine(subcontractor)</p>
        </header>

        @* Trades are managed here: each is a chip from the curated list, so when a company changes
           what it does (no longer a bricklayer, now a hod carrier) the record is updated in place. *@
        <div class="rounded-xl border border-line bg-surface p-4 mb-6">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-sm font-semibold text-content">Trades</h2>
                @if (tradesNote is not null)
                {
                    <span class="text-xs text-content-subtle">@tradesNote</span>
                }
            </div>
            @if (tradesError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@tradesError</p>
            }
            <div class="flex flex-wrap gap-1.5 mb-3">
                @if (subcontractor.Trades.Count == 0)
                {
                    <span class="text-sm text-content-subtle italic">No trades recorded.</span>
                }
                @foreach (var trade in subcontractor.Trades)
                {
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-surface-raised border border-line px-2.5 py-1 text-xs font-medium text-content-muted">
                        @trade.Name
                        <button type="button" class="text-content-subtle hover:text-content" title="Remove @trade.Name"
                                disabled="@tradesBusy" @onclick="() => RemoveTrade(trade.TradeId)">×</button>
                    </span>
                }
            </div>
            <div class="flex flex-wrap gap-2">
                <select class="field w-56" value="" disabled="@tradesBusy" @onchange="AddExistingTrade">
                    <option value="">Add a trade…</option>
                    @foreach (var trade in SubcontractorStore.Trades().Where(t => !subcontractor.HasTrade(t.TradeId)))
                    {
                        <option value="@trade.TradeId">@trade.Name</option>
                    }
                </select>
                <input class="field w-56" placeholder="New trade, e.g. Hod carrier" @bind="newTradeName" @bind:event="oninput" />
                <button type="button" class="btn-secondary" disabled="@(tradesBusy || string.IsNullOrWhiteSpace(newTradeName))" @onclick="AddNewTrade">
                    @(tradesBusy ? "Saving…" : "Add new trade")
                </button>
            </div>
        </div>

        @* Portal access: invites the record's contact to the subcontractor portal. The login is
           linked to this record server-side, scoping their session to their own company's data. *@
        <div class="rounded-xl border border-line bg-surface p-4 mb-6">
            <div class="flex items-center justify-between mb-2">
                <h2 class="text-sm font-semibold text-content">Portal access</h2>
            </div>
            @if (inviteError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@inviteError</p>
            }
            @if (inviteResult is not null)
            {
                <div class="rounded-lg bg-emerald-50 border border-emerald-200 px-3 py-2 text-sm text-emerald-900 mb-3">
                    <p class="mb-1">Invite sent to <span class="font-medium">@inviteResult.Email</span>. If the email doesn't arrive, share this link (valid until @inviteResult.ExpiresAt.LocalDateTime.ToString("d MMM yyyy")):</p>
                    <code class="block break-all text-xs bg-white/60 rounded px-2 py-1">@inviteResult.InviteLink</code>
                </div>
            }
            <div class="flex flex-wrap items-center gap-3">
                <button type="button" class="btn-secondary" disabled="@(inviteBusy || string.IsNullOrWhiteSpace(subcontractor.ContactEmail))" @onclick="InviteToPortal">
                    @(inviteBusy ? "Inviting…" : inviteResult is null ? "Invite to portal" : "Re-send invite")
                </button>
                <span class="text-xs text-content-subtle">
                    @(string.IsNullOrWhiteSpace(subcontractor.ContactEmail)
                        ? "Add a contact email to this record before inviting."
                        : $"Sends a set-password link to {subcontractor.ContactEmail}.")
                </span>
            </div>
        </div>

        @* Statement of account: this record's work orders across every project with the invoices
           claimed against each — downloadable as the branded PDF, or drafted to the contact by
           email (shared-mailbox convention: a human reviews and sends from Outlook). *@
        <div class="rounded-xl border border-line bg-surface p-4 mb-6">
            <div class="flex items-center justify-between mb-2">
                <h2 class="text-sm font-semibold text-content">Statement of account</h2>
            </div>
            <p class="text-xs text-content-subtle mb-3">
                Every work order this company holds, grouped by project, with the invoices claimed
                against each order and the remaining balances — generated from the register, so it's
                always current.
            </p>
            <div class="flex flex-wrap items-center gap-3">
                <a class="btn-secondary" href="@($"/api/subcontractors/{subcontractor.SubcontractorId}/statement/pdf")"
                   target="_blank" rel="noopener">
                    Download PDF
                </a>
                <button type="button" class="btn-secondary" @onclick="() => statementOpen = true">
                    Email statement…
                </button>
            </div>
        </div>

        <SubcontractorComplianceList SubcontractorId="@subcontractor.SubcontractorId" />

        <SubcontractorStatementModal IsOpen="@statementOpen"
                                     SubcontractorId="@subcontractor.SubcontractorId"
                                     SubcontractorName="@subcontractor.CompanyName"
                                     OnClose="() => statementOpen = false" />
    </section>
}

@code {
    [Parameter] public string SubcontractorId { get; set; } = "";

    private bool isLoaded;
    private Subcontractor? subcontractor;

    // Statement-of-account email modal (the download link needs no state).
    private bool statementOpen;

    // Restricted to administrators and the managing director / CEO.
    private bool CanAccess => Session.AvailableRoles.Any(r => r is Role.Admin or Role.ManagingDirector);

    private string PageTitleText => subcontractor?.CompanyName ?? "Subcontractor";

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        SubcontractorStore.OnChange += HandleChange;
        Reload();
        isLoaded = true;
    }

    protected override void OnParametersSet() => Reload();
    private void Reload() => subcontractor = SubcontractorStore.Find(SubcontractorId);
    private void HandleChange() { Reload(); StateHasChanged(); }

    public void Dispose() => SubcontractorStore.OnChange -= HandleChange;

    private static string ContactLine(Subcontractor sub) =>
        string.Join(" · ", new[] { sub.TradesLabel, sub.ContactName, sub.ContactEmail }.Where(x => !string.IsNullOrWhiteSpace(x)));

    // ---- Portal access ----

    private bool inviteBusy;
    private string? inviteError;
    private Contracts.Auth.InviteResult? inviteResult;

    private async Task InviteToPortal()
    {
        if (inviteBusy || subcontractor is null) return;
        inviteError = null;
        try
        {
            inviteBusy = true;
            var outcome = await Invites.InviteSubcontractorAsync(subcontractor.SubcontractorId);
            if (outcome.Success) inviteResult = outcome.Result;
            else inviteError = outcome.Error;
        }
        finally { inviteBusy = false; }
    }

    // ---- Trade management ----

    private bool tradesBusy;
    private string? tradesError;
    private string? tradesNote;
    private string newTradeName = "";

    private async Task AddExistingTrade(ChangeEventArgs e)
    {
        var tradeId = e.Value?.ToString();
        if (string.IsNullOrEmpty(tradeId) || subcontractor is null || subcontractor.HasTrade(tradeId)) return;
        await SaveTrades(subcontractor.Trades.Select(t => t.TradeId).Append(tradeId).ToList());
    }

    private async Task RemoveTrade(string tradeId)
    {
        if (subcontractor is null) return;
        await SaveTrades(subcontractor.Trades.Where(t => !string.Equals(t.TradeId, tradeId, StringComparison.OrdinalIgnoreCase))
            .Select(t => t.TradeId).ToList());
    }

    // Creates the trade in the curated list (or reuses it if the name already exists), then applies it.
    private async Task AddNewTrade()
    {
        if (tradesBusy || subcontractor is null || string.IsNullOrWhiteSpace(newTradeName)) return;
        tradesError = null; tradesNote = null;
        try
        {
            tradesBusy = true;
            var trade = await SubcontractorStore.AddTradeAsync(newTradeName.Trim());
            if (!subcontractor.HasTrade(trade.TradeId))
                await SubcontractorStore.SetTradesAsync(subcontractor.SubcontractorId,
                    subcontractor.Trades.Select(t => t.TradeId).Append(trade.TradeId).ToList());
            newTradeName = "";
            tradesNote = "Saved.";
        }
        catch (CommandFailedException ex) { tradesError = $"Couldn't update trades: {ex.Message}"; }
        catch { tradesError = "Couldn't update trades. Please try again."; }
        finally { tradesBusy = false; }
    }

    private async Task SaveTrades(IReadOnlyList<string> tradeIds)
    {
        if (tradesBusy || subcontractor is null) return;
        tradesError = null; tradesNote = null;
        try
        {
            tradesBusy = true;
            await SubcontractorStore.SetTradesAsync(subcontractor.SubcontractorId, tradeIds);
            tradesNote = "Saved.";
        }
        catch (CommandFailedException ex) { tradesError = $"Couldn't update trades: {ex.Message}"; }
        catch { tradesError = "Couldn't update trades. Please try again."; }
        finally { tradesBusy = false; }
    }
}
