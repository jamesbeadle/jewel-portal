@page "/reports/timesheets"
@inject AuthService Auth
@inject SessionService Session
@using Jewel.JPMS.Features.Projects
@inject ICommercialStore CommercialStore
@inject ProjectListReadModel Projects
@inject NavigationManager Nav

<PageTitle>Timesheets report · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/reports" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Reports</a>
            <span class="text-slate-400 mx-2">/</span>
            <span class="text-slate-700 font-medium">Approved timesheets</span>
        </nav>

        <header class="mb-6 flex items-end justify-between gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-slate-900 leading-tight">Approved timesheets</h1>
                <p class="text-sm text-slate-600 mt-2">@ApprovedTimesheets.Count approved entries · @TotalHours.ToString("0.#") hours.</p>
            </div>
            <a href="@CsvDownloadUrl" download="@FileName"
               class="rounded-lg bg-slate-900 text-white font-medium text-sm px-4 py-2 hover:bg-slate-800 transition">
                Download CSV
            </a>
        </header>

        <ApprovedTimesheetTable Timesheets="ApprovedTimesheets" />
    </section>
}

@code {
    private bool isLoaded;

    private IReadOnlyList<Timesheet> ApprovedTimesheets =>
        (Projects.Current ?? Array.Empty<Project>())
            .SelectMany(project => CommercialStore.TimesheetsFor(project.ProjectId))
            .Where(timesheet => timesheet.IsApproved)
            .OrderByDescending(timesheet => timesheet.WorkedOn)
            .ToList()
            .AsReadOnly();

    private decimal TotalHours => ApprovedTimesheets.Sum(timesheet => timesheet.Hours);

    private string FileName => $"jpms-timesheets-{DateTime.UtcNow:yyyyMMdd}.csv";

    private string CsvDownloadUrl
    {
        get
        {
            var headers = new[] { "TimesheetId", "ProjectReference", "Person", "WorkedOn", "Hours", "CostCode" };
            var rows = ApprovedTimesheets.Select(timesheet =>
            {
                var project = Projects.Find(timesheet.ProjectId);
                return new object?[]
                {
                    timesheet.TimesheetId, project?.Reference ?? timesheet.ProjectId,
                    timesheet.PersonEmail, timesheet.WorkedOn, timesheet.Hours, timesheet.CostCode
                };
            });
            return CsvBuilder.ToDataUrl(CsvBuilder.BuildRows(headers, rows));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
        isLoaded = true;
    }
}
