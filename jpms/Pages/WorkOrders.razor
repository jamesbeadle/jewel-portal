@page "/work-orders"
@inject AuthService Auth
@inject SessionService Session
@inject IProcurementStore ProcurementStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Work orders · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <header class="mb-6 md:mb-8">
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · Finance</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Work orders</h1>
            <p class="text-sm text-content-muted mt-2">
                @AllWorkOrders.Count work orders · total value @Money(TotalValue).
            </p>
        </header>

        <WorkOrderTable WorkOrders="AllWorkOrders" />
    </section>
}

@code {
    private bool isLoaded;
    private IReadOnlyList<WorkOrder> AllWorkOrders => ProcurementStore.AllWorkOrders();
    private decimal TotalValue => AllWorkOrders.Sum(w => w.Value);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        ProcurementStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => ProcurementStore.OnChange -= StateHasChanged;

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
