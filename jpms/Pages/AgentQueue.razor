@page "/agents"
@using Jewel.JPMS.Contracts.Agents
@using Jewel.JPMS.Models
@inject AuthService Auth
@inject SessionService Session
@inject NavigationManager Nav
@inject IAgentDesk Agents
@implements IDisposable

<PageTitle>Agent queue · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-6xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (!CanView)
{
    <section class="max-w-6xl mx-auto px-4 py-12">
        <div class="panel p-8 text-center">
            <p class="text-sm text-content">You don't have access to the agent queue.</p>
            <p class="text-xs text-content-subtle mt-1">The queue is available to administrators, directors, project managers, quantity surveyors and site managers.</p>
        </div>
    </section>
}
else
{
    <section class="max-w-6xl mx-auto px-4 py-8 md:py-12">
        <header class="mb-6">
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · agents</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Agent queue</h1>
            <p class="text-sm text-content-muted mt-2">
                @active active · @queue.Count total watched request@(queue.Count == 1 ? "" : "s") across every project.
            </p>
        </header>

        @if (loadError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4">@loadError</p>
        }

        @if (queue.Count == 0)
        {
            <div class="panel p-8 text-center">
                <p class="text-sm text-content">No agents are watching any requests yet.</p>
                <p class="text-xs text-content-subtle mt-1">Apply an agent from a request to add it to this queue.</p>
            </div>
        }
        else
        {
            <div class="space-y-2">
                @foreach (var item in queue)
                {
                    <a @key="item.RequestAgentId" href="@HrefFor(item)"
                       class="panel flex items-center justify-between gap-3 px-4 py-3 hover:border-line-strong transition">
                        <div class="min-w-0">
                            <div class="flex items-center gap-2 flex-wrap">
                                <span class="text-sm font-medium text-content">@item.DisplayName</span>
                                <span class="inline-flex items-center rounded bg-accent/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-accent">@item.Discipline.DisplayName()</span>
                                @if (item.Status == AgentAssignmentStatus.WorkComplete)
                                {
                                    <span class="inline-flex items-center rounded bg-emerald-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-emerald-600">Complete</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center rounded bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-600">Active</span>
                                }
                            </div>
                            <p class="text-sm text-content truncate mt-0.5">
                                @if (!string.IsNullOrEmpty(item.RequestDisplayNumber))
                                {
                                    <span class="font-mono text-xs text-content-muted mr-2">@item.RequestDisplayNumber</span>
                                }
                                @item.RequestTitle
                            </p>
                            <p class="text-[11px] text-content-subtle mt-0.5">@item.StatusMessage</p>
                        </div>
                        <span class="text-content-subtle shrink-0">&rarr;</span>
                    </a>
                }
            </div>
        }
    </section>
}

@code {
    private bool isLoaded;
    private string? loadError;
    private IReadOnlyList<AgentQueueItem> queue = Array.Empty<AgentQueueItem>();

    private int active => queue.Count(i => i.Status == AgentAssignmentStatus.Active);

    private bool CanView => Session.AvailableRoles.Any(r =>
        r is Role.Admin or Role.ManagingDirector or Role.ProjectManager or Role.QuantitySurveyor or Role.SiteManager);

    protected override void OnInitialized() => Agents.OnChange += OnStoreChanged;

    public void Dispose() => Agents.OnChange -= OnStoreChanged;

    private void OnStoreChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        if (CanView)
        {
            try { queue = await Agents.LoadQueueAsync(); }
            catch { loadError = "Couldn't load the agent queue. Please try again."; }
        }
        isLoaded = true;
    }

    private static string HrefFor(AgentQueueItem item) =>
        $"/projects/{item.ProjectId}/requests/view/{item.RequestId}";
}
