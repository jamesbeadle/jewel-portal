@page "/projects/{ProjectId}/boq/import"
@inject AuthService Auth
@inject SessionService Session
@inject IBoqStore BoqStore
@inject NavigationManager Nav

<PageTitle>Import BoQ · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="boq">
        <nav class="mb-4 text-sm">
            <a href="@($"/projects/{ProjectId}/boq")" class="text-content-subtle hover:text-content underline underline-offset-4">BoQ</a>
            <span class="text-content-subtle mx-2">/</span>
            <span class="text-content-muted font-medium">Bulk import</span>
        </nav>

        <BoqCsvImportForm ProjectId="@ProjectId" OnImported="HandleImported" />
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        isLoaded = true;
    }

    private void HandleImported() => Nav.NavigateTo($"/projects/{ProjectId}/boq");
}
