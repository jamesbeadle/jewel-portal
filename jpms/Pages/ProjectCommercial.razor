@page "/projects/{ProjectId}/commercial"
@page "/projects/{ProjectId}/commercial/{Section}"
@inject AuthService Auth
@inject SessionService Session
@inject ICommercialStore CommercialStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Commercial · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="commercial">
        <CommercialSubNav ProjectId="@ProjectId" ActiveTab="@ActiveSection" />
        <CommercialSectionBody ProjectId="@ProjectId" Section="@ActiveSection" />
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string? Section { get; set; }

    private bool isLoaded;
    private string ActiveSection => string.IsNullOrWhiteSpace(Section) ? "summary" : Section.ToLowerInvariant();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        CommercialStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => CommercialStore.OnChange -= StateHasChanged;
}
