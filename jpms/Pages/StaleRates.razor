@page "/rate-library/stale"
@inject AuthService Auth
@inject SessionService Session
@inject IRateLibrary RateLibrary
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Stale rates · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/rate-library" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Rate library</a>
            <span class="text-slate-400 mx-2">/</span>
            <span class="text-slate-700 font-medium">Stale rates</span>
        </nav>

        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900 leading-tight">Stale rates</h1>
            <p class="text-sm text-slate-600 mt-2">
                Rates not priced in over @StaleDayThreshold days. Re-price before next tender.
            </p>
        </header>

        @if (Stale.Count == 0)
        {
            <p class="text-sm text-slate-500 italic">No rates currently stale.</p>
        }
        else
        {
            <RateTable Rates="Stale" />
        }
    </section>
}

@code {
    private const int StaleDayThreshold = 60;
    private bool isLoaded;

    private IReadOnlyList<Rate> Stale => RateLibrary.Stale(StaleDayThreshold);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        RateLibrary.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => RateLibrary.OnChange -= StateHasChanged;
}
