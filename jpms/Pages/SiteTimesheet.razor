@page "/site/projects/{ProjectId}/timesheet"
@layout SiteLayout
@inject ICommercialStore CommercialStore
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Timesheet · JPMS</PageTitle>

<SiteHeader Eyebrow="Capture" Title="Today's hours" BackHref="@($"/site/projects/{ProjectId}")" />

<section class="max-w-md mx-auto px-4 py-6">
    @if (isSaved)
    {
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50 p-5 text-center">
            <p class="text-sm font-semibold text-emerald-900">Timesheet saved</p>
            <a href="@($"/site/projects/{ProjectId}")"
               class="inline-block mt-3 rounded-xl bg-accent text-accent-ink text-sm font-medium px-4 py-2">
                Back to project
            </a>
        </div>
    }
    else
    {
        <form @onsubmit="HandleSave" @onsubmit:preventDefault="true" class="space-y-3">
            <div>
                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Hours worked today</label>
                <input type="number" step="0.25" min="0" max="24" @bind="hours" required
                       class="field rounded-xl px-4 py-3 text-base" />
            </div>
            <div>
                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Cost code</label>
                <select @bind="costCode" required
                        class="field rounded-xl px-4 py-3 text-base">
                    <option value="">— Choose —</option>
                    @foreach (var budget in Budgets)
                    {
                        <option value="@budget.CostCode">@budget.CostCode (@($"{budget.RemainingAmount:C0}") remaining)</option>
                    }
                </select>
            </div>
            <button type="submit"
                    class="w-full rounded-xl bg-accent text-accent-ink font-semibold text-base px-4 py-4 active:bg-accent-hover"
                    disabled="@(!CanSubmit)">
                Submit timesheet
            </button>
        </form>
    }
</section>

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private decimal hours;
    private string costCode = "";
    private bool isSaved;

    private IReadOnlyList<CostCodeBudget> Budgets => CommercialStore.BudgetsFor(ProjectId);

    private bool CanSubmit => hours > 0 && !string.IsNullOrEmpty(costCode);

    private void HandleSave()
    {
        var timesheet = new Timesheet(
            $"TS-{Guid.NewGuid().ToString("N")[..8].ToUpperInvariant()}",
            ProjectId, Auth.CurrentUser?.Email ?? "site.manager@jewelenterprises.co.uk",
            DateTimeOffset.UtcNow, hours, costCode, false);
        CommercialStore.SaveTimesheet(timesheet);
        isSaved = true;
    }
}
