@page "/projects/{ProjectId}/variations"
@inject NavigationManager Nav

@*
    The Variations tab is retired — VOQ & VO live in the combined document register on the
    Requests tab (Requests → RFIs → Variations, one lifecycle, no tab-jumping between an RFI
    and the variation that prices it). Old links and bookmarks land here and are redirected;
    replace:true keeps Back working naturally.
*@

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    protected override void OnInitialized() =>
        Nav.NavigateTo($"/projects/{ProjectId}/requests/variations", replace: true);
}
