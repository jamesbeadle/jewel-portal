@page "/projects/{ProjectId}/bid-package-invites/{BidPackageId}"
@using Jewel.JPMS.Contracts.Procurement
@using Jewel.JPMS.Contracts.Boq
@using Jewel.JPMS.Contracts.Variations
@using Jewel.JPMS.Cqrs
@inject AuthService Auth
@inject SessionService Session
@inject IQueryClient Queries
@inject ICommandSender Commands
@inject ISubcontractorStore Subs
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Bid Package Invite · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="bid-package-invites">
        <nav class="mb-4 text-sm">
            <a href="@($"/projects/{ProjectId}/bid-package-invites")" class="text-content-subtle hover:text-content underline underline-offset-4">Bid package invites</a>
        </nav>

        @if (error is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4 whitespace-pre-wrap">@error</p>
        }

        @if (package is null)
        {
            <p class="text-sm text-content-subtle italic">That bid package could not be loaded.</p>
        }
        else
        {
            <header class="mb-6 flex flex-wrap items-start justify-between gap-3">
                <div>
                    @if (!string.IsNullOrWhiteSpace(package.Reference))
                    {
                        <p class="text-xs font-mono tracking-wide text-content-subtle mb-0.5">@package.Reference</p>
                    }
                    <div class="flex items-center gap-3">
                        <h2 class="text-lg font-semibold text-content">@package.Title</h2>
                        <span class="inline-flex items-center rounded-full bg-surface-raised border border-line px-2 py-0.5 text-[11px] font-medium text-content-muted">@package.Status</span>
                    </div>
                    <p class="text-sm text-content-muted">@package.Trade</p>
                </div>
                @if (CanManage)
                {
                    <button type="button" class="btn-secondary inline-flex items-center gap-2" disabled="@busy" @onclick="GenerateWithAi">
                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 4.6L18.5 9l-4.6 1.9L12 15l-1.9-4.1L5.5 9l4.6-1.4z"/></svg>
                        Generate using AI
                    </button>
                }
            </header>

            @if (aiNote is not null)
            {
                <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-sm text-content mb-6">@aiNote</p>
            }

            @* ---- Invited subcontractors ---- *@
            <section class="mb-8">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="eyebrow">Invited to tender</h3>
                    @if (CanManage)
                    {
                        <div class="flex items-center gap-4">
                            @if (recipients.Count > 0 && lineItems.Count > 0)
                            {
                                <button type="button" class="text-xs text-accent hover:underline" @onclick="OpenComposeModal">Send invite email</button>
                            }
                            <button type="button" class="text-xs text-accent hover:underline" @onclick="OpenInviteModal">+ Add subcontractor</button>
                        </div>
                    }
                </div>

                @if (sendNote is not null)
                {
                    <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-sm text-content mb-3">@sendNote</p>
                }

                @if (recipients.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">No subcontractors invited yet.</p>
                }
                else
                {
                    <div class="rounded-xl border border-line bg-surface overflow-hidden">
                        <table class="w-full text-sm">
                            <thead class="bg-surface-raised border-b border-line">
                                <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                    <th class="px-4 py-3">Subcontractor</th>
                                    <th class="px-4 py-3 hidden sm:table-cell">Trade</th>
                                    <th class="px-4 py-3">Invited</th>
                                    <th class="px-4 py-3">Status</th>
                                    <th class="px-4 py-3"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-line">
                                @foreach (var recipient in recipients)
                                {
                                    var sub = Subs.Find(recipient.SubcontractorId);
                                    <tr>
                                        <td class="px-4 py-3 text-content font-medium">@(sub?.CompanyName ?? recipient.SubcontractorId)</td>
                                        <td class="px-4 py-3 text-content-muted hidden sm:table-cell">@(sub?.PrimaryTrade ?? "")</td>
                                        <td class="px-4 py-3 text-content-subtle">@recipient.InvitedAt.LocalDateTime.ToString("d MMM yyyy, HH:mm")</td>
                                        <td class="px-4 py-3 text-content-muted">@recipient.Status</td>
                                        <td class="px-4 py-3 text-right">
                                            @if (CanManage)
                                            {
                                                <button type="button" class="text-xs text-content-muted hover:text-negative" disabled="@busy" @onclick="() => RemoveRecipient(recipient)">Remove</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>

            @* ---- Line items, grouped by trade ---- *@
            <section class="mb-8">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="eyebrow">Line items</h3>
                    @if (CanManage && !editingLines)
                    {
                        <button type="button" class="text-xs text-content-muted hover:text-content" @onclick="EditLines">Edit</button>
                    }
                </div>

                @if (editingLines)
                {
                    <div class="rounded-xl border border-line bg-surface overflow-hidden mb-3">
                        <table class="w-full text-sm">
                            <thead class="bg-surface-raised border-b border-line">
                                <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                    <th class="px-3 py-2">Trade</th>
                                    <th class="px-3 py-2">Description</th>
                                    <th class="px-3 py-2 hidden sm:table-cell">Unit</th>
                                    <th class="px-3 py-2">Qty</th>
                                    <th class="px-3 py-2"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-line">
                                @for (var i = 0; i < lineDrafts.Count; i++)
                                {
                                    var draft = lineDrafts[i];
                                    <tr>
                                        <td class="px-3 py-2"><input class="field" @bind="draft.Trade" placeholder="e.g. Electrical" /></td>
                                        <td class="px-3 py-2"><input class="field" @bind="draft.Description" placeholder="Description" /></td>
                                        <td class="px-3 py-2 hidden sm:table-cell"><input class="field" @bind="draft.Unit" placeholder="e.g. m²" /></td>
                                        <td class="px-3 py-2"><input class="field" type="number" step="any" @bind="draft.Quantity" /></td>
                                        <td class="px-3 py-2 text-right">
                                            <button type="button" class="text-xs text-content-muted hover:text-negative" @onclick="() => RemoveLine(draft)">Remove</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="flex items-center gap-3">
                        <button type="button" class="btn-secondary" disabled="@busy" @onclick="AddLine">Add line</button>
                        <button type="button" class="btn-primary" disabled="@busy" @onclick="SaveLines">@(busy ? "Saving…" : "Save line items")</button>
                        <button type="button" class="text-sm text-content-muted hover:text-content" disabled="@busy" @onclick="CancelLines">Cancel</button>
                    </div>
                }
                else if (lineItems.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">No line items on this package yet.</p>
                }
                else
                {
                    @foreach (var group in lineItems.GroupBy(item => item.Trade).OrderBy(g => g.Key))
                    {
                        <div class="mb-4">
                            <p class="text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">@(string.IsNullOrWhiteSpace(group.Key) ? "Unspecified" : group.Key)</p>
                            <div class="rounded-xl border border-line bg-surface overflow-hidden">
                                <table class="w-full text-sm">
                                    <thead class="bg-surface-raised border-b border-line">
                                        <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                            <th class="px-4 py-2">Description</th>
                                            <th class="px-4 py-2 hidden sm:table-cell">Unit</th>
                                            <th class="px-4 py-2">Qty</th>
                                            <th class="px-4 py-2">Covered by</th>
                                            @if (CanManage)
                                            {
                                                <th class="px-4 py-2"></th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-line">
                                        @foreach (var item in group)
                                        {
                                            <tr>
                                                <td class="px-4 py-2 text-content">@item.Description</td>
                                                <td class="px-4 py-2 text-content-muted hidden sm:table-cell">@item.Unit</td>
                                                <td class="px-4 py-2 text-content-muted">@item.Quantity</td>
                                                <td class="px-4 py-2">
                                                    @if (item.Coverage == BidPackageLineCoverage.Unassigned)
                                                    {
                                                        <span class="text-xs text-content-subtle italic">Not linked</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-[11px] font-medium @(item.Coverage == BidPackageLineCoverage.Variation ? "border-accent/30 bg-accent/10 text-accent" : "border-line bg-surface-raised text-content-muted")">@CoverageLabel(item)</span>
                                                    }
                                                </td>
                                                @if (CanManage)
                                                {
                                                    <td class="px-4 py-2 text-right">
                                                        <button type="button" class="text-xs text-accent hover:underline" disabled="@busy" @onclick="() => OpenCoverageModal(item)">@(item.Coverage == BidPackageLineCoverage.Unassigned ? "Link" : "Change")</button>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                }
            </section>

            @* ---- Tender submissions: quotes compared line by line ---- *@
            @if (quotes.Count > 0)
            {
                <section class="mb-8">
                    <h3 class="eyebrow mb-3">Tender submissions</h3>

                    @if (awardNote is not null)
                    {
                        <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-sm text-content mb-3">@awardNote</p>
                    }

                    <div class="rounded-xl border border-line bg-surface overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead class="bg-surface-raised border-b border-line">
                                <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                    <th class="px-4 py-2">Line item</th>
                                    <th class="px-4 py-2 hidden sm:table-cell">Qty</th>
                                    @foreach (var quote in quotes)
                                    {
                                        var sub = Subs.Find(quote.SubcontractorId);
                                        <th class="px-4 py-2 text-right">@(sub?.CompanyName ?? quote.SubcontractorId)</th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-line">
                                @foreach (var item in lineItems)
                                {
                                    <tr>
                                        <td class="px-4 py-2 text-content">@item.Description</td>
                                        <td class="px-4 py-2 text-content-muted hidden sm:table-cell">@item.Quantity @item.Unit</td>
                                        @foreach (var quote in quotes)
                                        {
                                            var line = quoteLines.FirstOrDefault(l => l.QuoteId == quote.QuoteId && l.BidPackageLineItemId == item.LineItemId);
                                            <td class="px-4 py-2 text-right text-content-muted">
                                                @(line is null ? "—" : line.Total.ToString("£#,##0.00"))
                                            </td>
                                        }
                                    </tr>
                                }
                                @{ var extras = quoteLines.Where(l => l.BidPackageLineItemId is null).ToList(); }
                                @if (extras.Count > 0)
                                {
                                    <tr>
                                        <td class="px-4 py-2 text-content-subtle italic">Outside package scope</td>
                                        <td class="px-4 py-2 hidden sm:table-cell"></td>
                                        @foreach (var quote in quotes)
                                        {
                                            var sum = extras.Where(l => l.QuoteId == quote.QuoteId).Sum(l => l.Total);
                                            <td class="px-4 py-2 text-right text-content-subtle italic">@(sum == 0 ? "—" : sum.ToString("£#,##0.00"))</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="bg-surface-raised border-t border-line">
                                <tr class="font-semibold text-content">
                                    <td class="px-4 py-2">Total</td>
                                    <td class="px-4 py-2 hidden sm:table-cell"></td>
                                    @foreach (var quote in quotes)
                                    {
                                        <td class="px-4 py-2 text-right">@quote.Value.ToString("£#,##0.00")</td>
                                    }
                                </tr>
                                @if (CanManage && package.Status != BidPackageStatus.Awarded)
                                {
                                    <tr>
                                        <td class="px-4 py-2"></td>
                                        <td class="px-4 py-2 hidden sm:table-cell"></td>
                                        @foreach (var quote in quotes)
                                        {
                                            <td class="px-4 py-2 text-right">
                                                <button type="button" class="text-xs text-accent hover:underline" disabled="@busy"
                                                        @onclick="() => AwardTo(quote)">Award</button>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tfoot>
                        </table>
                    </div>

                    @foreach (var quote in quotes.Where(q => !string.IsNullOrWhiteSpace(q.Notes)))
                    {
                        var sub = Subs.Find(quote.SubcontractorId);
                        <p class="text-xs text-content-subtle mt-2"><span class="font-medium text-content-muted">@(sub?.CompanyName ?? quote.SubcontractorId):</span> @quote.Notes</p>
                    }
                </section>
            }

            @* ---- Documents (placeholder) ---- *@
            <section class="mb-8">
                <h3 class="eyebrow mb-3">Documents</h3>
                <div class="rounded-xl border border-dashed border-line bg-surface-raised px-4 py-5 text-sm text-content-subtle">
                    Drawings and supporting documents for this package will live here — uploaded files and cloud-storage links you can send to invited subcontractors. Not wired up yet.
                </div>
            </section>

            @* ---- Tender responses & related emails (read live by the package's tag) ---- *@
            <section>
                <h3 class="eyebrow mb-3">Tender responses & related emails</h3>
                @if (emails.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">
                        No emails tagged to this bid package. Replies to the invite land in Triage —
                        tag them with @package.Reference and they appear here.
                    </p>
                }
                else
                {
                    <ul class="space-y-2">
                        @foreach (var email in emails)
                        {
                            <li class="rounded-lg border border-line bg-surface px-4 py-3">
                                <div class="flex flex-wrap items-center justify-between gap-2">
                                    <span class="text-sm font-medium text-content">@(string.IsNullOrWhiteSpace(email.FromName) ? email.FromEmail : email.FromName)</span>
                                    <div class="flex items-center gap-3">
                                        <span class="text-xs text-content-subtle">@email.ReceivedAt.LocalDateTime.ToString("d MMM yyyy, HH:mm")</span>
                                        @if (CanManage)
                                        {
                                            <button type="button" class="text-xs text-accent hover:underline" disabled="@busy"
                                                    @onclick="() => OpenExtractModal(email)">Extract tender</button>
                                        }
                                    </div>
                                </div>
                                <p class="text-sm text-content mt-0.5">
                                    @email.Subject
                                    @if (email.HasAttachments)
                                    {
                                        <span class="ml-2 inline-flex items-center rounded bg-surface-raised border border-line px-1.5 py-0.5 text-[10px] text-content-subtle">attachment</span>
                                    }
                                </p>
                                @if (!string.IsNullOrWhiteSpace(email.BodyPreview))
                                {
                                    <p class="text-xs text-content-subtle mt-1 line-clamp-2">@email.BodyPreview</p>
                                }
                            </li>
                        }
                    </ul>
                }
            </section>
        }
    </ProjectPageShell>

    @* ---- Add-subcontractor modal: the directory, searchable ---- *@
    <Modal IsOpen="showInviteModal" Title="Invite subcontractors" ShowFooter="true"
           ConfirmLabel="@($"Invite {selected.Count}")" CancelLabel="Cancel"
           OnCancel="CloseInviteModal" OnConfirm="ConfirmInvite" Class="max-w-lg w-full">
        <div class="mb-3">
            <input class="field" placeholder="Search by company, trade or contact…"
                   value="@subSearch" @oninput="OnSearchInput" />
        </div>
        @* One-tap trade filters — the distinct trades of invitable companies, for fast selection. *@
        @if (InvitableTrades().Count > 1)
        {
            <div class="mb-3 flex flex-wrap gap-1.5">
                <button type="button"
                        class="rounded-full border px-2.5 py-0.5 text-[11px] font-medium @(tradeFilter is null ? "border-accent bg-accent/10 text-accent" : "border-line bg-surface-raised text-content-muted hover:text-content")"
                        @onclick="() => tradeFilter = null">All trades</button>
                @foreach (var trade in InvitableTrades())
                {
                    var isActive = string.Equals(tradeFilter, trade, StringComparison.OrdinalIgnoreCase);
                    <button type="button"
                            class="rounded-full border px-2.5 py-0.5 text-[11px] font-medium @(isActive ? "border-accent bg-accent/10 text-accent" : "border-line bg-surface-raised text-content-muted hover:text-content")"
                            @onclick="() => tradeFilter = isActive ? null : trade">@trade</button>
                }
            </div>
        }
        @if (Invitable().Count == 0)
        {
            <p class="text-sm text-content-subtle italic">No matching subcontractors in the directory.</p>
        }
        else
        {
            <div class="space-y-1 max-h-80 overflow-y-auto">
                @foreach (var sub in Invitable())
                {
                    <label class="flex items-center gap-2 text-sm text-content py-1">
                        <input type="checkbox" checked="@selected.Contains(sub.SubcontractorId)"
                               @onchange="e => Toggle(sub.SubcontractorId, e)" />
                        <span class="font-medium">@sub.CompanyName</span>
                        <span class="text-content-subtle">· @sub.PrimaryTrade</span>
                    </label>
                }
            </div>
        }
    </Modal>

    @* ---- Line-item coverage modal: link to a contract BoQ line OR a variation ---- *@
    <Modal IsOpen="showCoverageModal" Title="Link line item" ShowFooter="true"
           ConfirmLabel="Save" CancelLabel="Cancel"
           OnCancel="CloseCoverageModal" OnConfirm="ConfirmCoverage" Class="max-w-lg w-full">
        @if (linkingLine is not null)
        {
            <p class="text-sm text-content mb-1 font-medium">@linkingLine.Description</p>
            <p class="text-xs text-content-subtle mb-4">A line is covered by a contract BoQ line (flows into the Valuation Report) or a Variation Order Quote — never both.</p>

            <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Covered by</label>
            <select class="field" @bind="coverageChoice">
                <option value="@BidPackageLineCoverage.Unassigned">Not linked</option>
                <option value="@BidPackageLineCoverage.ContractLine">Contract BoQ line</option>
                <option value="@BidPackageLineCoverage.Variation">Variation Order Quote</option>
            </select>

            @if (coverageChoice == BidPackageLineCoverage.ContractLine)
            {
                <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mt-3 mb-1">BoQ line</label>
                @if (boqLines.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">No BoQ lines on this project yet.</p>
                }
                else
                {
                    <select class="field" @bind="coverageBoqId">
                        <option value="">Select a BoQ line…</option>
                        @foreach (var b in boqLines)
                        {
                            <option value="@b.BoqLineItemId">@b.Description (@b.Unit)</option>
                        }
                    </select>
                }
            }
            else if (coverageChoice == BidPackageLineCoverage.Variation)
            {
                <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mt-3 mb-1">Variation Order Quote</label>
                @if (voqs.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">No variation order quotes on this project yet.</p>
                }
                else
                {
                    <select class="field" @bind="coverageVoqId">
                        <option value="">Select a variation…</option>
                        @foreach (var v in voqs)
                        {
                            <option value="@v.VariationOrderQuoteId">@v.Reference — @v.Title</option>
                        }
                    </select>
                }
            }
        }
    </Modal>

    @* ---- Compose & send the tender-invite email (recipients BCC'd) ---- *@
    <Modal IsOpen="showComposeModal" Title="Send invite email" ShowFooter="true"
           ConfirmLabel="@(busy ? "Sending…" : $"Send to {BccPreview().Count} (BCC)")" CancelLabel="Cancel"
           OnCancel="CloseComposeModal" OnConfirm="ConfirmSendInvite" Class="max-w-2xl w-full">
        <p class="text-xs text-content-subtle mb-3">
            Sent from the shared mailbox with every recipient in BCC — subcontractors never see each
            other. The sent email is tagged to this package, and tagged replies appear under
            Tender responses below.
        </p>

        <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Recipients (BCC)</label>
        @if (BccPreview().Count == 0)
        {
            <p class="text-sm text-negative mb-3">None of the invited subcontractors has an email address in the directory.</p>
        }
        else
        {
            <div class="mb-3 flex flex-wrap gap-1.5">
                @foreach (var name in BccPreview())
                {
                    <span class="inline-flex items-center rounded-full bg-surface-raised border border-line px-2 py-0.5 text-[11px] text-content-muted">@name</span>
                }
            </div>
        }

        <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Subject</label>
        <input class="field mb-3" @bind="composeSubject" />

        <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Message</label>
        <textarea class="field font-mono text-xs" rows="14" @bind="composeBody"></textarea>
        <p class="text-[11px] text-content-subtle mt-1">Sent as HTML — the pre-filled message includes the package's line items for pricing.</p>
    </Modal>

    @* ---- Review an extracted tender before saving it as a quote ---- *@
    <Modal IsOpen="showExtractModal" Title="Tender submission" ShowFooter="true"
           ConfirmLabel="@(busy ? "Saving…" : "Save submission")" CancelLabel="Cancel"
           OnCancel="CloseExtractModal" OnConfirm="ConfirmSaveExtracted" Class="max-w-3xl w-full">
        @if (extractBusy)
        {
            <p class="text-sm text-content-subtle">Reading the email…</p>
        }
        else
        {
            @if (extractProposed)
            {
                <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-xs text-content mb-3">
                    Extracted by Claude from the email — check every figure against the message before saving.
                </p>
            }
            else
            {
                <p class="rounded-lg bg-surface-raised border border-line px-3 py-2 text-xs text-content-muted mb-3">
                    Automatic extraction wasn't available — the package's line items are pre-filled for manual entry.
                </p>
            }

            <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Subcontractor</label>
            <select class="field mb-3" @bind="extractSubcontractorId">
                <option value="">Select the subcontractor…</option>
                @foreach (var recipient in recipients)
                {
                    var sub = Subs.Find(recipient.SubcontractorId);
                    <option value="@recipient.SubcontractorId">@(sub?.CompanyName ?? recipient.SubcontractorId)</option>
                }
            </select>

            <div class="rounded-xl border border-line bg-surface overflow-hidden mb-3">
                <table class="w-full text-sm">
                    <thead class="bg-surface-raised border-b border-line">
                        <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                            <th class="px-3 py-2">Description</th>
                            <th class="px-3 py-2 hidden sm:table-cell">Unit</th>
                            <th class="px-3 py-2">Qty</th>
                            <th class="px-3 py-2">Rate</th>
                            <th class="px-3 py-2">Total</th>
                            <th class="px-3 py-2"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-line">
                        @foreach (var draft in extractDrafts)
                        {
                            <tr class="@(draft.BidPackageLineItemId is null ? "bg-accent/5" : "")">
                                <td class="px-3 py-2"><input class="field" @bind="draft.Description" /></td>
                                <td class="px-3 py-2 hidden sm:table-cell"><input class="field w-16" @bind="draft.Unit" /></td>
                                <td class="px-3 py-2"><input class="field w-20" type="number" step="any" @bind="draft.Quantity" /></td>
                                <td class="px-3 py-2"><input class="field w-24" type="number" step="any" @bind="draft.Rate" @onblur="() => RecalcTotal(draft)" /></td>
                                <td class="px-3 py-2"><input class="field w-28" type="number" step="any" @bind="draft.Total" /></td>
                                <td class="px-3 py-2 text-right">
                                    <button type="button" class="text-xs text-content-muted hover:text-negative" @onclick="() => extractDrafts.Remove(draft)">Remove</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="flex items-center justify-between mb-3">
                <button type="button" class="btn-secondary" @onclick="AddExtractLine">Add line</button>
                <p class="text-sm text-content font-medium">Total: @extractDrafts.Sum(d => d.Total).ToString("£#,##0.00")</p>
            </div>

            <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Notes (exclusions, caveats, lead times)</label>
            <textarea class="field" rows="3" @bind="extractNotes"></textarea>
        }
    </Modal>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string BidPackageId { get; set; } = "";

    private bool isLoaded;
    private bool busy;
    private string? error;
    private string? aiNote;

    private BidPackage? package;
    private IReadOnlyList<BidPackageRecipient> recipients = Array.Empty<BidPackageRecipient>();
    private IReadOnlyList<BidPackageLineItem> lineItems = Array.Empty<BidPackageLineItem>();
    private IReadOnlyList<MailboxMessage> emails = Array.Empty<MailboxMessage>();
    private IReadOnlyList<Quote> quotes = Array.Empty<Quote>();
    private IReadOnlyList<QuoteLineItem> quoteLines = Array.Empty<QuoteLineItem>();
    private IReadOnlyList<BoqLineItem> boqLines = Array.Empty<BoqLineItem>();
    private IReadOnlyList<VariationOrderQuote> voqs = Array.Empty<VariationOrderQuote>();

    private bool showInviteModal;
    private string subSearch = "";
    private readonly HashSet<string> selected = new(StringComparer.OrdinalIgnoreCase);

    private bool CanManage => Session.AvailableRoles.Any(r =>
        r is Role.Admin or Role.ManagingDirector or Role.ProjectManager);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.EnsureLoadedAsync();
            if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
            Subs.OnChange += OnStoreChanged;
            try { _ = Subs.All(); } catch { /* directory load is best-effort */ }
            await LoadAsync();
        }
        catch (Exception ex)
        {
            error = $"Couldn't load this page: {ex.Message}";
        }
        finally
        {
            isLoaded = true;
        }
    }

    public void Dispose() => Subs.OnChange -= OnStoreChanged;

    private void OnStoreChanged() => InvokeAsync(StateHasChanged);

    // Each piece loads independently so one failing query doesn't take down the whole view.
    private async Task LoadAsync()
    {
        try { package = await Queries.AskAsync(new GetBidPackageById(BidPackageId), CancellationToken.None); }
        catch (Exception ex) { error = $"Couldn't load the bid package: {ex.Message}"; }

        try { recipients = await Queries.AskAsync(new ListBidPackageRecipients(BidPackageId), CancellationToken.None); }
        catch (Exception ex) { error = Append(error, $"Couldn't load invited subcontractors: {ex.Message}"); }

        try { lineItems = await Queries.AskAsync(new ListBidPackageLineItems(BidPackageId), CancellationToken.None); }
        catch (Exception ex) { error = Append(error, $"Couldn't load line items: {ex.Message}"); }

        try { emails = await Queries.AskAsync(new ListBidPackageEmails(BidPackageId), CancellationToken.None); }
        catch (Exception ex) { error = Append(error, $"Couldn't load related emails: {ex.Message}"); }

        try { quotes = await Queries.AskAsync(new ListQuotesForBidPackage(BidPackageId), CancellationToken.None); }
        catch (Exception ex) { error = Append(error, $"Couldn't load tender submissions: {ex.Message}"); }

        try { quoteLines = await Queries.AskAsync(new ListQuoteLineItemsForBidPackage(BidPackageId), CancellationToken.None); }
        catch { /* comparison simply shows totals only */ }

        // Coverage targets — best-effort so the picker can offer contract BoQ lines and variations.
        try { boqLines = await Queries.AskAsync(new ListBoqLinesForProject(ProjectId), CancellationToken.None); }
        catch { /* picker simply shows no BoQ lines */ }

        try { voqs = await Queries.AskAsync(new ListVoqsForProject(ProjectId), CancellationToken.None); }
        catch { /* picker simply shows no variations */ }
    }

    // ---- Line-item coverage (link to a contract BoQ line or a variation) ----

    private bool showCoverageModal;
    private BidPackageLineItem? linkingLine;
    private BidPackageLineCoverage coverageChoice = BidPackageLineCoverage.Unassigned;
    private string? coverageBoqId;
    private string? coverageVoqId;

    private string CoverageLabel(BidPackageLineItem item)
    {
        switch (item.Coverage)
        {
            case BidPackageLineCoverage.ContractLine:
                var boq = boqLines.FirstOrDefault(b => b.BoqLineItemId == item.BoqLineItemId);
                return boq is null ? "Contract line" : $"BoQ · {boq.Description}";
            case BidPackageLineCoverage.Variation:
                var voq = voqs.FirstOrDefault(v => v.VariationOrderQuoteId == item.VariationOrderQuoteId);
                return voq is null ? "Variation" : $"{voq.Reference} · {voq.Title}";
            default:
                return "";
        }
    }

    private void OpenCoverageModal(BidPackageLineItem item)
    {
        linkingLine = item;
        coverageChoice = item.Coverage;
        coverageBoqId = item.BoqLineItemId;
        coverageVoqId = item.VariationOrderQuoteId;
        showCoverageModal = true;
    }

    private void CloseCoverageModal()
    {
        showCoverageModal = false;
        linkingLine = null;
    }

    private async Task ConfirmCoverage()
    {
        if (busy || linkingLine is null || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            var boqId = coverageChoice == BidPackageLineCoverage.ContractLine && !string.IsNullOrWhiteSpace(coverageBoqId) ? coverageBoqId : null;
            var voqId = coverageChoice == BidPackageLineCoverage.Variation && !string.IsNullOrWhiteSpace(coverageVoqId) ? coverageVoqId : null;
            lineItems = await Commands.SendAsync(
                new SetBidPackageLineItemCoverage(linkingLine.LineItemId, coverageChoice, boqId, voqId), CancellationToken.None);
            showCoverageModal = false;
            linkingLine = null;
        }
        catch { error = "Couldn't update coverage. Make sure a BoQ line or variation is selected, then try again."; }
        finally { busy = false; }
    }

    private static string Append(string? existing, string line) =>
        string.IsNullOrEmpty(existing) ? line : existing + "\n" + line;

    private void GenerateWithAi() =>
        aiNote = "AI generation isn't wired up yet. When enabled, this will send the related emails and any drawings to Claude and draft the bid package — scope, line items and suggested subcontractors — for you to review.";

    // ---- Invite (modal over the directory) ----

    private string? tradeFilter;

    private void OpenInviteModal()
    {
        selected.Clear();
        subSearch = "";
        // Pre-filter to the package's trade when the directory knows it — one less tap.
        tradeFilter = InvitableTrades()
            .FirstOrDefault(t => string.Equals(t, package?.Trade, StringComparison.OrdinalIgnoreCase));
        showInviteModal = true;
    }

    // The distinct trades among companies that could be invited (never clients/architects).
    private IReadOnlyList<string> InvitableTrades() =>
        Subs.All()
            .Where(s => s.Category is DirectoryCategory.Subcontractor or DirectoryCategory.Supplier)
            .Select(s => (s.PrimaryTrade ?? "").Trim())
            .Where(t => t.Length > 0)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(t => t, StringComparer.OrdinalIgnoreCase)
            .ToList();

    private void CloseInviteModal() => showInviteModal = false;

    private void OnSearchInput(ChangeEventArgs e) => subSearch = e.Value?.ToString() ?? "";

    private IReadOnlyList<Subcontractor> Invitable()
    {
        var invited = recipients.Select(r => r.SubcontractorId).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var q = (subSearch ?? "").Trim();
        return Subs.All()
            // Only companies we tender to — never clients or architects.
            .Where(s => s.Category is DirectoryCategory.Subcontractor or DirectoryCategory.Supplier)
            .Where(s => !invited.Contains(s.SubcontractorId))
            .Where(s => tradeFilter is null || string.Equals((s.PrimaryTrade ?? "").Trim(), tradeFilter, StringComparison.OrdinalIgnoreCase))
            .Where(s => q.Length == 0
                || (s.CompanyName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || (s.PrimaryTrade ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || (s.ContactName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void Toggle(string subcontractorId, ChangeEventArgs e)
    {
        if (e.Value is true) selected.Add(subcontractorId);
        else selected.Remove(subcontractorId);
    }

    private async Task ConfirmInvite()
    {
        if (busy || selected.Count == 0 || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            recipients = await Commands.SendAsync(
                new InviteSubcontractorsToBidPackage(BidPackageId, selected.ToList()), CancellationToken.None);
            selected.Clear();
            showInviteModal = false;
            package = await Queries.AskAsync(new GetBidPackageById(BidPackageId), CancellationToken.None);
        }
        catch { error = "Couldn't send those invites. Please try again."; }
        finally { busy = false; }
    }

    private async Task RemoveRecipient(BidPackageRecipient recipient)
    {
        if (busy || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            recipients = await Commands.SendAsync(
                new RemoveBidPackageRecipient(BidPackageId, recipient.RecipientId), CancellationToken.None);
        }
        catch { error = "Couldn't remove that subcontractor. Please try again."; }
        finally { busy = false; }
    }

    // ---- Compose & send the tender-invite email ----

    private bool showComposeModal;
    private string composeSubject = "";
    private string composeBody = "";
    private string? sendNote;

    // The companies that will actually be BCC'd — invited recipients with a directory email.
    private IReadOnlyList<string> BccPreview() =>
        recipients
            .Select(r => Subs.Find(r.SubcontractorId))
            .Where(s => s is not null && !string.IsNullOrWhiteSpace(s.ContactEmail))
            .Select(s => s!.CompanyName)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

    private void OpenComposeModal()
    {
        if (package is null) return;
        composeSubject = $"Invitation to tender — {package.Title} ({package.Reference})";
        composeBody = DefaultInviteBody();
        sendNote = null;
        showComposeModal = true;
    }

    private void CloseComposeModal() => showComposeModal = false;

    // The pre-filled HTML invite: scope summary plus the line items to price, grouped by trade.
    private string DefaultInviteBody()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("<p>Hello,</p>");
        sb.AppendLine($"<p>Jewel Bespoke Build invites you to tender for the <strong>{package!.Title}</strong> package (ref {package.Reference}). Please price the items below and reply to this email with your rates, exclusions and lead times, quoting the reference in your reply.</p>");
        foreach (var group in lineItems.GroupBy(item => item.Trade).OrderBy(g => g.Key))
        {
            var heading = string.IsNullOrWhiteSpace(group.Key) ? "General" : group.Key;
            sb.AppendLine($"<p><strong>{heading}</strong></p>");
            sb.AppendLine("<table border=\"1\" cellpadding=\"6\" cellspacing=\"0\" style=\"border-collapse:collapse\">");
            sb.AppendLine("<tr><th align=\"left\">Description</th><th align=\"left\">Qty</th><th align=\"left\">Unit</th><th align=\"left\">Rate</th><th align=\"left\">Total</th></tr>");
            foreach (var item in group.OrderBy(i => i.SortOrder))
                sb.AppendLine($"<tr><td>{item.Description}</td><td>{item.Quantity}</td><td>{item.Unit}</td><td></td><td></td></tr>");
            sb.AppendLine("</table>");
        }
        sb.AppendLine("<p>Please confirm receipt and let us know if you need any further information or drawings.</p>");
        sb.AppendLine("<p>Kind regards,<br/>Jewel Bespoke Build</p>");
        return sb.ToString();
    }

    private async Task ConfirmSendInvite()
    {
        if (busy || package is null || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            package = await Commands.SendAsync(
                new SendBidPackageInvite(BidPackageId, composeSubject.Trim(), composeBody), CancellationToken.None);
            showComposeModal = false;
            sendNote = $"Invite sent to {BccPreview().Count} subcontractor(s) in BCC and tagged {package.Reference}.";
        }
        catch { error = "Couldn't send the invite email. Check the recipients have email addresses and that the mailbox can send, then try again."; }
        finally { busy = false; }
    }

    // ---- Extract a tender from a tagged email, review, save as a quote ----

    private sealed class ExtractDraft
    {
        public string? BidPackageLineItemId { get; set; }
        public string Description { get; set; } = "";
        public string Unit { get; set; } = "";
        public decimal Quantity { get; set; }
        public decimal Rate { get; set; }
        public decimal Total { get; set; }
    }

    private bool showExtractModal;
    private bool extractBusy;
    private bool extractProposed;
    private string extractSubcontractorId = "";
    private string extractNotes = "";
    private List<ExtractDraft> extractDrafts = new();
    private string? awardNote;

    private async Task OpenExtractModal(MailboxMessage email)
    {
        if (busy) return;
        showExtractModal = true;
        extractBusy = true;
        extractProposed = false;
        extractSubcontractorId = "";
        extractNotes = "";
        extractDrafts = new();
        StateHasChanged();
        try
        {
            var proposal = await Commands.SendAsync(
                new ExtractQuoteFromMessage(BidPackageId, email.Id), CancellationToken.None);
            extractProposed = proposal.Proposed;
            extractSubcontractorId = proposal.SubcontractorId ?? "";
            extractNotes = proposal.Notes;
            extractDrafts = proposal.Lines
                .Select(line => new ExtractDraft
                {
                    BidPackageLineItemId = line.BidPackageLineItemId,
                    Description = line.Description,
                    Unit = line.Unit,
                    Quantity = line.Quantity,
                    Rate = line.Rate,
                    Total = line.Total
                })
                .ToList();
            if (extractDrafts.Count == 0)
                extractDrafts = lineItems
                    .Select(item => new ExtractDraft { BidPackageLineItemId = item.LineItemId, Description = item.Description, Unit = item.Unit, Quantity = item.Quantity })
                    .ToList();
        }
        catch
        {
            error = "Couldn't read that email for extraction. You can still enter the submission manually.";
            extractDrafts = lineItems
                .Select(item => new ExtractDraft { BidPackageLineItemId = item.LineItemId, Description = item.Description, Unit = item.Unit, Quantity = item.Quantity })
                .ToList();
        }
        finally
        {
            extractBusy = false;
            StateHasChanged();
        }
    }

    private void CloseExtractModal() => showExtractModal = false;

    private void AddExtractLine() => extractDrafts.Add(new ExtractDraft { Quantity = 1 });

    private void RecalcTotal(ExtractDraft draft)
    {
        if (draft.Total == 0 && draft.Rate != 0 && draft.Quantity != 0)
            draft.Total = decimal.Round(draft.Rate * draft.Quantity, 2);
    }

    private async Task ConfirmSaveExtracted()
    {
        if (busy || !CanManage || string.IsNullOrWhiteSpace(extractSubcontractorId)) return;
        error = null;
        try
        {
            busy = true;
            var lines = extractDrafts
                .Where(draft => !string.IsNullOrWhiteSpace(draft.Description))
                .Select(draft => new QuoteExtractionLine(
                    draft.BidPackageLineItemId, draft.Description.Trim(), (draft.Unit ?? "").Trim(),
                    draft.Quantity, draft.Rate, draft.Total))
                .ToList();
            await Commands.SendAsync(
                new SaveExtractedQuote(BidPackageId, extractSubcontractorId, extractNotes ?? "", lines), CancellationToken.None);
            showExtractModal = false;
            await LoadAsync();
        }
        catch { error = "Couldn't save that submission. Make sure a subcontractor is selected and every line has a description."; }
        finally { busy = false; }
    }

    // ---- Award: winning quote → work order (the purchase-order record) ----

    private async Task AwardTo(Quote quote)
    {
        if (busy || package is null || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            var sub = Subs.Find(quote.SubcontractorId);
            var workOrder = await Commands.SendAsync(
                new AwardBidPackage(
                    BidPackageId, ProjectId, quote.SubcontractorId, quote.Value,
                    $"{package.Title} ({package.Reference}) — as tender submission received {quote.ReceivedAt.LocalDateTime:d MMM yyyy}",
                    Auth.CurrentUser?.Email ?? "", quote.QuoteId), CancellationToken.None);
            awardNote = $"Awarded to {sub?.CompanyName ?? quote.SubcontractorId} at {quote.Value:£#,##0.00} — work order {workOrder.WorkOrderId[..8]}… raised as the purchase order.";
            await LoadAsync();
        }
        catch { error = "Couldn't award the package. Please try again."; }
        finally { busy = false; }
    }

    // ---- Line-item editing ----

    private sealed class LineDraft
    {
        public string Trade { get; set; } = "";
        public string Description { get; set; } = "";
        public string Unit { get; set; } = "";
        public decimal Quantity { get; set; }
    }

    private bool editingLines;
    private List<LineDraft> lineDrafts = new();

    private void EditLines()
    {
        lineDrafts = lineItems
            .Select(item => new LineDraft { Trade = item.Trade, Description = item.Description, Unit = item.Unit, Quantity = item.Quantity })
            .ToList();
        if (lineDrafts.Count == 0) lineDrafts.Add(new LineDraft());
        editingLines = true;
    }

    private void AddLine() => lineDrafts.Add(new LineDraft());

    private void RemoveLine(LineDraft draft) => lineDrafts.Remove(draft);

    private void CancelLines()
    {
        editingLines = false;
        lineDrafts.Clear();
    }

    private async Task SaveLines()
    {
        if (busy || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            var inputs = lineDrafts
                .Where(draft => !string.IsNullOrWhiteSpace(draft.Description))
                .Select(draft => new BidPackageLineItemInput(
                    draft.Description.Trim(),
                    (draft.Unit ?? "").Trim(),
                    draft.Quantity,
                    (draft.Trade ?? "").Trim()))
                .ToList();
            lineItems = await Commands.SendAsync(new SetBidPackageLineItems(BidPackageId, inputs), CancellationToken.None);
            editingLines = false;
            lineDrafts.Clear();
        }
        catch { error = "Couldn't save the line items. Please try again."; }
        finally { busy = false; }
    }
}
