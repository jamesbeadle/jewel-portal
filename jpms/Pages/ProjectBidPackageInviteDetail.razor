@page "/projects/{ProjectId}/bid-package-invites/{BidPackageId}"
@using Jewel.JPMS.Contracts.Procurement
@using Jewel.JPMS.Contracts.Subcontractors
@using Jewel.JPMS.Contracts.Boq
@using Jewel.JPMS.Contracts.Drawings
@using Jewel.JPMS.Contracts.Variations
@using Jewel.JPMS.Cqrs
@using Jewel.JPMS.Features.CostCenters
@inject AuthService Auth
@inject SessionService Session
@inject IQueryClient Queries
@inject ICommandSender Commands
@inject CostCentersReadModel CostCenters
@inject ISubcontractorStore Subs
@inject IRequestRegister RequestRegister
@inject Jewel.JPMS.Features.Subcontractors.SubcontractorsReadModel SubsReadModel
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Bid Package Invite · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="bid-package-invites">
        <nav class="mb-4 text-sm">
            <a href="@($"/projects/{ProjectId}/bid-package-invites")" class="text-content-subtle hover:text-content underline underline-offset-4">Bid package invites</a>
        </nav>

        @if (error is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4 whitespace-pre-wrap">@error</p>
        }

        @if (package is null)
        {
            <p class="text-sm text-content-subtle italic">That bid package could not be loaded.</p>
        }
        else
        {
            <header class="mb-6 flex flex-wrap items-start justify-between gap-3">
                <div>
                    @if (!string.IsNullOrWhiteSpace(package.Reference))
                    {
                        <p class="text-xs font-mono tracking-wide text-content-subtle mb-0.5">@package.Reference</p>
                    }
                    <div class="flex items-center gap-3">
                        <h2 class="text-lg font-semibold text-content">@package.Title</h2>
                        <span class="inline-flex items-center rounded-full bg-surface-raised border border-line px-2 py-0.5 text-[11px] font-medium text-content-muted">@package.Status</span>
                    </div>
                    <p class="text-sm text-content-muted">@package.Trade</p>
                    @if (CanManage)
                    {
                        <label class="mt-1.5 flex items-center gap-2 text-xs text-content-muted cursor-pointer"
                               title="When ticked, the tender-invite email asks each subcontractor to state whether they will supply their own materials or price labour-only.">
                            <input type="checkbox" checked="@package.MaterialsApplicable" disabled="@busy"
                                   @onchange="e => ToggleMaterialsApplicable(e.Value is true)" />
                            Materials apply — ask tenderers whether they supply their own
                        </label>
                    }
                    else if (package.MaterialsApplicable)
                    {
                        <p class="text-xs text-content-subtle mt-1.5">Materials apply — the invite asks tenderers whether they supply their own.</p>
                    }
                </div>
                @if (CanManage)
                {
                    <button type="button" class="btn-secondary inline-flex items-center gap-2" disabled="@busy" @onclick="GenerateWithAi">
                        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 4.6L18.5 9l-4.6 1.9L12 15l-1.9-4.1L5.5 9l4.6-1.4z"/></svg>
                        Generate using AI
                    </button>
                }
            </header>

            @if (lineageVoq is not null)
            {
                <RecordLineage ProjectId="@ProjectId" ActiveId="@BidPackageId"
                               Request="lineageRequest" Voq="lineageVoq" Vo="lineageVo" BidPackages="siblingPackages" />
            }

            @if (aiNote is not null)
            {
                <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-sm text-content mb-6">@aiNote</p>
            }

            @* ---- Invited subcontractors ---- *@
            <section class="mb-8">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="eyebrow">Invited to tender</h3>
                    @if (CanManage)
                    {
                        <div class="flex items-center gap-4">
                            @if (recipients.Count > 0)
                            {
                                <button type="button" class="text-xs text-accent hover:underline" @onclick="OpenComposeModal">Draft invite email</button>
                            }
                            <button type="button" class="text-xs text-accent hover:underline" @onclick="OpenFindModal">Find subcontractors</button>
                            <button type="button" class="text-xs text-accent hover:underline" @onclick="OpenInviteModal">+ Add subcontractor</button>
                        </div>
                    }
                </div>

                @if (sendNote is not null)
                {
                    <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-sm text-content mb-3">
                        @sendNote
                        @if (draftWebLink is not null)
                        {
                            <a class="text-accent underline ml-1" href="@draftWebLink" target="_blank" rel="noopener">Open the draft in Outlook</a>
                        }
                    </p>
                }

                @if (recipients.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">No subcontractors invited yet.</p>
                }
                else
                {
                    <div class="rounded-xl border border-line bg-surface overflow-x-auto overflow-y-auto max-h-[85vh]">
                        <table class="w-full text-sm">
                            <thead class="bg-surface-raised border-b border-line">
                                <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                    <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Subcontractor</th>
                                    <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden sm:table-cell">Trade</th>
                                    <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Invited</th>
                                    <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Status</th>
                                    <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-line">
                                @foreach (var recipient in recipients)
                                {
                                    var sub = Subs.Find(recipient.SubcontractorId);
                                    <tr>
                                        <td class="px-4 py-3">
                                            <span class="text-content font-medium">@(sub?.CompanyName ?? recipient.SubcontractorId)</span>
                                            @if (sub is not null && string.IsNullOrWhiteSpace(sub.ContactEmail))
                                            {
                                                <span class="ml-2 inline-flex items-center rounded-full bg-amber-50 border border-amber-200 px-1.5 py-0.5 text-[10px] font-medium text-amber-800">No email address</span>
                                            }
                                            else if (sub is not null)
                                            {
                                                <span class="block text-xs text-content-subtle">@sub.ContactEmail</span>
                                            }
                                        </td>
                                        <td class="px-4 py-3 text-content-muted hidden sm:table-cell">@(sub?.TradesLabel ?? "")</td>
                                        <td class="px-4 py-3 text-content-subtle">@recipient.InvitedAt.LocalDateTime.ToString("d MMM yyyy, HH:mm")</td>
                                        <td class="px-4 py-3 @(recipient.Status == BidPackageRecipientStatus.Declined ? "text-content-subtle" : "text-content-muted")">@recipient.Status</td>
                                        <td class="px-4 py-3 text-right">
                                            @if (CanManage)
                                            {
                                                <span class="inline-flex items-center gap-3">
                                                    @if (recipient.Status == BidPackageRecipientStatus.Declined)
                                                    {
                                                        <button type="button" class="text-xs text-content-muted hover:text-content" disabled="@busy"
                                                                title="Put them back in the running — restores Responded if they have a tender in, otherwise Invited."
                                                                @onclick="() => SetDeclined(recipient, false)">Undo decline</button>
                                                    }
                                                    else if (recipient.Status != BidPackageRecipientStatus.Won)
                                                    {
                                                        <button type="button" class="text-xs text-content-muted hover:text-content" disabled="@busy"
                                                                title="Record that they've declined to tender (e.g. told you by phone). Keeps them on the list for the record."
                                                                @onclick="() => SetDeclined(recipient, true)">Mark declined</button>
                                                    }
                                                    <button type="button" class="text-xs text-content-muted hover:text-negative" disabled="@busy" @onclick="() => RemoveRecipient(recipient)">Remove</button>
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="text-xs text-content-subtle mt-2">
                        Adding a subcontractor only builds the invite list — nothing is emailed until you use
                        “Draft invite email” above, which creates a draft in the shared mailbox's Drafts folder
                        for you to review and send.
                    </p>
                }
            </section>

            @* ---- Line items, grouped by trade ---- *@
            <section class="mb-8">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="eyebrow">Line items</h3>
                    @if (CanManage && !editingLines)
                    {
                        <button type="button" class="text-xs text-content-muted hover:text-content" @onclick="EditLines">Edit</button>
                    }
                </div>

                @if (editingLines)
                {
                    <div class="rounded-xl border border-line bg-surface overflow-x-auto overflow-y-auto max-h-[85vh] mb-3">
                        <table class="w-full text-sm">
                            <thead class="bg-surface-raised border-b border-line">
                                <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                    <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Trade</th>
                                    <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Description</th>
                                    <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2 hidden sm:table-cell">Unit</th>
                                    <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Qty</th>
                                    <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Cost code</th>
                                    <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2"></th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-line">
                                @for (var i = 0; i < lineDrafts.Count; i++)
                                {
                                    var draft = lineDrafts[i];
                                    <tr>
                                        <td class="px-3 py-2"><input class="field" @bind="draft.Trade" placeholder="e.g. Electrical" /></td>
                                        <td class="px-3 py-2"><input class="field" @bind="draft.Description" placeholder="Description" /></td>
                                        <td class="px-3 py-2 hidden sm:table-cell"><input class="field" @bind="draft.Unit" placeholder="e.g. m²" /></td>
                                        <td class="px-3 py-2"><input class="field" type="number" step="any" @bind="draft.Quantity" /></td>
                                        <td class="px-3 py-2">
                                            <select class="field min-w-[14rem]" @bind="draft.CostCode">
                                                <option value="">Cost centre…</option>
                                                @foreach (var centre in CostCenters.Alphabetical)
                                                {
                                                    <option value="@centre.Code">@($"{centre.Code} — {centre.Name}")</option>
                                                }
                                            </select>
                                        </td>
                                        <td class="px-3 py-2 text-right">
                                            <button type="button" class="text-xs text-content-muted hover:text-negative" @onclick="() => RemoveLine(draft)">Remove</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="flex items-center gap-3">
                        <button type="button" class="btn-secondary" disabled="@busy" @onclick="AddLine">Add line</button>
                        <button type="button" class="btn-primary" disabled="@busy" @onclick="SaveLines">@(busy ? "Saving…" : "Save line items")</button>
                        <button type="button" class="text-sm text-content-muted hover:text-content" disabled="@busy" @onclick="CancelLines">Cancel</button>
                    </div>
                }
                else if (lineItems.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">No line items on this package yet.</p>
                }
                else
                {
                    @foreach (var group in lineItems.GroupBy(item => item.Trade).OrderBy(g => g.Key))
                    {
                        <div class="mb-4">
                            <p class="text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">@(string.IsNullOrWhiteSpace(group.Key) ? "Unspecified" : group.Key)</p>
                            <div class="rounded-xl border border-line bg-surface overflow-x-auto overflow-y-auto max-h-[85vh]">
                                <table class="w-full text-sm">
                                    <thead class="bg-surface-raised border-b border-line">
                                        <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-2">Description</th>
                                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-2 hidden sm:table-cell">Unit</th>
                                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-2">Qty</th>
                                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-2">Cost code</th>
                                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-2">Covered by</th>
                                            @if (CanManage)
                                            {
                                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-2"></th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-line">
                                        @foreach (var item in group)
                                        {
                                            <tr>
                                                <td class="px-4 py-2 text-content">@item.Description</td>
                                                <td class="px-4 py-2 text-content-muted hidden sm:table-cell">@item.Unit</td>
                                                <td class="px-4 py-2 text-content-muted">@item.Quantity</td>
                                                <td class="px-4 py-2">
                                                    @if (string.IsNullOrWhiteSpace(item.CostCode))
                                                    {
                                                        <span class="inline-flex items-center rounded-full bg-amber-50 border border-amber-200 px-1.5 py-0.5 text-[10px] font-medium text-amber-800"
                                                              title="This line predates the cost-code rule — edit the line items to set one.">No cost code</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-content-muted" title="@CostCentreLabel(item.CostCode)">@item.CostCode</span>
                                                    }
                                                </td>
                                                <td class="px-4 py-2">
                                                    @if (item.Coverage == BidPackageLineCoverage.Unassigned)
                                                    {
                                                        <span class="text-xs text-content-subtle italic">Not linked</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="inline-flex items-center gap-1 rounded-full border px-2 py-0.5 text-[11px] font-medium @(item.Coverage == BidPackageLineCoverage.Variation ? "border-accent/30 bg-accent/10 text-accent" : "border-line bg-surface-raised text-content-muted")">@CoverageLabel(item)</span>
                                                    }
                                                </td>
                                                @if (CanManage)
                                                {
                                                    <td class="px-4 py-2 text-right">
                                                        <button type="button" class="text-xs text-accent hover:underline" disabled="@busy" @onclick="() => OpenCoverageModal(item)">@(item.Coverage == BidPackageLineCoverage.Unassigned ? "Link" : "Change")</button>
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                }
            </section>

            @* ---- Tender submissions: quotes compared line by line ---- *@
            <section class="mb-8">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="eyebrow">Tender submissions</h3>
                    @if (CanManage && recipients.Count > 0)
                    {
                        <button type="button" class="text-xs text-accent hover:underline" disabled="@busy"
                                title="Key in a tender received outside email — phoned through, posted, or from a message that wasn't tagged."
                                @onclick="OpenManualTenderModal">Record tender manually</button>
                    }
                </div>

                @if (awardNote is not null)
                {
                    <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-sm text-content mb-3">@awardNote</p>
                }

                @* Persistent award summary — who won, for how much, and the purchase-order it raised. *@
                @if (package.Status == BidPackageStatus.Awarded && AwardedOrder is { } awarded)
                {
                    <div class="rounded-xl border border-positive/30 bg-positive/10 px-4 py-3 mb-3 flex flex-wrap items-center justify-between gap-3">
                        <p class="text-sm text-content">
                            <span class="font-semibold">Awarded</span> to
                            <span class="font-medium">@awarded.SubcontractorName</span>
                            at @awarded.Order.Value.ToString("£#,##0.00")
                            on @awarded.Order.AwardedAt.LocalDateTime.ToString("d MMM yyyy") —
                            <a class="text-accent hover:underline" href="@($"/projects/{ProjectId}/work-orders")"
                               title="Open the project's Work Orders tab, where this order's cost-coded lines feed the cost-centre totals.">
                                work order WO-@awarded.Order.Number.ToString("0000")</a>
                            raised as the purchase order.
                        </p>
                        @if (CanManage)
                        {
                            <button type="button" class="text-xs text-accent hover:underline" disabled="@busy"
                                    title="Draft the work-order email to the winning subcontractor in the shared mailbox — reviewed and sent from Outlook, nothing sends from here."
                                    @onclick="OpenWorkOrderEmailModal">Email work order to winner</button>
                        }
                    </div>
                    @if (woEmailNote is not null)
                    {
                        <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-sm text-content mb-3">
                            @woEmailNote
                            @if (woEmailLink is not null)
                            {
                                <a class="text-accent underline ml-1" href="@woEmailLink" target="_blank" rel="noopener">Open the draft in Outlook</a>
                            }
                        </p>
                    }
                }

                @if (quotes.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">
                        No tender submissions yet. Extract one from a tagged email below, or use
                        “Record tender manually” for prices that arrived by phone or outside the mailbox.
                    </p>
                }
                else
                {
                    <div class="rounded-xl border border-line bg-surface overflow-x-auto overflow-y-auto max-h-[85vh]">
                        <table class="w-full text-sm">
                            <thead class="bg-surface-raised border-b border-line">
                                <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                    <th class="sticky top-0 z-20 bg-surface-raised px-4 py-2">Line item</th>
                                    <th class="sticky top-0 z-20 bg-surface-raised px-4 py-2 hidden sm:table-cell">Qty</th>
                                    @foreach (var quote in quotes)
                                    {
                                        var sub = Subs.Find(quote.SubcontractorId);
                                        var won = recipients.Any(r =>
                                            string.Equals(r.SubcontractorId, quote.SubcontractorId, StringComparison.OrdinalIgnoreCase)
                                            && r.Status == BidPackageRecipientStatus.Won);
                                        <th class="sticky top-0 z-20 bg-surface-raised px-4 py-2 text-right">
                                            @(sub?.CompanyName ?? quote.SubcontractorId)
                                            @if (won)
                                            {
                                                <span class="ml-1.5 inline-flex items-center rounded-full bg-positive/10 border border-positive/30 px-1.5 py-0.5 text-[10px] font-medium text-positive normal-case tracking-normal">Won</span>
                                            }
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-line">
                                @foreach (var item in lineItems)
                                {
                                    <tr>
                                        <td class="px-4 py-2 text-content">@item.Description</td>
                                        <td class="px-4 py-2 text-content-muted hidden sm:table-cell">@item.Quantity @item.Unit</td>
                                        @foreach (var quote in quotes)
                                        {
                                            var line = quoteLines.FirstOrDefault(l => l.QuoteId == quote.QuoteId && l.BidPackageLineItemId == item.LineItemId);
                                            <td class="px-4 py-2 text-right text-content-muted">
                                                @(line is null ? "—" : line.Total.ToString("£#,##0.00"))
                                            </td>
                                        }
                                    </tr>
                                }
                                @{ var extras = quoteLines.Where(l => l.BidPackageLineItemId is null).ToList(); }
                                @if (extras.Count > 0)
                                {
                                    <tr>
                                        <td class="px-4 py-2 text-content-subtle italic">Outside package scope</td>
                                        <td class="px-4 py-2 hidden sm:table-cell"></td>
                                        @foreach (var quote in quotes)
                                        {
                                            var sum = extras.Where(l => l.QuoteId == quote.QuoteId).Sum(l => l.Total);
                                            <td class="px-4 py-2 text-right text-content-subtle italic">@(sum == 0 ? "—" : sum.ToString("£#,##0.00"))</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="bg-surface-raised border-t border-line">
                                <tr class="font-semibold text-content">
                                    <td class="px-4 py-2">Total</td>
                                    <td class="px-4 py-2 hidden sm:table-cell"></td>
                                    @foreach (var quote in quotes)
                                    {
                                        <td class="px-4 py-2 text-right">@quote.Value.ToString("£#,##0.00")</td>
                                    }
                                </tr>
                                @if (CanManage && package.Status != BidPackageStatus.Awarded)
                                {
                                    <tr>
                                        <td class="px-4 py-2"></td>
                                        <td class="px-4 py-2 hidden sm:table-cell"></td>
                                        @foreach (var quote in quotes)
                                        {
                                            <td class="px-4 py-2 text-right">
                                                <button type="button" class="text-xs text-accent hover:underline" disabled="@busy"
                                                        @onclick="() => AwardTo(quote)">Award</button>
                                            </td>
                                        }
                                    </tr>
                                }
                            </tfoot>
                        </table>
                    </div>

                    @foreach (var quote in quotes.Where(q => !string.IsNullOrWhiteSpace(q.Notes)))
                    {
                        var sub = Subs.Find(quote.SubcontractorId);
                        <p class="text-xs text-content-subtle mt-2"><span class="font-medium text-content-muted">@(sub?.CompanyName ?? quote.SubcontractorId):</span> @quote.Notes</p>
                    }
                }
            </section>

            @* ---- Documents: project drawings linked to this package ---- *@
            <section class="mb-8">
                <div class="flex items-center justify-between mb-3">
                    <h3 class="eyebrow">Documents</h3>
                    @if (CanManage)
                    {
                        <button type="button" class="text-xs text-accent hover:underline" @onclick="OpenDrawingsModal">Link drawings</button>
                    }
                </div>

                @if (packageDrawings.Count == 0)
                {
                    <div class="rounded-xl border border-dashed border-line bg-surface-raised px-4 py-5 text-sm text-content-subtle">
                        No drawings linked yet. Link drawings from the project's Drawings section — they're attached
                        to the invite email when it's sent. (Save drawings out of any email from Triage.)
                    </div>
                }
                else
                {
                    <ul class="space-y-2">
                        @foreach (var drawing in packageDrawings)
                        {
                            <li class="rounded-lg border border-line bg-surface px-4 py-3 flex flex-wrap items-center justify-between gap-2">
                                <div>
                                    <span class="text-sm font-medium text-content">@drawing.DrawingCode</span>
                                    <span class="text-sm text-content-muted ml-2">@drawing.Title</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <span class="inline-flex items-center rounded-full border px-2 py-0.5 text-[11px] font-medium @(drawing.CurrentApprovedRevisionLabel is null ? "border-amber-200 bg-amber-50 text-amber-800" : "border-line bg-surface-raised text-content-muted")">
                                        @(drawing.CurrentApprovedRevisionLabel is null ? "No approved revision" : $"Rev {drawing.CurrentApprovedRevisionLabel}")
                                    </span>
                                    <a class="text-xs text-accent hover:underline" href="@($"/projects/{ProjectId}/drawings/{drawing.DrawingId}")">Open</a>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </section>

            @* ---- Tender responses & related emails (read live by the package's tag) ---- *@
            <section>
                <h3 class="eyebrow mb-3">Tender responses & related emails</h3>
                @if (emails.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">
                        No emails tagged to this bid package. Replies to the invite land in Triage —
                        tag them with @package.Reference and they appear here.
                    </p>
                }
                else
                {
                    <ul class="space-y-2">
                        @foreach (var email in emails)
                        {
                            <li class="rounded-lg border border-line bg-surface px-4 py-3">
                                <div class="flex flex-wrap items-center justify-between gap-2">
                                    <span class="text-sm font-medium text-content">@(string.IsNullOrWhiteSpace(email.FromName) ? email.FromEmail : email.FromName)</span>
                                    <div class="flex items-center gap-3">
                                        <span class="text-xs text-content-subtle">@email.ReceivedAt.LocalDateTime.ToString("d MMM yyyy, HH:mm")</span>
                                        @if (CanManage)
                                        {
                                            <button type="button" class="text-xs text-accent hover:underline" disabled="@busy"
                                                    @onclick="() => OpenExtractModal(email)">Extract tender</button>
                                        }
                                    </div>
                                </div>
                                <p class="text-sm text-content mt-0.5">
                                    @email.Subject
                                    @if (email.HasAttachments)
                                    {
                                        <span class="ml-2 inline-flex items-center rounded bg-surface-raised border border-line px-1.5 py-0.5 text-[10px] text-content-subtle">attachment</span>
                                    }
                                </p>
                                @if (!string.IsNullOrWhiteSpace(email.BodyPreview))
                                {
                                    <p class="text-xs text-content-subtle mt-1 line-clamp-2">@email.BodyPreview</p>
                                }
                            </li>
                        }
                    </ul>
                }
            </section>
        }
    </ProjectPageShell>

    @* ---- Add-subcontractor modal: the directory, searchable ---- *@
    <Modal IsOpen="showInviteModal" Title="Invite subcontractors" ShowFooter="true"
           ConfirmLabel="@(InviteCount() == 0 ? "Invite" : $"Invite {InviteCount()}")" ConfirmDisabled="@(busy || InviteCount() == 0)" CancelLabel="Cancel"
           OnCancel="CloseInviteModal" OnConfirm="ConfirmInvite" Class="max-w-lg w-full">
        <div class="mb-3 flex gap-2">
            <input class="field flex-1" placeholder="Search by company, trade or contact…"
                   value="@subSearch" @oninput="OnSearchInput" />
            @* Trade filter — a compact dropdown (the full chip list overwhelmed the modal). *@
            @if (InvitableTrades().Count > 1)
            {
                <select class="field w-44 shrink-0" value="@(tradeFilter ?? "")"
                        @onchange="e => tradeFilter = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value!.ToString()">
                    <option value="">All trades</option>
                    @foreach (var trade in InvitableTrades())
                    {
                        <option value="@trade">@trade</option>
                    }
                </select>
            }
        </div>
        @if (Invitable().Count == 0)
        {
            <p class="text-sm text-content-subtle italic">No matching subcontractors in the directory.</p>
        }
        else
        {
            <div class="space-y-1 max-h-80 overflow-y-auto">
                @foreach (var sub in Invitable())
                {
                    <label class="flex items-center gap-2 text-sm text-content py-1">
                        <input type="checkbox" checked="@selected.Contains(sub.SubcontractorId)"
                               @onchange="e => Toggle(sub.SubcontractorId, e)" />
                        <span class="font-medium">@sub.CompanyName</span>
                        <span class="text-content-subtle">· @sub.TradesLabel</span>
                        @if (string.IsNullOrWhiteSpace(sub.ContactEmail))
                        {
                            <span class="inline-flex items-center rounded-full bg-amber-50 border border-amber-200 px-1.5 py-0.5 text-[10px] font-medium text-amber-800">No email</span>
                        }
                    </label>
                }
            </div>
        }

        @* Ad-hoc invite: saved to the directory, then included in this invite list. *@
        <div class="mt-4 pt-4 border-t border-line">
            <p class="text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Not in the directory?</p>
            <p class="text-xs text-content-subtle mb-2">Add their details — they're saved to the directory and included in this invite.</p>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-2">
                <input class="field" placeholder="Company or name *" @bind="quickAddName" @bind:event="oninput" />
                <input class="field" type="email" placeholder="Email address *" @bind="quickAddEmail" @bind:event="oninput" />
                <select class="field" @bind="quickAddTradeId">
                    <option value="">Trade…</option>
                    @foreach (var trade in Subs.Trades())
                    {
                        <option value="@trade.TradeId">@trade.Name</option>
                    }
                </select>
            </div>
            @if (quickAddPartial)
            {
                <p class="text-xs text-amber-800 mt-1">Enter both a name and a valid email address to include them.</p>
            }
        </div>
    </Modal>

    @* ---- Find local subcontractors: Google Places search near the project's site ---- *@
    <Modal IsOpen="showFindModal" Title="Find local subcontractors" ShowFooter="true"
           ConfirmLabel="@(busy ? "Inviting…" : selectedPlaces.Count == 0 ? "Invite" : $"Invite {selectedPlaces.Count}")"
           ConfirmDisabled="@(busy || selectedPlaces.Count == 0)" CancelLabel="Close"
           OnCancel="CloseFindModal" OnConfirm="ConfirmFindInvite" Class="max-w-2xl w-full">
        <p class="text-xs text-content-subtle mb-3">
            Searches the web for companies of a trade near the project's site (its town and postcode —
            set under Edit details on the project). Email addresses and phone numbers are picked up
            from each company's own website; companies where no email could be found are left out.
            Ticked companies are saved to the directory with their details and invited to this package.
        </p>

        <div class="flex gap-2 mb-3">
            <select class="field flex-1" @bind="findTrade">
                <option value="">Select a trade…</option>
                @foreach (var trade in FindTradeOptions())
                {
                    <option value="@trade">@trade</option>
                }
            </select>
            <button type="button" class="btn-primary shrink-0"
                    disabled="@(findBusy || string.IsNullOrWhiteSpace(findTrade))"
                    @onclick="() => RunFindSearch(loadMore: false)">
                @(findBusy ? "Searching…" : "Search")
            </button>
        </div>

        @if (findError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@findError</p>
        }

        @if (findResults.Count > 0)
        {
            <div class="space-y-1 max-h-96 overflow-y-auto">
                @foreach (var place in findResults)
                {
                    <label class="flex items-start gap-2.5 rounded-lg border border-line bg-surface px-3 py-2.5 cursor-pointer hover:border-line-strong">
                        <input type="checkbox" class="mt-1" checked="@selectedPlaces.ContainsKey(place.PlaceId)"
                               @onchange="e => TogglePlace(place, e)" />
                        <span class="min-w-0">
                            <span class="flex items-center gap-2 flex-wrap">
                                <span class="text-sm font-medium text-content">@place.Name</span>
                                @if (place.ExistingSubcontractorId is not null)
                                {
                                    <span class="inline-flex items-center rounded-full bg-accent/10 border border-accent/30 px-1.5 py-0.5 text-[10px] font-medium text-accent">Already in directory</span>
                                }
                                @if (place.Rating is not null)
                                {
                                    <span class="text-xs text-content-muted">★ @place.Rating.Value.ToString("0.0") (@place.RatingCount)</span>
                                }
                            </span>
                            <span class="block text-xs text-content-subtle truncate">@place.Address</span>
                            <span class="block text-xs text-content-subtle truncate">
                                <span class="text-content-muted">@place.Email</span>
                                @if (!string.IsNullOrEmpty(place.Phone))
                                {
                                    <span class="ml-1">· @place.Phone</span>
                                }
                                @if (!string.IsNullOrEmpty(place.Website))
                                {
                                    <a class="text-accent hover:underline ml-1" href="@place.Website" target="_blank" rel="noopener" @onclick:stopPropagation="true">Website</a>
                                }
                            </span>
                        </span>
                    </label>
                }
            </div>
            @if (findNextPageToken is not null)
            {
                <button type="button" class="btn-secondary w-full mt-3" disabled="@findBusy"
                        @onclick="() => RunFindSearch(loadMore: true)">
                    @(findBusy ? "Loading…" : "Load more results")
                </button>
            }
        }
        else if (findSearched && !findBusy && findError is null)
        {
            <p class="text-sm text-content-subtle italic">No companies with a findable email address for that trade near the project. Try a broader trade name.</p>
        }
    </Modal>

    @* ---- Line-item coverage modal: link to a contract BoQ line OR a variation ---- *@
    <Modal IsOpen="showCoverageModal" Title="Link line item" ShowFooter="true"
           ConfirmLabel="Save" CancelLabel="Cancel"
           OnCancel="CloseCoverageModal" OnConfirm="ConfirmCoverage" Class="max-w-lg w-full">
        @if (linkingLine is not null)
        {
            <p class="text-sm text-content mb-1 font-medium">@linkingLine.Description</p>
            <p class="text-xs text-content-subtle mb-4">A line is covered by a contract BoQ line (flows into the Valuation Report) or a Variation Order Quote — never both.</p>

            <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Covered by</label>
            <select class="field" @bind="coverageChoice">
                <option value="@BidPackageLineCoverage.Unassigned">Not linked</option>
                <option value="@BidPackageLineCoverage.ContractLine">Contract BoQ line</option>
                <option value="@BidPackageLineCoverage.Variation">Variation Order Quote</option>
            </select>

            @if (coverageChoice == BidPackageLineCoverage.ContractLine)
            {
                <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mt-3 mb-1">BoQ line</label>
                @if (boqLines.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">No BoQ lines on this project yet.</p>
                }
                else
                {
                    <select class="field" @bind="coverageBoqId">
                        <option value="">Select a BoQ line…</option>
                        @foreach (var b in boqLines)
                        {
                            <option value="@b.BoqLineItemId">@b.Description (@b.Unit)</option>
                        }
                    </select>
                }
            }
            else if (coverageChoice == BidPackageLineCoverage.Variation)
            {
                <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mt-3 mb-1">Variation Order Quote</label>
                @if (voqs.Count == 0)
                {
                    <p class="text-sm text-content-subtle italic">No variation order quotes on this project yet.</p>
                }
                else
                {
                    <select class="field" @bind="coverageVoqId">
                        <option value="">Select a variation…</option>
                        @foreach (var v in voqs)
                        {
                            <option value="@v.VariationOrderQuoteId">@v.Reference — @v.Title</option>
                        }
                    </select>
                }
            }
        }
    </Modal>

    @* ---- Link project drawings to the package (the tender documents) ---- *@
    <Modal IsOpen="showDrawingsModal" Title="Link drawings" ShowFooter="true"
           ConfirmLabel="@(busy ? "Saving…" : $"Link {selectedDrawingIds.Count}")" CancelLabel="Cancel"
           OnCancel="CloseDrawingsModal" OnConfirm="ConfirmDrawings" Class="max-w-lg w-full">
        @if (projectDrawings.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">
                No drawings on this project yet. Upload them in the Drawings tab, or save them out of
                an email from Triage ("Save to drawings").
            </p>
        }
        else
        {
            <p class="text-xs text-content-subtle mb-3">Linked drawings are attached to the invite email (latest approved revision, or the newest upload when none is approved).</p>
            <div class="space-y-1 max-h-80 overflow-y-auto">
                @foreach (var drawing in projectDrawings)
                {
                    <label class="flex items-center gap-2 text-sm text-content py-1">
                        <input type="checkbox" checked="@selectedDrawingIds.Contains(drawing.DrawingId)"
                               @onchange="e => ToggleDrawing(drawing.DrawingId, e)" />
                        <span class="font-medium">@drawing.DrawingCode</span>
                        <span class="text-content-subtle truncate">· @drawing.Title</span>
                        @if (drawing.CurrentApprovedRevisionLabel is not null)
                        {
                            <span class="text-content-subtle">· Rev @drawing.CurrentApprovedRevisionLabel</span>
                        }
                    </label>
                }
            </div>
        }
    </Modal>

    @* ---- Compose & send the tender-invite email (recipients BCC'd) ---- *@
    <Modal IsOpen="showComposeModal" Title="Draft invite email" ShowFooter="true"
           ConfirmLabel="@(busy ? "Creating draft…" : BccPreview().Count == 0 ? "No one to send to" : $"Create draft for {BccPreview().Count} subcontractor{(BccPreview().Count == 1 ? "" : "s")}")"
           ConfirmDisabled="@(busy || BccPreview().Count == 0)" CancelLabel="Cancel"
           OnCancel="CloseComposeModal" OnConfirm="ConfirmSendInvite" Class="max-w-2xl w-full">
        <p class="text-xs text-content-subtle mb-3">
            Creates a draft in the shared mailbox — nothing is sent until someone reviews and sends
            it from Outlook. Every recipient goes in BCC, so subcontractors never see each other.
            The email is tagged to this package, and tagged replies appear under
            Tender responses below.
            @if (packageDrawings.Count > 0)
            {
                <span> The @packageDrawings.Count linked drawing@(packageDrawings.Count == 1 ? "" : "s") will be attached.</span>
            }
        </p>

        <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Recipients (BCC)</label>
        @if (BccPreview().Count > 0)
        {
            <div class="mb-2 flex flex-wrap gap-1.5">
                @foreach (var name in BccPreview())
                {
                    <span class="inline-flex items-center rounded-full bg-surface-raised border border-line px-2 py-0.5 text-[11px] text-content-muted">@name</span>
                }
            </div>
        }
        @if (lineItems.Count == 0)
        {
            <p class="rounded-lg bg-amber-50 border border-amber-200 px-3 py-2 text-xs text-amber-800 mb-3">
                This package has no line items yet, so the pre-filled message has nothing for subcontractors
                to price. You can still create the draft — or cancel, add line items, and reopen this window
                to include them.
            </p>
        }
        @if (MissingEmail().Count > 0)
        {
            <p class="rounded-lg bg-amber-50 border border-amber-200 px-3 py-2 text-xs text-amber-800 mb-3">
                @(BccPreview().Count == 0 ? "None of the invited subcontractors has an email address, so this email can't be sent yet. " : "")
                Won't receive it (no email address): @string.Join(", ", MissingEmail()).
                Add their email in the <a class="underline" href="/directory">Directory</a> and reopen this window.
            </p>
        }

        <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Subject</label>
        <input class="field mb-3" @bind="composeSubject" />

        <div class="flex items-center justify-between mb-1">
            <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle">Message</label>
            <button type="button" class="text-xs text-accent hover:underline" @onclick="() => editingBody = !editingBody">
                @(editingBody ? "Back to preview" : "Edit message (HTML)")
            </button>
        </div>
        @if (editingBody)
        {
            <textarea class="field font-mono text-xs" rows="14" @bind="composeBody"></textarea>
            <p class="text-[11px] text-content-subtle mt-1">Sent as HTML — the pre-filled message includes the package's line items for pricing, when there are any.</p>
        }
        else
        {
            <div class="rounded-lg border border-line bg-white text-gray-900 p-4 text-sm max-h-80 overflow-y-auto">
                @((MarkupString)composeBody)
            </div>
            <p class="text-[11px] text-content-subtle mt-1">This is how the email will look. It includes the package's line items for the subcontractor to price, when there are any.</p>
        }
    </Modal>

    @* ---- Review an extracted tender before saving it as a quote ---- *@
    <Modal IsOpen="showExtractModal" Title="Tender submission" ShowFooter="true"
           ConfirmLabel="@(busy ? "Saving…" : "Save submission")" CancelLabel="Cancel"
           OnCancel="CloseExtractModal" OnConfirm="ConfirmSaveExtracted" Class="max-w-3xl w-full">
        @if (extractBusy)
        {
            <p class="text-sm text-content-subtle">Reading the email…</p>
        }
        else
        {
            @if (extractProposed)
            {
                <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-xs text-content mb-3">
                    Extracted by Claude from the email — check every figure against the message before saving.
                </p>
            }
            else if (manualExtract)
            {
                <p class="rounded-lg bg-surface-raised border border-line px-3 py-2 text-xs text-content-muted mb-3">
                    Recording a tender received outside the mailbox — the package's line items are pre-filled;
                    enter the rates as the subcontractor gave them.
                </p>
            }
            else
            {
                <p class="rounded-lg bg-surface-raised border border-line px-3 py-2 text-xs text-content-muted mb-3">
                    Automatic extraction wasn't available — the package's line items are pre-filled for manual entry.
                </p>
            }

            <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Subcontractor</label>
            <select class="field mb-3" @bind="extractSubcontractorId">
                <option value="">Select the subcontractor…</option>
                @foreach (var recipient in recipients)
                {
                    var sub = Subs.Find(recipient.SubcontractorId);
                    <option value="@recipient.SubcontractorId">@(sub?.CompanyName ?? recipient.SubcontractorId)</option>
                }
            </select>

            <div class="rounded-xl border border-line bg-surface mb-3">
                <table class="w-full text-sm">
                    <thead class="bg-surface-raised border-b border-line">
                        <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Description</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2 hidden sm:table-cell">Unit</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Qty</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Rate</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Total</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-line">
                        @foreach (var draft in extractDrafts)
                        {
                            <tr class="@(draft.BidPackageLineItemId is null ? "bg-accent/5" : "")">
                                <td class="px-3 py-2"><input class="field" @bind="draft.Description" /></td>
                                <td class="px-3 py-2 hidden sm:table-cell"><input class="field w-16" @bind="draft.Unit" /></td>
                                <td class="px-3 py-2"><input class="field w-20" type="number" step="any" @bind="draft.Quantity" /></td>
                                <td class="px-3 py-2"><input class="field w-24" type="number" step="any" @bind="draft.Rate" @onblur="() => RecalcTotal(draft)" /></td>
                                <td class="px-3 py-2"><input class="field w-28" type="number" step="any" @bind="draft.Total" /></td>
                                <td class="px-3 py-2 text-right">
                                    <button type="button" class="text-xs text-content-muted hover:text-negative" @onclick="() => extractDrafts.Remove(draft)">Remove</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="flex items-center justify-between mb-3">
                <button type="button" class="btn-secondary" @onclick="AddExtractLine">Add line</button>
                <p class="text-sm text-content font-medium">Total: @extractDrafts.Sum(d => d.Total).ToString("£#,##0.00")</p>
            </div>

            <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Notes (exclusions, caveats, lead times)</label>
            <textarea class="field" rows="3" @bind="extractNotes"></textarea>
        }
    </Modal>

    @* ---- Work-order email to the winning subcontractor (drafted, sent from Outlook) ---- *@
    <Modal IsOpen="showWoEmailModal" Title="Email work order to winner" ShowFooter="true"
           ConfirmLabel="@(busy ? "Drafting…" : "Create draft in mailbox")" ConfirmDisabled="@busy" CancelLabel="Cancel"
           OnCancel="CloseWorkOrderEmailModal" OnConfirm="ConfirmWorkOrderEmailDraft" Class="max-w-3xl w-full">
        <p class="rounded-lg bg-surface-raised border border-line px-3 py-2 text-xs text-content-muted mb-3">
            Nothing sends from here — this creates a draft in the shared mailbox, addressed to the winning
            subcontractor and tagged @package?.Reference, for you to review and send from Outlook.
        </p>

        <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Subject</label>
        <input class="field mb-3" @bind="woEmailSubject" />

        <label class="block text-xs font-semibold uppercase tracking-wide text-content-subtle mb-1">Body (HTML)</label>
        <textarea class="field font-mono text-xs" rows="14" @bind="woEmailBody"></textarea>
    </Modal>

    @* ---- Generate using AI: confirm before anything runs ---- *@
    <Modal IsOpen="showAiConfirmModal" Title="Generate using AI" ShowFooter="true"
           ConfirmLabel="@(aiBusy ? "Generating…" : "Generate draft")" ConfirmDisabled="@aiBusy" CancelLabel="Cancel"
           OnCancel="CloseAiConfirmModal" OnConfirm="ConfirmAiGenerate" Class="max-w-lg w-full">
        <p class="text-sm text-content mb-3">
            Claude drafts this package — scope and line items — from what's tagged to it:
        </p>
        <ul class="text-sm text-content-muted space-y-1 mb-4 list-disc pl-5">
            <li>@emails.Count related email@(emails.Count == 1 ? "" : "s")</li>
            <li>@packageDrawings.Count linked drawing@(packageDrawings.Count == 1 ? "" : "s")</li>
        </ul>
        @if (emails.Count == 0 && packageDrawings.Count == 0)
        {
            <p class="rounded-lg bg-amber-50 border border-amber-200 px-3 py-2 text-xs text-amber-800 mb-3">
                No related emails or linked drawings yet — Claude will only have the package title and trade
                to work from, so the draft may be thin.
            </p>
        }
        @if (lineItems.Count > 0)
        {
            <p class="rounded-lg bg-amber-50 border border-amber-200 px-3 py-2 text-xs text-amber-800">
                This package already has @lineItems.Count line item@(lineItems.Count == 1 ? "" : "s").
                Generating never changes or removes them — the draft opens in a review screen and only
                the lines you accept are added.
            </p>
        }
        else
        {
            <p class="text-xs text-content-subtle">
                The draft opens in a review screen — nothing is added to the package until you accept it.
            </p>
        }
    </Modal>

    @* ---- Generate using AI: review the draft before anything is saved ---- *@
    <Modal IsOpen="showAiReviewModal" Title="Review AI draft" ShowFooter="true"
           ConfirmLabel="@(busy ? "Adding…" : AiAcceptedCount() == 0 ? "Nothing selected" : $"Add {AiAcceptedCount()} line item{(AiAcceptedCount() == 1 ? "" : "s")}")"
           ConfirmDisabled="@(busy || AiAcceptedCount() == 0)" CancelLabel="Discard draft"
           OnCancel="CloseAiReviewModal" OnConfirm="ConfirmAiApply" Class="max-w-3xl w-full">
        <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-xs text-content mb-3">
            Drafted by Claude — nothing has been saved yet. Only ticked lines are added when you confirm;
            your existing line items are never changed or removed. Check every figure before accepting.
        </p>

        @if (!string.IsNullOrWhiteSpace(aiProposalNotes))
        {
            <p class="text-sm text-content-muted mb-3">@aiProposalNotes</p>
        }

        <div class="rounded-xl border border-line bg-surface mb-3">
            <table class="w-full text-sm">
                <thead class="bg-surface-raised border-b border-line">
                    <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Add</th>
                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Trade</th>
                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Description</th>
                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2 hidden sm:table-cell">Unit</th>
                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Qty</th>
                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2">Cost code</th>
                        <th class="sticky top-0 z-20 bg-surface-raised px-3 py-2"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-line">
                    @foreach (var draft in aiDrafts)
                    {
                        <tr class="@(draft.Include ? "" : "opacity-60")">
                            <td class="px-3 py-2">
                                <input type="checkbox" checked="@draft.Include"
                                       @onchange="e => draft.Include = e.Value is true" />
                            </td>
                            <td class="px-3 py-2"><input class="field w-28" @bind="draft.Trade" /></td>
                            <td class="px-3 py-2">
                                <input class="field" @bind="draft.Description" />
                                @if (draft.AlreadyOnPackage)
                                {
                                    <span class="inline-flex items-center rounded-full bg-surface-raised border border-line px-1.5 py-0.5 text-[10px] font-medium text-content-muted mt-1">Already on package</span>
                                }
                            </td>
                            <td class="px-3 py-2 hidden sm:table-cell"><input class="field w-16" @bind="draft.Unit" /></td>
                            <td class="px-3 py-2"><input class="field w-20" type="number" step="any" @bind="draft.Quantity" /></td>
                            <td class="px-3 py-2">
                                <select class="field min-w-[12rem]" @bind="draft.CostCode">
                                    <option value="">Cost centre…</option>
                                    @foreach (var centre in CostCenters.Alphabetical)
                                    {
                                        <option value="@centre.Code">@($"{centre.Code} — {centre.Name}")</option>
                                    }
                                </select>
                            </td>
                            <td class="px-3 py-2 text-right">
                                <button type="button" class="text-xs text-content-muted hover:text-negative" @onclick="() => aiDrafts.Remove(draft)">Remove</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <button type="button" class="btn-secondary" @onclick="AddAiDraftLine">Add line</button>
    </Modal>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string BidPackageId { get; set; } = "";

    private bool isLoaded;
    private bool busy;
    private string? error;
    private string? aiNote;

    private BidPackage? package;
    private IReadOnlyList<BidPackageRecipient> recipients = Array.Empty<BidPackageRecipient>();
    private IReadOnlyList<BidPackageLineItem> lineItems = Array.Empty<BidPackageLineItem>();
    private IReadOnlyList<MailboxMessage> emails = Array.Empty<MailboxMessage>();
    private IReadOnlyList<Quote> quotes = Array.Empty<Quote>();
    private IReadOnlyList<QuoteLineItem> quoteLines = Array.Empty<QuoteLineItem>();
    private IReadOnlyList<Drawing> packageDrawings = Array.Empty<Drawing>();
    private IReadOnlyList<ProjectWorkOrderDetail> projectOrders = Array.Empty<ProjectWorkOrderDetail>();
    private IReadOnlyList<BoqLineItem> boqLines = Array.Empty<BoqLineItem>();
    private IReadOnlyList<VariationOrderQuote> voqs = Array.Empty<VariationOrderQuote>();

    private bool showInviteModal;
    private string subSearch = "";
    private readonly HashSet<string> selected = new(StringComparer.OrdinalIgnoreCase);

    private bool CanManage => Session.AvailableRoles.Any(r =>
        r is Role.Admin or Role.ManagingDirector or Role.ProjectManager);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.EnsureLoadedAsync();
            if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
            Subs.OnChange += OnStoreChanged;
            CostCenters.OnChanged += OnStoreChanged;
            try { _ = Subs.All(); } catch { /* directory load is best-effort */ }
            // Cost centres feed the line-item cost-code selects — best-effort background refresh.
            try { _ = CostCenters.RefreshAsync(CancellationToken.None); } catch { }
            await LoadAsync();
        }
        catch (Exception ex)
        {
            error = $"Couldn't load this page: {ex.Message}";
        }
        finally
        {
            isLoaded = true;
        }
    }

    public void Dispose()
    {
        Subs.OnChange -= OnStoreChanged;
        CostCenters.OnChanged -= OnStoreChanged;
    }

    private void OnStoreChanged() => InvokeAsync(StateHasChanged);

    // Each piece loads independently so one failing query doesn't take down the whole view.
    private async Task LoadAsync()
    {
        try { package = await Queries.AskAsync(new GetBidPackageById(BidPackageId), CancellationToken.None); }
        catch (Exception ex) { error = $"Couldn't load the bid package: {ex.Message}"; }

        try { recipients = await Queries.AskAsync(new ListBidPackageRecipients(BidPackageId), CancellationToken.None); }
        catch (Exception ex) { error = Append(error, $"Couldn't load invited subcontractors: {ex.Message}"); }

        try { lineItems = await Queries.AskAsync(new ListBidPackageLineItems(BidPackageId), CancellationToken.None); }
        catch (Exception ex) { error = Append(error, $"Couldn't load line items: {ex.Message}"); }

        try { emails = await Queries.AskAsync(new ListBidPackageEmails(BidPackageId), CancellationToken.None); }
        catch (Exception ex) { error = Append(error, $"Couldn't load related emails: {ex.Message}"); }

        try { quotes = await Queries.AskAsync(new ListQuotesForBidPackage(BidPackageId), CancellationToken.None); }
        catch (Exception ex) { error = Append(error, $"Couldn't load tender submissions: {ex.Message}"); }

        try { quoteLines = await Queries.AskAsync(new ListQuoteLineItemsForBidPackage(BidPackageId), CancellationToken.None); }
        catch { /* comparison simply shows totals only */ }

        try { packageDrawings = await Queries.AskAsync(new ListBidPackageDrawings(BidPackageId), CancellationToken.None); }
        catch { /* documents section simply shows none */ }

        // The order this package's award raised — drives the persistent award summary. Best-effort:
        // without it the summary simply doesn't render (statuses still show Awarded/Won).
        try { projectOrders = await Queries.AskAsync(new ListProjectWorkOrders(ProjectId), CancellationToken.None); }
        catch { /* award summary simply hidden */ }

        // Coverage targets — best-effort so the picker can offer contract BoQ lines and variations.
        try { boqLines = await Queries.AskAsync(new ListBoqLinesForProject(ProjectId), CancellationToken.None); }
        catch { /* picker simply shows no BoQ lines */ }

        try { voqs = await Queries.AskAsync(new ListVoqsForProject(ProjectId), CancellationToken.None); }
        catch { /* picker simply shows no variations */ }

        await LoadLineageAsync();
    }

    // ---- Record lineage (Request → VOQ → VO, plus sibling packages) for the navigation bar ----
    // Only packages that belong to a VOQ have a lineage; BoQ-covered packages show no bar. Every
    // read is best-effort: a missing piece renders as a placeholder chip, never an error.

    private Request? lineageRequest;
    private VariationOrderQuote? lineageVoq;
    private VariationOrder? lineageVo;
    private IReadOnlyList<BidPackage> siblingPackages = Array.Empty<BidPackage>();

    private async Task LoadLineageAsync()
    {
        if (string.IsNullOrEmpty(package?.VariationOrderQuoteId))
        {
            lineageRequest = null; lineageVoq = null; lineageVo = null;
            siblingPackages = Array.Empty<BidPackage>();
            return;
        }

        var voqId = package.VariationOrderQuoteId;
        try { lineageVoq = await Queries.AskAsync(new GetVoqById(voqId), CancellationToken.None); }
        catch { lineageVoq = null; }
        if (lineageVoq is null) return;

        try { lineageRequest = await RequestRegister.GetAsync(lineageVoq.RequestId); }
        catch { lineageRequest = null; }
        try { lineageVo = await Queries.AskAsync(new GetVariationOrderByVoq(voqId), CancellationToken.None); }
        catch { lineageVo = null; }
        try { siblingPackages = await Queries.AskAsync(new ListBidPackagesForVoq(voqId), CancellationToken.None); }
        catch { siblingPackages = Array.Empty<BidPackage>(); }
    }

    // ---- Line-item coverage (link to a contract BoQ line or a variation) ----

    private bool showCoverageModal;
    private BidPackageLineItem? linkingLine;
    private BidPackageLineCoverage coverageChoice = BidPackageLineCoverage.Unassigned;
    private string? coverageBoqId;
    private string? coverageVoqId;

    private string CoverageLabel(BidPackageLineItem item)
    {
        switch (item.Coverage)
        {
            case BidPackageLineCoverage.ContractLine:
                var boq = boqLines.FirstOrDefault(b => b.BoqLineItemId == item.BoqLineItemId);
                return boq is null ? "Contract line" : $"BoQ · {boq.Description}";
            case BidPackageLineCoverage.Variation:
                var voq = voqs.FirstOrDefault(v => v.VariationOrderQuoteId == item.VariationOrderQuoteId);
                return voq is null ? "Variation" : $"{voq.Reference} · {voq.Title}";
            default:
                return "";
        }
    }

    private void OpenCoverageModal(BidPackageLineItem item)
    {
        linkingLine = item;
        coverageChoice = item.Coverage;
        coverageBoqId = item.BoqLineItemId;
        coverageVoqId = item.VariationOrderQuoteId;
        showCoverageModal = true;
    }

    private void CloseCoverageModal()
    {
        showCoverageModal = false;
        linkingLine = null;
    }

    private async Task ConfirmCoverage()
    {
        if (busy || linkingLine is null || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            var boqId = coverageChoice == BidPackageLineCoverage.ContractLine && !string.IsNullOrWhiteSpace(coverageBoqId) ? coverageBoqId : null;
            var voqId = coverageChoice == BidPackageLineCoverage.Variation && !string.IsNullOrWhiteSpace(coverageVoqId) ? coverageVoqId : null;
            lineItems = await Commands.SendAsync(
                new SetBidPackageLineItemCoverage(linkingLine.LineItemId, coverageChoice, boqId, voqId), CancellationToken.None);
            showCoverageModal = false;
            linkingLine = null;
        }
        catch { error = "Couldn't update coverage. Make sure a BoQ line or variation is selected, then try again."; }
        finally { busy = false; }
    }

    private static string Append(string? existing, string line) =>
        string.IsNullOrEmpty(existing) ? line : existing + "\n" + line;

    // ---- Generate using AI: confirm → generate → review → apply (merge, never replace) ----

    private sealed class AiDraftLine
    {
        public string Trade { get; set; } = "";
        public string Description { get; set; } = "";
        public string Unit { get; set; } = "";
        public decimal Quantity { get; set; }
        public string CostCode { get; set; } = "";
        public bool Include { get; set; } = true;
        public bool AlreadyOnPackage { get; set; }
    }

    private sealed class AiDraftProposal
    {
        public string? Notes { get; set; }
        public List<AiDraftLine> Lines { get; set; } = new();
    }

    private bool showAiConfirmModal;
    private bool showAiReviewModal;
    private bool aiBusy;
    private string? aiProposalNotes;
    private List<AiDraftLine> aiDrafts = new();

    // The header button never generates directly — it opens the confirm screen.
    private void GenerateWithAi()
    {
        aiNote = null;
        showAiConfirmModal = true;
    }

    private void CloseAiConfirmModal() => showAiConfirmModal = false;

    private async Task ConfirmAiGenerate()
    {
        if (aiBusy || !CanManage) return;
        aiBusy = true;
        try
        {
            var proposal = await RequestAiProposalAsync();
            showAiConfirmModal = false;
            if (proposal is null)
            {
                aiNote = "AI generation isn't wired up yet. When enabled, Claude will draft the package — scope and line items — from the related emails and drawings, and the draft will open here for review. Nothing is added to the package until you accept it, and existing content is never changed or removed.";
                return;
            }
            aiProposalNotes = proposal.Notes;
            aiDrafts = proposal.Lines;
            foreach (var draft in aiDrafts)
            {
                draft.AlreadyOnPackage = IsExistingLine(draft);
                if (draft.AlreadyOnPackage) draft.Include = false; // never re-add what's already there
            }
            showAiReviewModal = true;
        }
        finally { aiBusy = false; }
    }

    // The generation seam. When the backend command lands, call it here and map the result to
    // AiDraftProposal — the confirm → review → apply flow around it stays exactly as is.
    private Task<AiDraftProposal?> RequestAiProposalAsync() =>
        Task.FromResult<AiDraftProposal?>(null);

    private bool IsExistingLine(AiDraftLine draft) =>
        lineItems.Any(item =>
            string.Equals(item.Description.Trim(), draft.Description.Trim(), StringComparison.OrdinalIgnoreCase)
            && string.Equals((item.Trade ?? "").Trim(), (draft.Trade ?? "").Trim(), StringComparison.OrdinalIgnoreCase));

    private void CloseAiReviewModal() => showAiReviewModal = false;

    private void AddAiDraftLine() => aiDrafts.Add(new AiDraftLine { Trade = package?.Trade ?? "", Quantity = 1 });

    private int AiAcceptedCount() => aiDrafts.Count(d => d.Include && !string.IsNullOrWhiteSpace(d.Description));

    // Apply = append-only: AddBidPackageLineItems never reads, deletes or recreates existing rows,
    // so their ids, coverage links and quote-line references stay intact. (Deliberately NOT
    // SetBidPackageLineItems — that replaces the whole set and would drop those links.)
    private async Task ConfirmAiApply()
    {
        if (busy || !CanManage) return;
        error = null;
        try
        {
            var accepted = aiDrafts.Where(d => d.Include && !string.IsNullOrWhiteSpace(d.Description)).ToList();
            if (accepted.Count == 0) { showAiReviewModal = false; return; }
            // Every line put out to tender must know its cost-centre home.
            if (accepted.Any(d => string.IsNullOrWhiteSpace(d.CostCode)))
            {
                error = "Every accepted line needs a cost code — pick a cost centre for each ticked line before applying.";
                return;
            }
            busy = true;
            var inputs = accepted
                .Select(d => new BidPackageLineItemInput(
                    d.Description.Trim(), (d.Unit ?? "").Trim(), d.Quantity, (d.Trade ?? "").Trim(), d.CostCode.Trim()))
                .ToList();
            lineItems = await Commands.SendAsync(new AddBidPackageLineItems(BidPackageId, inputs), CancellationToken.None);
            showAiReviewModal = false;
            aiNote = $"Added {accepted.Count} line item{(accepted.Count == 1 ? "" : "s")} from the AI draft. Existing line items were left untouched.";
        }
        catch { error = "Couldn't add the accepted line items. Please try again."; }
        finally { busy = false; }
    }

    // ---- Invite (modal over the directory) ----

    private string? tradeFilter;

    private void OpenInviteModal()
    {
        selected.Clear();
        subSearch = "";
        // Trade is required by the directory — prefill with the package's trade so quick-add just works.
        if (string.IsNullOrWhiteSpace(quickAddTradeId))
            quickAddTradeId = CuratedTradeIdFor(package?.Trade) ?? "";
        // Pre-filter to the package's trade when the directory knows it — one less tap.
        tradeFilter = InvitableTrades()
            .FirstOrDefault(t => string.Equals(t, package?.Trade, StringComparison.OrdinalIgnoreCase));
        showInviteModal = true;
    }

    // The distinct trade names among companies that could be invited (never clients/architects).
    // A company with several trades appears under each of them.
    private IReadOnlyList<string> InvitableTrades() =>
        Subs.All()
            .Where(s => s.Category is DirectoryCategory.Subcontractor or DirectoryCategory.Supplier)
            .SelectMany(s => s.Trades)
            .Select(t => t.Name.Trim())
            .Where(t => t.Length > 0)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(t => t, StringComparer.OrdinalIgnoreCase)
            .ToList();

    // The curated trade id for a trade name, when the list knows it.
    private string? CuratedTradeIdFor(string? name) =>
        string.IsNullOrWhiteSpace(name) ? null
        : Subs.Trades().FirstOrDefault(t => string.Equals(t.Name, name.Trim(), StringComparison.OrdinalIgnoreCase))?.TradeId;

    // Resolves a trade name to a curated trade id, adding it to the curated list if new — the
    // server normalises and de-duplicates, so this never mints case-variant duplicates.
    private async Task<string> EnsureTradeIdAsync(string? name)
    {
        var trimmed = string.IsNullOrWhiteSpace(name) ? "General" : name.Trim();
        if (CuratedTradeIdFor(trimmed) is string existing) return existing;
        var created = await Commands.SendAsync(new AddTrade(trimmed), CancellationToken.None);
        return created.TradeId;
    }

    private void CloseInviteModal() => showInviteModal = false;

    private void OnSearchInput(ChangeEventArgs e) => subSearch = e.Value?.ToString() ?? "";

    private IReadOnlyList<Subcontractor> Invitable()
    {
        var invited = recipients.Select(r => r.SubcontractorId).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var q = (subSearch ?? "").Trim();
        return Subs.All()
            // Only companies we tender to — never clients or architects.
            .Where(s => s.Category is DirectoryCategory.Subcontractor or DirectoryCategory.Supplier)
            .Where(s => !invited.Contains(s.SubcontractorId))
            // Any of the company's trades counts — "Boarding" and "Plastering" both surface a
            // company that carries both, where the old free-text compound string never matched.
            .Where(s => tradeFilter is null || s.Trades.Any(t => string.Equals(t.Name.Trim(), tradeFilter, StringComparison.OrdinalIgnoreCase)))
            .Where(s => q.Length == 0
                || (s.CompanyName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || s.Trades.Any(t => t.Name.Contains(q, StringComparison.OrdinalIgnoreCase))
                || (s.ContactName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void Toggle(string subcontractorId, ChangeEventArgs e)
    {
        if (e.Value is true) selected.Add(subcontractorId);
        else selected.Remove(subcontractorId);
    }

    // ---- Quick-add: invite someone who isn't in the directory yet ----

    private string quickAddName = "";
    private string quickAddEmail = "";
    private string quickAddTradeId = "";

    private bool QuickAddReady =>
        !string.IsNullOrWhiteSpace(quickAddName)
        && quickAddEmail.Contains('@') && quickAddEmail.Trim().Length >= 5;

    // Something typed but not enough to include — surfaced so a half-filled row isn't silently dropped.
    private bool quickAddPartial =>
        !QuickAddReady && (!string.IsNullOrWhiteSpace(quickAddName) || !string.IsNullOrWhiteSpace(quickAddEmail));

    private int InviteCount() => selected.Count + (QuickAddReady ? 1 : 0);

    private async Task ConfirmInvite()
    {
        if (busy || InviteCount() == 0 || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            var ids = selected.ToList();
            if (QuickAddReady)
            {
                // Save the ad-hoc contact to the directory first, then invite like any other.
                // The directory requires a trade — fall back to the package's, then "General".
                var tradeId = !string.IsNullOrWhiteSpace(quickAddTradeId) ? quickAddTradeId
                    : await EnsureTradeIdAsync(package?.Trade);
                var created = await Commands.SendAsync(
                    new AddSubcontractorToDirectory(
                        quickAddName.Trim(), new[] { tradeId }, quickAddName.Trim(),
                        quickAddEmail.Trim(), "", ""), CancellationToken.None);
                ids.Add(created.SubcontractorId);
                await SubsReadModel.RefreshAsync(CancellationToken.None);
            }
            recipients = await Commands.SendAsync(
                new InviteSubcontractorsToBidPackage(BidPackageId, ids), CancellationToken.None);
            selected.Clear();
            quickAddName = quickAddEmail = quickAddTradeId = "";
            showInviteModal = false;
            package = await Queries.AskAsync(new GetBidPackageById(BidPackageId), CancellationToken.None);
        }
        catch (CommandFailedException ex) { error = $"Couldn't send those invites: {ex.Message}"; }
        catch { error = "Couldn't send those invites. Please try again."; }
        finally { busy = false; }
    }

    // ---- Find local subcontractors (Google Places search near the project's site) ----

    private bool showFindModal;
    private bool findBusy;
    private bool findSearched;
    private string findTrade = "";
    private string? findError;
    private string? findNextPageToken;
    private readonly List<LocalSubcontractor> findResults = new();
    private readonly Dictionary<string, LocalSubcontractor> selectedPlaces = new(StringComparer.Ordinal);

    // The curated trade list, with the package's own trade offered even if the curated list
    // doesn't know it yet (searching can precede curating).
    private IReadOnlyList<string> FindTradeOptions()
    {
        var trades = Subs.Trades()
            .Select(t => t.Name)
            .OrderBy(t => t, StringComparer.OrdinalIgnoreCase)
            .ToList();
        if (!string.IsNullOrWhiteSpace(package?.Trade)
            && !trades.Contains(package!.Trade, StringComparer.OrdinalIgnoreCase))
        {
            trades.Insert(0, package.Trade);
        }
        return trades;
    }

    private void OpenFindModal()
    {
        findTrade = package?.Trade ?? "";
        findResults.Clear();
        selectedPlaces.Clear();
        findNextPageToken = null;
        findError = null;
        findSearched = false;
        showFindModal = true;
    }

    private void CloseFindModal() => showFindModal = false;

    private async Task RunFindSearch(bool loadMore)
    {
        if (findBusy || string.IsNullOrWhiteSpace(findTrade)) return;
        findBusy = true;
        findError = null;
        try
        {
            var result = await Queries.AskAsync(
                new SearchLocalSubcontractors(ProjectId, findTrade.Trim(), loadMore ? findNextPageToken : null),
                CancellationToken.None);
            if (!loadMore)
            {
                findResults.Clear();
                selectedPlaces.Clear();
            }
            if (result.Error is not null)
            {
                findError = result.Error;
                findNextPageToken = null;
            }
            else
            {
                findResults.AddRange(result.Results.Where(hit => findResults.All(existing => existing.PlaceId != hit.PlaceId)));
                findNextPageToken = result.NextPageToken;
            }
            findSearched = true;
        }
        catch { findError = "The search failed. Please try again."; }
        finally { findBusy = false; }
    }

    private void TogglePlace(LocalSubcontractor place, ChangeEventArgs e)
    {
        if (e.Value is true) selectedPlaces[place.PlaceId] = place;
        else selectedPlaces.Remove(place.PlaceId);
    }

    // Save each ticked company to the directory (unless it's already there), then invite them all.
    private async Task ConfirmFindInvite()
    {
        if (busy || selectedPlaces.Count == 0 || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            var ids = new List<string>();
            var directoryChanged = false;
            foreach (var place in selectedPlaces.Values)
            {
                if (!string.IsNullOrEmpty(place.ExistingSubcontractorId))
                {
                    ids.Add(place.ExistingSubcontractorId);
                    // Backfill contact details the search discovered but the directory entry lacks
                    // (e.g. entries added before email discovery existed). Blanks only — a value
                    // someone typed into the directory deliberately is never overwritten.
                    var existing = Subs.Find(place.ExistingSubcontractorId);
                    var needsEmail = existing is not null
                        && string.IsNullOrWhiteSpace(existing.ContactEmail) && !string.IsNullOrWhiteSpace(place.Email);
                    var needsPhone = existing is not null
                        && string.IsNullOrWhiteSpace(existing.ContactPhone) && !string.IsNullOrWhiteSpace(place.Phone);
                    if (needsEmail || needsPhone)
                    {
                        await Commands.SendAsync(
                            new UpdateSubcontractor(
                                existing!.SubcontractorId, existing.CompanyName, existing.Trades.Select(t => t.TradeId).ToList(), existing.ContactName,
                                needsEmail ? place.Email! : existing.ContactEmail,
                                needsPhone ? place.Phone! : existing.ContactPhone,
                                existing.CisStatus),
                            CancellationToken.None);
                        directoryChanged = true; // refresh the read model so the new email shows immediately
                    }
                    continue;
                }
                var created = await Commands.SendAsync(
                    new AddSubcontractorToDirectory(
                        place.Name, new[] { await EnsureTradeIdAsync(findTrade) }, "", place.Email ?? "", place.Phone ?? "", "",
                        DirectoryCategory.Subcontractor, "", "", "", place.Website ?? ""),
                    CancellationToken.None);
                ids.Add(created.SubcontractorId);
                directoryChanged = true;
            }
            if (directoryChanged) await SubsReadModel.RefreshAsync(CancellationToken.None);

            recipients = await Commands.SendAsync(
                new InviteSubcontractorsToBidPackage(BidPackageId, ids), CancellationToken.None);
            selectedPlaces.Clear();
            showFindModal = false;
            package = await Queries.AskAsync(new GetBidPackageById(BidPackageId), CancellationToken.None);
            sendNote = $"Invited {ids.Count} compan{(ids.Count == 1 ? "y" : "ies")} from the local search. Their emails were picked up from their websites — worth a quick check in the Directory before drafting the invite email.";
            draftWebLink = null;
        }
        catch (CommandFailedException ex) { error = $"Couldn't invite those companies: {ex.Message}"; }
        catch { error = "Couldn't invite those companies. Please try again."; }
        finally { busy = false; }
    }

    private async Task RemoveRecipient(BidPackageRecipient recipient)
    {
        if (busy || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            recipients = await Commands.SendAsync(
                new RemoveBidPackageRecipient(BidPackageId, recipient.RecipientId), CancellationToken.None);
        }
        catch { error = "Couldn't remove that subcontractor. Please try again."; }
        finally { busy = false; }
    }

    // ---- Decline: record "not tendering" without losing them from the invite list ----

    private async Task SetDeclined(BidPackageRecipient recipient, bool declined)
    {
        if (busy || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            recipients = await Commands.SendAsync(
                new DeclineBidPackageRecipient(BidPackageId, recipient.RecipientId, declined), CancellationToken.None);
        }
        catch { error = "Couldn't update that subcontractor's status. Please try again."; }
        finally { busy = false; }
    }

    // ---- Link project drawings to the package ----

    private bool showDrawingsModal;
    private IReadOnlyList<Drawing> projectDrawings = Array.Empty<Drawing>();
    private readonly HashSet<string> selectedDrawingIds = new(StringComparer.OrdinalIgnoreCase);

    private async Task OpenDrawingsModal()
    {
        selectedDrawingIds.Clear();
        foreach (var drawing in packageDrawings) selectedDrawingIds.Add(drawing.DrawingId);
        showDrawingsModal = true;
        try { projectDrawings = await Queries.AskAsync(new ListDrawingsForProject(ProjectId), CancellationToken.None); }
        catch { projectDrawings = Array.Empty<Drawing>(); }
    }

    private void CloseDrawingsModal() => showDrawingsModal = false;

    private void ToggleDrawing(string drawingId, ChangeEventArgs e)
    {
        if (e.Value is true) selectedDrawingIds.Add(drawingId);
        else selectedDrawingIds.Remove(drawingId);
    }

    private async Task ConfirmDrawings()
    {
        if (busy || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            packageDrawings = await Commands.SendAsync(
                new SetBidPackageDrawings(BidPackageId, selectedDrawingIds.ToList()), CancellationToken.None);
            showDrawingsModal = false;
        }
        catch { error = "Couldn't update the linked drawings. Please try again."; }
        finally { busy = false; }
    }

    // ---- Compose & send the tender-invite email ----

    private bool showComposeModal;
    private bool editingBody;
    private string composeSubject = "";
    private string composeBody = "";
    private string? sendNote;
    private string? draftWebLink;

    // The companies that will actually be BCC'd — invited recipients with a directory email.
    private IReadOnlyList<string> BccPreview() =>
        recipients
            .Select(r => Subs.Find(r.SubcontractorId))
            .Where(s => s is not null && !string.IsNullOrWhiteSpace(s.ContactEmail))
            .Select(s => s!.CompanyName)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

    // Invited but unreachable — no email address in the directory.
    private IReadOnlyList<string> MissingEmail() =>
        recipients
            .Select(r => Subs.Find(r.SubcontractorId) is { } s
                ? (Name: s.CompanyName, HasEmail: !string.IsNullOrWhiteSpace(s.ContactEmail))
                : (Name: r.SubcontractorId, HasEmail: false))
            .Where(x => !x.HasEmail)
            .Select(x => x.Name)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

    private void OpenComposeModal()
    {
        if (package is null) return;
        composeSubject = $"Invitation to tender — {package.Title} ({package.Reference})";
        composeBody = DefaultInviteBody();
        sendNote = null;
        editingBody = false;
        showComposeModal = true;
    }

    private void CloseComposeModal() => showComposeModal = false;

    // The pre-filled HTML invite: scope summary plus the line items to price, grouped by trade.
    private string DefaultInviteBody()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("<p>Hello,</p>");
        if (lineItems.Count > 0)
            sb.AppendLine($"<p>Jewel Bespoke Build invites you to tender for the <strong>{package!.Title}</strong> package (ref {package.Reference}). Please price the items below and reply to this email with your rates, exclusions and lead times, quoting the reference in your reply.</p>");
        else
            sb.AppendLine($"<p>Jewel Bespoke Build invites you to tender for the <strong>{package!.Title}</strong> package (ref {package.Reference}). Please price the works described in the attached documents and reply to this email with your rates, exclusions and lead times, quoting the reference in your reply.</p>");
        foreach (var group in lineItems.GroupBy(item => item.Trade).OrderBy(g => g.Key))
        {
            var heading = string.IsNullOrWhiteSpace(group.Key) ? "General" : group.Key;
            sb.AppendLine($"<p><strong>{heading}</strong></p>");
            sb.AppendLine("<table border=\"1\" cellpadding=\"6\" cellspacing=\"0\" style=\"border-collapse:collapse\">");
            sb.AppendLine("<tr><th align=\"left\">Description</th><th align=\"left\">Qty</th><th align=\"left\">Unit</th><th align=\"left\">Rate</th><th align=\"left\">Total</th></tr>");
            foreach (var item in group.OrderBy(i => i.SortOrder))
                sb.AppendLine($"<tr><td>{item.Description}</td><td>{item.Quantity}</td><td>{item.Unit}</td><td></td><td></td></tr>");
            sb.AppendLine("</table>");
        }
        sb.AppendLine("<p><strong>Please include the following with your tender:</strong></p>");
        sb.AppendLine("<ul>");
        if (package!.MaterialsApplicable)
            sb.AppendLine("<li><strong>Materials</strong> — please state whether you will be supplying your own materials for this work. If your rates are supply-and-fit, itemise the materials included; if they are labour-only, state what you expect us to supply.</li>");
        sb.AppendLine("<li><strong>Deposit</strong> — our preference is not to pay a deposit upfront. If one is required for you to take on the work, please state the amount and terms in your tender.</li>");
        sb.AppendLine("<li><strong>Duration</strong> — how long the work will take.</li>");
        sb.AppendLine("<li><strong>Availability</strong> — if selected, when you would be able to start.</li>");
        sb.AppendLine("<li><strong>Insurances</strong> — confirmation that you hold all insurances required for this work.</li>");
        sb.AppendLine("<li><strong>RAMS</strong> — confirmation that you will provide the required RAMS documentation.</li>");
        sb.AppendLine("<li><strong>Portfolio</strong> — examples of prior comparable work.</li>");
        sb.AppendLine("</ul>");
        sb.AppendLine("<p>Please confirm receipt and let us know if you need any further information or drawings.</p>");
        sb.AppendLine("<p>Kind regards,<br/>Jewel Bespoke Build</p>");
        return sb.ToString();
    }

    private async Task ConfirmSendInvite()
    {
        if (busy || package is null || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            var draft = await Commands.SendAsync(
                new PrepareBidPackageInviteDraft(BidPackageId, composeSubject.Trim(), composeBody), CancellationToken.None);
            package = draft.Package;
            showComposeModal = false;
            draftWebLink = draft.WebLink;
            sendNote = $"Draft created in the shared mailbox with {draft.Bcc.Count} subcontractor(s) in BCC, tagged {package.Reference}. Review and send it from the mailbox's Drafts folder.";
        }
        catch (CommandFailedException ex) { error = $"Couldn't create the draft: {ex.Message}"; }
        catch { error = "Couldn't create the draft. Check the recipients have email addresses and the mailbox connection, then try again."; }
        finally { busy = false; }
    }

    // ---- Extract a tender from a tagged email, review, save as a quote ----

    private sealed class ExtractDraft
    {
        public string? BidPackageLineItemId { get; set; }
        public string Description { get; set; } = "";
        public string Unit { get; set; } = "";
        public decimal Quantity { get; set; }
        public decimal Rate { get; set; }
        public decimal Total { get; set; }
    }

    private bool showExtractModal;
    private bool extractBusy;
    private bool extractProposed;
    private bool manualExtract;
    private string extractSubcontractorId = "";
    private string extractNotes = "";
    private List<ExtractDraft> extractDrafts = new();
    private string? awardNote;

    // Opens the same review modal with no source email — for tenders phoned through, posted, or
    // sat in an email that never got tagged. Saving goes through SaveExtractedQuote exactly as the
    // email path does, so recipient/package statuses and supersede-on-resubmit behave identically.
    private void OpenManualTenderModal()
    {
        if (busy || !CanManage) return;
        showExtractModal = true;
        extractBusy = false;
        extractProposed = false;
        manualExtract = true;
        extractSubcontractorId = "";
        extractNotes = "";
        extractDrafts = lineItems
            .Select(item => new ExtractDraft { BidPackageLineItemId = item.LineItemId, Description = item.Description, Unit = item.Unit, Quantity = item.Quantity })
            .ToList();
        if (extractDrafts.Count == 0) extractDrafts.Add(new ExtractDraft { Quantity = 1 });
    }

    private async Task OpenExtractModal(MailboxMessage email)
    {
        if (busy) return;
        showExtractModal = true;
        extractBusy = true;
        extractProposed = false;
        manualExtract = false;
        extractSubcontractorId = "";
        extractNotes = "";
        extractDrafts = new();
        StateHasChanged();
        try
        {
            var proposal = await Commands.SendAsync(
                new ExtractQuoteFromMessage(BidPackageId, email.Id), CancellationToken.None);
            extractProposed = proposal.Proposed;
            extractSubcontractorId = proposal.SubcontractorId ?? "";
            extractNotes = proposal.Notes;
            extractDrafts = proposal.Lines
                .Select(line => new ExtractDraft
                {
                    BidPackageLineItemId = line.BidPackageLineItemId,
                    Description = line.Description,
                    Unit = line.Unit,
                    Quantity = line.Quantity,
                    Rate = line.Rate,
                    Total = line.Total
                })
                .ToList();
            if (extractDrafts.Count == 0)
                extractDrafts = lineItems
                    .Select(item => new ExtractDraft { BidPackageLineItemId = item.LineItemId, Description = item.Description, Unit = item.Unit, Quantity = item.Quantity })
                    .ToList();
        }
        catch
        {
            error = "Couldn't read that email for extraction. You can still enter the submission manually.";
            extractDrafts = lineItems
                .Select(item => new ExtractDraft { BidPackageLineItemId = item.LineItemId, Description = item.Description, Unit = item.Unit, Quantity = item.Quantity })
                .ToList();
        }
        finally
        {
            extractBusy = false;
            StateHasChanged();
        }
    }

    private void CloseExtractModal() => showExtractModal = false;

    private void AddExtractLine() => extractDrafts.Add(new ExtractDraft { Quantity = 1 });

    private void RecalcTotal(ExtractDraft draft)
    {
        if (draft.Total == 0 && draft.Rate != 0 && draft.Quantity != 0)
            draft.Total = decimal.Round(draft.Rate * draft.Quantity, 2);
    }

    private async Task ConfirmSaveExtracted()
    {
        if (busy || !CanManage || string.IsNullOrWhiteSpace(extractSubcontractorId)) return;
        error = null;
        try
        {
            busy = true;
            var lines = extractDrafts
                .Where(draft => !string.IsNullOrWhiteSpace(draft.Description))
                .Select(draft => new QuoteExtractionLine(
                    draft.BidPackageLineItemId, draft.Description.Trim(), (draft.Unit ?? "").Trim(),
                    draft.Quantity, draft.Rate, draft.Total))
                .ToList();
            await Commands.SendAsync(
                new SaveExtractedQuote(BidPackageId, extractSubcontractorId, extractNotes ?? "", lines), CancellationToken.None);
            showExtractModal = false;
            await LoadAsync();
        }
        catch { error = "Couldn't save that submission. Make sure a subcontractor is selected and every line has a description."; }
        finally { busy = false; }
    }

    // ---- Award summary & work-order email to the winner ----

    // The order this package's award raised (latest, if re-awarded). Null until orders load or
    // when the package has never been awarded.
    private ProjectWorkOrderDetail? AwardedOrder => projectOrders
        .Where(detail => string.Equals(detail.Order.BidPackageId, BidPackageId, StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(detail => detail.Order.AwardedAt)
        .FirstOrDefault();

    private bool showWoEmailModal;
    private string woEmailSubject = "";
    private string woEmailBody = "";
    private string? woEmailNote;
    private string? woEmailLink;

    private void OpenWorkOrderEmailModal()
    {
        if (busy || package is null || AwardedOrder is not { } awarded) return;
        woEmailSubject = $"Work order WO-{awarded.Order.Number:0000} — {awarded.Order.Title} ({package.Reference})";
        woEmailBody = DefaultWorkOrderEmailBody(awarded);
        woEmailNote = null;
        showWoEmailModal = true;
    }

    private void CloseWorkOrderEmailModal() => showWoEmailModal = false;

    // The pre-filled order email: award confirmation, the priced lines (or the order total and scope
    // for legacy orders without lines), and the pre-start paperwork the tender invite asked about.
    private string DefaultWorkOrderEmailBody(ProjectWorkOrderDetail awarded)
    {
        var order = awarded.Order;
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"<p>Hello {awarded.SubcontractorName},</p>");
        sb.AppendLine($"<p>Following your tender for the <strong>{package!.Title}</strong> package (ref {package.Reference}), we are pleased to confirm the award and attach our work order <strong>WO-{order.Number:0000}</strong> below.</p>");
        if (awarded.Lines.Count > 0)
        {
            sb.AppendLine("<table border=\"1\" cellpadding=\"6\" cellspacing=\"0\" style=\"border-collapse:collapse\">");
            sb.AppendLine("<tr><th align=\"left\">Item</th><th align=\"left\">Qty</th><th align=\"left\">Unit</th><th align=\"right\">Total</th></tr>");
            foreach (var line in awarded.Lines.OrderBy(l => l.SortOrder))
                sb.AppendLine($"<tr><td>{line.Title}</td><td>{line.Quantity}</td><td>{line.Unit}</td><td align=\"right\">{line.LineTotal:£#,##0.00}</td></tr>");
            sb.AppendLine($"<tr><td colspan=\"3\"><strong>Order total</strong></td><td align=\"right\"><strong>{order.Value:£#,##0.00}</strong></td></tr>");
            sb.AppendLine("</table>");
        }
        else
        {
            sb.AppendLine($"<p><strong>Order value:</strong> {order.Value:£#,##0.00}</p>");
            if (!string.IsNullOrWhiteSpace(order.Scope))
                sb.AppendLine($"<p><strong>Scope:</strong> {order.Scope}</p>");
        }
        if (order.ScheduledCompletion is { } completion)
            sb.AppendLine($"<p><strong>Scheduled completion:</strong> {completion.LocalDateTime:d MMM yyyy}</p>");
        sb.AppendLine("<p>Please reply to confirm receipt and acceptance of this order, quoting the reference. Before starting on site, please provide your RAMS documentation and current insurance certificates as set out in the tender invitation.</p>");
        sb.AppendLine("<p>Kind regards,<br/>Jewel Bespoke Build</p>");
        return sb.ToString();
    }

    private async Task ConfirmWorkOrderEmailDraft()
    {
        if (busy || !CanManage || AwardedOrder is not { } awarded) return;
        error = null;
        try
        {
            busy = true;
            var draft = await Commands.SendAsync(
                new PrepareWorkOrderEmailDraft(awarded.Order.WorkOrderId, woEmailSubject.Trim(), woEmailBody), CancellationToken.None);
            showWoEmailModal = false;
            woEmailLink = draft.WebLink;
            woEmailNote = $"Draft created in the shared mailbox to {draft.RecipientEmail}, tagged {package?.Reference}. Review and send it from the mailbox's Drafts folder.";
        }
        catch (CommandFailedException ex) { error = $"Couldn't create the draft: {ex.Message}"; }
        catch { error = "Couldn't create the draft. Check the supplier has an email address in the directory and the mailbox connection, then try again."; }
        finally { busy = false; }
    }

    // ---- Award: winning quote → work order (the purchase-order record) ----

    private async Task AwardTo(Quote quote)
    {
        if (busy || package is null || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            var sub = Subs.Find(quote.SubcontractorId);
            var workOrder = await Commands.SendAsync(
                new AwardBidPackage(
                    BidPackageId, ProjectId, quote.SubcontractorId, quote.Value,
                    $"{package.Title} ({package.Reference}) — as tender submission received {quote.ReceivedAt.LocalDateTime:d MMM yyyy}",
                    Auth.CurrentUser?.Email ?? "", quote.QuoteId), CancellationToken.None);
            awardNote = $"Awarded to {sub?.CompanyName ?? quote.SubcontractorId} at {quote.Value:£#,##0.00} — work order {workOrder.WorkOrderId[..8]}… raised as the purchase order.";
            await LoadAsync();
        }
        catch { error = "Couldn't award the package. Please try again."; }
        finally { busy = false; }
    }

    // ---- Line-item editing ----

    private sealed class LineDraft
    {
        public string Trade { get; set; } = "";
        public string Description { get; set; } = "";
        public string Unit { get; set; } = "";
        public decimal Quantity { get; set; }
        public string CostCode { get; set; } = "";
    }

    // "00006-12 — Plastering" for a known code; the bare code when the master list hasn't loaded.
    private string CostCentreLabel(string code)
    {
        var centre = CostCenters.Alphabetical.FirstOrDefault(c => string.Equals(c.Code, code, StringComparison.OrdinalIgnoreCase));
        return centre is null ? code : $"{centre.Code} — {centre.Name}";
    }

    // Flip the package's materials flag: when on, the drafted tender invite asks each
    // subcontractor to state whether they will supply their own materials or price labour-only.
    private async Task ToggleMaterialsApplicable(bool applicable)
    {
        if (busy || package is null || !CanManage) return;
        error = null;
        try
        {
            busy = true;
            package = await Commands.SendAsync(
                new UpdateBidPackageScope(package.BidPackageId, package.Title, package.Trade, package.Status, package.OwnerEmail, applicable),
                CancellationToken.None);
        }
        catch { error = "Couldn't update the materials setting. Please try again."; }
        finally { busy = false; }
    }

    private bool editingLines;
    private List<LineDraft> lineDrafts = new();

    private void EditLines()
    {
        lineDrafts = lineItems
            .Select(item => new LineDraft { Trade = item.Trade, Description = item.Description, Unit = item.Unit, Quantity = item.Quantity, CostCode = item.CostCode })
            .ToList();
        if (lineDrafts.Count == 0) lineDrafts.Add(new LineDraft());
        editingLines = true;
    }

    private void AddLine() => lineDrafts.Add(new LineDraft());

    private void RemoveLine(LineDraft draft) => lineDrafts.Remove(draft);

    private void CancelLines()
    {
        editingLines = false;
        lineDrafts.Clear();
    }

    private async Task SaveLines()
    {
        if (busy || !CanManage) return;
        error = null;
        try
        {
            var kept = lineDrafts
                .Where(draft => !string.IsNullOrWhiteSpace(draft.Description))
                .ToList();
            // Every line put out to tender must know its cost-centre home.
            if (kept.Any(draft => string.IsNullOrWhiteSpace(draft.CostCode)))
            {
                error = "Every line item needs a cost code — pick a cost centre for each line before saving.";
                return;
            }
            busy = true;
            var inputs = kept
                .Select(draft => new BidPackageLineItemInput(
                    draft.Description.Trim(),
                    (draft.Unit ?? "").Trim(),
                    draft.Quantity,
                    (draft.Trade ?? "").Trim(),
                    draft.CostCode.Trim()))
                .ToList();
            lineItems = await Commands.SendAsync(new SetBidPackageLineItems(BidPackageId, inputs), CancellationToken.None);
            editingLines = false;
            lineDrafts.Clear();
        }
        catch { error = "Couldn't save the line items. Please try again."; }
        finally { busy = false; }
    }
}
