@page "/projects/{ProjectId}/drawings/{DrawingId}"
@inject AuthService Auth
@inject SessionService Session
@inject IDrawingStore DrawingStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Drawing · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="drawings">
        @if (!DrawingStore.DrawingsLoadedFor(ProjectId))
        {
            @* Register fetch still in flight — don't flash "not found" before it lands. *@
            <p class="text-sm text-content-subtle italic">Loading…</p>
        }
        else if (drawing is null)
        {
            <p class="text-sm text-content-subtle italic">Drawing not found.</p>
        }
        else
        {
            <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
                <a href="@($"/projects/{ProjectId}/drawings")"
                   class="text-sm text-content-subtle hover:text-content underline underline-offset-4">← Back to register</a>
                <div class="flex items-center gap-2">
                    @if (PreviousDrawing is not null)
                    {
                        <a href="@DrawingHref(PreviousDrawing)"
                           class="rounded-lg border border-line-strong text-sm px-3 py-1.5 text-content-muted hover:bg-surface-raised transition">← Previous</a>
                    }
                    @if (Position is not null)
                    {
                        <span class="text-xs text-content-subtle tabular-nums">@Position.Value.index of @Position.Value.total</span>
                    }
                    @if (NextDrawing is not null)
                    {
                        <a href="@DrawingHref(NextDrawing)"
                           class="rounded-lg border border-line-strong text-sm px-3 py-1.5 text-content-muted hover:bg-surface-raised transition">Next →</a>
                    }
                </div>
            </div>

            <header class="mb-6 flex flex-wrap items-start justify-between gap-3">
                <div>
                    <p class="font-mono text-xs text-content-subtle mb-1">@drawing.DrawingCode</p>
                    <h2 class="text-xl md:text-2xl font-semibold text-content">@drawing.Title</h2>
                    <p class="text-sm text-content-muted mt-1">
                        Latest approved:
                        @if (string.IsNullOrEmpty(drawing.CurrentApprovedRevisionLabel))
                        {
                            <span class="italic text-content-subtle">none yet</span>
                        }
                        else
                        {
                            <span class="font-mono">Rev @drawing.CurrentApprovedRevisionLabel</span>
                        }
                    </p>
                </div>
                @if (CanManage)
                {
                    <div class="flex items-center gap-2">
                        @* Manual pipeline trigger — analysis is deliberately NOT automatic yet.
                           Disabled until the Bluebeam extraction + change-analysis pipeline is
                           connected; the revision list below shows each stage's status. *@
                        <button type="button" disabled title="The drawing analysis pipeline (Bluebeam metadata extraction + change analysis) is not connected yet"
                                class="rounded-lg border border-line-strong text-content-subtle font-medium text-sm px-3 py-2 cursor-not-allowed opacity-60">
                            Analyse drawing
                        </button>
                        <button type="button" @onclick="() => isUploading = !isUploading"
                                class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-3 py-2 hover:bg-accent-hover transition">
                            @(isUploading ? "Cancel" : "+ Upload new version")
                        </button>
                        <button type="button" disabled="@deleteBusy" @onclick="() => confirmingDelete = true"
                                class="rounded-lg border border-red-300 text-red-700 font-medium text-sm px-3 py-2 hover:bg-red-50 transition disabled:opacity-60">
                            Delete drawing
                        </button>
                    </div>
                }
            </header>

            @if (deleteError is not null)
            {
                <p class="mb-4 rounded-lg border border-red-200 bg-red-50 px-4 py-2.5 text-sm text-red-700">@deleteError</p>
            }

            <Modal IsOpen="confirmingDelete"
                   Title="Delete drawing?"
                   ConfirmLabel="@(deleteBusy ? "Deleting…" : "Delete drawing")"
                   OnCancel="() => confirmingDelete = false"
                   OnConfirm="DeleteDrawingAsync">
                <p class="text-sm text-content-muted">
                    This permanently deletes <strong>@drawing.DrawingCode · @drawing.Title</strong>,
                    including all @DrawingStore.RevisionsFor(drawing.DrawingId).Count revision(s) and their files.
                    This cannot be undone.
                </p>
            </Modal>

            @if (isUploading)
            {
                <div class="mb-6">
                    <DrawingRevisionUploadForm ProjectId="@ProjectId" DrawingId="@drawing.DrawingId"
                                               OnUploaded="() => isUploading = false" />
                </div>
            }

            <div class="grid gap-6 lg:grid-cols-5">
                <div class="lg:col-span-3">
                    @if (PreviewRevision is null)
                    {
                        <div class="rounded-xl border border-line bg-surface p-8 text-center text-sm text-content-subtle italic">
                            No file to preview yet.
                        </div>
                    }
                    else if (IsPreviewable(PreviewRevision))
                    {
                        <div class="rounded-xl border border-line bg-surface overflow-hidden">
                            <header class="px-4 py-2.5 border-b border-line bg-surface-raised flex items-center justify-between gap-3">
                                <span class="text-xs text-content-muted font-medium truncate">
                                    Showing Rev @PreviewRevision.RevisionLabel · @PreviewRevision.FileName
                                </span>
                                <a href="@FileUrl(PreviewRevision, inline: false)" target="_blank" rel="noopener"
                                   class="text-xs text-accent hover:underline underline-offset-2 shrink-0">Open / download</a>
                            </header>
                            <iframe src="@FileUrl(PreviewRevision, inline: true)"
                                    class="w-full h-[70vh] bg-white" title="Drawing preview"></iframe>
                        </div>
                    }
                    else
                    {
                        <div class="rounded-xl border border-line bg-surface p-8 text-center text-sm text-content-subtle">
                            This file type can't be previewed inline.
                            <a href="@FileUrl(PreviewRevision, inline: false)" target="_blank" rel="noopener"
                               class="text-accent hover:underline underline-offset-2">Download @PreviewRevision.FileName</a>.
                        </div>
                    }
                </div>
                <div class="lg:col-span-2">
                    <DrawingRevisionList Revisions="DrawingStore.RevisionsFor(drawing.DrawingId)"
                                         ProjectId="@ProjectId" DrawingId="@drawing.DrawingId" />
                </div>
            </div>
        }
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string DrawingId { get; set; } = "";

    private bool isLoaded;
    private bool isUploading;
    private bool confirmingDelete;
    private bool deleteBusy;
    private string? deleteError;
    private Drawing? drawing;

    private bool CanManage =>
        Auth.CurrentRoles.Any(role => role is Role.Admin or Role.ManagingDirector or Role.ProjectManager);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        DrawingStore.OnChange += HandleChange;
        Reload();
        isLoaded = true;
    }

    protected override void OnParametersSet() => Reload();

    // Read from the cached register rather than a blocking query. A synchronous
    // wait on an async HTTP call (the old DrawingStore.Find) deadlocks on WebAssembly.
    private void Reload() =>
        drawing = Siblings.FirstOrDefault(candidate => candidate.DrawingId == DrawingId);

    private IReadOnlyList<Drawing> Siblings => DrawingStore.DrawingsFor(ProjectId);

    private int CurrentIndex
    {
        get
        {
            var list = Siblings;
            for (var i = 0; i < list.Count; i++)
                if (list[i].DrawingId == DrawingId) return i;
            return -1;
        }
    }

    private Drawing? PreviousDrawing => CurrentIndex > 0 ? Siblings[CurrentIndex - 1] : null;

    private Drawing? NextDrawing =>
        CurrentIndex >= 0 && CurrentIndex < Siblings.Count - 1 ? Siblings[CurrentIndex + 1] : null;

    private (int index, int total)? Position =>
        CurrentIndex >= 0 ? (CurrentIndex + 1, Siblings.Count) : null;

    // The version to preview: the approved revision if there is one, otherwise the
    // most recently received revision that has a stored file.
    private DrawingRevision? PreviewRevision =>
        DrawingStore.RevisionsFor(DrawingId)
            .Where(revision => !string.IsNullOrEmpty(revision.BlobRef))
            .OrderByDescending(revision => revision.ApprovalStatus == DrawingApprovalStatus.Approved)
            .ThenByDescending(revision => revision.ReceivedAt)
            .FirstOrDefault();

    private static bool IsPreviewable(DrawingRevision revision)
    {
        var type = revision.ContentType ?? "";
        return type.Contains("pdf", StringComparison.OrdinalIgnoreCase)
            || type.StartsWith("image/", StringComparison.OrdinalIgnoreCase);
    }

    private string FileUrl(DrawingRevision revision, bool inline) =>
        $"/api/drawings/revisions/{revision.DrawingRevisionId}/file{(inline ? "?inline=1" : "")}";

    private string DrawingHref(Drawing target) => $"/projects/{ProjectId}/drawings/{target.DrawingId}";

    private async Task DeleteDrawingAsync()
    {
        if (drawing is null || deleteBusy) return;
        deleteBusy = true;
        deleteError = null;
        try
        {
            await DrawingStore.DeleteDrawingAsync(ProjectId, drawing.DrawingId, CancellationToken.None);
            confirmingDelete = false;
            Nav.NavigateTo($"/projects/{ProjectId}/drawings");
        }
        catch (Exception ex)
        {
            confirmingDelete = false;
            deleteError = $"Delete failed: {ex.Message}";
        }
        finally
        {
            deleteBusy = false;
        }
    }

    private void HandleChange() { Reload(); StateHasChanged(); }

    public void Dispose() => DrawingStore.OnChange -= HandleChange;
}
