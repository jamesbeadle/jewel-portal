@page "/cashflow/pm"
@inject AuthService Auth
@inject SessionService Session
@using Jewel.JPMS.Features.Projects
@inject ICommercialStore CommercialStore
@inject ProjectListReadModel Projects
@inject NavigationManager Nav

<PageTitle>Cashflow — PM · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/cashflow" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Cashflow</a>
            <span class="text-slate-400 mx-2">/</span>
            <span class="text-slate-700 font-medium">PM view</span>
        </nav>

        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900">Cashflow — your projects</h1>
            <p class="text-sm text-slate-600 mt-1">Scoped to projects where you are the assigned Project Manager.</p>
        </header>

        @if (MyProjects.Count == 0)
        {
            <p class="text-sm text-slate-500 italic">You're not assigned as PM on any active projects.</p>
        }
        else
        {
            <CashflowByProjectTable Projects="MyProjects" />
        }
    </section>
}

@code {
    private bool isLoaded;

    private IReadOnlyList<Project> MyProjects =>
        (Projects.Current ?? Array.Empty<Project>())
            .Where(project => string.Equals(project.ProjectManagerEmail, Auth.CurrentUser?.Email, StringComparison.OrdinalIgnoreCase))
            .ToList()
            .AsReadOnly();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
        isLoaded = true;
    }
}
