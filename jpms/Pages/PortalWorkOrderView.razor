@page "/portal/work-orders/{WorkOrderId}"
@using Jewel.JPMS.Contracts.Portal
@inject AuthService Auth
@inject SessionService Session
@inject IPortalStore PortalStore
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

@* The subcontractor's view of one issued work order: the printable purchase order plus the
   one-click electronic acceptance. Everything is scoped server-side to the signed-in company —
   this page can only ever show (and accept) the caller's own orders. *@

<PageTitle>@Title · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-4 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (!CanAccess || !HasLinkedRecord)
{
    <section class="px-4 md:px-8 py-12">
        <h1 class="text-2xl font-semibold text-content mb-2">Not available</h1>
        <p class="text-content-muted">
            This page shows a subcontractor one of their own work orders. Your login isn't linked
            to a subcontractor record.
        </p>
    </section>
}
else if (!PortalStore.IsLoaded)
{
    <section class="px-4 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (Order is null)
{
    <section class="px-4 md:px-8 py-12">
        <h1 class="text-2xl font-semibold text-content mb-2">Work order not found</h1>
        <p class="text-content-muted">
            This work order isn't one of yours, or hasn't been issued yet.
            <a class="underline underline-offset-4" href="/portal">Back to your record</a>
        </p>
    </section>
}
else
{
    <section class="px-4 md:px-8 py-6">
        <div class="po-toolbar max-w-[820px] mx-auto mb-5">
            <div class="flex items-center justify-between gap-3 flex-wrap">
                <a class="text-sm text-content-subtle hover:text-content underline underline-offset-4" href="/portal">← Your record</a>
                <div class="flex items-center gap-3">
                    @if (Order.Order.IsAccepted)
                    {
                        <span class="rounded-full border border-emerald-200 bg-emerald-50 text-emerald-800 px-2.5 py-0.5 text-xs font-medium">
                            Accepted @Order.Order.AcceptedAt!.Value.LocalDateTime.ToString("d MMM yyyy")
                        </span>
                    }
                    else if (CanAcceptThisOrder)
                    {
                        <button type="button" class="btn-primary text-sm" disabled="@acceptBusy" @onclick="AcceptAsync"
                                title="Accept this work order electronically — your name and today's date are recorded on the order">
                            @(acceptBusy ? "Accepting…" : "Accept work order")
                        </button>
                    }
                    <button type="button" class="btn-secondary text-sm" @onclick="PrintAsync"
                            title="Print the purchase order, or save it as a PDF from the print dialog">
                        Print / save PDF
                    </button>
                </div>
            </div>
            @if (!Order.Order.IsAccepted && CanAcceptThisOrder)
            {
                <p class="text-xs text-content-subtle mt-2 text-right">
                    Accepting records your electronic acceptance (@Auth.CurrentUser!.DisplayName) on the purchase order —
                    it then forms part of the contract per the terms below.
                </p>
            }
            @if (acceptError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mt-2">@acceptError</p>
            }
            @if (acceptNote is not null)
            {
                <p class="rounded-lg bg-emerald-50 border border-emerald-200 px-3 py-2 text-sm text-emerald-900 mt-2">@acceptNote</p>
            }
        </div>

        <PurchaseOrderSheet Order="Order.Order"
                            Lines="Order.Lines"
                            SupplierName="@(MyRecord?.Record.CompanyName ?? "")"
                            SupplierContactName="@(MyRecord?.Record.ContactName ?? "")"
                            SupplierAddress="@SupplierAddress"
                            ProjectName="@Order.ProjectName"
                            SiteAddress="@Order.SiteAddress"
                            ApprovedByName="@Order.ApprovedByName" />
    </section>
}

<style>
    @@media print {
        .po-toolbar { display: none; }
    }
</style>

@code {
    [Parameter] public string WorkOrderId { get; set; } = "";

    private bool isLoaded;
    private bool acceptBusy;
    private string? acceptError;
    private string? acceptNote;

    private bool CanAccess => Session.AvailableRoles.Contains(Role.Subcontractor);
    private bool HasLinkedRecord => !string.IsNullOrEmpty(Auth.CurrentSubcontractorId);

    private SubcontractorPortalRecord? MyRecord =>
        CanAccess && HasLinkedRecord ? PortalStore.MyRecord() : null;

    private PortalWorkOrder? Order =>
        ((CanAccess && HasLinkedRecord ? PortalStore.MyWorkOrders() : null) ?? Array.Empty<PortalWorkOrder>())
            .FirstOrDefault(workOrder =>
                string.Equals(workOrder.Order.WorkOrderId, WorkOrderId, StringComparison.OrdinalIgnoreCase));

    // Acceptance applies to live issued orders only — Complete/Cancelled are history.
    private bool CanAcceptThisOrder => Order?.Order.Status == WorkOrderStatus.Released;

    private string SupplierAddress =>
        MyRecord is null
            ? ""
            : string.Join(", ", new[] { MyRecord.Record.Town, MyRecord.Record.County }.Where(part => !string.IsNullOrWhiteSpace(part)));

    private string Title => Order is null ? "Work order" : $"WO-{Order.Order.Number:0000}";

    private async Task AcceptAsync()
    {
        if (acceptBusy) return;
        acceptError = null;
        acceptNote = null;
        try
        {
            acceptBusy = true;
            var accepted = await PortalStore.AcceptWorkOrderAsync(WorkOrderId);
            acceptNote = $"WO-{accepted.Number:0000} accepted — thank you. Your acceptance is recorded on the purchase order.";
        }
        catch (CommandFailedException ex) { acceptError = ex.Message; }
        catch { acceptError = "Couldn't record your acceptance. Please try again."; }
        finally { acceptBusy = false; }
    }

    private async Task PrintAsync() => await JS.InvokeVoidAsync("window.print");

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        PortalStore.OnChange += HandleChange;
        // Revalidate in the background on every visit (stale-while-revalidate, per CLAUDE.md).
        if (CanAccess && HasLinkedRecord) _ = PortalStore.Refresh();
        isLoaded = true;
    }

    private void HandleChange() => StateHasChanged();

    public void Dispose() => PortalStore.OnChange -= HandleChange;
}
