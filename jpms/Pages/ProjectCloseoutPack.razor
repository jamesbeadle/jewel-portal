@page "/projects/{ProjectId}/closeout/pack"
@inject AuthService Auth
@inject SessionService Session
@inject IDrawingStore DrawingStore
@inject ICloseoutStore CloseoutStore
@inject NavigationManager Nav

<PageTitle>Close-out pack · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="closeout">
        <nav class="mb-4 text-sm">
            <a href="@($"/projects/{ProjectId}/closeout")" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Close-out</a>
            <span class="text-slate-400 mx-2">/</span>
            <span class="text-slate-700 font-medium">Pack composer</span>
        </nav>

        <h2 class="text-lg font-semibold text-slate-900 mb-3">Close-out pack</h2>
        <p class="text-sm text-slate-600 mb-5">
            Compile warranties, O&M manuals and sign-offs into one bundle to issue to the architect and client.
        </p>

        <CloseoutPackChecklist
            DrawingCount="@DrawingCount"
            HasSettlement="@HasSettlement"
            HasVat="@HasVat"
            HasRetention="@HasRetention" />
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;
    private int DrawingCount => DrawingStore.DrawingsFor(ProjectId).Count;
    private bool HasSettlement => CloseoutStore.SettlementFor(ProjectId) is not null;
    private bool HasVat => CloseoutStore.VatFor(ProjectId) is not null;
    private bool HasRetention => CloseoutStore.RetentionFor(ProjectId) is not null;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        isLoaded = true;
    }
}
