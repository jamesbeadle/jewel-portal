@page "/projects/{ProjectId}/procurement"
@inject AuthService Auth
@inject SessionService Session
@inject IProcurementStore ProcurementStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Procurement · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="procurement">
        <div class="mb-5">
            <h2 class="text-lg font-semibold text-content">Bid packages</h2>
            <p class="text-sm text-content-muted">@Packages.Count packages on this project.</p>
        </div>

        @if (Packages.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">No bid packages yet.</p>
        }
        else
        {
            <BidPackageTable Packages="Packages" />
        }

        <div class="mt-8">
            <h2 class="text-lg font-semibold text-content mb-3">Work orders awarded</h2>
            @if (WorkOrders.Count == 0)
            {
                <p class="text-sm text-content-subtle italic">No work orders awarded yet.</p>
            }
            else
            {
                <WorkOrderTable WorkOrders="WorkOrders" ShowProject="false" />
            }
        </div>
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;
    private IReadOnlyList<BidPackage> Packages => ProcurementStore.PackagesFor(ProjectId);
    private IReadOnlyList<WorkOrder> WorkOrders => ProcurementStore.WorkOrdersFor(ProjectId);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        ProcurementStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => ProcurementStore.OnChange -= StateHasChanged;
}
