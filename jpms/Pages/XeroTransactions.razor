@page "/finance/xero"
@using Jewel.JPMS.Contracts.Xero
@inject AuthService Auth
@inject SessionService Session
@inject IXeroTransactionStore Xero
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Xero transactions · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="px-6 md:px-8 py-8 md:py-12">
        <header class="mb-6 md:mb-8 flex items-end justify-between gap-4">
            <div>
                <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · Finance</p>
                <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Xero transactions</h1>
                <p class="text-sm text-content-muted mt-2">
                    Purchase invoices read live from Xero since @FromDateText — with each line's site and cost code, ready for reconciliation.
                </p>
            </div>
            <button class="text-sm font-medium text-content-muted hover:text-content underline underline-offset-4 disabled:opacity-50"
                    disabled="@isRefreshing" @onclick="ForceRefreshAsync">
                @(isRefreshing ? "Refreshing…" : "Refresh from Xero")
            </button>
        </header>

        @if (Snapshot is null)
        {
            <p class="text-sm text-content-subtle py-8">Fetching transactions from Xero — a multi-year read can take a little while…</p>
        }
        else if (!Snapshot.IsConfigured)
        {
            <div class="rounded-xl border border-line bg-surface-raised px-5 py-4 text-sm text-content-muted">
                Xero isn't connected yet. Add the custom connection's credentials as the
                <span class="font-mono text-content">Xero__ClientId</span> and
                <span class="font-mono text-content">Xero__ClientSecret</span> app settings on the API, then reload.
            </div>
        }
        else if (Snapshot.Error is not null)
        {
            <div class="rounded-xl border border-line bg-surface-raised px-5 py-4 text-sm text-content-muted">
                <p class="text-content font-medium mb-1">Xero returned an error</p>
                <p>@Snapshot.Error</p>
            </div>
        }
        else if (Snapshot.Transactions.Count == 0)
        {
            <p class="text-sm text-content-subtle py-8">Xero returned no purchase invoices since @FromDateText.</p>
        }
        else
        {
            @if (Snapshot.Truncated)
            {
                <div class="rounded-xl border border-line bg-surface-raised px-5 py-4 text-sm text-content-muted mb-6">
                    <p class="text-content font-medium mb-1">Fetch cap reached — totals are incomplete</p>
                    <p>
                        Xero holds more records since @FromDateText than the API's page cap allows.
                        Raise the <span class="font-mono text-content">Xero__MaxPages</span> app setting and refresh.
                    </p>
                </div>
            }

            <div class="mb-6 flex items-center justify-between gap-4 flex-wrap">
                <div class="inline-flex rounded-lg border border-line overflow-hidden">
                    <button class="@TabClass(View.Transactions)" @onclick="() => activeView = View.Transactions">Transactions</button>
                    <button class="@TabClass(View.BySite)" @onclick="() => activeView = View.BySite">Site × cost code</button>
                </div>
                <p class="text-xs text-content-subtle">
                    @BillCount bills · @CreditNoteCount credit notes ·
                    fetched @FetchedText
                </p>
            </div>

            @if (activeView == View.Transactions)
            {
                <p class="text-sm text-content-muted mb-4">
                    @Filtered.Count shown · @Money(Filtered.Sum(t => Sign(t) * t.Total)) total (net of credit notes) ·
                    @Money(Filtered.Sum(t => Sign(t) * t.AmountDue)) outstanding.
                    <span class="text-content-subtle">Click a row for its lines.</span>
                </p>

                <div class="mb-4 flex flex-wrap items-center gap-2">
                    <input class="text-sm bg-surface border border-line rounded-lg px-3 py-1.5 text-content placeholder:text-content-subtle w-64"
                           placeholder="Search supplier, number, reference…"
                           value="@search" @oninput="e => search = e.Value?.ToString() ?? string.Empty" />
                    @foreach (var status in Statuses)
                    {
                        <button class="@ChipClassFor(status)" @onclick="() => ToggleStatus(status)">@status</button>
                    }
                </div>

                <div class="rounded-xl border border-line bg-surface overflow-hidden">
                    <table class="w-full text-sm">
                        <thead class="bg-surface-raised border-b border-line">
                            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                <th class="px-4 py-3">Date</th>
                                <th class="px-4 py-3">Supplier</th>
                                <th class="px-4 py-3 hidden md:table-cell">Number</th>
                                <th class="px-4 py-3">Site</th>
                                <th class="px-4 py-3 hidden lg:table-cell">Cost code</th>
                                <th class="px-4 py-3">Status</th>
                                <th class="px-4 py-3 text-right hidden md:table-cell">Net</th>
                                <th class="px-4 py-3 text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-line">
                            @foreach (var transaction in Filtered)
                            {
                                <tr class="cursor-pointer hover:bg-surface-raised" @onclick="() => ToggleExpanded(transaction.TransactionId)">
                                    <td class="px-4 py-3 text-content-muted whitespace-nowrap">@DateText(transaction.Date)</td>
                                    <td class="px-4 py-3 text-content font-medium">@(transaction.ContactName ?? "—")</td>
                                    <td class="px-4 py-3 text-content-muted hidden md:table-cell">
                                        @(transaction.Number ?? "—")
                                        @if (IsCreditNote(transaction))
                                        {
                                            <span class="ml-1.5 text-[10px] uppercase tracking-wider font-semibold border border-line rounded px-1 py-0.5">Credit note</span>
                                        }
                                    </td>
                                    <td class="px-4 py-3 text-content-muted">@DistinctText(transaction.Lines.Select(l => l.Site))</td>
                                    <td class="px-4 py-3 text-content-muted hidden lg:table-cell">@DistinctText(transaction.Lines.Select(l => l.CostCode))</td>
                                    <td class="px-4 py-3 text-content-subtle">@transaction.Status</td>
                                    <td class="px-4 py-3 text-right text-content-muted hidden md:table-cell">@Money(transaction.SubTotal)</td>
                                    <td class="px-4 py-3 text-right text-content font-medium">@Money(transaction.Total)</td>
                                </tr>
                                @if (expandedId == transaction.TransactionId)
                                {
                                    <tr>
                                        <td colspan="8" class="px-4 pb-4 pt-1 bg-surface-raised">
                                            @if (transaction.Reference is not null)
                                            {
                                                <p class="text-xs text-content-subtle mb-2">Reference: @transaction.Reference</p>
                                            }
                                            @if (transaction.Lines.Count == 0)
                                            {
                                                <p class="text-xs text-content-subtle">Xero returned no line detail for this invoice.</p>
                                            }
                                            else
                                            {
                                                <table class="w-full text-xs">
                                                    <thead>
                                                        <tr class="text-left text-[10px] uppercase tracking-wider text-content-subtle">
                                                            <th class="px-2 py-1.5">Description</th>
                                                            <th class="px-2 py-1.5">Account</th>
                                                            <th class="px-2 py-1.5">Site</th>
                                                            <th class="px-2 py-1.5">Cost code</th>
                                                            <th class="px-2 py-1.5 text-right">Net</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody class="divide-y divide-line">
                                                        @foreach (var line in transaction.Lines)
                                                        {
                                                            <tr>
                                                                <td class="px-2 py-1.5 text-content-muted">@(line.Description ?? "—")</td>
                                                                <td class="px-2 py-1.5 text-content-muted">@AccountText(line)</td>
                                                                <td class="px-2 py-1.5 text-content-muted">@(line.Site ?? "—")</td>
                                                                <td class="px-2 py-1.5 text-content-muted">@(line.CostCode ?? "—")</td>
                                                                <td class="px-2 py-1.5 text-right text-content">@Money(line.LineAmount)</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-sm text-content-muted mb-4">
                    Net (pre-VAT) spend by site and cost code, per calendar year — bills that are paid,
                    authorised or awaiting approval, minus credit notes (the same basis as the accountant's
                    payable invoice summary).
                    <span class="text-content-subtle">
                        @if (AwaitingApprovalNet != 0)
                        {
                            <text>Includes @Money(AwaitingApprovalNet) awaiting approval. </text>
                        }
                        @if (OtherExcludedNet != 0)
                        {
                            <text>Draft / voided: @Money(OtherExcludedNet) excluded.</text>
                        }
                    </span>
                </p>

                <div class="rounded-xl border border-line bg-surface overflow-hidden">
                    <table class="w-full text-sm">
                        <thead class="bg-surface-raised border-b border-line">
                            <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                                <th class="px-4 py-3">Site / cost code</th>
                                @foreach (var year in Years)
                                {
                                    <th class="px-4 py-3 text-right">@year</th>
                                }
                                <th class="px-4 py-3 text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-line">
                            @foreach (var site in Breakdown)
                            {
                                <tr class="bg-surface-raised/50">
                                    <td class="px-4 py-3 text-content font-semibold">@site.Name</td>
                                    @foreach (var year in Years)
                                    {
                                        <td class="px-4 py-3 text-right text-content font-semibold">@MoneyOrDash(site.ForYear(year))</td>
                                    }
                                    <td class="px-4 py-3 text-right text-content font-semibold">@Money(site.Total)</td>
                                </tr>
                                @foreach (var costCode in site.CostCodes)
                                {
                                    <tr>
                                        <td class="px-4 py-2.5 pl-8 text-content-muted">@costCode.Name</td>
                                        @foreach (var year in Years)
                                        {
                                            <td class="px-4 py-2.5 text-right text-content-muted">@MoneyOrDash(costCode.ForYear(year))</td>
                                        }
                                        <td class="px-4 py-2.5 text-right text-content-muted">@Money(costCode.Total)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot class="bg-surface-raised border-t border-line">
                            <tr>
                                <td class="px-4 py-3 text-content font-semibold">All sites</td>
                                @foreach (var year in Years)
                                {
                                    <td class="px-4 py-3 text-right text-content font-semibold">@MoneyOrDash(Breakdown.Sum(site => site.ForYear(year)))</td>
                                }
                                <td class="px-4 py-3 text-right text-content font-semibold">@Money(Breakdown.Sum(site => site.Total))</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        }
    </section>
}

@code {
    private enum View { Transactions, BySite }

    private bool isLoaded;
    private bool isRefreshing;
    private string? statusFilter;
    private string search = string.Empty;
    private string? expandedId;
    private View activeView = View.Transactions;

    private XeroTransactionsSnapshot? Snapshot => Xero.Snapshot();

    // Mirrors the accountant's payable invoice summary basis: paid, authorised and awaiting-approval
    // (SUBMITTED) records all count as committed cost. DRAFT and VOIDED never count.
    private static bool CountsInBreakdown(XeroTransaction transaction) =>
        transaction.Status is "AUTHORISED" or "PAID" or "SUBMITTED";

    private static bool IsCreditNote(XeroTransaction transaction) =>
        transaction.Type == "ACCPAYCREDIT";

    private static decimal Sign(XeroTransaction transaction) =>
        IsCreditNote(transaction) ? -1m : 1m;

    private int BillCount =>
        Snapshot?.Transactions.Count(transaction => !IsCreditNote(transaction)) ?? 0;

    private int CreditNoteCount =>
        Snapshot?.Transactions.Count(IsCreditNote) ?? 0;

    /// <summary>Net value of awaiting-approval records — the usual gap to the accountant's reports.</summary>
    private decimal AwaitingApprovalNet =>
        Snapshot?.Transactions
            .Where(transaction => transaction.Status == "SUBMITTED")
            .Sum(transaction => Sign(transaction) * transaction.SubTotal) ?? 0m;

    /// <summary>Net value of draft/voided records the breakdown never counts.</summary>
    private decimal OtherExcludedNet =>
        Snapshot?.Transactions
            .Where(transaction => transaction.Status is not ("AUTHORISED" or "PAID" or "SUBMITTED"))
            .Sum(transaction => Sign(transaction) * transaction.SubTotal) ?? 0m;

    private string FromDateText => (Snapshot?.FromDate)?.ToString("MMM yyyy") ?? "Jan 2023";

    private string FetchedText =>
        Snapshot?.FetchedAtUtc is { } fetched ? fetched.ToLocalTime().ToString("HH:mm") : "—";

    private IReadOnlyList<string> Statuses =>
        Snapshot?.Transactions.Select(transaction => transaction.Status).Distinct().OrderBy(status => status).ToList()
        ?? (IReadOnlyList<string>)Array.Empty<string>();

    private IReadOnlyList<XeroTransaction> Filtered =>
        Snapshot is null
            ? Array.Empty<XeroTransaction>()
            : Snapshot.Transactions
                .Where(transaction => statusFilter is null || transaction.Status == statusFilter)
                .Where(MatchesSearch)
                .OrderByDescending(transaction => transaction.Date ?? DateTime.MinValue)
                .ToList();

    private bool MatchesSearch(XeroTransaction transaction)
    {
        if (string.IsNullOrWhiteSpace(search)) return true;
        return Contains(transaction.ContactName) || Contains(transaction.Number) || Contains(transaction.Reference);

        bool Contains(string? value) =>
            value is not null && value.Contains(search.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private IReadOnlyList<int> Years
    {
        get
        {
            var fromYear = Snapshot?.FromDate?.Year ?? 2023;
            return Enumerable.Range(fromYear, DateTime.Today.Year - fromYear + 1).ToList();
        }
    }

    private sealed record CostCodeRow(string Name, IReadOnlyDictionary<int, decimal> ByYear)
    {
        public decimal ForYear(int year) => ByYear.TryGetValue(year, out var value) ? value : 0m;
        public decimal Total => ByYear.Values.Sum();
    }

    private sealed record SiteRow(string Name, IReadOnlyList<CostCodeRow> CostCodes)
    {
        public decimal ForYear(int year) => CostCodes.Sum(costCode => costCode.ForYear(year));
        public decimal Total => CostCodes.Sum(costCode => costCode.Total);
    }

    private IReadOnlyList<SiteRow> Breakdown
    {
        get
        {
            if (Snapshot is null) return Array.Empty<SiteRow>();

            // Approved records only — mirrors Xero's own reports, which exclude drafts and
            // records awaiting approval. Credit notes subtract.
            var cells = Snapshot.Transactions
                .Where(CountsInBreakdown)
                .SelectMany(transaction => transaction.Lines.Select(line => new
                {
                    Site = string.IsNullOrWhiteSpace(line.Site) ? "(no site)" : line.Site!,
                    CostCode = string.IsNullOrWhiteSpace(line.CostCode) ? "(no cost code)" : line.CostCode!,
                    Year = transaction.Date?.Year ?? 0,
                    Net = Sign(transaction) * line.LineAmount
                }))
                .Where(cell => cell.Year > 0);

            return cells
                .GroupBy(cell => cell.Site)
                .Select(siteGroup => new SiteRow(
                    siteGroup.Key,
                    siteGroup
                        .GroupBy(cell => cell.CostCode)
                        .Select(codeGroup => new CostCodeRow(
                            codeGroup.Key,
                            codeGroup.GroupBy(cell => cell.Year)
                                     .ToDictionary(yearGroup => yearGroup.Key, yearGroup => yearGroup.Sum(cell => cell.Net))))
                        .OrderByDescending(row => row.Total)
                        .ToList()))
                .OrderByDescending(row => row.Total)
                .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        Xero.OnChange += StateHasChanged;
        isLoaded = true;

        // Revalidate cached data in the background on tab entry (stale-while-revalidate) —
        // the store's fetch-once guard handles the very first load.
        _ = Xero.RefreshAsync();
    }

    private async Task ForceRefreshAsync()
    {
        isRefreshing = true;
        try { await Xero.RefreshAsync(force: true); }
        finally { isRefreshing = false; }
    }

    private void ToggleExpanded(string transactionId) =>
        expandedId = expandedId == transactionId ? null : transactionId;

    private void ToggleStatus(string status) =>
        statusFilter = statusFilter == status ? null : status;

    private string TabClass(View view) =>
        (activeView == view
            ? "bg-content text-surface"
            : "bg-surface text-content-muted hover:text-content")
        + " text-sm font-medium px-4 py-1.5 transition-colors";

    private string ChipClassFor(string status) =>
        (statusFilter == status
            ? "bg-content text-surface border-content"
            : "bg-surface text-content-muted border-line hover:text-content")
        + " text-xs font-medium border rounded-full px-3 py-1 transition-colors";

    private static string AccountText(XeroTransactionLine line) =>
        line.AccountCode is null
            ? "—"
            : line.AccountName is null ? line.AccountCode : $"{line.AccountCode} — {line.AccountName}";

    private static string DistinctText(IEnumerable<string?> values)
    {
        var distinct = values.Where(value => !string.IsNullOrWhiteSpace(value)).Distinct().ToList();
        return distinct.Count == 0 ? "—" : string.Join(", ", distinct);
    }

    private static string DateText(DateTime? date) =>
        date?.ToString("d MMM yyyy") ?? "—";

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string MoneyOrDash(decimal value) =>
        value == 0m ? "—" : Money(value);

    public void Dispose() => Xero.OnChange -= StateHasChanged;
}
