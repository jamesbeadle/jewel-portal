@page "/portal/client/project/{ProjectId}/variations"
@layout PortalLayout
@using Jewel.JPMS.Features.Projects
@inject ProjectListReadModel Projects
@inject IChangeRegister ChangeRegister
@implements IDisposable

<PageTitle>Variations · Client portal</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <nav class="mb-4 text-sm">
        <a href="/portal/client" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Client portal</a>
        <span class="text-slate-400 mx-2">/</span>
        <span class="text-slate-700 font-medium">Variations</span>
    </nav>

    <header class="mb-6">
        <h1 class="text-2xl md:text-3xl font-semibold text-slate-900">Variation approvals</h1>
        <p class="text-sm text-slate-600 mt-1">Cost-impacting changes that need your approval.</p>
    </header>

    @if (project is null)
    {
        <p class="text-sm text-slate-500 italic">Project not found.</p>
    }
    else if (Pending.Count == 0)
    {
        <p class="text-sm text-slate-500 italic">No variations pending your approval.</p>
    }
    else
    {
        <div class="rounded-xl border border-slate-200 bg-white divide-y divide-slate-200">
            @foreach (var variation in Pending)
            {
                <ArchitectApprovalCard Record="variation" ProjectName="@project.Name" />
            }
        </div>
    }
</section>

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private Project? project;
    private IReadOnlyList<ChangeRecord> Pending =>
        ChangeRegister.ForProject(ProjectId, ChangeKind.Variation)
                      .Where(record => record.Status is ChangeStatus.Open or ChangeStatus.AwaitingResponse)
                      .ToList()
                      .AsReadOnly();

    protected override async Task OnInitializedAsync()
    {
        ChangeRegister.OnChange += StateHasChanged;
        Projects.OnChanged += StateHasChanged;
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
    }

    protected override void OnParametersSet() => project = Projects.Find(ProjectId);

    public void Dispose()
    {
        ChangeRegister.OnChange -= StateHasChanged;
        Projects.OnChanged -= StateHasChanged;
    }
}
