@page "/projects/{ProjectId}/changes"
@page "/projects/{ProjectId}/changes/{Kind}"
@inject AuthService Auth
@inject SessionService Session
@inject IChangeRegister ChangeRegister
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Changes · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="changes">
        <h2 class="text-lg font-semibold text-slate-900 mb-3">Change register</h2>

        <div class="flex flex-wrap items-center gap-2 mb-5 text-sm">
            @foreach (var filter in Filters)
            {
                <a href="@HrefFor(filter.Slug)" class="@FilterClass(filter.Slug)">
                    @filter.Label
                </a>
            }
        </div>

        @if (FilteredRecords.Count == 0)
        {
            <p class="text-sm text-slate-500 italic">No changes recorded.</p>
        }
        else
        {
            <ChangeRecordTable Records="FilteredRecords" />
        }
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string? Kind { get; set; }

    private bool isLoaded;

    private record Filter(string Slug, string Label, ChangeKind? Kind);

    private static readonly Filter[] Filters =
    {
        new("all",        "All",          null),
        new("rfis",       "RFIs",         ChangeKind.Rfi),
        new("submittals", "Submittals",   ChangeKind.Submittal),
        new("variations", "Variations",   ChangeKind.Variation),
        new("delays",     "Delays",       ChangeKind.NoticeOfDelay)
    };

    private string ActiveSlug => string.IsNullOrWhiteSpace(Kind) ? "all" : Kind.ToLowerInvariant();

    private IReadOnlyList<ChangeRecord> FilteredRecords
    {
        get
        {
            var filter = Filters.FirstOrDefault(f => f.Slug == ActiveSlug);
            if (filter?.Kind is null) return ChangeRegister.ForProject(ProjectId);
            return ChangeRegister.ForProject(ProjectId, filter.Kind.Value);
        }
    }

    private string HrefFor(string slug) =>
        slug == "all" ? $"/projects/{ProjectId}/changes" : $"/projects/{ProjectId}/changes/{slug}";

    private string FilterClass(string slug)
    {
        if (slug == ActiveSlug) return "px-3 py-1.5 rounded-md bg-slate-900 text-white font-medium";
        return "px-3 py-1.5 rounded-md text-slate-600 hover:text-slate-900 hover:bg-slate-100";
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        ChangeRegister.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => ChangeRegister.OnChange -= StateHasChanged;
}
