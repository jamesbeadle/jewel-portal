@page "/sales-analytics"
@inject AuthService Auth
@inject SessionService Session
@inject ILeadStore LeadStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Sales analytics · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <header class="mb-6 md:mb-8">
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · CRM</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Sales analytics</h1>
            <p class="text-sm text-content-muted mt-2">Source attribution and win rate by channel.</p>
        </header>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-6">
            <Stat Label="Total leads" Value="@TotalLeads.ToString()" />
            <Stat Label="Won"         Value="@WonCount.ToString()" />
            <Stat Label="Win rate"    Value="@WinRate" />
        </div>

        <LeadsBySourceTable Leads="LeadStore.All()" />
    </section>
}

@code {
    private bool isLoaded;

    private int TotalLeads => LeadStore.All().Count;
    private int WonCount => LeadStore.All().Count(lead => lead.Stage == LeadStage.Won);
    private string WinRate => TotalLeads == 0 ? "—" : $"{100.0 * WonCount / TotalLeads:0}%";

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        LeadStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => LeadStore.OnChange -= StateHasChanged;
}
