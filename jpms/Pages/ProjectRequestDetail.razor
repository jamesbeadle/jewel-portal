@page "/projects/{ProjectId}/requests/view/{RequestId}"
@using Jewel.JPMS.Contracts.Requests
@inject AuthService Auth
@inject SessionService Session
@inject IRequestRegister RequestRegister
@inject IClientStore ClientStore
@inject IArchitectStore ArchitectStore
@inject ICorrespondenceStore Correspondence
@inject IVariationStore Variations
@inject IAgentDesk Agents
@inject NavigationManager Nav

<PageTitle>Request · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (record is null)
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="requests">
        <p class="text-sm text-content-subtle italic">That request could not be found.</p>
        <a href="@RegisterHref" class="btn-secondary mt-4">Back to register</a>
    </ProjectPageShell>
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="requests">
        <a href="@RegisterHref" class="text-sm text-content-muted hover:text-content inline-flex items-center gap-1 mb-4">
            &larr; Request register
        </a>

        <div class="flex flex-wrap items-start justify-between gap-3 mb-1">
            <div class="flex items-center gap-3">
                @if (!string.IsNullOrEmpty(record.DisplayNumber))
                {
                    <span class="font-mono text-sm font-semibold text-content" title="Mailbox folder name">@record.DisplayNumber</span>
                }
                <span class="font-mono text-sm text-content-muted">@record.Reference</span>
                <span class="text-content-subtle text-xs uppercase tracking-wide" title="@record.Kind.LongName()">@record.Kind.DisplayName()</span>
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium @StatusClass(record.Status)">@StatusLabel(record.Status)</span>
                @if (record.ImpliesVariation)
                {
                    <span class="inline-flex items-center rounded bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-600">Variation</span>
                }
            </div>
        </div>
        <h2 class="text-xl font-semibold text-content mb-5">@record.Title</h2>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
            <div class="lg:col-span-2 space-y-5">
                <div class="panel p-5">
                    <div class="flex items-start justify-between gap-3 mb-2">
                        <h3 class="eyebrow">Detail</h3>
                        @if (CanEditDetails)
                        {
                            <button type="button" class="text-xs font-medium text-content-muted hover:text-content underline underline-offset-2" @onclick="OpenEdit">Edit</button>
                        }
                    </div>
                    <p class="text-sm text-content whitespace-pre-wrap">@(string.IsNullOrWhiteSpace(record.Description) ? "—" : record.Description)</p>
                </div>

                <div class="panel p-5">
                    <div class="flex items-start justify-between gap-3 mb-3">
                        <div>
                            <h3 class="eyebrow">Official @record.Kind.DisplayName() form</h3>
                            <p class="text-xs text-content-subtle mt-0.5">The itemised queries and sections rendered on the issued document.</p>
                        </div>
                        @if (CanEditDetails && !editingForm)
                        {
                            <button type="button" class="text-xs font-medium text-content-muted hover:text-content underline underline-offset-2" @onclick="OpenFormEditor">Edit form</button>
                        }
                    </div>

                    @if (formError is not null)
                    {
                        <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@formError</p>
                    }

                    @if (!editingForm)
                    {
                        @if (record.ItemList.Count == 0
                            && string.IsNullOrWhiteSpace(record.BasisOfQueries)
                            && string.IsNullOrWhiteSpace(record.ResponseActionRequired)
                            && string.IsNullOrWhiteSpace(record.ImpactIfLate))
                        {
                            <p class="text-sm text-content-subtle italic">No itemised queries yet. The issued document carries the detail above only.</p>
                        }
                        else
                        {
                            @if (record.ItemList.Count > 0)
                            {
                                <div class="overflow-x-auto -mx-1 px-1">
                                    <table class="w-full text-sm">
                                        <thead>
                                            <tr class="text-left text-content-subtle border-b border-line">
                                                <th class="py-2 pr-3 font-medium w-10">Item</th>
                                                <th class="py-2 pr-3 font-medium">Drawing ref</th>
                                                <th class="py-2 pr-3 font-medium">Member / area</th>
                                                <th class="py-2 pr-3 font-medium">Query</th>
                                                <th class="py-2 font-medium">Response</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in record.ItemList)
                                            {
                                                <tr class="border-b border-line last:border-0 align-top">
                                                    <td class="py-2 pr-3 font-mono text-content-muted">@item.Position</td>
                                                    <td class="py-2 pr-3 text-content-muted whitespace-pre-wrap">@Dash(item.DrawingRef)</td>
                                                    <td class="py-2 pr-3 text-content whitespace-pre-wrap">@Dash(item.MemberArea)</td>
                                                    <td class="py-2 pr-3 text-content whitespace-pre-wrap">@Dash(item.Query)</td>
                                                    <td class="py-2 text-content-muted whitespace-pre-wrap">@Dash(item.Response)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(record.BasisOfQueries))
                            {
                                <div class="mt-3">
                                    <h4 class="eyebrow mb-1">Basis of queries</h4>
                                    <p class="text-sm text-content-muted whitespace-pre-wrap">@record.BasisOfQueries</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(record.ResponseActionRequired))
                            {
                                <div class="mt-3">
                                    <h4 class="eyebrow mb-1">Response / action required</h4>
                                    <p class="text-sm text-content whitespace-pre-wrap">@record.ResponseActionRequired</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(record.ImpactIfLate))
                            {
                                <div class="mt-3">
                                    <h4 class="eyebrow mb-1">Impact if not received by the required date</h4>
                                    <p class="text-sm text-content-muted whitespace-pre-wrap">@record.ImpactIfLate</p>
                                </div>
                            }
                        }
                    }
                    else
                    {
                        <div class="space-y-4">
                            <div>
                                <label class="eyebrow block mb-2">Itemised queries</label>
                                @if (formItems.Count == 0)
                                {
                                    <p class="text-sm text-content-subtle italic mb-2">No items — add the first numbered query below.</p>
                                }
                                <div class="space-y-3">
                                    @{ var itemNumber = 0; }
                                    @foreach (var row in formItems)
                                    {
                                        itemNumber++;
                                        <div class="rounded-lg border border-line p-3 space-y-2">
                                            <div class="flex items-center justify-between">
                                                <span class="font-mono text-xs font-semibold text-content-muted">Item @itemNumber</span>
                                                <button type="button" class="text-xs text-negative hover:underline underline-offset-2" @onclick="() => RemoveFormItem(row)">Remove</button>
                                            </div>
                                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                                <div>
                                                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Drawing ref</label>
                                                    <textarea class="field" rows="2" value="@row.DrawingRef" @oninput="e => row.DrawingRef = e.Value?.ToString() ?? string.Empty"
                                                              placeholder="Dwg 1986_111 Rev D&#10;SD8, SD3"></textarea>
                                                </div>
                                                <div>
                                                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Member / area</label>
                                                    <textarea class="field" rows="2" value="@row.MemberArea" @oninput="e => row.MemberArea = e.Value?.ToString() ?? string.Empty"
                                                              placeholder="West Elevation — lead valley gutter"></textarea>
                                                </div>
                                            </div>
                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Query</label>
                                                <textarea class="field" rows="3" value="@row.Query" @oninput="e => row.Query = e.Value?.ToString() ?? string.Empty"
                                                          placeholder="Please confirm…"></textarea>
                                            </div>
                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Response (when received)</label>
                                                <textarea class="field" rows="2" value="@row.Response" @oninput="e => row.Response = e.Value?.ToString() ?? string.Empty"></textarea>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <button type="button" class="btn-secondary mt-2" @onclick="AddFormItem">Add item</button>
                            </div>

                            <div>
                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Basis of queries</label>
                                <textarea class="field" rows="2" value="@formBasis" @oninput="e => formBasis = e.Value?.ToString() ?? string.Empty"
                                          placeholder="Architect's email ref…, site inspection observations, drawings…"></textarea>
                            </div>
                            <div>
                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Response / action required</label>
                                <textarea class="field" rows="3" value="@formResponseAction" @oninput="e => formResponseAction = e.Value?.ToString() ?? string.Empty"
                                          placeholder="Please provide written confirmation / instruction on the items above…"></textarea>
                            </div>
                            <div>
                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Impact if not received by the required date</label>
                                <textarea class="field" rows="2" value="@formImpact" @oninput="e => formImpact = e.Value?.ToString() ?? string.Empty"
                                          placeholder="Works cannot proceed, risking programme delay while scaffold remains in place…"></textarea>
                            </div>

                            <div class="flex flex-wrap gap-2">
                                <button type="button" class="btn-primary" disabled="@busy" @onclick="SaveForm">@(busy ? "Saving…" : "Save form")</button>
                                <button type="button" class="btn-secondary" disabled="@busy" @onclick="CancelFormEdit">Cancel</button>
                            </div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(record.ResponseText))
                {
                    <div class="panel p-5">
                        <h3 class="eyebrow mb-2">Response</h3>
                        <p class="text-sm text-content whitespace-pre-wrap">@record.ResponseText</p>
                        @if (!string.IsNullOrWhiteSpace(record.RespondedByEmail))
                        {
                            <p class="text-xs text-content-subtle mt-2">@record.RespondedByEmail · @Date(record.RespondedAt)</p>
                        }
                    </div>
                }

                <RequestConversation RequestId="@RequestId" />

                @* Agents are parked for now — the workspace is hidden until we settle on whether
                   attaching agents to requests is the right model. Re-add <AgentWorkspace> here. *@
            </div>

            <div class="space-y-5">
                <div class="panel p-5 space-y-3 text-sm">
                    <MetaRow Label="Raised by" Value="@record.RaisedByEmail" />
                    <MetaRow Label="Date issued" Value="@Date(record.RaisedAt)" />
                    <MetaRow Label="Raised to" Value="@Dash(record.RaisedTo)" />
                    <MetaRow Label="Drawing / detail" Value="@Dash(record.DrawingRef)" />
                    <MetaRow Label="Response due" Value="@Date(record.ResponseDue)" />
                    <MetaRow Label="Days outstanding" Value="@(record.DaysOutstanding is int d ? d.ToString() : "—")" />
                    @if (record.Kind is not RequestType.Rfi)
                    {
                        <MetaRow Label="Value" Value="@(record.Value is null ? "—" : Money(record.Value.Value))" />
                    }
                    <MetaRow Label="Related drawing / spec" Value="@Dash(record.RelatedDrawingSpec)" />
                </div>

                <div class="panel p-5 space-y-3">
                    <h3 class="eyebrow">Official document</h3>
                    <a href="@DocumentHref" target="_blank" rel="noopener"
                       class="btn-secondary w-full inline-flex justify-center">Download @record.Kind.DisplayName() PDF</a>
                    <p class="text-xs text-content-subtle">Regenerated from the register on every download, so it always reflects the request as it stands.</p>

                    @if (CanDraftEmail)
                    {
                        <div class="pt-3 border-t border-line">
                            <button type="button" class="btn-primary w-full" disabled="@(busy || preparingDraft)" @onclick="PrepareEmailDraft">
                                @(preparingDraft ? "Preparing draft…" : "Prepare email draft")
                            </button>
                            <p class="text-xs text-content-subtle mt-1">Creates a draft in the projects mailbox — PDF attached, To/CC/BCC pre-filled from the correspondence profile. Review and send from Outlook; nothing is sent from here.</p>
                        </div>

                        @if (draftError is not null)
                        {
                            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@draftError</p>
                        }
                        @if (draftResult is not null)
                        {
                            <div class="rounded-lg bg-emerald-500/10 border border-emerald-500/30 px-3 py-2">
                                <p class="text-sm font-medium text-emerald-600">Draft created in the projects mailbox.</p>
                                <p class="text-xs text-content-subtle mt-1">To: @string.Join(", ", draftResult.Recipients)</p>
                                @if (draftResult.Cc is { Count: > 0 } draftCc)
                                {
                                    <p class="text-xs text-content-subtle">CC: @string.Join(", ", draftCc)</p>
                                }
                                @if (draftResult.Bcc is { Count: > 0 } draftBcc)
                                {
                                    <p class="text-xs text-content-subtle">BCC: @string.Join(", ", draftBcc)</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(draftResult.WebLink))
                                {
                                    <a href="@draftResult.WebLink" target="_blank" rel="noopener"
                                       class="text-xs text-accent hover:underline underline-offset-2">Open the draft in Outlook</a>
                                }
                            </div>
                        }
                    }
                </div>

                @if (CanEditDetails)
                {
                    <div class="panel p-5 space-y-4">
                        <h3 class="eyebrow">Request type</h3>
                        <p class="text-sm text-content">
                            Current: <span class="font-medium">@record.Kind.DisplayName()</span>
                            @if (record.HasRfq)
                            {
                                <span class="ml-2 inline-flex items-center rounded bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-600">RFQ enabled</span>
                            }
                        </p>

                        @if (ladderError is not null)
                        {
                            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@ladderError</p>
                        }

                        @if (record.Kind is not RequestType.Rfi)
                        {
                            <div>
                                <button type="button" class="btn-primary w-full" disabled="@busy" @onclick="PromoteToRfi">Promote to RFI</button>
                                <p class="text-xs text-content-subtle mt-1">Issues the official RFI to the resolved recipients below — the linked party's primary contact, with the project's CC/BCC recipients copied.</p>
                            </div>
                        }
                        else if (!record.HasRfq)
                        {
                            <div>
                                <button type="button" class="btn-secondary w-full" disabled="@busy" @onclick="EnableRfq">Enable RFQ</button>
                                <p class="text-xs text-content-subtle mt-1">Marks this RFI as carrying an RFQ, unlocking a Variation Order Quote.</p>
                            </div>
                        }

                        <div>
                            <label class="eyebrow block mb-1">Issued to</label>
                            <select class="field" value="@PartySelectionValue" @onchange="OnPartyChanged" disabled="@busy">
                                <option value="">— None —</option>
                                @if (clients.Count > 0)
                                {
                                    <optgroup label="Clients">
                                        @foreach (var client in clients)
                                        {
                                            <option value="@($"{ClientPrefix}{client.ClientId}")">@client.Name</option>
                                        }
                                    </optgroup>
                                }
                                @if (architects.Count > 0)
                                {
                                    <optgroup label="Architects">
                                        @foreach (var architect in architects)
                                        {
                                            <option value="@($"{ArchitectPrefix}{architect.ArchitectId}")">@architect.Name</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <p class="text-xs text-content-subtle mt-1">The email an RFI is issued to comes from this party — a client directly, or an architect acting on the client's behalf.</p>
                        </div>

                        @if (record.PartyKind == PartyKind.Architect && !string.IsNullOrEmpty(record.PartyId))
                        {
                            <div>
                                <label class="eyebrow block mb-1">On behalf of client</label>
                                <select class="field" value="@(record.OnBehalfOfClientId ?? "")" @onchange="OnOnBehalfOfClientChanged" disabled="@busy">
                                    <option value="">— Not recorded —</option>
                                    @foreach (var client in clients)
                                    {
                                        <option value="@client.ClientId">@client.Name</option>
                                    }
                                </select>
                                <p class="text-xs text-content-subtle mt-1">Optional: the client this architect is acting for.</p>
                            </div>
                        }

                        @if (recipientPreview is not null)
                        {
                            <div class="rounded-lg bg-surface-raised border border-line px-3 py-2 space-y-1">
                                <p class="text-[10px] uppercase tracking-wide font-semibold text-content-subtle">Will be sent</p>
                                @if (recipientPreview.To.Count == 0)
                                {
                                    <p class="text-xs text-negative">No correspondent resolves — link a party or set a project contact's routing to To.</p>
                                }
                                else
                                {
                                    <p class="text-xs text-content"><span class="font-medium">To:</span> @RecipientLine(recipientPreview.To)</p>
                                }
                                @if (recipientPreview.Cc.Count > 0)
                                {
                                    <p class="text-xs text-content"><span class="font-medium">CC:</span> @RecipientLine(recipientPreview.Cc)</p>
                                }
                                @if (recipientPreview.Bcc.Count > 0)
                                {
                                    <p class="text-xs text-content"><span class="font-medium">BCC:</span> @RecipientLine(recipientPreview.Bcc)</p>
                                }
                                <p class="text-[10px] text-content-subtle">From the project's correspondence profile (Setup tab). BCC never appears on the document or the shared trail.</p>
                            </div>
                        }
                    </div>
                }

                @if (record.HasRfq)
                {
                    <div class="panel p-5 space-y-3">
                        <h3 class="eyebrow">Variation Order Quote</h3>
                        @if (voq is not null)
                        {
                            <p class="text-sm text-content">
                                <span class="font-mono font-semibold">@voq.DisplayNumber</span>
                                <span class="text-content-subtle ml-2">@voq.Status</span>
                            </p>
                            <a href="@VoqHref" class="btn-secondary w-full inline-flex justify-center">Open VOQ</a>
                        }
                        else
                        {
                            @if (voqError is not null)
                            {
                                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@voqError</p>
                            }
                            <p class="text-xs text-content-subtle">This RFI carries an RFQ. Create a Variation Order Quote to send bid packages to subcontractors.</p>
                            @if (CanEditDetails)
                            {
                                <button type="button" class="btn-primary w-full" disabled="@busy" @onclick="CreateVoq">Create VOQ</button>
                            }
                        }
                    </div>
                }

                <div class="panel p-5">
                    <h3 class="eyebrow mb-3">Manage</h3>
                    @if (actionError is not null)
                    {
                        <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@actionError</p>
                    }

                    @if (CanEditDetails)
                    {
                        <div class="mb-4 pb-4 border-b border-line">
                            <button type="button" class="btn-secondary w-full" disabled="@busy" @onclick="OpenEdit">Edit details</button>
                        </div>
                    }

                    @if (blockingAgents.Count > 0)
                    {
                        <div class="rounded-lg bg-amber-500/10 border border-amber-500/30 px-3 py-2 mb-3">
                            <p class="text-sm font-medium text-amber-700 mb-1">This request can't be closed yet.</p>
                            <p class="text-xs text-content-subtle mb-2">The following agents have outstanding work:</p>
                            <ul class="space-y-1">
                                @foreach (var blocker in blockingAgents)
                                {
                                    <li class="text-xs text-content"><span class="font-medium">@blocker.DisplayName</span> — @blocker.Message</li>
                                }
                            </ul>
                        </div>
                    }

                    @if (record.Status is not RequestStatus.Closed)
                    {
                        <label class="eyebrow block mb-1">Record a response</label>
                        <textarea class="field mb-2" rows="3" value="@responseDraft" @oninput="OnResponseDraftInput"
                                  placeholder="The answer or decision…"></textarea>
                        <div class="flex flex-wrap gap-2">
                            <button type="button" class="btn-secondary" disabled="@busy" @onclick="SaveResponse">Save response</button>
                            <button type="button" class="btn-primary" disabled="@busy" @onclick="CloseRequest">Close request</button>
                        </div>
                    }
                    else
                    {
                        <p class="text-sm text-content-subtle mb-3">This request is closed.</p>
                        <button type="button" class="btn-secondary" disabled="@busy" @onclick="ReopenRequest">Reopen</button>
                    }

                    @if (CanTriage)
                    {
                        <div class="mt-4 pt-4 border-t border-line">
                            <h4 class="eyebrow mb-1">Return to triage</h4>
                            <p class="text-xs text-content-subtle mb-2">Sends every email linked to this request back to the triage queue so the whole thread can be processed again. If that empties the request, it is removed.</p>
                            <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => confirmingReturn = true">
                                Return to triage
                            </button>
                        </div>
                    }

                    @if (IsAdmin)
                    {
                        <div class="mt-4 pt-4 border-t border-line">
                            <h4 class="eyebrow mb-1 text-negative">Danger zone</h4>
                            <p class="text-xs text-content-subtle mb-2">Permanently deletes this request and its conversation. Administrators only.</p>
                            <button type="button" class="btn-secondary border-negative/40 text-negative hover:border-negative" disabled="@busy" @onclick="() => confirmingDelete = true">
                                Delete request
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </ProjectPageShell>

    <Modal IsOpen="confirmingDelete"
           Title="Delete this request?"
           ConfirmLabel="@(busy ? "Deleting…" : "Delete request")"
           OnCancel="CancelDelete"
           OnConfirm="PerformDelete">
        <p class="text-sm text-content">
            This will permanently remove <span class="font-mono">@record?.Reference</span> — “@record?.Title” — and its entire conversation. This cannot be undone.
        </p>
    </Modal>

    <Modal IsOpen="confirmingReturn"
           Title="Return this request to triage?"
           ConfirmLabel="@(busy ? "Returning…" : "Return to triage")"
           OnCancel="CancelReturn"
           OnConfirm="PerformReturn">
        <p class="text-sm text-content">
            Every email linked to <span class="font-mono">@record?.Reference</span> — “@record?.Title” — will go back to the triage queue so the thread can be triaged again from scratch. As this empties the request, it will be removed from the register.
        </p>
    </Modal>

    <Modal IsOpen="editing"
           Title="Edit request details"
           ConfirmLabel="@(busy ? "Saving…" : "Save changes")"
           OnCancel="CancelEdit"
           OnConfirm="SaveEdit"
           Class="max-w-2xl">
        <div class="space-y-4">
            @if (editError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@editError</p>
            }

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <FormField Label="Reference" Value="@editReference" OnChange="v => editReference = v" Required="true" />
                <div>
                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Status</label>
                    <select class="field" value="@((int)editStatus)" @onchange="OnEditStatusChanged">
                        @foreach (var option in StatusOptions)
                        {
                            <option value="@((int)option)">@StatusLabel(option)</option>
                        }
                    </select>
                </div>
            </div>

            <FormField Label="Subject" Value="@editTitle" OnChange="v => editTitle = v" Required="true" />

            <div>
                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Detail</label>
                <textarea class="field" rows="4" value="@editDescription" @oninput="OnEditDescriptionInput"></textarea>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <FormField Label="Date issued" Value="@editRaisedAt" OnChange="v => editRaisedAt = v" InputType="date" />
                <FormField Label="Response due" Value="@editResponseDue" OnChange="v => editResponseDue = v" InputType="date" />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <FormField Label="Raised to" Value="@editRaisedTo" OnChange="v => editRaisedTo = v" />
                <FormField Label="Drawing / detail ref" Value="@editDrawingRef" OnChange="v => editDrawingRef = v" />
            </div>

            <FormField Label="Related drawing / spec" Value="@editRelatedSpec" OnChange="v => editRelatedSpec = v" />
        </div>
    </Modal>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string RequestId { get; set; } = "";

    private bool isLoaded;
    private Request? record;
    private string responseDraft = "";
    private bool busy;
    private string? actionError;
    private bool confirmingDelete;
    private bool confirmingReturn;
    private IReadOnlyList<AgentCompletionState> blockingAgents = Array.Empty<AgentCompletionState>();
    private IReadOnlyList<Client> clients = Array.Empty<Client>();
    private IReadOnlyList<Architect> architects = Array.Empty<Architect>();

    private const string ClientPrefix = "client:";
    private const string ArchitectPrefix = "architect:";

    // The composite value driving the party select: "client:{id}" / "architect:{id}" / "".
    private string PartySelectionValue =>
        record is null || string.IsNullOrEmpty(record.PartyId)
            ? ""
            : (record.PartyKind == PartyKind.Architect ? ArchitectPrefix : ClientPrefix) + record.PartyId;
    private string? ladderError;
    private VariationOrderQuote? voq;
    private string? voqError;

    // Official document form editor (the itemised queries + narrative sections).
    private bool editingForm;
    private string? formError;
    private List<FormItemRow> formItems = new();
    private string formBasis = "";
    private string formResponseAction = "";
    private string formImpact = "";

    // Email draft staging (Outlook draft in the projects mailbox).
    private bool preparingDraft;
    private string? draftError;
    private RequestEmailDraft? draftResult;
    private RequestRecipientSet? recipientPreview;

    private string VoqHref => voq is null ? "" : $"/projects/{ProjectId}/voq/{voq.VariationOrderQuoteId}";

    private string RegisterHref => $"/projects/{ProjectId}/requests";

    // Streams the official PDF from the api, regenerated from SQL on every download.
    private string DocumentHref => $"/api/requests/{RequestId}/document";

    // Mirrors PrepareRequestEmailDraftAuthorisation server-side (directors, project managers, site
    // managers and architects; admins carry every role server-side).
    private bool CanDraftEmail => Session.AvailableRoles.Any(role =>
        role is Role.Admin or Role.ManagingDirector or Role.ProjectManager or Role.SiteManager or Role.Architect);

    private bool IsAdmin => Auth.CurrentUser is not null && JpmsAdministrators.Contains(Auth.CurrentUser.Email);

    // Returning to triage is a triage action, open to administrators and project managers (admins
    // carry every role server-side, so they always satisfy this too).
    private bool CanTriage => Session.AvailableRoles.Any(role => role is Role.Admin or Role.ProjectManager);

    // Editing request field values (date issued, references, status, etc.) is open to project
    // managers and administrators. Admins carry every role server-side, so they always qualify.
    private bool CanEditDetails => Session.AvailableRoles.Any(role => role is Role.Admin or Role.ProjectManager);

    private static readonly RequestStatus[] StatusOptions =
    {
        RequestStatus.Open, RequestStatus.AwaitingResponse, RequestStatus.Responded,
        RequestStatus.Approved, RequestStatus.Rejected, RequestStatus.Closed
    };

    private bool editing;
    private string editReference = "";
    private string editTitle = "";
    private string editDescription = "";
    private string editRaisedAt = "";
    private string editResponseDue = "";
    private string editRaisedTo = "";
    private string editDrawingRef = "";
    private string editRelatedSpec = "";
    private RequestStatus editStatus = RequestStatus.Open;
    private string? editError;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        await LoadAsync();
        if (CanEditDetails)
        {
            try { clients = await ClientStore.ListAsync(); } catch { clients = Array.Empty<Client>(); }
            try { architects = await ArchitectStore.ListAsync(); } catch { architects = Array.Empty<Architect>(); }
        }
        await LoadVoqAsync();
        await LoadRecipientPreviewAsync();
        isLoaded = true;
    }

    // The resolved To/CC/BCC an issue or draft would use right now — same resolver as the send
    // paths, refreshed whenever the linked party changes. Best-effort: the panel just hides on error.
    private async Task LoadRecipientPreviewAsync()
    {
        try { recipientPreview = record is null ? null : await Correspondence.ResolveRequestRecipientsAsync(record.RequestId); }
        catch { recipientPreview = null; }
    }

    private static string RecipientLine(IReadOnlyList<CorrespondenceRecipient> recipients) =>
        string.Join(", ", recipients.Select(r => string.IsNullOrWhiteSpace(r.Name) ? r.Email : $"{r.Name} <{r.Email}>"));

    private async Task LoadVoqAsync()
    {
        if (record?.HasRfq == true)
        {
            try { voq = await Variations.GetByRequestAsync(RequestId); }
            catch { voq = null; }
        }
        else
        {
            voq = null;
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (isLoaded) await LoadAsync();
    }

    private async Task LoadAsync()
    {
        record = await RequestRegister.GetAsync(RequestId);
        responseDraft = record?.ResponseText ?? "";
    }

    private void OnResponseDraftInput(ChangeEventArgs e) => responseDraft = e.Value?.ToString() ?? "";

    private async Task SaveResponse() => await Apply(RequestStatus.Responded, responseDraft);

    // Closing goes through the agent gate: the request only closes if every applied agent agrees
    // its work is complete. Any drafted response is persisted first so it isn't lost. The stub
    // agents always report incomplete, so a request with an applied agent stays open by design.
    private async Task CloseRequest()
    {
        if (record is null || busy) return;
        actionError = null;
        blockingAgents = Array.Empty<AgentCompletionState>();

        if (!string.IsNullOrWhiteSpace(responseDraft) && responseDraft.Trim() != (record.ResponseText ?? "").Trim())
            await Apply(RequestStatus.Responded, responseDraft);
        if (record is null) return;

        try
        {
            busy = true;
            var outcome = await Agents.AttemptCloseAsync(record.RequestId);
            if (outcome.Closed)
            {
                record = await RequestRegister.GetAsync(RequestId);
                responseDraft = record?.ResponseText ?? "";
            }
            else
            {
                blockingAgents = outcome.BlockingAgents;
            }
        }
        catch
        {
            actionError = "Couldn't close the request. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ReopenRequest() => await Apply(RequestStatus.Open, record?.ResponseText);

    private async Task PromoteToRfi()
    {
        if (record is null || busy) return;
        ladderError = null;
        try
        {
            busy = true;
            record = await RequestRegister.PromoteToRfiAsync(record.RequestId, ProjectId);
            responseDraft = record.ResponseText ?? "";
        }
        catch
        {
            ladderError = "Couldn't promote the request to an RFI. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task EnableRfq()
    {
        if (record is null || busy) return;
        ladderError = null;
        try
        {
            busy = true;
            record = await RequestRegister.EnableRfqAsync(record.RequestId, ProjectId);
            await LoadVoqAsync();
        }
        catch
        {
            ladderError = "Couldn't enable the RFQ. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task CreateVoq()
    {
        if (record is null || busy) return;
        voqError = null;
        try
        {
            busy = true;
            voq = await Variations.CreateFromRfqAsync(record.RequestId);
            Nav.NavigateTo($"/projects/{ProjectId}/voq/{voq.VariationOrderQuoteId}");
        }
        catch
        {
            voqError = "Couldn't create the VOQ. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task OnPartyChanged(ChangeEventArgs e)
    {
        if (record is null || busy) return;
        ladderError = null;

        var selection = e.Value?.ToString() ?? "";
        var partyKind = PartyKind.Client;
        string? partyId = null;
        string? onBehalfOfClientId = null;

        if (selection.StartsWith(ArchitectPrefix, StringComparison.Ordinal))
        {
            partyKind = PartyKind.Architect;
            partyId = selection[ArchitectPrefix.Length..];
            // Keep the recorded on-behalf-of client when switching between architects.
            onBehalfOfClientId = record.OnBehalfOfClientId;
        }
        else if (selection.StartsWith(ClientPrefix, StringComparison.Ordinal))
        {
            partyId = selection[ClientPrefix.Length..];
        }

        try
        {
            busy = true;
            record = await RequestRegister.LinkToPartyAsync(record.RequestId, partyKind, partyId, onBehalfOfClientId, ProjectId);
            await LoadRecipientPreviewAsync();
        }
        catch
        {
            ladderError = "Couldn't update the linked party. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task OnOnBehalfOfClientChanged(ChangeEventArgs e)
    {
        if (record is null || busy || string.IsNullOrEmpty(record.PartyId)) return;
        ladderError = null;
        var clientId = e.Value?.ToString();
        if (string.IsNullOrWhiteSpace(clientId)) clientId = null;
        try
        {
            busy = true;
            record = await RequestRegister.LinkToPartyAsync(record.RequestId, PartyKind.Architect, record.PartyId, clientId, ProjectId);
            await LoadRecipientPreviewAsync();
        }
        catch
        {
            ladderError = "Couldn't update the on-behalf-of client. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task Apply(RequestStatus status, string? responseText)
    {
        if (record is null || busy) return;
        actionError = null;
        var email = Auth.CurrentUser?.Email;
        var hasResponse = !string.IsNullOrWhiteSpace(responseText);

        var command = new UpdateRequestDetails(
            record.RequestId,
            record.Reference,
            record.Title,
            record.Description,
            status,
            record.Value,
            hasResponse ? responseText!.Trim() : null,
            hasResponse ? (record.RespondedByEmail ?? email) : record.RespondedByEmail,
            record.ImpliesVariation,
            record.RaisedTo,
            record.DrawingRef,
            record.ResponseDue,
            record.RelatedDrawingSpec,
            record.InternalNotes,
            record.ClientNotes);

        try
        {
            busy = true;
            record = await RequestRegister.UpdateAsync(command);
            responseDraft = record.ResponseText ?? "";
        }
        catch (CommandFailedException ex)
        {
            actionError = ex.Message;
        }
        catch
        {
            actionError = "Couldn't update the request. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private void OpenEdit()
    {
        if (record is null) return;
        editReference = record.Reference;
        editTitle = record.Title;
        editDescription = record.Description ?? "";
        editRaisedAt = record.RaisedAt.LocalDateTime.ToString("yyyy-MM-dd");
        editResponseDue = record.ResponseDue?.LocalDateTime.ToString("yyyy-MM-dd") ?? "";
        editRaisedTo = record.RaisedTo ?? "";
        editDrawingRef = record.DrawingRef ?? "";
        editRelatedSpec = record.RelatedDrawingSpec ?? "";
        editStatus = record.Status;
        editError = null;
        editing = true;
    }

    private void CancelEdit() => editing = false;

    private void OnEditStatusChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var raw)) editStatus = (RequestStatus)raw;
    }

    private void OnEditDescriptionInput(ChangeEventArgs e) => editDescription = e.Value?.ToString() ?? "";

    private async Task SaveEdit()
    {
        if (record is null || busy || !CanEditDetails) return;
        editError = null;

        if (string.IsNullOrWhiteSpace(editReference)) { editError = "A reference is required."; return; }
        if (string.IsNullOrWhiteSpace(editTitle)) { editError = "A subject is required."; return; }

        var issued = ParseDate(editRaisedAt) ?? record.RaisedAt;

        var command = new UpdateRequestDetails(
            record.RequestId,
            editReference.Trim(),
            editTitle.Trim(),
            editDescription?.Trim() ?? "",
            editStatus,
            record.Value,
            record.ResponseText,
            record.RespondedByEmail,
            record.ImpliesVariation,
            NullIfBlank(editRaisedTo),
            NullIfBlank(editDrawingRef),
            ParseDate(editResponseDue),
            NullIfBlank(editRelatedSpec),
            record.InternalNotes,
            record.ClientNotes,
            issued);

        try
        {
            busy = true;
            record = await RequestRegister.UpdateAsync(command);
            responseDraft = record.ResponseText ?? "";
            editing = false;
        }
        catch (CommandFailedException ex)
        {
            // e.g. the reference was manually edited onto a number already in use on this project.
            editError = ex.Message;
        }
        catch
        {
            editError = "Couldn't save the changes. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private void CancelDelete() => confirmingDelete = false;

    private async Task PerformDelete()
    {
        if (record is null || busy || !IsAdmin) return;
        actionError = null;
        try
        {
            busy = true;
            await RequestRegister.DeleteAsync(record.RequestId, ProjectId);
            Nav.NavigateTo(RegisterHref);
        }
        catch
        {
            actionError = "Couldn't delete the request. Please try again.";
            confirmingDelete = false;
            busy = false;
        }
    }

    private void CancelReturn() => confirmingReturn = false;

    private async Task PerformReturn()
    {
        if (record is null || busy || !CanTriage) return;
        actionError = null;
        try
        {
            busy = true;
            await RequestRegister.ReturnToTriageAsync(record.RequestId, ProjectId);
            Nav.NavigateTo(RegisterHref);
        }
        catch
        {
            actionError = "Couldn't return the request to triage. Please try again.";
            confirmingReturn = false;
            busy = false;
        }
    }

    // ---- Official document form (itemised queries + narrative sections) ------------------------

    /// <summary>A mutable editor row for one itemised query; positions are re-minted on save.</summary>
    private sealed class FormItemRow
    {
        public string DrawingRef { get; set; } = "";
        public string MemberArea { get; set; } = "";
        public string Query { get; set; } = "";
        public string Response { get; set; } = "";
    }

    private void OpenFormEditor()
    {
        if (record is null) return;
        formItems = record.ItemList
            .OrderBy(item => item.Position)
            .Select(item => new FormItemRow
            {
                DrawingRef = item.DrawingRef,
                MemberArea = item.MemberArea,
                Query = item.Query,
                Response = item.Response ?? ""
            })
            .ToList();
        if (formItems.Count == 0) formItems.Add(new FormItemRow());
        formBasis = record.BasisOfQueries ?? "";
        formResponseAction = record.ResponseActionRequired ?? "";
        formImpact = record.ImpactIfLate ?? "";
        formError = null;
        editingForm = true;
    }

    private void CancelFormEdit()
    {
        editingForm = false;
        formError = null;
    }

    private void AddFormItem() => formItems.Add(new FormItemRow());

    private void RemoveFormItem(FormItemRow row) => formItems.Remove(row);

    private async Task SaveForm()
    {
        if (record is null || busy || !CanEditDetails) return;
        formError = null;

        var items = formItems
            .Select(row => new RequestItemDraft(
                row.DrawingRef.Trim(),
                row.MemberArea.Trim(),
                row.Query.Trim(),
                NullIfBlank(row.Response)))
            .ToList();

        var command = new UpdateRequestForm(
            record.RequestId,
            NullIfBlank(formBasis),
            NullIfBlank(formResponseAction),
            NullIfBlank(formImpact),
            items);

        try
        {
            busy = true;
            record = await RequestRegister.SaveFormAsync(command);
            editingForm = false;
        }
        catch (CommandFailedException ex)
        {
            formError = ex.Message;
        }
        catch
        {
            formError = "Couldn't save the form. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    // ---- Email draft staging --------------------------------------------------------------------

    private async Task PrepareEmailDraft()
    {
        if (record is null || busy || preparingDraft || !CanDraftEmail) return;
        draftError = null;
        draftResult = null;
        try
        {
            preparingDraft = true;
            draftResult = await RequestRegister.PrepareEmailDraftAsync(record.RequestId);
        }
        catch (CommandFailedException ex)
        {
            draftError = ex.Message;
        }
        catch
        {
            draftError = "Couldn't create the draft. Please try again.";
        }
        finally
        {
            preparingDraft = false;
        }
    }

    private static string Dash(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string? NullIfBlank(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static DateTimeOffset? ParseDate(string value) =>
        DateTimeOffset.TryParse(value, out var parsed) ? parsed : null;

    private static string Date(DateTimeOffset? value) =>
        value is null ? "—" : value.Value.LocalDateTime.ToString("d MMM yyyy");

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string StatusLabel(RequestStatus status) => status switch
    {
        RequestStatus.AwaitingResponse => "Awaiting response",
        _ => status.ToString()
    };

    private static string StatusClass(RequestStatus status) => status switch
    {
        RequestStatus.Open             => "bg-blue-500/10 text-blue-600",
        RequestStatus.AwaitingResponse => "bg-amber-500/10 text-amber-600",
        RequestStatus.Approved         => "bg-emerald-500/10 text-emerald-600",
        RequestStatus.Responded        => "bg-emerald-500/10 text-emerald-600",
        RequestStatus.Rejected         => "bg-red-500/10 text-red-600",
        RequestStatus.Closed           => "bg-surface-raised border border-line text-content-muted",
        _                              => "bg-surface-raised border border-line text-content-muted"
    };
}
