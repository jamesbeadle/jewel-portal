@page "/projects/{ProjectId}/requests/view/{RequestId}"
@using Jewel.JPMS.Contracts.Requests
@using Jewel.JPMS.Contracts.Procurement
@using Jewel.JPMS.Contracts.Variations
@using Jewel.JPMS.Features.CostCenters
@inject AuthService Auth
@inject ICommandSender Commands
@inject CostCentersReadModel CostCenters
@inject SessionService Session
@inject IRequestRegister RequestRegister
@inject IClientStore ClientStore
@inject IArchitectStore ArchitectStore
@inject ICorrespondenceStore Correspondence
@inject IVariationStore Variations
@inject IAgentDesk Agents
@inject NavigationManager Nav

<PageTitle>Request · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (record is null)
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="requests">
        <p class="text-sm text-content-subtle italic">That request could not be found.</p>
        <a href="@RegisterHref" class="btn-secondary mt-4">Back to register</a>
    </ProjectPageShell>
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="requests">
        <a href="@RegisterHref" class="text-sm text-content-muted hover:text-content inline-flex items-center gap-1 mb-4">
            &larr; Request register
        </a>

        <div class="flex flex-wrap items-start justify-between gap-3 mb-1">
            <div class="flex items-center gap-3">
                @* Lead with the official instrument number (RFI-014) once promoted; the REQ container
                   number is secondary context (it names the request's folder in the projects mailbox). *@
                <span class="font-mono text-base font-semibold text-content" title="@record.Kind.LongName()">@PrimaryReference</span>
                @if (ShowContainerNumber)
                {
                    <span class="font-mono text-sm text-content-muted" title="Container number — the request's folder in the projects mailbox">@record.DisplayNumber</span>
                }
                <span class="text-content-subtle text-xs uppercase tracking-wide" title="@record.Kind.LongName()">@record.Kind.DisplayName()</span>
                <span class="inline-flex items-center whitespace-nowrap rounded-full px-2 py-0.5 text-[11px] font-medium @StatusClass(record.Status)">@StatusLabel(record.Status)</span>
                @if (record.ImpliesVariation)
                {
                    <span class="inline-flex items-center rounded bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-600">Variation</span>
                }
                @if (record.CriticalPath)
                {
                    <span class="inline-flex items-center rounded bg-rose-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-rose-600"
                          title="Programme-related — the answer gates work on the programme's critical path">Critical path</span>
                }
            </div>

            @* The page's actions live up here with the record they act on: emailing (the most-used
               action) as its own button, everything else behind one Actions dropdown — no rail of
               scattered buttons. *@
            <div class="flex flex-wrap items-center gap-2">
                @if (record.Kind.IsEmailable() && CanDraftEmail)
                {
                    <button type="button" class="btn-primary" disabled="@(busy || preparingDraft)" @onclick="OpenEmailModal">
                        Email @record.Kind.DisplayName()
                    </button>
                }
                <div class="relative">
                    <button type="button" class="btn-secondary inline-flex items-center gap-1.5" @onclick="() => actionsOpen = !actionsOpen">
                        Actions <span class="text-content-faint text-xs" aria-hidden="true">@(actionsOpen ? "▲" : "▼")</span>
                    </button>
                    @if (actionsOpen)
                    {
                        <div class="absolute right-0 mt-2 w-64 rounded-lg border border-line bg-surface shadow-lg z-20 overflow-hidden">
                            <ul class="divide-y divide-line">
                                @if (record.Kind.IsEmailable())
                                {
                                    <li>
                                        <a href="@DocumentHref" target="_blank" rel="noopener"
                                           class="block w-full text-left px-3 py-2 text-sm text-content hover:bg-surface-raised transition"
                                           @onclick="() => actionsOpen = false"
                                           title="Regenerated from the register on every download, so it always reflects the request as it stands">Download @record.Kind.DisplayName() PDF</a>
                                    </li>
                                }
                                @if (record.Status is not RequestStatus.Closed)
                                {
                                    <li>
                                        <button type="button" class="w-full text-left px-3 py-2 text-sm text-content hover:bg-surface-raised transition"
                                                @onclick="OpenResponseModal"
                                                title="The formal answer recorded on the request — it prints on the official document">Record response…</button>
                                    </li>
                                    <li>
                                        <button type="button" class="w-full text-left px-3 py-2 text-sm text-content hover:bg-surface-raised transition"
                                                @onclick="() => { actionsOpen = false; OpenCloseConfirm(); }">Close request…</button>
                                    </li>
                                }
                                else
                                {
                                    <li>
                                        <button type="button" class="w-full text-left px-3 py-2 text-sm text-content hover:bg-surface-raised transition"
                                                @onclick="ReopenFromMenu">Reopen request</button>
                                    </li>
                                }
                                @if (CanEditDetails && record.Kind is RequestType.Rfi)
                                {
                                    <li>
                                        <button type="button" class="w-full text-left px-3 py-2 text-sm text-content hover:bg-surface-raised transition"
                                                @onclick="ToggleCriticalPathFromMenu"
                                                title="The Critical Path tag marks this RFI as programme-related; tagged RFIs show under Critical Path RFIs on the Programme tab">
                                            @(record.CriticalPath ? "Remove critical path tag" : "Mark as critical path")
                                        </button>
                                    </li>
                                }
                                @if (CanEditDetails && record.Kind is RequestType.Rfi && !record.HasRfq)
                                {
                                    <li>
                                        <button type="button" class="w-full text-left px-3 py-2 text-sm text-content hover:bg-surface-raised transition"
                                                @onclick="CreateBidPackagesFromMenu"
                                                title="Marks this RFI as carrying an RFQ, unlocking a Variation Order Quote and its bid packages">Create bid packages</button>
                                    </li>
                                }
                                @if (CanTriage)
                                {
                                    <li>
                                        <button type="button" class="w-full text-left px-3 py-2 text-sm text-content hover:bg-surface-raised transition"
                                                @onclick="() => { actionsOpen = false; confirmingReturn = true; }"
                                                title="Sends every email linked to this request back to the triage queue">Return to triage…</button>
                                    </li>
                                }
                                @if (IsAdmin)
                                {
                                    <li>
                                        <button type="button" class="w-full text-left px-3 py-2 text-sm text-negative hover:bg-negative/10 transition"
                                                @onclick="() => { actionsOpen = false; confirmingDelete = true; }">Delete request…</button>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="flex items-baseline gap-3 mb-5">
            <h2 class="text-xl font-semibold text-content">@record.Title</h2>
            @if (CanEditDetails)
            {
                <button type="button" class="text-xs font-medium text-content-muted hover:text-content underline underline-offset-2"
                        title="Edit the reference, status and subject" @onclick="OpenHeaderEdit">Edit</button>
            }
        </div>

        <RecordLineage ProjectId="@ProjectId" ActiveId="request"
                       Request="record" Voq="voq" Vo="vo" BidPackages="bidPackages" />

        @* At-a-glance facts run across the top rather than down a rail, so the columns below are
           left for the substance: the request itself on the left, actions on the right. *@
        <div class="panel px-5 py-4 mb-5">
            <div class="flex items-start justify-between gap-6">
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-x-6 gap-y-3 text-sm flex-1">
                <MetaCell Label="Raised by" Value="@record.RaisedByEmail" />
                @* The one visible date. Rows predating the IssuedAt backfill fall back to the
                   internal created-on stamp rather than showing a dash. *@
                <MetaCell Label="Date issued" Value="@Date(record.IssuedAt ?? record.RaisedAt)" />
                <MetaCell Label="Raised to" Value="@Dash(record.RaisedTo)" />
                <MetaCell Label="Response due" Value="@Date(record.ResponseDue)" />
                <div>
                    <p class="text-[10px] uppercase tracking-wide font-semibold text-content-subtle mb-0.5">Days outstanding</p>
                    <p class="@(record.IsOverdue ? "text-negative font-semibold" : "text-content")">@(record.DaysOutstanding is int d ? d.ToString() : "—")</p>
                </div>
                @if (record.ClosedAt is not null)
                {
                    <MetaCell Label="Date closed" Value="@Date(record.ClosedAt)" />
                }
                <MetaCell Label="Drawing / detail" Value="@Dash(record.DrawingRef)" />
                <MetaCell Label="Related drawing / spec" Value="@Dash(record.RelatedDrawingSpec)" />
                @if (record.Kind is not RequestType.Rfi)
                {
                    <MetaCell Label="Value" Value="@(record.Value is null ? "—" : Money(record.Value.Value))" />
                }
            </div>
            @if (CanEditDetails)
            {
                <button type="button" class="text-xs font-medium text-content-muted hover:text-content underline underline-offset-2"
                        title="Edit the dates, raised to and drawing references" @onclick="OpenFactsEdit">Edit</button>
            }
            </div>
        </div>

        @* Outcomes of header actions (close/reopen/response/triage/delete) surface here, under the
           facts strip, now that the Manage panel is gone. *@
        @if (actionError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-5">@actionError</p>
        }
        @if (blockingAgents.Count > 0)
        {
            <div class="rounded-lg bg-amber-500/10 border border-amber-500/30 px-3 py-2 mb-5">
                <p class="text-sm font-medium text-amber-700 mb-1">This request can't be closed yet.</p>
                <p class="text-xs text-content-subtle mb-2">The following agents have outstanding work:</p>
                <ul class="space-y-1">
                    @foreach (var blocker in blockingAgents)
                    {
                        <li class="text-xs text-content"><span class="font-medium">@blocker.DisplayName</span> — @blocker.Message</li>
                    }
                </ul>
            </div>
        }

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
            <div class="lg:col-span-2 space-y-5">
                <div class="panel p-5">
                    <div class="flex items-start justify-between gap-3 mb-2">
                        <h3 class="eyebrow">Detail</h3>
                        @if (CanEditDetails)
                        {
                            <button type="button" class="text-xs font-medium text-content-muted hover:text-content underline underline-offset-2" @onclick="OpenDetailEdit">Edit</button>
                        }
                    </div>
                    <p class="text-sm text-content whitespace-pre-wrap">@(string.IsNullOrWhiteSpace(record.Description) ? "—" : record.Description)</p>
                </div>

                <div class="panel p-5">
                    <div class="flex items-start justify-between gap-3 mb-3">
                        <div>
                            <h3 class="eyebrow">@(record.Kind.IsEmailable() ? $"Official {record.Kind.DisplayName()} form" : "Official form")</h3>
                            <p class="text-xs text-content-subtle mt-0.5">@(record.Kind.IsEmailable()
                                ? "The itemised queries and sections rendered on the issued document."
                                : "Prepared ahead: these sections are carried onto the official document when the request is promoted to an RFI.")</p>
                        </div>
                        @if (CanEditDetails && !editingForm)
                        {
                            <button type="button" class="text-xs font-medium text-content-muted hover:text-content underline underline-offset-2" @onclick="OpenFormEditor">Edit form</button>
                        }
                    </div>

                    @if (formError is not null)
                    {
                        <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@formError</p>
                    }

                    @if (!editingForm)
                    {
                        @if (record.ItemList.Count == 0
                            && string.IsNullOrWhiteSpace(record.BasisOfQueries)
                            && string.IsNullOrWhiteSpace(record.ResponseActionRequired)
                            && string.IsNullOrWhiteSpace(record.ImpactIfLate))
                        {
                            <p class="text-sm text-content-subtle italic">No itemised queries yet. The issued document carries the detail above only.</p>
                        }
                        else
                        {
                            @if (record.ItemList.Count > 0)
                            {
                                <div class="overflow-x-auto -mx-1 px-1">
                                    <table class="w-full text-sm">
                                        <thead>
                                            <tr class="text-left text-content-subtle border-b border-line">
                                                <th class="py-2 pr-3 font-medium w-10">Item</th>
                                                <th class="py-2 pr-3 font-medium">Drawing ref</th>
                                                <th class="py-2 pr-3 font-medium">Member / area</th>
                                                <th class="py-2 pr-3 font-medium">Query</th>
                                                <th class="py-2 font-medium">Response</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var item in record.ItemList)
                                            {
                                                <tr class="border-b border-line last:border-0 align-top">
                                                    <td class="py-2 pr-3 font-mono text-content-muted">@item.Position</td>
                                                    <td class="py-2 pr-3 text-content-muted whitespace-pre-wrap">@Dash(item.DrawingRef)</td>
                                                    <td class="py-2 pr-3 text-content whitespace-pre-wrap">@Dash(item.MemberArea)</td>
                                                    <td class="py-2 pr-3 text-content whitespace-pre-wrap">@Dash(item.Query)</td>
                                                    <td class="py-2 text-content-muted whitespace-pre-wrap">@Dash(item.Response)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(record.BasisOfQueries))
                            {
                                <div class="mt-3">
                                    <h4 class="eyebrow mb-1">Basis of queries</h4>
                                    <p class="text-sm text-content-muted whitespace-pre-wrap">@record.BasisOfQueries</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(record.ResponseActionRequired))
                            {
                                <div class="mt-3">
                                    <h4 class="eyebrow mb-1">Response / action required</h4>
                                    <p class="text-sm text-content whitespace-pre-wrap">@record.ResponseActionRequired</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(record.ImpactIfLate))
                            {
                                <div class="mt-3">
                                    <h4 class="eyebrow mb-1">Impact if not received by the required date</h4>
                                    <p class="text-sm text-content-muted whitespace-pre-wrap">@record.ImpactIfLate</p>
                                </div>
                            }
                        }
                    }
                    else
                    {
                        <div class="space-y-4">
                            <div>
                                <label class="eyebrow block mb-2">Itemised queries</label>
                                @if (formItems.Count == 0)
                                {
                                    <p class="text-sm text-content-subtle italic mb-2">No items — add the first numbered query below.</p>
                                }
                                <div class="space-y-3">
                                    @{ var itemNumber = 0; }
                                    @foreach (var row in formItems)
                                    {
                                        itemNumber++;
                                        <div class="rounded-lg border border-line p-3 space-y-2">
                                            <div class="flex items-center justify-between">
                                                <span class="font-mono text-xs font-semibold text-content-muted">Item @itemNumber</span>
                                                <button type="button" class="text-xs text-negative hover:underline underline-offset-2" @onclick="() => RemoveFormItem(row)">Remove</button>
                                            </div>
                                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                                                <div>
                                                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Drawing ref</label>
                                                    <textarea class="field" rows="2" value="@row.DrawingRef" @oninput="e => row.DrawingRef = e.Value?.ToString() ?? string.Empty"
                                                              placeholder="Dwg 1986_111 Rev D&#10;SD8, SD3"></textarea>
                                                </div>
                                                <div>
                                                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Member / area</label>
                                                    <textarea class="field" rows="2" value="@row.MemberArea" @oninput="e => row.MemberArea = e.Value?.ToString() ?? string.Empty"
                                                              placeholder="West Elevation — lead valley gutter"></textarea>
                                                </div>
                                            </div>
                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Query</label>
                                                <textarea class="field" rows="3" value="@row.Query" @oninput="e => row.Query = e.Value?.ToString() ?? string.Empty"
                                                          placeholder="Please confirm…"></textarea>
                                            </div>
                                            <div>
                                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Response (when received)</label>
                                                <textarea class="field" rows="2" value="@row.Response" @oninput="e => row.Response = e.Value?.ToString() ?? string.Empty"></textarea>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <button type="button" class="btn-secondary mt-2" @onclick="AddFormItem">Add item</button>
                            </div>

                            <div>
                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Basis of queries</label>
                                <textarea class="field" rows="2" value="@formBasis" @oninput="e => formBasis = e.Value?.ToString() ?? string.Empty"
                                          placeholder="Architect's email ref…, site inspection observations, drawings…"></textarea>
                            </div>
                            <div>
                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Response / action required</label>
                                <textarea class="field" rows="3" value="@formResponseAction" @oninput="e => formResponseAction = e.Value?.ToString() ?? string.Empty"
                                          placeholder="Please provide written confirmation / instruction on the items above…"></textarea>
                            </div>
                            <div>
                                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Impact if not received by the required date</label>
                                <textarea class="field" rows="2" value="@formImpact" @oninput="e => formImpact = e.Value?.ToString() ?? string.Empty"
                                          placeholder="Works cannot proceed, risking programme delay while scaffold remains in place…"></textarea>
                            </div>

                            <div class="flex flex-wrap gap-2">
                                <button type="button" class="btn-primary" disabled="@busy" @onclick="SaveForm">@(busy ? "Saving…" : "Save form")</button>
                                <button type="button" class="btn-secondary" disabled="@busy" @onclick="CancelFormEdit">Cancel</button>
                            </div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(record.ResponseText))
                {
                    <div class="panel p-5">
                        <h3 class="eyebrow mb-2">Response</h3>
                        <p class="text-sm text-content whitespace-pre-wrap">@record.ResponseText</p>
                        @if (!string.IsNullOrWhiteSpace(record.RespondedByEmail))
                        {
                            <p class="text-xs text-content-subtle mt-2">@record.RespondedByEmail · @Date(record.RespondedAt)</p>
                        }
                    </div>
                }

                @* Per-message reply drafting is off: emailing the document (fresh or into a tagged
                   chain) is consolidated behind the single Email button in the page header. *@
                <RequestConversation RequestId="@RequestId" CanDraftReply="false" />

                @* Agents are parked for now — the workspace is hidden until we settle on whether
                   attaching agents to requests is the right model. Re-add <AgentWorkspace> here. *@
            </div>

            <div class="space-y-5">
                @* Document + email actions live in the page header; this rail panel is just the
                   record's shape — its type (with promotion) and who it corresponds with. Hidden
                   entirely when there is nothing to show (official kind, no edit rights). *@
                @if (!record.Kind.IsEmailable() || CanEditDetails)
                {
                <div class="panel p-5 space-y-3">
                    <h3 class="eyebrow">Request type &amp; recipients</h3>
                    @if (!record.Kind.IsEmailable())
                    {
                        <p class="text-sm text-content-subtle">
                            A @record.Kind.DisplayName() request is the pre-official stage — there is no
                            official document yet and nothing is emailed. Promoting it to an RFI mints the
                            reference and creates the official document, ready to email when you choose.
                        </p>
                    }

                    @if (CanEditDetails)
                    {
                        <div class="space-y-4">
                        <p class="text-sm text-content">
                            Current: <span class="font-medium">@record.Kind.DisplayName()</span>
                            @if (record.HasRfq)
                            {
                                <span class="ml-2 inline-flex items-center rounded bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-600">RFQ enabled</span>
                            }
                        </p>

                        @if (ladderError is not null)
                        {
                            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@ladderError</p>
                        }

                        @if (record.Kind is not RequestType.Rfi)
                        {
                            <div>
                                <button type="button" class="btn-primary w-full" disabled="@busy" @onclick="PromoteToRfi">Promote to RFI</button>
                                <p class="text-xs text-content-subtle mt-1">Mints the RFI reference and creates the official document. No email is drafted by promotion — when you're ready to issue, use the Email button at the top of the page.</p>
                            </div>
                        }
                        <div>
                            <label class="eyebrow block mb-1">Issued to</label>
                            <select class="field" value="@PartySelectionValue" @onchange="OnPartyChanged" disabled="@busy">
                                <option value="">— None —</option>
                                @if (clients.Count > 0)
                                {
                                    <optgroup label="Clients">
                                        @foreach (var client in clients)
                                        {
                                            <option value="@($"{ClientPrefix}{client.ClientId}")">@client.Name</option>
                                        }
                                    </optgroup>
                                }
                                @if (architects.Count > 0)
                                {
                                    <optgroup label="Architects">
                                        @foreach (var architect in architects)
                                        {
                                            <option value="@($"{ArchitectPrefix}{architect.ArchitectId}")">@architect.Name</option>
                                        }
                                    </optgroup>
                                }
                            </select>
                            <p class="text-xs text-content-subtle mt-1">The email an RFI is issued to comes from this party — a client directly, or an architect acting on the client's behalf.</p>
                        </div>

                        @if (record.PartyKind == PartyKind.Architect && !string.IsNullOrEmpty(record.PartyId))
                        {
                            <div>
                                <label class="eyebrow block mb-1">On behalf of client</label>
                                <select class="field" value="@(record.OnBehalfOfClientId ?? "")" @onchange="OnOnBehalfOfClientChanged" disabled="@busy">
                                    <option value="">— Not recorded —</option>
                                    @foreach (var client in clients)
                                    {
                                        <option value="@client.ClientId">@client.Name</option>
                                    }
                                </select>
                                <p class="text-xs text-content-subtle mt-1">Optional: the client this architect is acting for.</p>
                            </div>
                        }

                        @if (recipientPreview is not null)
                        {
                            <div class="rounded-lg bg-surface-raised border border-line px-3 py-2 space-y-1">
                                <p class="text-[10px] uppercase tracking-wide font-semibold text-content-subtle">Draft will be addressed to</p>
                                @if (recipientPreview.To.Count == 0)
                                {
                                    <p class="text-xs text-negative">No correspondent resolves — link a party or set a project contact's routing to To.</p>
                                }
                                else
                                {
                                    <p class="text-xs text-content"><span class="font-medium">To:</span> @RecipientLine(recipientPreview.To)</p>
                                }
                                @if (recipientPreview.Cc.Count > 0)
                                {
                                    <p class="text-xs text-content"><span class="font-medium">CC:</span> @RecipientLine(recipientPreview.Cc)</p>
                                }
                                @if (recipientPreview.Bcc.Count > 0)
                                {
                                    <p class="text-xs text-content"><span class="font-medium">BCC:</span> @RecipientLine(recipientPreview.Bcc)</p>
                                }
                                <p class="text-[10px] text-content-subtle">From the project's correspondence profile (Setup tab). BCC never appears on the document or the shared trail.</p>
                            </div>
                        }
                        </div>
                    }
                </div>
                }

                @if (record.HasRfq)
                {
                    <div class="panel p-5 space-y-3">
                        <h3 class="eyebrow">Variation Order Quote</h3>
                        @if (voq is not null)
                        {
                            <p class="text-sm text-content">
                                <span class="font-mono font-semibold">@voq.DisplayNumber</span>
                                <span class="text-content-subtle ml-2">@voq.Status</span>
                            </p>
                            <a href="@VoqHref" class="btn-secondary w-full inline-flex justify-center">Open VOQ</a>
                        }
                        else
                        {
                            @if (voqError is not null)
                            {
                                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@voqError</p>
                            }
                            <p class="text-xs text-content-subtle">This RFI carries an RFQ. Create a Variation Order Quote to send bid packages to subcontractors — the draft is prepared from this RFI and its tagged emails for you to review.</p>
                            @if (CanEditDetails)
                            {
                                <button type="button" class="btn-primary w-full" disabled="@busy" @onclick="OpenVoqDraft">Create VOQ</button>
                            }
                        }
                    </div>
                }

            </div>
        </div>
    </ProjectPageShell>

    <Modal IsOpen="confirmingDelete"
           Title="Delete this request?"
           ConfirmLabel="@(busy ? "Deleting…" : "Delete request")"
           OnCancel="CancelDelete"
           OnConfirm="PerformDelete">
        <p class="text-sm text-content">
            This will permanently remove <span class="font-mono">@record?.Reference</span> — “@record?.Title” — and its entire conversation. This cannot be undone.
        </p>
    </Modal>

    <Modal IsOpen="confirmingReturn"
           Title="Return this request to triage?"
           ConfirmLabel="@(busy ? "Returning…" : "Return to triage")"
           OnCancel="CancelReturn"
           OnConfirm="PerformReturn">
        <p class="text-sm text-content">
            Every email linked to <span class="font-mono">@record?.Reference</span> — “@record?.Title” — will go back to the triage queue so the thread can be triaged again from scratch. The request itself and its conversation history stay in the register.
        </p>
    </Modal>

    <Modal IsOpen="confirmingClose"
           Title="Close this request?"
           ConfirmLabel="@(busy ? "Closing…" : "Close request")"
           OnCancel="CancelClose"
           OnConfirm="PerformClose">
        <div class="space-y-3">
            <p class="text-sm text-content">
                Closes <span class="font-mono">@record?.Reference</span> — “@record?.Title”. If the request was actually resolved earlier, set the date it closed below.
            </p>
            <FormField Label="Date closed" Value="@closeDate" OnChange="v => closeDate = v" InputType="date" />
            @if (closeError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@closeError</p>
            }
        </div>
    </Modal>

    <Modal IsOpen="emailModalOpen"
           Title="@($"Email this {record.Kind.DisplayName()}")"
           ConfirmLabel="@(preparingDraft ? "Creating draft…" : "Create draft")"
           ConfirmDisabled="@preparingDraft"
           ShowFooter="@(draftResult is null)"
           OnCancel="CloseEmailModal"
           OnConfirm="ConfirmEmailDraft"
           Class="max-w-xl">
        <div class="space-y-4">
            @if (draftResult is null)
            {
                <p class="text-sm text-content-subtle">
                    Stages a draft in the projects mailbox with the @record.Kind.DisplayName() PDF attached.
                    Review and send it from Outlook — nothing is sent from here.
                </p>

                <div class="space-y-2">
                    <label class="flex items-start gap-2.5 rounded-lg border p-3 cursor-pointer @(selectedChainMailboxId == "" ? "border-accent bg-accent/5" : "border-line hover:border-line-strong")">
                        <input type="radio" name="email-target" class="mt-0.5" checked="@(selectedChainMailboxId == "")"
                               @onchange="@(() => selectedChainMailboxId = "")" />
                        <span>
                            <span class="block text-sm font-medium text-content">Start a fresh email</span>
                            <span class="block text-xs text-content-subtle mt-0.5">A new thread — To/CC/BCC pre-filled from the project's correspondence profile.</span>
                        </span>
                    </label>

                    @if (taggedEmailsLoading)
                    {
                        <p class="text-xs text-content-subtle italic px-1">Loading tagged emails…</p>
                    }
                    else if (taggedEmails.Count == 0)
                    {
                        <p class="text-xs text-content-subtle px-1">No emails are tagged to this request yet, so there is no chain to append to.</p>
                    }
                    else
                    {
                        <p class="eyebrow pt-1">Or append to a tagged email chain</p>
                        @foreach (var email in taggedEmails)
                        {
                            <label class="flex items-start gap-2.5 rounded-lg border p-3 cursor-pointer @(selectedChainMailboxId == email.MailboxId ? "border-accent bg-accent/5" : "border-line hover:border-line-strong")">
                                <input type="radio" name="email-target" class="mt-0.5" checked="@(selectedChainMailboxId == email.MailboxId)"
                                       @onchange="@(() => selectedChainMailboxId = email.MailboxId!)" />
                                <span class="min-w-0">
                                    <span class="block text-sm font-medium text-content truncate">@(string.IsNullOrWhiteSpace(email.Subject) ? Truncate(email.Body, 80) : email.Subject)</span>
                                    <span class="block text-xs text-content-subtle mt-0.5">@AuthorLabel(email) · @email.PostedAt.LocalDateTime.ToString("d MMM yyyy, HH:mm") — reply-all in this thread, the whole chain quoted beneath.</span>
                                </span>
                            </label>
                        }
                    }
                </div>

                @if (draftError is not null)
                {
                    <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@draftError</p>
                }
            }
            else
            {
                <div class="rounded-lg bg-emerald-500/10 border border-emerald-500/30 px-3 py-2.5">
                    <p class="text-sm font-medium text-emerald-600">Draft created in the projects mailbox.</p>
                    <p class="text-xs text-content-subtle mt-1">To: @string.Join(", ", draftResult.Recipients)</p>
                    @if (draftResult.Cc is { Count: > 0 } draftCc)
                    {
                        <p class="text-xs text-content-subtle">CC: @string.Join(", ", draftCc)</p>
                    }
                    @if (draftResult.Bcc is { Count: > 0 } draftBcc)
                    {
                        <p class="text-xs text-content-subtle">BCC: @string.Join(", ", draftBcc)</p>
                    }
                    <p class="text-xs text-content-subtle mt-1">Review the recipients and send it from Outlook — nothing has been sent.</p>
                    @if (!string.IsNullOrWhiteSpace(draftResult.WebLink))
                    {
                        <a href="@draftResult.WebLink" target="_blank" rel="noopener"
                           class="text-xs text-accent hover:underline underline-offset-2">Open the draft in Outlook</a>
                    }
                </div>
                <div class="flex justify-end">
                    <button type="button" class="btn-primary" @onclick="CloseEmailModal">Done</button>
                </div>
            }
        </div>
    </Modal>

    <Modal IsOpen="respondingOpen"
           Title="Record a response"
           ConfirmLabel="@(busy ? "Saving…" : "Save response")"
           ConfirmDisabled="@busy"
           OnCancel="CancelResponseModal"
           OnConfirm="SaveResponseFromModal">
        <div class="space-y-3">
            <p class="text-sm text-content-subtle">
                The formal answer or decision recorded on the request itself — it appears in the
                Response panel, prints on the official document, and marks the request as Responded.
                (Use the conversation for ordinary discussion.)
            </p>
            <textarea class="field" rows="4" value="@responseDraft" @oninput="OnResponseDraftInput"
                      placeholder="The answer or decision…"></textarea>
            @if (actionError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@actionError</p>
            }
        </div>
    </Modal>

    @* The old single "Edit request details" modal is split three ways, each opened from an Edit
       control on the surface it edits: the page header (reference, status, subject), the facts
       strip (dates, raised to, drawing refs, value) and the Detail panel (the detail text). *@
    <Modal IsOpen="editingHeader"
           Title="Edit reference &amp; status"
           ConfirmLabel="@(busy ? "Saving…" : "Save changes")"
           OnCancel="CancelHeaderEdit"
           OnConfirm="SaveHeaderEdit"
           Class="max-w-xl">
        <div class="space-y-4">
            @if (editError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@editError</p>
            }

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <FormField Label="Reference" Value="@editReference" OnChange="v => editReference = v" Required="true" />
                <div>
                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Status</label>
                    <select class="field" value="@((int)editStatus)" @onchange="OnEditStatusChanged">
                        @foreach (var option in StatusOptions)
                        {
                            <option value="@((int)option)">@StatusLabel(option)</option>
                        }
                    </select>
                </div>
            </div>

            <FormField Label="Subject" Value="@editTitle" OnChange="v => editTitle = v" Required="true" />

            @if (editStatus == RequestStatus.Closed)
            {
                <FormField Label="Date closed" Value="@editClosedAt" OnChange="v => editClosedAt = v" InputType="date" />
            }

            @if (record.Kind is RequestType.Rfi)
            {
                <label class="flex items-start gap-2 text-sm text-content">
                    <input type="checkbox" class="mt-0.5" @bind="editCriticalPath" />
                    <span>Critical path <span class="text-content-subtle">— programme-related; shows under Critical Path RFIs on the Programme tab</span></span>
                </label>
            }
        </div>
    </Modal>

    <Modal IsOpen="editingFacts"
           Title="Edit request facts"
           ConfirmLabel="@(busy ? "Saving…" : "Save changes")"
           OnCancel="CancelFactsEdit"
           OnConfirm="SaveFactsEdit"
           Class="max-w-2xl">
        <div class="space-y-4">
            @if (editError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@editError</p>
            }

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <FormField Label="Date issued" Value="@editIssuedAt" OnChange="v => editIssuedAt = v" InputType="date" />
                <FormField Label="Response due" Value="@editResponseDue" OnChange="v => editResponseDue = v" InputType="date" />
                @if (record.ClosedAt is not null)
                {
                    <FormField Label="Date closed" Value="@editClosedAt" OnChange="v => editClosedAt = v" InputType="date" />
                }
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <ProjectContactSelect Contacts="@projectContacts"
                                      Value="@editRaisedToContactId"
                                      OnChange="v => editRaisedToContactId = v"
                                      LegacyText="@editLegacyRaisedTo" />
                <FormField Label="Drawing / detail ref" Value="@editDrawingRef" OnChange="v => editDrawingRef = v" />
            </div>

            <FormField Label="Related drawing / spec" Value="@editRelatedSpec" OnChange="v => editRelatedSpec = v" />

            @if (record.Kind is not RequestType.Rfi)
            {
                <FormField Label="Value (£, optional)" Value="@editValue" OnChange="v => editValue = v" />
            }
        </div>
    </Modal>

    <Modal IsOpen="editingDetail"
           Title="Edit detail"
           ConfirmLabel="@(busy ? "Saving…" : "Save changes")"
           OnCancel="CancelDetailEdit"
           OnConfirm="SaveDetailEdit"
           Class="max-w-2xl">
        <div class="space-y-4">
            @if (editError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@editError</p>
            }

            <div>
                <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Detail</label>
                <textarea class="field" rows="6" value="@editDescription" @oninput="OnEditDescriptionInput"></textarea>
            </div>
        </div>
    </Modal>

    <Modal IsOpen="voqDraftOpen"
           Title="Create Variation Order Quote"
           ConfirmLabel="@(busy ? "Creating…" : "Create VOQ")"
           ConfirmDisabled="@(busy || voqDraftLoading)"
           OnCancel="CancelVoqDraft"
           OnConfirm="ConfirmVoqDraft"
           Class="max-w-2xl">
        <div class="space-y-4">
            @if (voqDraftError is not null)
            {
                <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@voqDraftError</p>
            }

            @if (voqDraftLoading)
            {
                <p class="text-sm text-content-subtle">Drafting the VOQ from this RFI and its tagged emails…</p>
            }
            else
            {
                @if (voqDraft?.Proposed == true)
                {
                    <p class="rounded-lg bg-accent/10 border border-accent/30 px-3 py-2 text-xs text-content">
                        Drafted by AI from this RFI and its tagged emails. Review and edit everything below — nothing is created until you confirm.
                    </p>
                }
                else if (voqDraft is not null)
                {
                    <p class="text-xs text-content-subtle">AI drafting isn't available right now, so this starts from the RFI's own details.</p>
                }

                <FormField Label="Title" Value="@draftVoqTitle" OnChange="v => draftVoqTitle = v" Required="true" />

                <div>
                    <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Scope description</label>
                    <textarea class="field" rows="6" value="@draftVoqDescription" @oninput="e => draftVoqDescription = e.Value?.ToString() ?? string.Empty"></textarea>
                </div>

                <FormField Label="Estimated value (£, optional)" Value="@draftVoqValue" OnChange="v => draftVoqValue = v" />

                @if (draftVoqLines.Count > 0)
                {
                    <div>
                        <label class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Suggested scope lines</label>
                        <p class="text-xs text-content-subtle mb-2">Ticked lines are added to a draft bid package (@DraftPackageTrade) under the VOQ, ready to send to subcontractors. Every ticked line needs a cost centre — that's the cost code its committed value lands on.</p>
                        <ul class="space-y-1.5">
                            @foreach (var (row, index) in draftVoqLines.Select((r, i) => (r, i)))
                            {
                                var i = index;
                                <li>
                                    <label class="flex items-start gap-2 text-sm text-content">
                                        <input type="checkbox" class="mt-0.5" checked="@row.Accepted"
                                               @onchange="e => draftVoqLines[i] = draftVoqLines[i] with { Accepted = e.Value is true }" />
                                        <span>@row.Line.Description <span class="text-content-subtle">— @row.Line.Quantity @row.Line.Unit · @row.Line.Trade</span></span>
                                    </label>
                                    @if (row.Accepted)
                                    {
                                        <select class="field mt-1 ml-6 min-w-[14rem] text-sm" value="@row.CostCode"
                                                @onchange="e => draftVoqLines[i] = draftVoqLines[i] with { CostCode = e.Value?.ToString() ?? string.Empty }">
                                            <option value="">Cost centre…</option>
                                            @foreach (var centre in CostCenters.Alphabetical)
                                            {
                                                <option value="@centre.Code">@($"{centre.Code} — {centre.Name}")</option>
                                            }
                                        </select>
                                    }
                                </li>
                            }
                        </ul>
                    </div>
                }
            }
        </div>
    </Modal>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string RequestId { get; set; } = "";

    private bool isLoaded;
    private Request? record;
    private string responseDraft = "";
    private bool busy;
    private string? actionError;
    private bool confirmingDelete;
    private bool confirmingReturn;
    // The header's Actions dropdown; every item closes it before running (same pattern as
    // RoleSwitcher — no outside-click handling, the toggle is the dismiss).
    private bool actionsOpen;
    private bool respondingOpen;
    private IReadOnlyList<AgentCompletionState> blockingAgents = Array.Empty<AgentCompletionState>();
    private IReadOnlyList<Client> clients = Array.Empty<Client>();
    private IReadOnlyList<Architect> architects = Array.Empty<Architect>();

    private const string ClientPrefix = "client:";
    private const string ArchitectPrefix = "architect:";

    // The composite value driving the party select: "client:{id}" / "architect:{id}" / "".
    private string PartySelectionValue =>
        record is null || string.IsNullOrEmpty(record.PartyId)
            ? ""
            : (record.PartyKind == PartyKind.Architect ? ArchitectPrefix : ClientPrefix) + record.PartyId;
    private string? ladderError;
    private VariationOrderQuote? voq;
    private string? voqError;
    // Downstream lineage (VO + bid packages hang off the VOQ) for the RecordLineage bar.
    private VariationOrder? vo;
    private IReadOnlyList<BidPackage> bidPackages = Array.Empty<BidPackage>();

    // Official document form editor (the itemised queries + narrative sections).
    private bool editingForm;
    private string? formError;
    private List<FormItemRow> formItems = new();
    private string formBasis = "";
    private string formResponseAction = "";
    private string formImpact = "";

    // Email draft staging (Outlook draft in the projects mailbox) — all lives in the email modal.
    private bool emailModalOpen;
    private bool preparingDraft;
    private string? draftError;
    private RequestEmailDraft? draftResult;
    private RequestRecipientSet? recipientPreview;

    // The emails tagged to this request (inbound legs with a live mailbox id), offered in the
    // modal as chains the official document can be issued into as a reply — newest first.
    // "" = no chain selected = start a fresh email.
    private IReadOnlyList<RequestMessage> taggedEmails = Array.Empty<RequestMessage>();
    private bool taggedEmailsLoading;
    private string selectedChainMailboxId = "";

    private string VoqHref => voq is null ? "" : $"/projects/{ProjectId}/voq/{voq.VariationOrderQuoteId}";

    // The reference the page leads with: once promoted, the official instrument number (RFI-014) —
    // the number correspondents know it by — with the REQ container number as secondary context.
    // A General request leads with its REQ-#### container number.
    private string PrimaryReference =>
        record is null ? "" :
        record.Kind != RequestType.General && !string.IsNullOrWhiteSpace(record.Reference)
            ? record.Reference
            : string.IsNullOrEmpty(record.DisplayNumber) ? record.Reference : record.DisplayNumber;

    private bool ShowContainerNumber =>
        record is not null && !string.IsNullOrEmpty(record.DisplayNumber) && record.DisplayNumber != PrimaryReference;

    private string RegisterHref => $"/projects/{ProjectId}/requests";

    // Streams the official PDF from the api, regenerated from SQL on every download.
    private string DocumentHref => $"/api/requests/{RequestId}/document";

    // Mirrors PrepareRequestEmailDraftAuthorisation server-side (directors, project managers, site
    // managers and architects; admins carry every role server-side).
    private bool CanDraftEmail => Session.AvailableRoles.Any(role =>
        role is Role.Admin or Role.ManagingDirector or Role.ProjectManager or Role.SiteManager or Role.Architect);

    // Mirrors DeleteRequestAuthorisation server-side: the Admin role only (master administrators
    // carry every role, so they qualify too).
    private bool IsAdmin => Session.AvailableRoles.Any(role => role is Role.Admin);

    // Returning to triage is a triage action, open to administrators, project managers, and the
    // finance director (admins carry every role server-side, so they always satisfy this too).
    private bool CanTriage => Session.AvailableRoles.Any(role => role is Role.Admin or Role.ProjectManager or Role.FinanceDirector);

    // Editing request field values (date issued, references, status, etc.) is open to project
    // managers and administrators. Admins carry every role server-side, so they always qualify.
    private bool CanEditDetails => Session.AvailableRoles.Any(role => role is Role.Admin or Role.ProjectManager);

    private static readonly RequestStatus[] StatusOptions =
    {
        RequestStatus.Open, RequestStatus.AwaitingResponse, RequestStatus.Responded,
        RequestStatus.Approved, RequestStatus.Rejected, RequestStatus.Closed
    };

    // Close confirm modal: the close date defaults to today but is editable, so a request that
    // actually closed days ago can be recorded against the date it really closed (never a future one).
    private bool confirmingClose;
    private string closeDate = "";
    private string? closeError;

    // One flag per edit modal — header (reference/status/subject), facts strip, Detail panel.
    // The edit* fields below are shared scratch state; each Open* seeds the ones its modal uses,
    // and only one modal is ever open at a time.
    private bool editingHeader;
    private bool editingFacts;
    private bool editingDetail;
    private string editReference = "";
    private string editTitle = "";
    private string editDescription = "";
    private string editIssuedAt = "";
    private string editResponseDue = "";
    private string editClosedAt = "";
    private string editRaisedToContactId = "";
    private string? editLegacyRaisedTo;
    private string editDrawingRef = "";
    private string editRelatedSpec = "";
    private string editValue = "";
    private RequestStatus editStatus = RequestStatus.Open;
    private bool editCriticalPath;
    private string? editError;

    // The project's own contact list (Setup tab → Project contacts) backing the "Raised to"
    // dropdown in the edit modal. On-demand async store, fetched once with the page.
    private IReadOnlyList<ProjectContact> projectContacts = Array.Empty<ProjectContact>();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        await LoadAsync();
        if (CanEditDetails)
        {
            try { clients = await ClientStore.ListAsync(); } catch { clients = Array.Empty<Client>(); }
            try { architects = await ArchitectStore.ListAsync(); } catch { architects = Array.Empty<Architect>(); }
            try
            {
                // Ad-hoc rows only: the contacts added on the Setup tab's Project contacts list
                // (party-linked rows are routing overrides, not list entries).
                projectContacts = (await Correspondence.ListProjectContactsAsync(ProjectId))
                    .Where(row => row.PartyContactId is null)
                    .ToList();
            }
            catch { projectContacts = Array.Empty<ProjectContact>(); }
        }
        await LoadVoqAsync();
        await LoadRecipientPreviewAsync();
        isLoaded = true;
    }

    // The tagged emails offered as reply targets in the email modal, fetched fresh each time the
    // modal opens. Best-effort: the modal just shows its empty state on error.
    private async Task LoadTaggedEmailsAsync()
    {
        if (record is null || !record.Kind.IsEmailable() || !CanDraftEmail)
        {
            taggedEmails = Array.Empty<RequestMessage>();
            return;
        }
        try
        {
            taggedEmailsLoading = true;
            // Any live email leg (MailboxId set) can anchor a reply — including the mailbox's own
            // sent copy, where reply-all correctly re-addresses the original recipients.
            taggedEmails = (await RequestRegister.ListMessagesAsync(record.RequestId))
                .Where(m => !string.IsNullOrEmpty(m.MailboxId))
                .OrderByDescending(m => m.PostedAt)
                .ToList();
        }
        catch
        {
            taggedEmails = Array.Empty<RequestMessage>();
        }
        finally
        {
            taggedEmailsLoading = false;
        }
    }

    // The resolved To/CC/BCC an issue or draft would use right now — same resolver as the send
    // paths, refreshed whenever the linked party changes. Best-effort: the panel just hides on error.
    private async Task LoadRecipientPreviewAsync()
    {
        try { recipientPreview = record is null ? null : await Correspondence.ResolveRequestRecipientsAsync(record.RequestId); }
        catch { recipientPreview = null; }
    }

    private static string RecipientLine(IReadOnlyList<CorrespondenceRecipient> recipients) =>
        string.Join(", ", recipients.Select(r => string.IsNullOrWhiteSpace(r.Name) ? r.Email : $"{r.Name} <{r.Email}>"));

    private async Task LoadVoqAsync()
    {
        if (record?.HasRfq == true)
        {
            try { voq = await Variations.GetByRequestAsync(RequestId); }
            catch { voq = null; }
        }
        else
        {
            voq = null;
        }

        // Downstream of the VOQ, for the lineage bar: the VO it produced (if approved) and its bid
        // packages. Best-effort — the bar simply shows placeholders when these can't be read.
        if (voq is not null)
        {
            try { vo = await Variations.GetVariationOrderByVoqAsync(voq.VariationOrderQuoteId); }
            catch { vo = null; }
            try { bidPackages = await Variations.ListBidPackagesAsync(voq.VariationOrderQuoteId); }
            catch { bidPackages = Array.Empty<BidPackage>(); }
        }
        else
        {
            vo = null;
            bidPackages = Array.Empty<BidPackage>();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (isLoaded) await LoadAsync();
    }

    private async Task LoadAsync()
    {
        record = await RequestRegister.GetAsync(RequestId);
        responseDraft = record?.ResponseText ?? "";
    }

    private void OnResponseDraftInput(ChangeEventArgs e) => responseDraft = e.Value?.ToString() ?? "";

    // ---- Actions dropdown items -----------------------------------------------------------------

    private void OpenResponseModal()
    {
        actionsOpen = false;
        actionError = null;
        responseDraft = record?.ResponseText ?? "";
        respondingOpen = true;
    }

    private void CancelResponseModal()
    {
        if (busy) return;
        respondingOpen = false;
    }

    private async Task SaveResponseFromModal()
    {
        await Apply(RequestStatus.Responded, responseDraft);
        if (actionError is null) respondingOpen = false;
    }

    private async Task ReopenFromMenu()
    {
        actionsOpen = false;
        await ReopenRequest();
    }

    // "Create bid packages": marks the RFI as carrying an RFQ, which unlocks the Variation Order
    // Quote (and its bid packages) in the rail.
    private async Task CreateBidPackagesFromMenu()
    {
        actionsOpen = false;
        await EnableRfq();
    }

    // The close confirm modal: opens with today's date pre-filled so the common case is one click,
    // but the date is editable for closures only recorded after the fact.
    private void OpenCloseConfirm()
    {
        if (record is null || busy) return;
        closeDate = DateTime.Today.ToString("yyyy-MM-dd");
        closeError = null;
        confirmingClose = true;
    }

    private void CancelClose() => confirmingClose = false;

    private async Task PerformClose()
    {
        var closedAt = ParseDate(closeDate);
        if (closedAt is null) { closeError = "A close date is required."; return; }
        if (closedAt.Value.Date > DateTime.Today) { closeError = "The closed date cannot be in the future."; return; }
        confirmingClose = false;
        await CloseRequest(closedAt.Value);
    }

    // Closing goes through the agent gate: the request only closes if every applied agent agrees
    // its work is complete. Any drafted response is persisted first so it isn't lost. The stub
    // agents always report incomplete, so a request with an applied agent stays open by design.
    private async Task CloseRequest(DateTimeOffset closedAt)
    {
        if (record is null || busy) return;
        actionError = null;
        blockingAgents = Array.Empty<AgentCompletionState>();

        if (!string.IsNullOrWhiteSpace(responseDraft) && responseDraft.Trim() != (record.ResponseText ?? "").Trim())
            await Apply(RequestStatus.Responded, responseDraft);
        if (record is null) return;

        try
        {
            busy = true;
            var outcome = await Agents.AttemptCloseAsync(record.RequestId, closedAt);
            if (outcome.Closed)
            {
                record = await RequestRegister.GetAsync(RequestId);
                responseDraft = record?.ResponseText ?? "";
            }
            else
            {
                blockingAgents = outcome.BlockingAgents;
            }
        }
        catch
        {
            actionError = "Couldn't close the request. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task ReopenRequest() => await Apply(RequestStatus.Open, record?.ResponseText);

