    // AI-drafted VOQ review: PrepareVoqDraft proposes, the user edits, CreateVoqFromRfq commits.
    private bool voqDraftOpen;
    private bool voqDraftLoading;
    private VoqDraftProposal? voqDraft;
    private string? voqDraftError;
    private string draftVoqTitle = "";
    private string draftVoqDescription = "";
    private string draftVoqValue = "";
    private List<DraftLineRow> draftVoqLines = new();

    private sealed record DraftLineRow(VoqDraftLine Line, bool Accepted, string CostCode = "");

    // The trade for the draft bid package: the first accepted line's, else the model's suggestion.
    private string DraftPackageTrade
    {
        get
        {
            var accepted = draftVoqLines.FirstOrDefault(row => row.Accepted && !string.IsNullOrWhiteSpace(row.Line.Trade));
            if (accepted is not null) return accepted.Line.Trade;
            return string.IsNullOrWhiteSpace(voqDraft?.SuggestedTrade) ? "General" : voqDraft!.SuggestedTrade;
        }
    }

    private async Task OpenVoqDraft()
    {
        if (record is null || busy) return;
        voqError = null;
        voqDraftError = null;
        voqDraft = null;
        voqDraftOpen = true;
        voqDraftLoading = true;
        draftVoqTitle = record.Title;
        draftVoqDescription = record.Description;
        draftVoqValue = "";
        draftVoqLines = new();

        // Cost centres feed the scope lines' cost-code selects — best-effort background refresh.
        try { _ = CostCenters.RefreshAsync(CancellationToken.None); } catch { }

        try
        {
            voqDraft = await Variations.PrepareVoqDraftAsync(record.RequestId);
            draftVoqTitle = voqDraft.Title;
            draftVoqDescription = voqDraft.Description;
            draftVoqValue = voqDraft.EstimatedValue?.ToString("0.##") ?? "";
            draftVoqLines = voqDraft.Lines.Select(line => new DraftLineRow(line, true)).ToList();
        }
        catch
        {
            // A failed draft never blocks raising the VOQ — fall back to the RFI's own details.
            voqDraftError = "Couldn't draft from the tagged emails; starting from the RFI's details instead.";
        }
        finally
        {
            voqDraftLoading = false;
        }
    }

    private void CancelVoqDraft()
    {
        if (busy) return;
        voqDraftOpen = false;
    }

    private async Task ConfirmVoqDraft()
    {
        if (record is null || busy || voqDraftLoading) return;
        voqDraftError = null;

        if (string.IsNullOrWhiteSpace(draftVoqTitle))
        {
            voqDraftError = "A title is required.";
            return;
        }

        decimal? estimatedValue = null;
        if (!string.IsNullOrWhiteSpace(draftVoqValue))
        {
            var raw = draftVoqValue.Replace("£", "").Replace(",", "").Trim();
            if (!decimal.TryParse(raw, out var parsedValue) || parsedValue < 0)
            {
                voqDraftError = "Estimated value must be a number.";
                return;
            }
            estimatedValue = parsedValue;
        }

        // Accepted scope lines become the VOQ's first (draft) bid package — every line put out to
        // tender must know its cost-centre home, so a ticked line without a code blocks the create.
        var acceptedRows = draftVoqLines.Where(row => row.Accepted).ToList();
        if (acceptedRows.Any(row => string.IsNullOrWhiteSpace(row.CostCode)))
        {
            voqDraftError = "Every ticked scope line needs a cost code — pick a cost centre for each, or untick it.";
            return;
        }

        try
        {
            busy = true;
            voq = await Variations.CreateFromRfqAsync(
                record.RequestId, draftVoqTitle.Trim(), draftVoqDescription.Trim(), estimatedValue);

            if (acceptedRows.Count > 0)
            {
                var package = await Variations.AddBidPackageAsync(voq.VariationOrderQuoteId, voq.Title, DraftPackageTrade);
                var inputs = acceptedRows
                    .Select(row => new BidPackageLineItemInput(
                        row.Line.Description, row.Line.Unit, row.Line.Quantity,
                        string.IsNullOrWhiteSpace(row.Line.Trade) ? DraftPackageTrade : row.Line.Trade,
                        row.CostCode.Trim()))
                    .ToList();
                await Commands.SendAsync(new AddBidPackageLineItems(package.BidPackageId, inputs), CancellationToken.None);
            }

            voqDraftOpen = false;
            Nav.NavigateTo($"/projects/{ProjectId}/voq/{voq.VariationOrderQuoteId}");
        }
        catch
        {
            voqDraftError = voq is null
                ? "Couldn't create the VOQ. Please try again."
                : "The VOQ was created, but adding the scope lines failed. Open it from the panel to add them manually.";
        }
        finally
        {
            busy = false;
        }
    }

    private async Task OnPartyChanged(ChangeEventArgs e)
    {
        if (record is null || busy) return;
        ladderError = null;

        var selection = e.Value?.ToString() ?? "";
        var partyKind = PartyKind.Client;
        string? partyId = null;
        string? onBehalfOfClientId = null;

        if (selection.StartsWith(ArchitectPrefix, StringComparison.Ordinal))
        {
            partyKind = PartyKind.Architect;
            partyId = selection[ArchitectPrefix.Length..];
            // Keep the recorded on-behalf-of client when switching between architects.
            onBehalfOfClientId = record.OnBehalfOfClientId;
        }
        else if (selection.StartsWith(ClientPrefix, StringComparison.Ordinal))
        {
            partyId = selection[ClientPrefix.Length..];
        }

        try
        {
            busy = true;
            record = await RequestRegister.LinkToPartyAsync(record.RequestId, partyKind, partyId, onBehalfOfClientId, ProjectId);
            await LoadRecipientPreviewAsync();
        }
        catch
        {
            ladderError = "Couldn't update the linked party. Please try again.";
        }
        finally
        {
            busy = false;
        }
    }

