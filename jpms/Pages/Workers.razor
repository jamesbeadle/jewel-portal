@page "/labour/workers"
@inject AuthService Auth
@inject SessionService Session
@inject ILabourStore Labour
@inject ISubcontractorStore Subcontractors
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Workers · JPMS</PageTitle>

@*
    The worker registry (docs/Labour-Time-Tracking-Scope.md §4): day-rate subcontractor
    operatives and their cost rates, managed by the FD and PM. The hourly rate is the agreed
    day rate ÷ 8; rate changes take effect for future approvals only — approved timesheets
    keep their snapshotted rate. Rates never reach the site capture page.
*@

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="px-6 md:px-8 py-8 max-w-3xl">
        <h2 class="text-lg font-semibold text-content mb-1">Workers</h2>
        <p class="text-sm text-content-subtle mb-5">
            Day-rate site operatives and their cost rates. Each worker logs their own time on the
            My day page: invite them as a user with the Site Operative role, then enter the same
            email here — that links their account to this record. Assign workers to projects from
            each project's Labour tab.
        </p>

        @if (actionError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@actionError</p>
        }

        <div class="panel p-4 mb-6">
            <h3 class="text-sm font-semibold text-content mb-3">@(editingWorkerId is null ? "Add worker" : "Edit worker")</h3>
            <div class="flex flex-wrap items-end gap-3">
                <label class="text-xs text-content-subtle">Name
                    <input class="field mt-1" @bind="formName" placeholder="e.g. Marek Kowalski" />
                </label>
                <label class="text-xs text-content-subtle">Portal email (their user account)
                    <input class="field mt-1 w-56" type="email" @bind="formEmail" placeholder="name@example.com" />
                </label>
                <label class="text-xs text-content-subtle">Day rate £ (÷ 8 = hourly)
                    <input class="field mt-1 w-28" type="number" step="1" min="0" @bind="formDayRate" />
                </label>
                <label class="text-xs text-content-subtle">Subcontractor
                    <select class="field mt-1" @bind="formSubcontractorId">
                        <option value="">— none —</option>
                        @foreach (var subcontractor in Subcontractors.All())
                        {
                            <option value="@subcontractor.SubcontractorId">@subcontractor.CompanyName</option>
                        }
                    </select>
                </label>
                <label class="text-xs text-content-subtle">Phone
                    <input class="field mt-1 w-36" @bind="formPhone" />
                </label>
                @if (editingWorkerId is not null)
                {
                    <label class="text-xs text-content-subtle flex items-center gap-2 pb-1">
                        <input type="checkbox" @bind="formIsActive" /> Active
                    </label>
                }
                <button type="button" class="btn-primary" @onclick="SaveAsync">@(editingWorkerId is null ? "Add" : "Save")</button>
                @if (editingWorkerId is not null)
                {
                    <button type="button" class="btn-secondary" @onclick="ClearForm">Cancel</button>
                }
            </div>
            <p class="text-xs text-content-subtle mt-2">
                Hourly rate stored: £@HourlyRate().ToString("N2")/h. Rate changes apply to future approvals only.
            </p>
        </div>

        @{ var workers = Labour.Workers(); }
        @if (workers.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">No workers yet — add the first one above.</p>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th><th>Portal email</th><th>Subcontractor</th><th class="text-right">Hourly £</th>
                        <th class="text-right">Day £ (8h)</th><th>Status</th><th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var worker in workers)
                    {
                        <tr>
                            <td class="text-content">@worker.Name</td>
                            <td class="text-content-subtle">@(worker.ContactEmail == "" ? "— not linked —" : worker.ContactEmail)</td>
                            <td>@SubcontractorName(worker.SubcontractorId)</td>
                            <td class="text-right">@worker.HourlyRate.ToString("N2")</td>
                            <td class="text-right">@((worker.HourlyRate * 8m).ToString("N2"))</td>
                            <td>
                                @if (worker.IsActive) { <span class="text-positive">Active</span> }
                                else { <span class="text-content-subtle">Inactive</span> }
                            </td>
                            <td class="text-right">
                                <button type="button" class="btn-secondary" @onclick="() => StartEdit(worker)">Edit</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
}

@code {
    private const decimal StandardDayHours = 8m; // scope §4: standard day; per-worker override deferred

    private bool isLoaded;
    private string? actionError;

    private string? editingWorkerId;
    private string formName = "";
    private decimal formDayRate;
    private string formSubcontractorId = "";
    private string formPhone = "";
    private bool formIsActive = true;
    private string formEmail = "";

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        Labour.OnChange += StateHasChanged;
        isLoaded = true;
        _ = Labour.RefreshWorkersAsync();
    }

    public void Dispose() => Labour.OnChange -= StateHasChanged;

    private decimal HourlyRate() => StandardDayHours == 0m ? 0m : Math.Round(formDayRate / StandardDayHours, 2);

    private string SubcontractorName(string? subcontractorId) =>
        subcontractorId is null ? "—"
        : Subcontractors.All().FirstOrDefault(subcontractor => subcontractor.SubcontractorId == subcontractorId)?.CompanyName ?? "—";

    private void StartEdit(Worker worker)
    {
        editingWorkerId = worker.WorkerId;
        formName = worker.Name;
        formDayRate = worker.HourlyRate * StandardDayHours;
        formSubcontractorId = worker.SubcontractorId ?? "";
        formPhone = worker.ContactPhone;
        formEmail = worker.ContactEmail;
        formIsActive = worker.IsActive;
    }

    private void ClearForm()
    {
        editingWorkerId = null;
        formName = "";
        formDayRate = 0m;
        formSubcontractorId = "";
        formPhone = "";
        formEmail = "";
        formIsActive = true;
    }

    private async Task SaveAsync()
    {
        actionError = null;
        if (string.IsNullOrWhiteSpace(formName) || formDayRate <= 0m)
        {
            actionError = "A name and a day rate above zero are required.";
            return;
        }
        var subcontractorId = formSubcontractorId == "" ? null : formSubcontractorId;
        try
        {
            if (editingWorkerId is null)
                await Labour.AddWorkerAsync(formName, HourlyRate(), subcontractorId, formEmail, formPhone);
            else
                await Labour.UpdateWorkerAsync(new Worker(editingWorkerId, formName, subcontractorId, HourlyRate(), formIsActive, formEmail, formPhone));
            ClearForm();
        }
        catch (Exception) { actionError = "Could not save the worker — try again."; }
    }
}
