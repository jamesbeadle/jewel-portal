@page "/projects/{ProjectId}"
@inject NavigationManager Nav

@*
    The bare project URL has no tab of its own any more — the old Overview tab was retired (its
    to-do list moved to the To-do tab, correspondence and details to Setup). Financials is the
    project landing tab, so redirect there; replace:true keeps Back working naturally.
*@

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    protected override void OnInitialized() =>
        Nav.NavigateTo($"/projects/{ProjectId}/financials", replace: true);
}
