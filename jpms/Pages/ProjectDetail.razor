@page "/projects/{ProjectId}"
@using Jewel.JPMS.Services.Navigation
@inject NavigationManager Nav

@*
    The bare project URL has no page of its own — the Overview landing was retired (Home is the
    landing; the sidebar's workspace blocks are the map). Redirect to the workspace's first page;
    replace:true keeps Back working naturally.
*@

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    protected override void OnInitialized() =>
        Nav.NavigateTo(ProjectSections.FirstTabHref(ProjectId, ProjectSections.All[0]), replace: true);
}
