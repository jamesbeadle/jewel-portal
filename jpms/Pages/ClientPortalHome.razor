@page "/portal/client"
@layout PortalLayout
@inject PortalContext PortalContext
@inject IProjectStore ProjectStore
@implements IDisposable

<PageTitle>Client portal · JPMS</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">

    <ClientActAsPicker />

    @if (Project is null)
    {
        <p class="text-sm text-slate-500 italic">Choose your project above to continue.</p>
    }
    else
    {
        <header class="mb-6">
            <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1">@Project.Reference</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900">@Project.Name</h1>
            <p class="text-sm text-slate-600 mt-2">@Project.ClientName · <ProjectStageBadge Stage="Project.Stage" /></p>
        </header>

        <nav class="rounded-xl border border-slate-200 bg-white divide-y divide-slate-200">
            <PortalNavLink Href="@($"/portal/client/project/{Project.ProjectId}/dashboard")"  Label="Progress dashboard"      Detail="What's happening on your build" />
            <PortalNavLink Href="@($"/portal/client/project/{Project.ProjectId}/variations")"  Label="Variation approvals"     Detail="Cost-impacting changes for your approval" />
            <PortalNavLink Href="@($"/portal/client/project/{Project.ProjectId}/valuations")"  Label="Valuation reports"       Detail="Programme Valuation Report per period" />
            <PortalNavLink Href="@($"/portal/client/project/{Project.ProjectId}/defects")"     Label="Defects"                 Detail="Raise or track defects during defects period" />
        </nav>
    }
</section>

@code {
    private Project? Project =>
        string.IsNullOrEmpty(PortalContext.ActingClientProjectId)
            ? null
            : ProjectStore.Find(PortalContext.ActingClientProjectId);

    protected override void OnInitialized() => PortalContext.OnChange += StateHasChanged;
    public void Dispose() => PortalContext.OnChange -= StateHasChanged;
}
