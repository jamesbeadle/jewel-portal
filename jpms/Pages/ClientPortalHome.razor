@page "/portal/client"
@layout PortalLayout
@using Jewel.JPMS.Features.Projects
@inject PortalContext PortalContext
@inject ProjectListReadModel Projects
@implements IDisposable

<PageTitle>Client portal · JPMS</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">

    <ClientActAsPicker />

    @if (Project is null)
    {
        <p class="text-sm text-content-subtle italic">Choose your project above to continue.</p>
    }
    else
    {
        <header class="mb-6">
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">@Project.Reference</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-content">@Project.Name</h1>
            <p class="text-sm text-content-muted mt-2">@Project.ClientName · <ProjectStageBadge Stage="Project.Stage" /></p>
        </header>

        <nav class="rounded-xl border border-line bg-surface divide-y divide-line">
            <PortalNavLink Href="@($"/portal/client/project/{Project.ProjectId}/dashboard")"  Label="Progress dashboard"      Detail="What's happening on your build" />
            <PortalNavLink Href="@($"/portal/client/project/{Project.ProjectId}/variations")"  Label="Variation approvals"     Detail="Cost-impacting changes for your approval" />
            <PortalNavLink Href="@($"/portal/client/project/{Project.ProjectId}/valuations")"  Label="Valuation reports"       Detail="Programme Valuation Report per period" />
            <PortalNavLink Href="@($"/portal/client/project/{Project.ProjectId}/defects")"     Label="Defects"                 Detail="Raise or track defects during defects period" />
        </nav>
    }
</section>

@code {
    private Project? Project =>
        string.IsNullOrEmpty(PortalContext.ActingClientProjectId)
            ? null
            : Projects.Find(PortalContext.ActingClientProjectId);

    protected override async Task OnInitializedAsync()
    {
        PortalContext.OnChange += StateHasChanged;
        Projects.OnChanged += StateHasChanged;
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
    }

    public void Dispose()
    {
        PortalContext.OnChange -= StateHasChanged;
        Projects.OnChanged -= StateHasChanged;
    }
}
