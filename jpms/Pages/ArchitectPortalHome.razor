@page "/portal/architect"
@layout PortalLayout
@using Jewel.JPMS.Features.Projects
@inject PortalContext PortalContext
@inject IRequestRegister RequestRegister
@inject ProjectListReadModel Projects
@implements IDisposable

<PageTitle>Architect portal · JPMS</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">

    <ArchitectActAsPicker />

    @if (string.IsNullOrEmpty(PortalContext.ActingArchitectEmail))
    {
        <p class="text-sm text-content-subtle italic">Choose an architect above to continue.</p>
    }
    else
    {
        <header class="mb-6">
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">Welcome</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-content">@PortalContext.ActingArchitectEmail</h1>
            <p class="text-sm text-content-muted mt-2">Open RFIs, submittals and variations awaiting your input.</p>
        </header>

        <div class="grid grid-cols-3 gap-3 md:gap-4 mb-6">
            <Stat Label="Open RFIs"      Value="@OpenRfis.ToString()" />
            <Stat Label="Submittals"     Value="@OpenSubmittals.ToString()" />
            <Stat Label="Variations"     Value="@OpenVariations.ToString()" />
        </div>

        <nav class="rounded-xl border border-line bg-surface divide-y divide-line">
            <PortalNavLink Href="/portal/architect/rfis"        Label="Open RFIs"        Detail="Reply with attached drawings or clarifications" />
            <PortalNavLink Href="/portal/architect/submittals"  Label="Submittals"       Detail="Approve or reject material/sample submittals" />
            <PortalNavLink Href="/portal/architect/variations"  Label="Variation orders" Detail="Approve cost-impacting changes" />
        </nav>
    }
</section>

@code {
    private IReadOnlyList<Project> AllProjects => Projects.Current ?? Array.Empty<Project>();
    private int OpenRfis =>
        AllProjects.Sum(p => RequestRegister.ForProject(p.ProjectId, RequestType.Rfi).Count(c => c.Status != RequestStatus.Closed));
    private int OpenSubmittals =>
        AllProjects.Sum(p => RequestRegister.ForProject(p.ProjectId, RequestType.Rfa).Count(c => c.Status != RequestStatus.Closed));
    private int OpenVariations =>
        AllProjects.Sum(p => RequestRegister.ForProject(p.ProjectId, RequestType.Rfc).Count(c => c.Status != RequestStatus.Closed));

    protected override async Task OnInitializedAsync()
    {
        PortalContext.OnChange += StateHasChanged;
        Projects.OnChanged += StateHasChanged;
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
    }

    public void Dispose()
    {
        PortalContext.OnChange -= StateHasChanged;
        Projects.OnChanged -= StateHasChanged;
    }
}
