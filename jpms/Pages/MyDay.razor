@page "/my-day"
@inject NavigationManager Nav

@*
    The standalone My day page is retired — the worker's day now renders on the Dashboard
    (RoleHome → MyDayWorkspace) for site-floor roles. Old links and bookmarks land here and are
    redirected; replace:true keeps Back working naturally.
*@

@code {
    protected override void OnInitialized() =>
        Nav.NavigateTo("/dashboard", replace: true);
}
