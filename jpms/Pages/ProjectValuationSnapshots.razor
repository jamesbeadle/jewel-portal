@page "/projects/{ProjectId}/valuation-snapshots"
@inject AuthService Auth
@inject SessionService Session
@inject IValuationReportStore Store
@inject IValuationInvoiceStore Invoices
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Valuation Snapshots · JPMS</PageTitle>

@*
    The read-only register of the project's frozen valuation report snapshots — the client-facing
    statements (decision 2026-07-22: the live Valuation Report tab is internal; ONLY snapshots are
    ever client-facing). One is frozen automatically when a valuation invoice is raised, and again
    on submit/issue after an amendment; on-demand period-end captures appear here too. Superseded
    rows (the invoice was amended after the freeze) stay on the register muted — the trail of what
    was asked is part of the record. Managing snapshots (take/delete) stays on the Valuation
    Report tab; this page only reads.
*@

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="valuation-snapshots">
        <div class="mb-4">
            <h2 class="text-lg font-semibold text-content">Valuation Snapshots</h2>
            <p class="text-sm text-content-muted mt-1">
                The frozen valuation report behind each valuation invoice — the as-at-a-point-in-time
                statements. The live Valuation Report tab is internal; these snapshots are the only
                client-facing form of the report.
            </p>
        </div>

        @if (Snapshots.Count == 0)
        {
            <div class="panel p-8 text-center">
                <p class="text-sm text-content">No snapshots yet.</p>
                <p class="text-xs text-content-subtle mt-1">
                    One is frozen automatically when a valuation invoice is raised; period-end
                    captures can be taken on the Valuation Report tab.
                </p>
            </div>
        }
        else
        {
            <div class="rounded-xl border border-line bg-surface overflow-x-auto overflow-y-auto max-h-[85vh]">
                <table class="w-full text-sm border-collapse">
                    <thead class="bg-surface-raised border-b border-line">
                        <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 whitespace-nowrap">Captured</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 min-w-[200px]">Snapshot</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 whitespace-nowrap">Valuation invoice</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">Works complete £</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">Certified £</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 text-right whitespace-nowrap">Payment due £</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-line">
                        @foreach (var snapshot in Snapshots)
                        {
                            <tr class="hover:bg-surface-raised cursor-pointer transition @(snapshot.IsSuperseded ? "opacity-60" : "")"
                                title="View the frozen report"
                                @onclick="() => viewingSnapshotId = snapshot.ValuationReportSnapshotId">
                                <td class="px-4 py-3 text-content-muted whitespace-nowrap">@snapshot.TakenAt.ToString("dd MMM yyyy HH:mm")</td>
                                <td class="px-4 py-3 text-content">
                                    @snapshot.Label
                                    @if (snapshot.IsSuperseded)
                                    {
                                        <span class="ml-1.5 inline-flex items-center rounded-full border border-line px-1.5 py-0.5 text-[10px] text-content-subtle"
                                              title="A later snapshot replaced this one (the invoice was amended)">Superseded</span>
                                    }
                                </td>
                                <td class="px-4 py-3 whitespace-nowrap">
                                    @* No invoice detail page exists — the reference reads as plain
                                       text; invoices are managed on the Valuation Report tab. *@
                                    @if (InvoiceFor(snapshot) is { } invoice)
                                    {
                                        <span class="font-mono text-xs text-content">@invoice.Reference</span>
                                        <span class="block text-xs text-content-subtle">@invoice.Status · @invoice.PeriodMonth.ToString("MMM yyyy")</span>
                                    }
                                    else if (snapshot.ValuationInvoiceId is not null)
                                    {
                                        <span class="text-xs text-content-subtle">Invoice deleted</span>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-content-subtle italic">Period-end capture</span>
                                    }
                                </td>
                                <td class="px-4 py-3 text-right text-content-muted whitespace-nowrap">@Money(snapshot.TotalWorksComplete)</td>
                                <td class="px-4 py-3 text-right text-content-muted whitespace-nowrap">@Money(snapshot.CertifiedToDate)</td>
                                <td class="px-4 py-3 text-right text-content whitespace-nowrap">@Money(snapshot.PaymentDueExVat)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <Modal IsOpen="@(viewingSnapshotId is not null)"
               Title="Valuation report snapshot"
               ShowFooter="false" Class="max-w-6xl" OnCancel="@(() => viewingSnapshotId = null)">
            @if (viewingSnapshotId is not null)
            {
                <ValuationSnapshotViewer SnapshotId="@viewingSnapshotId" />
            }
        </Modal>
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;
    private string? viewingSnapshotId;

    // Invoice references for the register's invoice column, keyed once per load. A failed fetch
    // leaves the map empty — rows fall back to their label, never blocking the register itself.
    private IReadOnlyList<ValuationInvoice> invoices = Array.Empty<ValuationInvoice>();

    private static readonly System.Globalization.CultureInfo Gb = System.Globalization.CultureInfo.GetCultureInfo("en-GB");
    private static string Money(decimal value) => value.ToString("C2", Gb);

    private IReadOnlyList<ValuationReportSnapshot> Snapshots => Store.SnapshotsFor(ProjectId);

    private ValuationInvoice? InvoiceFor(ValuationReportSnapshot snapshot) =>
        snapshot.ValuationInvoiceId is null
            ? null
            : invoices.FirstOrDefault(invoice => invoice.ValuationInvoiceId == snapshot.ValuationInvoiceId);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        Store.OnChange += OnStoreChanged;
        // Refresh on entry per the store convention: cached headers render immediately, the
        // background reload revalidates them (stale-while-revalidate).
        Store.Refresh(ProjectId);
        try { invoices = await Invoices.ListAsync(ProjectId); } catch { }
        isLoaded = true;
    }

    private void OnStoreChanged() => StateHasChanged();

    public void Dispose() => Store.OnChange -= OnStoreChanged;
}
