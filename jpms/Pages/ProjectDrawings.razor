@page "/projects/{ProjectId}/drawings"
@inject AuthService Auth
@inject SessionService Session
@inject IDrawingStore DrawingStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Drawings · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="drawings">
        <div class="flex flex-wrap items-end justify-between gap-3 mb-5">
            <div>
                <h2 class="text-lg font-semibold text-content">Drawing register</h2>
                <p class="text-sm text-content-muted">
                    @Drawings.Count drawings
                    @if (Ambiguous.Count > 0)
                    {
                        <span class="ml-2 inline-flex items-center rounded-full bg-amber-50 border border-amber-200 px-1.5 py-0.5 text-[10px] font-medium text-amber-800">
                            @Ambiguous.Count ambiguous
                        </span>
                    }
                </p>
            </div>
            <div class="flex items-center gap-2">
                <ExportToExcelButton FileName="Drawing register"
                                     Disabled="@(Drawings.Count == 0)"
                                     ShowIncludeAllRows="@approvedOnly"
                                     IncludeAllLabel="Include unapproved"
                                     BuildWorkbook="BuildExportWorkbook" />
                <button type="button" @onclick="() => approvedOnly = !approvedOnly"
                        class="rounded-lg border text-sm px-3 py-2 transition @(approvedOnly ? "bg-emerald-50 border-emerald-200 text-emerald-800" : "border-line-strong text-content-muted hover:bg-surface-raised")">
                    @(approvedOnly ? "Showing approved" : "All drawings")
                </button>
                @if (CanManage)
                {
                    <button type="button" @onclick="() => isUploading = !isUploading"
                            class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-3 py-2 hover:bg-accent-hover transition">
                        @(isUploading ? "Cancel" : "+ Upload drawing")
                    </button>
                }
            </div>
        </div>

        @if (isUploading)
        {
            <div class="mb-5">
                <DrawingUploadForm ProjectId="@ProjectId" OnUploaded="() => isUploading = false" />
            </div>
        }

        @if (VisibleDrawings.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">
                @(approvedOnly ? "No approved drawings yet." : "No drawings uploaded yet.")
            </p>
        }
        else
        {
            <DrawingsTable Drawings="VisibleDrawings" />
        }
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;
    private bool isUploading;
    private bool approvedOnly;

    private IReadOnlyList<Drawing> Drawings => DrawingStore.DrawingsFor(ProjectId);
    private IReadOnlyList<DrawingRevision> Ambiguous => DrawingStore.AmbiguousFor(ProjectId);

    private IReadOnlyList<Drawing> VisibleDrawings =>
        approvedOnly
            ? Drawings.Where(drawing => !string.IsNullOrEmpty(drawing.CurrentApprovedRevisionLabel)).ToList()
            : Drawings;

    private bool CanManage =>
        Auth.CurrentRoles.Any(role => role is Role.Admin or Role.ManagingDirector or Role.ProjectManager);

    private ExcelWorkbook? BuildExportWorkbook(bool includeUnapproved)
    {
        // "Include unapproved" (offered while the approved-only toggle is on) exports the whole
        // register — the Status column separates approved from pending.
        var drawings = includeUnapproved ? Drawings : VisibleDrawings;
        if (drawings.Count == 0) return null;

        var workbook = new ExcelWorkbook();
        var sheet = workbook.AddSheet("Drawings",
            new ExcelColumn("Code"),
            new ExcelColumn("Title"),
            new ExcelColumn("Latest approved"),
            new ExcelColumn("Status"),
            new ExcelColumn("Pipeline"),
            new ExcelColumn("Added", ExcelFormat.Date));

        foreach (var drawing in drawings)
        {
            sheet.AddRow(
                drawing.DrawingCode,
                drawing.Title,
                LatestApprovedText(drawing),
                StatusText(drawing),
                PipelineText(drawing),
                drawing.CreatedAt.LocalDateTime);
        }
        return workbook;
    }

    // Mirrors DrawingsTable's "Latest approved" cell (the em-dash there becomes a blank export cell).
    private static string? LatestApprovedText(Drawing drawing) =>
        string.IsNullOrEmpty(drawing.CurrentApprovedRevisionLabel) ? null : $"Rev {drawing.CurrentApprovedRevisionLabel}";

    // Mirrors DrawingsTable's Status badges: pending/archived counts, or "Approved" when neither
    // applies and a current approval exists — blank when none of those hold.
    private static string? StatusText(Drawing drawing)
    {
        var parts = new List<string>();
        if (drawing.UnapprovedCount > 0) parts.Add($"{drawing.UnapprovedCount} pending");
        if (drawing.ArchivedCount > 0) parts.Add($"{drawing.ArchivedCount} archived");
        if (drawing.UnapprovedCount == 0 && drawing.ArchivedCount == 0 && !string.IsNullOrEmpty(drawing.CurrentApprovedRevisionLabel))
            parts.Add("Approved");
        return parts.Count == 0 ? null : string.Join(" · ", parts);
    }

    // Mirrors DrawingsTable's Pipeline badges: metadata-extraction and change-analysis status of
    // the latest revision.
    private static string PipelineText(Drawing drawing) =>
        $"{(drawing.LatestMetadataExtractedAt is not null ? "Metadata ✓" : "Not extracted")} · "
        + $"{(drawing.LatestAnalysedAt is not null ? "Analysed ✓" : "Not analysed")}";

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        DrawingStore.OnChange += StateHasChanged;
        // Refresh on entry: cached drawings render immediately, then update when the
        // background reload lands — so navigating back to this tab never shows stale data.
        DrawingStore.Refresh(ProjectId);
        isLoaded = true;
    }

    public void Dispose() => DrawingStore.OnChange -= StateHasChanged;
}
