@page "/projects"
@inject AuthService Auth
@inject SessionService Session
@inject IProjectStore ProjectStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Projects · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">
        Loading projects…
    </section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <header class="mb-6 md:mb-8 flex items-end justify-between gap-4">
            <div>
                <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1">JPMS · Projects</p>
                <h1 class="text-2xl md:text-3xl font-semibold text-slate-900 leading-tight">Project portfolio</h1>
                <p class="text-sm text-slate-600 mt-2">@ActiveProjects.Count active. New projects are created from a won lead.</p>
            </div>
        </header>

        <ProjectsTable Projects="ActiveProjects" />
    </section>
}

@code {
    private bool isLoaded;

    private IReadOnlyList<Project> ActiveProjects => ProjectStore.All();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }
        ProjectStore.OnChange += StateHasChanged;
        Session.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose()
    {
        ProjectStore.OnChange -= StateHasChanged;
        Session.OnChange -= StateHasChanged;
    }
}
