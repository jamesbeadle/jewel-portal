@page "/projects/{ProjectId}/cash-calls"
@using Jewel.JPMS.Contracts.CashCalls
@inject AuthService Auth
@inject SessionService Session
@inject ICashCallStore CashCalls
@inject NavigationManager Nav

<PageTitle>Cash Calls · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="cash-calls">
        <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
            <div>
                <h2 class="text-lg font-semibold text-content">Cash calls</h2>
                <p class="text-sm text-content-subtle mt-0.5">Monthly demands for funds and what has been received.</p>
            </div>
            @if (CanManage)
            {
                <button type="button" class="btn-primary" @onclick="() => creating = true">New cash call</button>
            }
        </div>

        @if (error is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4">@error</p>
        }

        @if (summary is not null)
        {
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
                <div class="panel p-4"><p class="eyebrow mb-1">Called up</p><p class="text-xl font-semibold text-content">@Money(summary.TotalRequested)</p></div>
                <div class="panel p-4"><p class="eyebrow mb-1">Received</p><p class="text-xl font-semibold text-content">@Money(summary.TotalReceived)</p></div>
                <div class="panel p-4"><p class="eyebrow mb-1">Outstanding</p><p class="text-xl font-semibold text-content">@Money(summary.Outstanding)</p></div>
            </div>
        }

        @if (creating)
        {
            <div class="panel p-5 mb-6 space-y-3">
                <h3 class="eyebrow">New cash call</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                    <FormField Label="Period month" Value="@newMonth" OnChange="v => newMonth = v" InputType="month" />
                    <FormField Label="Amount to call up (£)" Value="@newAmount" OnChange="v => newAmount = v" InputType="number" />
                </div>
                <div class="flex gap-2">
                    <button type="button" class="btn-primary" disabled="@busy" @onclick="Create">Raise cash call</button>
                    <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => creating = false">Cancel</button>
                </div>
            </div>
        }

        @if (calls.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">No cash calls raised yet.</p>
        }
        else
        {
            <div class="panel overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="text-left text-content-subtle border-b border-line">
                            <th class="px-4 py-3 font-medium">Ref</th>
                            <th class="px-4 py-3 font-medium">Period</th>
                            <th class="px-4 py-3 font-medium">Called up</th>
                            <th class="px-4 py-3 font-medium">Received</th>
                            <th class="px-4 py-3 font-medium">Status</th>
                            <th class="px-4 py-3"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var call in calls)
                        {
                            <tr class="border-b border-line last:border-0">
                                <td class="px-4 py-3 font-mono">@call.DisplayNumber</td>
                                <td class="px-4 py-3 text-content-muted">@call.PeriodMonth.ToString("MMM yyyy")</td>
                                <td class="px-4 py-3">@Money(call.AmountRequested)</td>
                                <td class="px-4 py-3">@(call.AmountReceived > 0 ? Money(call.AmountReceived) : "—")</td>
                                <td class="px-4 py-3">@StatusLabel(call.Status)</td>
                                <td class="px-4 py-3 text-right">
                                    @if (CanManage && call.Status == CashCallStatus.Requested)
                                    {
                                        <button type="button" class="text-sm font-medium text-content-muted hover:text-content" disabled="@busy" @onclick="() => Invoice(call)">Mark invoiced</button>
                                    }
                                    else if (CanManage && call.Status == CashCallStatus.Invoiced)
                                    {
                                        <button type="button" class="text-sm font-medium text-content-muted hover:text-content" disabled="@busy" @onclick="() => OpenReceipt(call)">Record receipt</button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </ProjectPageShell>

    <Modal IsOpen="receiptCall is not null"
           Title="Record client payment"
           ConfirmLabel="@(busy ? "Saving…" : "Record receipt")"
           OnCancel="() => receiptCall = null"
           OnConfirm="RecordReceipt"
           Class="max-w-md">
        <div class="space-y-3">
            @if (receiptCall is not null)
            {
                <p class="text-sm text-content">Payment received against <span class="font-mono">@receiptCall.DisplayNumber</span> (called up @Money(receiptCall.AmountRequested)).</p>
            }
            <FormField Label="Amount received (£)" Value="@receiptAmount" OnChange="v => receiptAmount = v" InputType="number" />
        </div>
    </Modal>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;
    private bool busy;
    private string? error;
    private IReadOnlyList<CashCall> calls = Array.Empty<CashCall>();
    private ProjectCashCallSummary? summary;

    private bool creating;
    private string newMonth = "";
    private string newAmount = "";

    private CashCall? receiptCall;
    private string receiptAmount = "";

    private bool CanManage => Session.AvailableRoles.Any(role =>
        role is Role.Admin or Role.ManagingDirector or Role.FinanceDirector or Role.ProjectManager);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        newMonth = DateTimeOffset.UtcNow.ToString("yyyy-MM");
        await ReloadAsync();
        isLoaded = true;
    }

    private async Task ReloadAsync()
    {
        try
        {
            calls = await CashCalls.ListAsync(ProjectId);
            summary = await CashCalls.GetSummaryAsync(ProjectId);
            error = null;
        }
        catch { error = "Couldn't load cash calls. Please try again."; }
    }

    private async Task Create()
    {
        if (busy) return;
        error = null;
        if (!decimal.TryParse(newAmount, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var amount) || amount <= 0)
        { error = "Enter an amount greater than zero."; return; }
        var month = ParseMonth(newMonth);
        try
        {
            busy = true;
            await CashCalls.CreateAsync(ProjectId, month, amount, null);
            creating = false;
            newAmount = "";
            await ReloadAsync();
        }
        catch { error = "Couldn't raise the cash call. Please try again."; }
        finally { busy = false; }
    }

    private async Task Invoice(CashCall call)
    {
        if (busy) return;
        error = null;
        try { busy = true; await CashCalls.IssueInvoiceAsync(call.CashCallId); await ReloadAsync(); }
        catch { error = "Couldn't mark the invoice as prepared. Please try again."; }
        finally { busy = false; }
    }

    private void OpenReceipt(CashCall call)
    {
        receiptCall = call;
        receiptAmount = call.AmountRequested.ToString(System.Globalization.CultureInfo.InvariantCulture);
    }

    private async Task RecordReceipt()
    {
        if (busy || receiptCall is null) return;
        error = null;
        if (!decimal.TryParse(receiptAmount, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var amount) || amount <= 0)
        { error = "Enter an amount greater than zero."; return; }
        try
        {
            busy = true;
            await CashCalls.RecordReceiptAsync(receiptCall.CashCallId, amount);
            receiptCall = null;
            await ReloadAsync();
        }
        catch { error = "Couldn't record the receipt. Please try again."; }
        finally { busy = false; }
    }

    private static DateTimeOffset ParseMonth(string value) =>
        DateTimeOffset.TryParse(string.IsNullOrWhiteSpace(value) ? "" : value + "-01", out var parsed)
            ? parsed
            : DateTimeOffset.UtcNow;

    private static string StatusLabel(CashCallStatus status) => status switch
    {
        CashCallStatus.Requested => "Requested",
        CashCallStatus.Invoiced  => "Invoiced",
        CashCallStatus.Received  => "Received",
        _ => status.ToString()
    };

    private static string Money(decimal value) => value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
