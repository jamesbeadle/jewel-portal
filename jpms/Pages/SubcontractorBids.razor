@page "/portal/subcontractor/bids"
@layout PortalLayout
@inject PortalContext PortalContext
@inject ISubcontractorStore SubcontractorStore
@inject IProcurementStore ProcurementStore
@inject IProjectStore ProjectStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Bid invitations · JPMS</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <nav class="mb-4 text-sm">
        <a href="/portal/subcontractor" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Portal home</a>
        <span class="text-slate-400 mx-2">/</span>
        <span class="text-slate-700 font-medium">Bid invitations</span>
    </nav>

    @if (Subcontractor is null)
    {
        <p class="text-sm text-slate-500 italic">Return to <a href="/portal/subcontractor" class="underline">portal home</a> to select a subcontractor.</p>
    }
    else
    {
        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900">Bid invitations</h1>
            <p class="text-sm text-slate-600 mt-1">@Subcontractor.CompanyName</p>
        </header>

        @if (RelevantPackages.Count == 0)
        {
            <p class="text-sm text-slate-500 italic">No bid invitations for your trade right now.</p>
        }
        else
        {
            <div class="rounded-xl border border-slate-200 bg-white divide-y divide-slate-200">
                @foreach (var package in RelevantPackages)
                {
                    <a href="@($"/portal/subcontractor/bids/{package.BidPackageId}")"
                       class="block p-4 hover:bg-slate-50 transition">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="text-sm font-medium text-slate-900">@package.Title</p>
                                <p class="text-xs text-slate-500 mt-1">
                                    @(ProjectStore.Find(package.ProjectId)?.Name ?? package.ProjectId) · @package.Trade
                                </p>
                            </div>
                            <span class="text-[11px] font-medium text-slate-500">@package.Status</span>
                        </div>
                    </a>
                }
            </div>
        }
    }
</section>

@code {
    private Subcontractor? Subcontractor =>
        string.IsNullOrEmpty(PortalContext.ActingSubcontractorId)
            ? null
            : SubcontractorStore.Find(PortalContext.ActingSubcontractorId);

    private IReadOnlyList<BidPackage> RelevantPackages
    {
        get
        {
            if (Subcontractor is null) return Array.Empty<BidPackage>();
            return ProjectStore.All()
                .SelectMany(project => ProcurementStore.PackagesFor(project.ProjectId))
                .Where(package => package.Status is BidPackageStatus.Inviting or BidPackageStatus.QuotesReceived)
                .Where(package => string.Equals(package.Trade, Subcontractor.PrimaryTrade, StringComparison.OrdinalIgnoreCase))
                .ToList()
                .AsReadOnly();
        }
    }

    protected override void OnInitialized() => PortalContext.OnChange += StateHasChanged;
    public void Dispose() => PortalContext.OnChange -= StateHasChanged;
}
