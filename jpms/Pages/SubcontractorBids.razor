@page "/portal/subcontractor/bids"
@layout PortalLayout
@using Jewel.JPMS.Features.Projects
@inject PortalContext PortalContext
@inject ISubcontractorStore SubcontractorStore
@inject IProcurementStore ProcurementStore
@inject ProjectListReadModel Projects
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Bid invitations · JPMS</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <nav class="mb-4 text-sm">
        <a href="/portal/subcontractor" class="text-content-subtle hover:text-content underline underline-offset-4">Portal home</a>
        <span class="text-content-subtle mx-2">/</span>
        <span class="text-content-muted font-medium">Bid invitations</span>
    </nav>

    @if (Subcontractor is null)
    {
        <p class="text-sm text-content-subtle italic">Return to <a href="/portal/subcontractor" class="underline">portal home</a> to select a subcontractor.</p>
    }
    else
    {
        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-content">Bid invitations</h1>
            <p class="text-sm text-content-muted mt-1">@Subcontractor.CompanyName</p>
        </header>

        @if (RelevantPackages.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">No bid invitations for your trade right now.</p>
        }
        else
        {
            <div class="rounded-xl border border-line bg-surface divide-y divide-line">
                @foreach (var package in RelevantPackages)
                {
                    <a href="@($"/portal/subcontractor/bids/{package.BidPackageId}")"
                       class="block p-4 hover:bg-surface-raised transition">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <p class="text-sm font-medium text-content">@package.Title</p>
                                <p class="text-xs text-content-subtle mt-1">
                                    @(Projects.Find(package.ProjectId)?.Name ?? package.ProjectId) · @package.Trade
                                </p>
                            </div>
                            <span class="text-[11px] font-medium text-content-subtle">@package.Status</span>
                        </div>
                    </a>
                }
            </div>
        }
    }
</section>

@code {
    private Subcontractor? Subcontractor =>
        string.IsNullOrEmpty(PortalContext.ActingSubcontractorId)
            ? null
            : SubcontractorStore.Find(PortalContext.ActingSubcontractorId);

    private IReadOnlyList<BidPackage> RelevantPackages
    {
        get
        {
            if (Subcontractor is null) return Array.Empty<BidPackage>();
            return (Projects.Current ?? Array.Empty<Project>())
                .SelectMany(project => ProcurementStore.PackagesFor(project.ProjectId))
                .Where(package => package.Status is BidPackageStatus.Inviting or BidPackageStatus.QuotesReceived)
                .Where(package => string.Equals(package.Trade, Subcontractor.PrimaryTrade, StringComparison.OrdinalIgnoreCase))
                .ToList()
                .AsReadOnly();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        PortalContext.OnChange += StateHasChanged;
        Projects.OnChanged += StateHasChanged;
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
    }

    public void Dispose()
    {
        PortalContext.OnChange -= StateHasChanged;
        Projects.OnChanged -= StateHasChanged;
    }
}
