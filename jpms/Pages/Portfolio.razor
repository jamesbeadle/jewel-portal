@page "/portfolio"
@inject AuthService Auth
@inject SessionService Session
@inject IProjectStore ProjectStore
@inject ICommercialStore CommercialStore
@inject ICvrStore CvrStore
@inject IHsRegister HsRegister
@inject IChangeRegister ChangeRegister
@inject NavigationManager Nav

<PageTitle>Portfolio · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <header class="mb-6 md:mb-8">
            <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1">JPMS · Director / FD</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900 leading-tight">Portfolio</h1>
            <p class="text-sm text-slate-600 mt-2">Cross-project health, commercial trend, and exceptions.</p>
        </header>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-6">
            <Stat Label="Active projects"        Value="@ActiveProjects.ToString()" />
            <Stat Label="Open changes"           Value="@OpenChanges.ToString()" />
            <Stat Label="Open H&S items"         Value="@OpenHs.ToString()" />
            <Stat Label="Cashflow net (13w)"     Value="@Money(CommercialStore.LatestCashflow().NetPosition13Week)" />
        </div>

        <PortfolioMarginTable Projects="ProjectStore.All()" />
    </section>
}

@code {
    private bool isLoaded;

    private int ActiveProjects =>
        ProjectStore.All().Count(p => p.Stage != ProjectStage.Completed);
    private int OpenChanges =>
        ProjectStore.All().Sum(p => ChangeRegister.ForProject(p.ProjectId).Count(c => c.Status != ChangeStatus.Closed));
    private int OpenHs =>
        HsRegister.All().Count(r => r.Status != HsStatus.Closed);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        isLoaded = true;
    }

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
