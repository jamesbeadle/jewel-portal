@page "/portal/architect/rfis"
@layout PortalLayout
@using Jewel.JPMS.Features.Projects
@inject PortalContext PortalContext
@inject IChangeRegister ChangeRegister
@inject ProjectListReadModel Projects
@implements IDisposable

<PageTitle>RFIs · Architect portal</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <nav class="mb-4 text-sm">
        <a href="/portal/architect" class="text-content-subtle hover:text-content underline underline-offset-4">Architect portal</a>
        <span class="text-content-subtle mx-2">/</span>
        <span class="text-content-muted font-medium">RFIs</span>
    </nav>

    <header class="mb-6">
        <h1 class="text-2xl md:text-3xl font-semibold text-content">Open RFIs</h1>
        <p class="text-sm text-content-muted mt-1">Reply directly — your response feeds the change register and onward to programme + valuation.</p>
    </header>

    @if (OpenRfis.Count == 0)
    {
        <p class="text-sm text-content-subtle italic">No open RFIs requiring your response.</p>
    }
    else
    {
        <div class="rounded-xl border border-line bg-surface divide-y divide-line">
            @foreach (var (rfi, project) in OpenRfis)
            {
                <ArchitectRfiCard Rfi="rfi" ProjectName="@project.Name" />
            }
        </div>
    }
</section>

@code {
    private IReadOnlyList<(ChangeRecord Rfi, Project Project)> OpenRfis =>
        (Projects.Current ?? Array.Empty<Project>())
            .SelectMany(project => ChangeRegister.ForProject(project.ProjectId, ChangeKind.Rfi)
                .Where(rfi => rfi.Status != ChangeStatus.Closed)
                .Select(rfi => (rfi, project)))
            .ToList()
            .AsReadOnly();

    protected override async Task OnInitializedAsync()
    {
        ChangeRegister.OnChange += StateHasChanged;
        Projects.OnChanged += StateHasChanged;
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
    }

    public void Dispose()
    {
        ChangeRegister.OnChange -= StateHasChanged;
        Projects.OnChanged -= StateHasChanged;
    }
}
