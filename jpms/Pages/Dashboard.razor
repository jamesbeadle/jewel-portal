@page "/dashboard"
@inject AuthService Auth
@inject IUserDirectory UserDirectory
@inject NavigationManager Nav

<PageTitle>Dashboard · JPMS</PageTitle>

@if (!Auth.IsSignedIn)
{
    @* Bounce back to the login screen — handled in OnInitialized as well. *@
    <section class="max-w-3xl mx-auto px-4 py-12">
        <p class="text-slate-700">You need to <a href="/" class="text-slate-900 underline">sign in</a> to continue.</p>
    </section>
}
else if (directoryUser is null)
{
    @* Signed in, but not on the company's approved list — request access. *@
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (directoryUser.Role.IsAdministrative())
{
    @* Role-routed home: administrators get the admin homepage. *@
    <AdminHome CurrentUser="Auth.CurrentUser!" />
}
else
{
    @* Every other approved role lands on the placeholder home until their
       role-specific homepage is built out. *@
    <PlaceholderHome User="directoryUser" Provider="Auth.CurrentUser!.Provider" />
}

@code {
    private DirectoryUser? directoryUser;

    protected override void OnInitialized()
    {
        if (!Auth.IsSignedIn)
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }
        directoryUser = UserDirectory.Find(Auth.CurrentUser!.Email);
    }
}
