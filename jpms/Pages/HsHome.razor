@page "/hs"
@inject AuthService Auth
@inject SessionService Session
@inject IHsRegister HsRegister
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Health & Safety · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <header class="mb-6 md:mb-8">
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · H&S Officer</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Health & Safety register</h1>
            <p class="text-sm text-content-muted mt-2">Portfolio-wide H&S records, latest first.</p>
        </header>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4 mb-6">
            <Stat Label="Open" Value="@OpenCount" />
            <Stat Label="High severity" Value="@HighSeverityCount" />
            <Stat Label="Open corrective actions" Value="@OpenCorrectiveActions" />
            <Stat Label="Active permits" Value="@OpenPermits" />
        </div>

        <HsRecordTable Records="HsRegister.All()" />
    </section>
}

@code {
    private bool isLoaded;

    private string OpenCount => HsRegister.All().Count(r => r.Status != HsStatus.Closed).ToString();
    private string HighSeverityCount =>
        HsRegister.All().Count(r => r.Severity >= HsSeverity.High && r.Status != HsStatus.Closed).ToString();
    private string OpenCorrectiveActions =>
        HsRegister.All().Count(r => r.Kind == HsRecordKind.CorrectiveAction && r.Status != HsStatus.Closed).ToString();
    private string OpenPermits =>
        HsRegister.All().Count(r => r.Kind == HsRecordKind.Permit && r.Status == HsStatus.Open).ToString();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        HsRegister.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => HsRegister.OnChange -= StateHasChanged;
}
