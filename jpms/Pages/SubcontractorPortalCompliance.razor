@page "/portal/subcontractor/compliance"
@layout PortalLayout
@inject PortalContext PortalContext
@inject ISubcontractorStore SubcontractorStore
@implements IDisposable

<PageTitle>Compliance · JPMS</PageTitle>

<section class="max-w-3xl mx-auto px-4 py-8 md:py-12">
    <nav class="mb-4 text-sm">
        <a href="/portal/subcontractor" class="text-content-subtle hover:text-content underline underline-offset-4">Portal home</a>
        <span class="text-content-subtle mx-2">/</span>
        <span class="text-content-muted font-medium">Compliance</span>
    </nav>

    @if (Subcontractor is null)
    {
        <p class="text-sm text-content-subtle italic">Return to <a href="/portal/subcontractor" class="underline">portal home</a> to select a subcontractor.</p>
    }
    else
    {
        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-content">Compliance status</h1>
            <p class="text-sm text-content-muted mt-1">@Subcontractor.CompanyName</p>
        </header>

        <SubcontractorComplianceList SubcontractorId="@Subcontractor.SubcontractorId" />

        <p class="text-xs text-content-subtle mt-4">
            Need to upload a renewed certificate? Drop it on the Jewel office team —
            the upload form lands here in the next release.
        </p>
    }
</section>

@code {
    private Subcontractor? Subcontractor =>
        string.IsNullOrEmpty(PortalContext.ActingSubcontractorId)
            ? null
            : SubcontractorStore.Find(PortalContext.ActingSubcontractorId);

    protected override void OnInitialized() => PortalContext.OnChange += StateHasChanged;
    public void Dispose() => PortalContext.OnChange -= StateHasChanged;
}
