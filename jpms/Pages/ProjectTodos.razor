@page "/projects/{ProjectId}/todos"
@inject AuthService Auth
@inject SessionService Session
@inject NavigationManager Nav

<PageTitle>To-do · JPMS</PageTitle>

@*
    The project's To-do tab — the to-do list formerly shown on the retired Overview tab, now a
    first-class tab (second in the nav, right after Financials). Items are added here directly or
    captured from an email at triage; the list component itself is unchanged.
*@

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="todos">
        <ProjectTodoList ProjectId="@ProjectId" />
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        isLoaded = true;
    }
}
