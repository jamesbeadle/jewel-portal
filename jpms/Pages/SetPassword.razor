@page "/set-password"
@layout LandingLayout
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Set your password · JPMS</PageTitle>

<div class="min-h-dvh flex flex-col md:flex-row">

    <div class="order-1 md:order-2 w-full md:w-1/2 h-[25vh] md:h-auto bg-surface overflow-hidden">
        <img src="about-team.png" alt="" class="w-full h-full object-cover" />
    </div>

    <div class="order-2 md:order-1 w-full md:w-1/2 flex-1 flex flex-col p-8 md:p-10">

        <div class="flex items-center gap-2.5 shrink-0 justify-center md:justify-start">
            <JewelIcon Class="w-6 h-6 text-content" />
            <span class="font-semibold text-content">Jewel Project Management System</span>
        </div>

        <div class="flex-1 flex flex-col items-center justify-center w-full max-w-sm mx-auto py-10">

            @if (state == PageState.Checking)
            {
                <p class="text-content-muted text-sm">Checking your invite…</p>
            }
            else if (state == PageState.Invalid)
            {
                <h1 class="text-3xl font-semibold text-content leading-tight mb-3 text-center">Link expired</h1>
                <p class="text-base text-content-muted leading-relaxed mb-8 text-center">
                    This invite link is invalid or has expired. Ask a Jewel administrator to send you a new one.
                </p>
                <a href="/" class="text-sm font-medium text-accent hover:text-accent-hover">Back to sign in</a>
            }
            else
            {
                <h1 class="text-3xl font-semibold text-content leading-tight mb-2 text-center">
                    Welcome@(string.IsNullOrWhiteSpace(displayName) ? "" : $", {displayName}")
                </h1>
                <p class="text-base text-content-muted leading-relaxed mb-8 text-center">
                    Choose a password to finish setting up your account.
                </p>

                <form @onsubmit="HandleSubmit" @onsubmit:preventDefault="true" class="w-full space-y-4">
                    <div>
                        <label for="password" class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">New password</label>
                        <input id="password" type="password" autocomplete="new-password"
                               value="@password" @oninput="e => password = e.Value?.ToString() ?? string.Empty"
                               class="w-full rounded-lg border border-line bg-surface-raised px-3 py-2.5 text-sm text-content focus:outline-none focus:ring-2 focus:ring-accent focus:border-line-strong" />
                    </div>
                    <div>
                        <label for="confirm" class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Confirm password</label>
                        <input id="confirm" type="password" autocomplete="new-password"
                               value="@confirm" @oninput="e => confirm = e.Value?.ToString() ?? string.Empty"
                               class="w-full rounded-lg border border-line bg-surface-raised px-3 py-2.5 text-sm text-content focus:outline-none focus:ring-2 focus:ring-accent focus:border-line-strong" />
                    </div>

                    <p class="text-xs text-content-subtle leading-relaxed">
                        At least 12 characters, including an uppercase letter, a lowercase letter and a number.
                    </p>

                    @if (error is not null)
                    {
                        <p class="text-sm text-negative">@error</p>
                    }

                    <button type="submit" disabled="@(busy || !CanSubmit)"
                            class="w-full rounded-lg bg-accent text-accent-ink font-medium px-4 py-2.5 hover:bg-accent-hover disabled:opacity-50 disabled:cursor-not-allowed transition">
                        @(busy ? "Setting password…" : "Set password & sign in")
                    </button>
                </form>
            }

        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private enum PageState { Checking, Valid, Invalid }

    private PageState state = PageState.Checking;
    private string displayName = "";
    private string password = "";
    private string confirm = "";
    private string? error;
    private bool busy;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(password) && !string.IsNullOrWhiteSpace(confirm);

    protected override async Task OnInitializedAsync()
    {
        var validation = await Auth.ValidateInviteAsync(Token ?? "");
        if (validation.Valid)
        {
            displayName = validation.DisplayName ?? "";
            state = PageState.Valid;
        }
        else
        {
            state = PageState.Invalid;
        }
    }

    private async Task HandleSubmit()
    {
        if (!CanSubmit || busy) return;
        error = null;

        if (password != confirm)
        {
            error = "Those passwords don't match.";
            return;
        }
        if (password.Length < 12)
        {
            error = "Use at least 12 characters.";
            return;
        }

        busy = true;
        error = await Auth.SetPasswordAsync(Token ?? "", password);
        busy = false;
        if (error is null) Nav.NavigateTo("/dashboard", replace: true);
    }
}
