@page "/leads/new"
@inject AuthService Auth
@inject SessionService Session
@inject ILeadStore LeadStore
@inject NavigationManager Nav

<PageTitle>New lead · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-2xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-2xl mx-auto px-4 py-8 md:py-12">
        <nav class="mb-6 text-sm">
            <a href="/leads" class="text-content-subtle hover:text-content underline underline-offset-4">Leads</a>
            <span class="text-content-subtle mx-2">/</span>
            <span class="text-content-muted font-medium">New lead</span>
        </nav>

        <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight mb-6">Capture a new lead</h1>

        <NewLeadForm CurrentUserEmail="@Auth.CurrentUser!.Email"
                     OnCreated="HandleCreated" />
    </section>
}

@code {
    private bool isLoaded;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        isLoaded = true;
    }

    private void HandleCreated(Lead lead) => Nav.NavigateTo($"/leads/{lead.LeadId}");
}
