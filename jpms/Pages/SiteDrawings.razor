@page "/site/projects/{ProjectId}/drawings"
@layout SiteLayout
@inject IDrawingStore DrawingStore

<PageTitle>Drawings · JPMS</PageTitle>

<SiteHeader Eyebrow="Reference" Title="Current drawings" BackHref="@($"/site/projects/{ProjectId}")" />

<section class="max-w-md mx-auto px-4 py-6 space-y-3">
    @if (Drawings.Count == 0)
    {
        <p class="text-sm text-content-subtle italic">No drawings on this project yet.</p>
    }
    else
    {
        @foreach (var drawing in Drawings)
        {
            <div class="rounded-2xl border border-line bg-surface p-5">
                <div class="flex items-start justify-between gap-3">
                    <div class="min-w-0">
                        <p class="font-mono text-xs text-content-subtle">@drawing.DrawingCode</p>
                        <p class="text-sm font-semibold text-content mt-1">@drawing.Title</p>
                    </div>
                    <span class="inline-flex items-center justify-center rounded-lg bg-accent text-accent-ink px-3 py-1 text-xs font-mono font-medium shrink-0">
                        Rev @drawing.CurrentRevision
                    </span>
                </div>
            </div>
        }
    }
</section>

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private IReadOnlyList<Drawing> Drawings => DrawingStore.DrawingsFor(ProjectId);
}
