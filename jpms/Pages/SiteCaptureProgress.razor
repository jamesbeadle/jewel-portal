@page "/site/projects/{ProjectId}/capture-progress"
@layout SiteLayout
@inject ISiteStore SiteStore
@inject NavigationManager Nav

<PageTitle>Capture progress · JPMS</PageTitle>

<SiteHeader Eyebrow="Capture" Title="Progress per section" BackHref="@($"/site/projects/{ProjectId}")" />

<section class="max-w-md mx-auto px-4 py-6 space-y-3">
    @foreach (var task in Tasks)
    {
        <div class="rounded-2xl border border-line bg-surface p-5">
            <p class="text-sm font-semibold text-content">@task.Title</p>
            <p class="text-xs text-content-subtle mt-1">Currently @task.ProgressPercent.ToString("0")%</p>
            <div class="flex items-center gap-2 mt-3">
                <button type="button" @onclick="() => Bump(task, -5)"
                        class="w-12 h-12 rounded-full bg-surface-raised text-content-muted text-xl font-medium active:bg-surface-field">−</button>
                <div class="flex-1 h-2 bg-surface-raised rounded-full overflow-hidden">
                    <div class="h-full bg-emerald-500" style="width: @((int)task.ProgressPercent)%"></div>
                </div>
                <button type="button" @onclick="() => Bump(task, +5)"
                        class="w-12 h-12 rounded-full bg-accent text-accent-ink text-xl font-medium active:bg-accent-hover">+</button>
            </div>
        </div>
    }
</section>

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private IReadOnlyList<ProgrammeTask> Tasks => SiteStore.ProgrammeFor(ProjectId);

    private void Bump(ProgrammeTask task, int delta)
    {
        var nextPercent = Math.Clamp(task.ProgressPercent + delta, 0m, 100m);
        SiteStore.SaveProgrammeTask(task with { ProgressPercent = nextPercent });
    }
}
