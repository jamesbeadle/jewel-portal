@page "/portfolio/alerts"
@using Jewel.JPMS.Features.Projects
@inject AuthService Auth
@inject SessionService Session
@inject ProjectListReadModel Projects
@inject IChangeRegister ChangeRegister
@inject IHsRegister HsRegister
@inject ICommercialStore CommercialStore
@inject NavigationManager Nav

<PageTitle>Exception alerts · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/portfolio" class="text-content-subtle hover:text-content underline underline-offset-4">Portfolio</a>
            <span class="text-content-subtle mx-2">/</span>
            <span class="text-content-muted font-medium">Alerts</span>
        </nav>

        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-content">Exception alerts</h1>
            <p class="text-sm text-content-muted mt-1">Threshold-driven items needing director attention.</p>
        </header>

        @if (Alerts.Count == 0)
        {
            <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-5 text-center">
                <p class="text-sm font-medium text-emerald-900">All clear — no active alerts</p>
            </div>
        }
        else
        {
            <ul class="space-y-3">
                @foreach (var alert in Alerts)
                {
                    <li class="rounded-xl border border-rose-200 bg-rose-50 p-4">
                        <p class="text-sm font-medium text-rose-900">@alert.Title</p>
                        <p class="text-xs text-rose-800 mt-1">@alert.Detail</p>
                    </li>
                }
            </ul>
        }
    </section>
}

@code {
    private bool isLoaded;

    private record AlertRow(string Title, string Detail);

    private IReadOnlyList<AlertRow> Alerts
    {
        get
        {
            var alerts = new List<AlertRow>();
            foreach (var project in Projects.Current ?? Array.Empty<Project>())
            {
                var openRfis = ChangeRegister.ForProject(project.ProjectId, ChangeKind.Rfi).Count(c => c.Status != ChangeStatus.Closed);
                if (openRfis >= 2) alerts.Add(new($"{project.Name} — {openRfis} open RFIs", "Long-standing RFIs delay programme."));

                var highHs = HsRegister.ForProject(project.ProjectId).Count(r => r.Status != HsStatus.Closed && r.Severity >= HsSeverity.High);
                if (highHs > 0) alerts.Add(new($"{project.Name} — {highHs} open high-severity H&S items", "Director annual review attention."));

                var unissued = CommercialStore.ValuationsFor(project.ProjectId).Count(v => !v.IsIssued);
                if (unissued > 0) alerts.Add(new($"{project.Name} — PVR draft unissued", $"{unissued} valuation(s) waiting to issue."));
            }
            return alerts.AsReadOnly();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
        isLoaded = true;
    }
}
