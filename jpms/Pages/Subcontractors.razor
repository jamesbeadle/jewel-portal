@page "/directory"
@inject AuthService Auth
@inject SessionService Session
@inject ISubcontractorStore SubcontractorStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Directory · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (!CanAccess)
{
    <section class="max-w-3xl mx-auto px-4 py-12">
        <h1 class="text-2xl font-semibold text-content mb-2">Not available</h1>
        <p class="text-content-muted">The company directory is restricted to administrators and the managing director.</p>
    </section>
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <header class="mb-6 flex flex-wrap items-start justify-between gap-3">
            <div>
                <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · Company directory</p>
                <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Directory</h1>
                <p class="text-sm text-content-muted mt-2">@Filtered().Count of @SubcontractorStore.All().Count companies.</p>
            </div>
            @if (CanManage)
            {
                <button type="button" class="btn-primary" @onclick="OpenAddModal">+ Add company</button>
            }
        </header>

        @* Filters: category + free-text search across all types *@
        <div class="flex flex-wrap items-end gap-3 mb-5">
            <div class="grow min-w-[14rem]">
                <label class="eyebrow block mb-1">Search</label>
                <input class="field" placeholder="Company, trade, contact, town…" value="@search" @oninput="OnSearchInput" />
            </div>
            <div>
                <label class="eyebrow block mb-1">Type</label>
                <select class="field" value="@categoryFilter" @onchange="OnCategoryChanged">
                    <option value="">All types</option>
                    @foreach (var c in AllCategories)
                    {
                        <option value="@c">@Label(c)</option>
                    }
                </select>
            </div>
        </div>

        @if (Filtered().Count == 0)
        {
            <p class="text-sm text-content-subtle italic">No companies match.</p>
        }
        else
        {
            <div class="rounded-xl border border-line bg-surface overflow-hidden">
                <table class="w-full text-sm">
                    <thead class="bg-surface-raised border-b border-line">
                        <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                            <th class="px-4 py-3">Company</th>
                            <th class="px-4 py-3">Type</th>
                            <th class="px-4 py-3 hidden sm:table-cell">Trade</th>
                            <th class="px-4 py-3 hidden md:table-cell">Primary contact</th>
                            <th class="px-4 py-3 hidden lg:table-cell">Location</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-line">
                        @foreach (var sub in Filtered())
                        {
                            <tr class="hover:bg-surface-raised cursor-pointer transition" @onclick="() => Open(sub.SubcontractorId)">
                                <td class="px-4 py-3 text-content font-medium">@sub.CompanyName</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center rounded-full bg-surface-raised border border-line px-2 py-0.5 text-[11px] font-medium text-content-muted">@Label(sub.Category)</span>
                                </td>
                                <td class="px-4 py-3 text-content-muted hidden sm:table-cell">@sub.PrimaryTrade</td>
                                <td class="px-4 py-3 text-content-muted hidden md:table-cell">
                                    @sub.ContactName
                                    @if (!string.IsNullOrWhiteSpace(sub.ContactEmail))
                                    {
                                        <span class="block text-xs text-content-subtle">@sub.ContactEmail</span>
                                    }
                                </td>
                                <td class="px-4 py-3 text-content-subtle hidden lg:table-cell">@Location(sub)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <Modal IsOpen="showAddModal" Title="Add company" ShowFooter="true"
           ConfirmLabel="@(saving ? "Saving…" : "Add company")" CancelLabel="Cancel"
           OnCancel="CloseAddModal" OnConfirm="SaveCompany" Class="max-w-lg w-full">
        @if (addError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@addError</p>
        }
        <div class="space-y-3">
            <div>
                <label class="eyebrow block mb-1">Company name</label>
                <input class="field" @bind="nCompany" />
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="eyebrow block mb-1">Type</label>
                    <select class="field" @bind="nCategory">
                        @foreach (var c in AllCategories)
                        {
                            <option value="@c">@Label(c)</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="eyebrow block mb-1">Trade</label>
                    <input class="field" @bind="nTrade" placeholder="e.g. Electrician" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="eyebrow block mb-1">Contact name</label>
                    <input class="field" @bind="nContact" />
                </div>
                <div>
                    <label class="eyebrow block mb-1">Email</label>
                    <input class="field" @bind="nEmail" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="eyebrow block mb-1">Phone</label>
                    <input class="field" @bind="nPhone" />
                </div>
                <div>
                    <label class="eyebrow block mb-1">Mobile</label>
                    <input class="field" @bind="nMobile" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="eyebrow block mb-1">Town</label>
                    <input class="field" @bind="nTown" />
                </div>
                <div>
                    <label class="eyebrow block mb-1">County</label>
                    <input class="field" @bind="nCounty" />
                </div>
            </div>
            <div>
                <label class="eyebrow block mb-1">Website</label>
                <input class="field" @bind="nWebsite" />
            </div>
        </div>
    </Modal>
}

@code {
    private bool isLoaded;
    private string search = "";
    private string categoryFilter = ""; // "" = all

    private static readonly DirectoryCategory[] AllCategories =
        (DirectoryCategory[])Enum.GetValues(typeof(DirectoryCategory));

    // The directory is restricted to administrators and the managing director / CEO.
    private bool CanAccess => Session.AvailableRoles.Any(r => r is Role.Admin or Role.ManagingDirector);

    private bool CanManage => CanAccess;

    // Add-company form state
    private bool showAddModal;
    private bool saving;
    private string? addError;
    private string nCompany = "", nTrade = "", nContact = "", nEmail = "", nPhone = "", nMobile = "", nTown = "", nCounty = "", nWebsite = "";
    private DirectoryCategory nCategory = DirectoryCategory.Subcontractor;

    private void OpenAddModal()
    {
        nCompany = nTrade = nContact = nEmail = nPhone = nMobile = nTown = nCounty = nWebsite = "";
        nCategory = DirectoryCategory.Subcontractor;
        addError = null;
        showAddModal = true;
    }

    private void CloseAddModal() => showAddModal = false;

    private void SaveCompany()
    {
        if (saving) return;
        addError = null;
        if (string.IsNullOrWhiteSpace(nCompany)) { addError = "Company name is required."; return; }
        if ((nCategory is DirectoryCategory.Subcontractor or DirectoryCategory.Supplier) && string.IsNullOrWhiteSpace(nTrade))
        { addError = "Trade is required for subcontractors and suppliers."; return; }
        try
        {
            saving = true;
            SubcontractorStore.Upsert(new Subcontractor(
                "", nCompany.Trim(), nTrade.Trim(), nContact.Trim(), nEmail.Trim(), nPhone.Trim(),
                "", DateTimeOffset.UtcNow, nCategory, nMobile.Trim(), nTown.Trim(), nCounty.Trim(), nWebsite.Trim()));
            showAddModal = false;
        }
        catch { addError = "Couldn't add the company. Please try again."; }
        finally { saving = false; }
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        SubcontractorStore.OnChange += OnStoreChanged;
        _ = SubcontractorStore.All(); // kick off the directory load (async; raises OnChange)
        isLoaded = true;
    }

    public void Dispose() => SubcontractorStore.OnChange -= OnStoreChanged;

    private void OnStoreChanged() => InvokeAsync(StateHasChanged);

    private void OnSearchInput(ChangeEventArgs e) => search = e.Value?.ToString() ?? "";

    private void OnCategoryChanged(ChangeEventArgs e) => categoryFilter = e.Value?.ToString() ?? "";

    private IReadOnlyList<Subcontractor> Filtered()
    {
        var q = (search ?? "").Trim();
        DirectoryCategory? cat = Enum.TryParse<DirectoryCategory>(categoryFilter, out var c) ? c : null;
        return SubcontractorStore.All()
            .Where(s => cat is null || s.Category == cat)
            .Where(s => q.Length == 0
                || (s.CompanyName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || (s.PrimaryTrade ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || (s.ContactName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || (s.ContactEmail ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || (s.Town ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || (s.County ?? "").Contains(q, StringComparison.OrdinalIgnoreCase))
            .OrderBy(s => s.CompanyName)
            .ToList();
    }

    private void Open(string id) => Nav.NavigateTo($"/directory/{id}");

    private static string Location(Subcontractor s) =>
        string.Join(", ", new[] { s.Town, s.County }.Where(x => !string.IsNullOrWhiteSpace(x)));

    private static string Label(DirectoryCategory c) => c switch
    {
        DirectoryCategory.Subcontractor => "Subcontractor",
        DirectoryCategory.Client => "Client",
        DirectoryCategory.Architect => "Architect",
        DirectoryCategory.Supplier => "Supplier",
        _ => "Other"
    };
}
