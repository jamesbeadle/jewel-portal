@page "/directory"
@inject AuthService Auth
@inject SessionService Session
@inject ISubcontractorStore SubcontractorStore
@inject IClientStore ClientStore
@inject IArchitectStore ArchitectStore
@inject Jewel.JPMS.Features.Directory.DirectoryReadModel Staff
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Directory · JPMS</PageTitle>

@*
    THE unified directory (pathway-split plan §5/§9): one page, filter chips — Clients, Architects,
    Subcontractors (the company directory), Internal staff — replacing the three separate nav
    entries. A presentation-layer merge only: the company directory keeps its DirectoryCategory
    rows and detail pages; first-class Client accounts and Architect practices render read-only
    here with links to their own pages, where creating/editing and the contacts / correspondence
    profile editors stay; Internal staff folds in the RBAC user list. Gate widened (2026-07-22) to
    Admin / MD / FD / PM — though each group's API keeps its own gate, so a group a role can't
    read shows a quiet restriction note instead of rows.
*@

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (!CanAccess)
{
    <section class="px-6 md:px-8 py-12">
        <h1 class="text-2xl font-semibold text-content mb-2">Not available</h1>
        <p class="text-content-muted">The directory is restricted to administrators, directors and project managers.</p>
    </section>
}
else
{
    <section class="px-6 md:px-8 py-8 md:py-12">
        <header class="mb-6 flex flex-wrap items-start justify-between gap-3">
            <div>
                <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · Directory</p>
                <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Directory</h1>
                <p class="text-sm text-content-muted mt-2">@GroupSummary</p>
            </div>
            @if (group == DirectoryGroup.Subcontractors)
            {
                <div class="flex items-center gap-4 shrink-0">
                    <ExportToExcelButton FileName="Directory"
                                         Disabled="@(SubcontractorStore.All().Count == 0)"
                                         ShowIncludeAllRows="@(!string.IsNullOrWhiteSpace(search) || !string.IsNullOrWhiteSpace(categoryFilter))"
                                         IncludeAllLabel="Ignore search & filter"
                                         BuildWorkbook="BuildExportWorkbook" />
                    @if (CanManage)
                    {
                        <button type="button" class="btn-primary" @onclick="OpenAddModal">+ Add company</button>
                    }
                </div>
            }
        </header>

        @* The group chips: who you're looking for. Subcontractors is the company directory
           (the page's original body, unchanged); the other groups fold in alongside. *@
        <div class="flex flex-wrap items-center gap-2 mb-5">
            @foreach (var option in GroupChips)
            {
                var value = option.Group;
                <button type="button" class="@GroupChipClass(value)" @onclick="() => SelectGroup(value)">@option.Label</button>
            }
        </div>

        @if (group == DirectoryGroup.Clients)
        {
            @if (clientsError is not null)
            {
                <p class="text-sm text-content-subtle italic">@clientsError</p>
            }
            else if (clients.Count == 0)
            {
                <p class="text-sm text-content-subtle italic">@(clientsLoaded ? "No client accounts yet." : "Loading…")</p>
            }
            else
            {
                <div class="panel overflow-x-auto overflow-y-auto max-h-[85vh]">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-content-subtle border-b border-line">
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 font-medium">Client</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 font-medium">Primary contact</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 font-medium">Contact email</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var client in clients)
                            {
                                <tr class="border-b border-line last:border-0">
                                    <td class="px-4 py-3 font-medium text-content">@client.Name</td>
                                    <td class="px-4 py-3 text-content-muted">@Dash(client.PrimaryContactName)</td>
                                    <td class="px-4 py-3 text-content-muted">@Dash(client.PrimaryContactEmail)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            <p class="text-xs text-content-subtle mt-3">
                Create, edit and manage contacts on the
                <a class="underline hover:text-content" href="/clients">Client accounts</a> page.
            </p>
        }
        else if (group == DirectoryGroup.Architects)
        {
            @if (architectsError is not null)
            {
                <p class="text-sm text-content-subtle italic">@architectsError</p>
            }
            else if (architects.Count == 0)
            {
                <p class="text-sm text-content-subtle italic">@(architectsLoaded ? "No architect practices yet." : "Loading…")</p>
            }
            else
            {
                <div class="panel overflow-x-auto overflow-y-auto max-h-[85vh]">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-content-subtle border-b border-line">
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 font-medium">Practice</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 font-medium">Contact</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 font-medium">Contact email</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var architect in architects)
                            {
                                <tr class="border-b border-line last:border-0">
                                    <td class="px-4 py-3 font-medium text-content">@architect.Name</td>
                                    <td class="px-4 py-3 text-content-muted">@Dash(architect.ContactName)</td>
                                    <td class="px-4 py-3 text-content-muted">@Dash(architect.ContactEmail)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            <p class="text-xs text-content-subtle mt-3">
                Create, edit and manage contacts on the
                <a class="underline hover:text-content" href="/architects">Architects</a> page.
            </p>
        }
        else if (group == DirectoryGroup.Staff)
        {
            @if (staffError is not null)
            {
                <p class="text-sm text-content-subtle italic">@staffError</p>
            }
            else if (StaffUsers.Count == 0)
            {
                <p class="text-sm text-content-subtle italic">@(staffLoaded ? "No internal staff recorded." : "Loading…")</p>
            }
            else
            {
                <div class="panel overflow-x-auto overflow-y-auto max-h-[85vh]">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-content-subtle border-b border-line">
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 font-medium">Name</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 font-medium">Email</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 font-medium">Roles</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in StaffUsers)
                            {
                                <tr class="border-b border-line last:border-0">
                                    <td class="px-4 py-3 font-medium text-content">@user.DisplayName</td>
                                    <td class="px-4 py-3 text-content-muted">@user.Email</td>
                                    <td class="px-4 py-3">
                                        <span class="flex flex-wrap gap-1">
                                            @foreach (var role in user.Roles)
                                            {
                                                <RoleBadge Role="role" />
                                            }
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
        @* Filters: category + free-text search across all types *@
        <div class="flex flex-wrap items-end gap-3 mb-5">
            <div class="grow min-w-[14rem]">
                <label class="eyebrow block mb-1">Search</label>
                <input class="field" placeholder="Company, trade, contact, town…" value="@search" @oninput="OnSearchInput" />
            </div>
            <div>
                <label class="eyebrow block mb-1">Type</label>
                <select class="field" value="@categoryFilter" @onchange="OnCategoryChanged">
                    <option value="">All types</option>
                    @foreach (var c in AllCategories)
                    {
                        <option value="@c">@Label(c)</option>
                    }
                </select>
            </div>
        </div>

        @if (Filtered().Count == 0)
        {
            <p class="text-sm text-content-subtle italic">No companies match.</p>
        }
        else
        {
            <div class="rounded-xl border border-line bg-surface overflow-x-auto overflow-y-auto max-h-[85vh]">
                <table class="w-full text-sm">
                    <thead class="bg-surface-raised border-b border-line">
                        <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Company</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3">Type</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden sm:table-cell">Trade</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden md:table-cell">Primary contact</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-4 py-3 hidden lg:table-cell">Location</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-line">
                        @foreach (var sub in Filtered())
                        {
                            <tr class="hover:bg-surface-raised cursor-pointer transition" @onclick="() => Open(sub.SubcontractorId)">
                                <td class="px-4 py-3 text-content font-medium">@sub.CompanyName</td>
                                <td class="px-4 py-3">
                                    <span class="inline-flex items-center rounded-full bg-surface-raised border border-line px-2 py-0.5 text-[11px] font-medium text-content-muted">@Label(sub.Category)</span>
                                </td>
                                <td class="px-4 py-3 hidden sm:table-cell">
                                    <span class="flex flex-wrap gap-1">
                                        @foreach (var trade in sub.Trades)
                                        {
                                            <span class="inline-flex items-center rounded-full bg-surface-raised border border-line px-2 py-0.5 text-[11px] font-medium text-content-muted">@trade.Name</span>
                                        }
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-content-muted hidden md:table-cell">
                                    @sub.ContactName
                                    @if (!string.IsNullOrWhiteSpace(sub.ContactEmail))
                                    {
                                        <span class="block text-xs text-content-subtle">@sub.ContactEmail</span>
                                    }
                                </td>
                                <td class="px-4 py-3 text-content-subtle hidden lg:table-cell">@Location(sub)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        }
    </section>

    <Modal IsOpen="showAddModal" Title="Add company" ShowFooter="true"
           ConfirmLabel="@(saving ? "Saving…" : "Add company")" CancelLabel="Cancel"
           OnCancel="CloseAddModal" OnConfirm="SaveCompany" Class="max-w-lg w-full">
        @if (addError is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@addError</p>
        }
        <div class="space-y-3">
            <div>
                <label class="eyebrow block mb-1">Company name</label>
                <input class="field" @bind="nCompany" />
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="eyebrow block mb-1">Type</label>
                    <select class="field" @bind="nCategory">
                        @foreach (var c in AllCategories)
                        {
                            <option value="@c">@Label(c)</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="eyebrow block mb-1">Trades</label>
                    @if (nTradeIds.Count > 0)
                    {
                        <div class="flex flex-wrap gap-1 mb-1">
                            @foreach (var trade in SelectedTrades(nTradeIds))
                            {
                                <span class="inline-flex items-center gap-1 rounded-full bg-surface-raised border border-line px-2 py-0.5 text-[11px] font-medium text-content-muted">
                                    @trade.Name
                                    <button type="button" class="text-content-subtle hover:text-content" @onclick="() => nTradeIds.Remove(trade.TradeId)">×</button>
                                </span>
                            }
                        </div>
                    }
                    <select class="field" value="" @onchange="e => AddTradeToSelection(e, nTradeIds)">
                        <option value="">Add a trade…</option>
                        @foreach (var trade in SubcontractorStore.Trades().Where(t => !nTradeIds.Contains(t.TradeId)))
                        {
                            <option value="@trade.TradeId">@trade.Name</option>
                        }
                    </select>
                </div>
            </div>
            <div>
                <label class="eyebrow block mb-1">Not in the list?</label>
                <div class="flex gap-2">
                    <input class="field flex-1" @bind="nNewTrade" @bind:event="oninput" placeholder="New trade, e.g. Hod carrier" />
                    <button type="button" class="btn-secondary shrink-0" disabled="@(addingTrade || string.IsNullOrWhiteSpace(nNewTrade))" @onclick="CreateTrade">
                        @(addingTrade ? "Adding…" : "Add trade")
                    </button>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="eyebrow block mb-1">Contact name</label>
                    <input class="field" @bind="nContact" />
                </div>
                <div>
                    <label class="eyebrow block mb-1">Email</label>
                    <input class="field" @bind="nEmail" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="eyebrow block mb-1">Phone</label>
                    <input class="field" @bind="nPhone" />
                </div>
                <div>
                    <label class="eyebrow block mb-1">Mobile</label>
                    <input class="field" @bind="nMobile" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="eyebrow block mb-1">Town</label>
                    <input class="field" @bind="nTown" />
                </div>
                <div>
                    <label class="eyebrow block mb-1">County</label>
                    <input class="field" @bind="nCounty" />
                </div>
            </div>
            <div>
                <label class="eyebrow block mb-1">Website</label>
                <input class="field" @bind="nWebsite" />
            </div>
        </div>
    </Modal>
}

@code {
    private bool isLoaded;
    private string search = "";
    private string categoryFilter = ""; // "" = all

    private static readonly DirectoryCategory[] AllCategories =
        (DirectoryCategory[])Enum.GetValues(typeof(DirectoryCategory));

    // Widened for the unified directory (2026-07-22): Admin, MD, FD and PM may browse.
    private bool CanAccess => Session.AvailableRoles.Any(r =>
        r is Role.Admin or Role.ManagingDirector or Role.FinanceDirector or Role.ProjectManager);

    // Adding companies keeps the original narrower gate (mirrors the API's add authorisation).
    private bool CanManage => Session.AvailableRoles.Any(r => r is Role.Admin or Role.ManagingDirector);

    // ---- Group chips -------------------------------------------------------
    private enum DirectoryGroup { Clients, Architects, Subcontractors, Staff }

    // Subcontractors default: the company directory is what /directory has always shown.
    private DirectoryGroup group = DirectoryGroup.Subcontractors;

    private static readonly (DirectoryGroup Group, string Label)[] GroupChips =
    {
        (DirectoryGroup.Clients,        "Clients"),
        (DirectoryGroup.Architects,     "Architects"),
        (DirectoryGroup.Subcontractors, "Subcontractors"),
        (DirectoryGroup.Staff,          "Internal staff")
    };

    private string GroupChipClass(DirectoryGroup value) =>
        group == value
            ? "btn-primary text-xs px-2.5 py-1.5"
            : "btn-secondary text-xs px-2.5 py-1.5";

    private string GroupSummary => group switch
    {
        DirectoryGroup.Clients => clientsLoaded
            ? $"{clients.Count} client account{(clients.Count == 1 ? "" : "s")}."
            : "Client accounts.",
        DirectoryGroup.Architects => architectsLoaded
            ? $"{architects.Count} architect practice{(architects.Count == 1 ? "" : "s")}."
            : "Architect practices.",
        DirectoryGroup.Staff => staffLoaded
            ? $"{StaffUsers.Count} internal staff."
            : "Internal staff.",
        _ => $"{Filtered().Count} of {SubcontractorStore.All().Count} companies."
    };

    // Each group loads on first selection, best-effort: the groups keep their own API gates
    // (clients: Admin/MD/PM; staff: Admin/FD), so a 403 for this user's roles shows a quiet
    // restriction note rather than failing the page.
    private void SelectGroup(DirectoryGroup value)
    {
        group = value;
        _ = value switch
        {
            DirectoryGroup.Clients => LoadClientsAsync(),
            DirectoryGroup.Architects => LoadArchitectsAsync(),
            DirectoryGroup.Staff => LoadStaffAsync(),
            _ => Task.CompletedTask
        };
    }

    private IReadOnlyList<Client> clients = Array.Empty<Client>();
    private bool clientsLoaded;
    private string? clientsError;

    private async Task LoadClientsAsync()
    {
        if (clientsLoaded) return;
        try
        {
            clients = await ClientStore.ListAsync();
            clientsLoaded = true;
            clientsError = null;
        }
        catch { clientsError = "Client accounts couldn't be loaded — they're restricted to administrators, the managing director and project managers."; }
        StateHasChanged();
    }

    private IReadOnlyList<Architect> architects = Array.Empty<Architect>();
    private bool architectsLoaded;
    private string? architectsError;

    private async Task LoadArchitectsAsync()
    {
        if (architectsLoaded) return;
        try
        {
            architects = await ArchitectStore.ListAsync();
            architectsLoaded = true;
            architectsError = null;
        }
        catch { architectsError = "Architect practices couldn't be loaded — they're restricted to administrators, the managing director and project managers."; }
        StateHasChanged();
    }

    private bool staffLoaded;
    private string? staffError;

    private IReadOnlyList<DirectoryUser> StaffUsers =>
        Staff.Current ?? (IReadOnlyList<DirectoryUser>)Array.Empty<DirectoryUser>();

    private async Task LoadStaffAsync()
    {
        if (staffLoaded) return;
        try
        {
            await Staff.RefreshAsync(CancellationToken.None);
            staffLoaded = true;
            staffError = null;
        }
        catch { staffError = "The internal staff list couldn't be loaded — it's restricted to administrators and the finance director."; }
        StateHasChanged();
    }

    // Add-company form state
    private bool showAddModal;
    private bool saving;
    private string? addError;
    private string nCompany = "", nContact = "", nEmail = "", nPhone = "", nMobile = "", nTown = "", nCounty = "", nWebsite = "";
    private string nNewTrade = "";
    private bool addingTrade;
    private readonly HashSet<string> nTradeIds = new(StringComparer.OrdinalIgnoreCase);
    private DirectoryCategory nCategory = DirectoryCategory.Subcontractor;

    private void OpenAddModal()
    {
        nCompany = nContact = nEmail = nPhone = nMobile = nTown = nCounty = nWebsite = nNewTrade = "";
        nTradeIds.Clear();
        nCategory = DirectoryCategory.Subcontractor;
        addError = null;
        showAddModal = true;
    }

    private void CloseAddModal() => showAddModal = false;

    private void AddTradeToSelection(ChangeEventArgs e, HashSet<string> target)
    {
        var id = e.Value?.ToString();
        if (!string.IsNullOrEmpty(id)) target.Add(id);
    }

    private IReadOnlyList<Trade> SelectedTrades(HashSet<string> ids) =>
        SubcontractorStore.Trades().Where(t => ids.Contains(t.TradeId)).ToList();

    // Adds a brand-new trade to the curated list and selects it for this company.
    private async Task CreateTrade()
    {
        if (addingTrade || string.IsNullOrWhiteSpace(nNewTrade)) return;
        addError = null;
        try
        {
            addingTrade = true;
            var trade = await SubcontractorStore.AddTradeAsync(nNewTrade.Trim());
            nTradeIds.Add(trade.TradeId);
            nNewTrade = "";
        }
        catch { addError = "Couldn't add that trade. Please try again."; }
        finally { addingTrade = false; }
    }

    private void SaveCompany()
    {
        if (saving) return;
        addError = null;
        if (string.IsNullOrWhiteSpace(nCompany)) { addError = "Company name is required."; return; }
        if ((nCategory is DirectoryCategory.Subcontractor or DirectoryCategory.Supplier) && nTradeIds.Count == 0)
        { addError = "At least one trade is required for subcontractors and suppliers."; return; }
        try
        {
            saving = true;
            SubcontractorStore.Upsert(new Subcontractor(
                "", nCompany.Trim(), SelectedTrades(nTradeIds), nContact.Trim(), nEmail.Trim(), nPhone.Trim(),
                "", DateTimeOffset.UtcNow, nCategory, nMobile.Trim(), nTown.Trim(), nCounty.Trim(), nWebsite.Trim()));
            showAddModal = false;
        }
        catch { addError = "Couldn't add the company. Please try again."; }
        finally { saving = false; }
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        SubcontractorStore.OnChange += OnStoreChanged;
        _ = SubcontractorStore.All(); // kick off the directory load (async; raises OnChange)
        _ = SubcontractorStore.Trades(); // and the curated trade list for the add-company form
        isLoaded = true;
    }

    public void Dispose() => SubcontractorStore.OnChange -= OnStoreChanged;

    private void OnStoreChanged() => InvokeAsync(StateHasChanged);

    private void OnSearchInput(ChangeEventArgs e) => search = e.Value?.ToString() ?? "";

    private void OnCategoryChanged(ChangeEventArgs e) => categoryFilter = e.Value?.ToString() ?? "";

    private IReadOnlyList<Subcontractor> Filtered()
    {
        var q = (search ?? "").Trim();
        DirectoryCategory? cat = Enum.TryParse<DirectoryCategory>(categoryFilter, out var c) ? c : null;
        return SubcontractorStore.All()
            .Where(s => cat is null || s.Category == cat)
            .Where(s => q.Length == 0
                || (s.CompanyName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || s.Trades.Any(t => t.Name.Contains(q, StringComparison.OrdinalIgnoreCase))
                || (s.ContactName ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || (s.ContactEmail ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || (s.Town ?? "").Contains(q, StringComparison.OrdinalIgnoreCase)
                || (s.County ?? "").Contains(q, StringComparison.OrdinalIgnoreCase))
            .OrderBy(s => s.CompanyName)
            .ToList();
    }

    private void Open(string id) => Nav.NavigateTo($"/directory/{id}");

    // The screen's "Primary contact" cell is compound (name + email subtitle) — split
    // into two columns so the email isn't lost from the export.
    private ExcelWorkbook? BuildExportWorkbook(bool ignoreFilters)
    {
        // "Ignore search & filter" (offered while either is narrowing the table) exports the
        // complete directory in the same company-name order.
        var subs = ignoreFilters
            ? SubcontractorStore.All().OrderBy(s => s.CompanyName).ToList()
            : Filtered();
        if (subs.Count == 0) return null;

        var workbook = new ExcelWorkbook();
        var sheet = workbook.AddSheet("Directory",
            new ExcelColumn("Company"),
            new ExcelColumn("Type"),
            new ExcelColumn("Trade"),
            new ExcelColumn("Primary contact"),
            new ExcelColumn("Contact email"),
            new ExcelColumn("Location"));

        foreach (var sub in subs)
        {
            sheet.AddRow(
                sub.CompanyName,
                Label(sub.Category),
                sub.TradesLabel,
                sub.ContactName,
                sub.ContactEmail,
                Location(sub));
        }
        return workbook;
    }

    private static string Location(Subcontractor s) =>
        string.Join(", ", new[] { s.Town, s.County }.Where(x => !string.IsNullOrWhiteSpace(x)));

    private static string Dash(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string Label(DirectoryCategory c) => c switch
    {
        DirectoryCategory.Subcontractor => "Subcontractor",
        DirectoryCategory.Client => "Client",
        DirectoryCategory.Architect => "Architect",
        DirectoryCategory.Supplier => "Supplier",
        _ => "Other"
    };
}
