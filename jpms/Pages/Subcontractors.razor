@page "/subcontractors"
@inject AuthService Auth
@inject SessionService Session
@inject ISubcontractorStore SubcontractorStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Subcontractors · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <header class="mb-6 md:mb-8">
            <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1">JPMS · OCC</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900 leading-tight">Subcontractors</h1>
            <p class="text-sm text-slate-600 mt-2">@SubcontractorStore.All().Count subcontractors on the directory.</p>
        </header>

        <SubcontractorTable Subcontractors="SubcontractorStore.All()" />
    </section>
}

@code {
    private bool isLoaded;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        SubcontractorStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => SubcontractorStore.OnChange -= StateHasChanged;
}
