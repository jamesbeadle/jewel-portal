@page "/"
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Sign in · JPMS</PageTitle>

<section class="max-w-md mx-auto px-4 py-12 md:py-20">

    <div class="text-center mb-8 md:mb-10">
        <span class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-surface border border-line text-content mb-5">
            <JewelIcon Class="w-12 h-12" />
        </span>
        <p class="eyebrow mb-2">Jewel Project Management System</p>
        <h1 class="text-3xl md:text-4xl font-semibold text-content leading-tight mb-3">Welcome back</h1>
        <p class="text-base text-content-muted leading-relaxed">
            Use your Microsoft work account to continue.
        </p>
    </div>

    <div class="space-y-3">
        <ProviderButton Provider="AuthProvider.Microsoft" OnClick="SignInWithMicrosoft" />
    </div>

    <p class="mt-8 text-center text-xs text-content-subtle leading-relaxed">
        By signing in you agree to the JPMS acceptable-use policy.<br />
        New here? Sign in first — you'll be able to request access on the next screen.
    </p>

</section>

@code {
    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureInitialisedAsync();
        if (Auth.IsSignedIn) Nav.NavigateTo("/dashboard", replace: true);
    }

    private void SignInWithMicrosoft() =>
        Nav.NavigateTo("/login", forceLoad: true);
}
