@page "/"
@page "/login"
@layout LandingLayout
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Sign in · JPMS</PageTitle>

<div class="min-h-dvh flex flex-col md:flex-row">

    <div class="order-1 md:order-2 w-full md:w-1/2 h-[25vh] md:h-auto bg-surface overflow-hidden">
        <img src="about-team.png" alt="" class="w-full h-full object-cover" />
    </div>

    <div class="order-2 md:order-1 w-full md:w-1/2 flex-1 flex flex-col p-8 md:p-10">

        <div class="flex items-center gap-2.5 shrink-0 justify-center md:justify-start">
            <JewelIcon Class="w-6 h-6 text-content" />
            <span class="font-semibold text-content">Jewel Project Management System</span>
        </div>

        <div class="flex-1 flex flex-col items-center justify-center w-full max-w-sm mx-auto py-10">
            <h1 class="text-4xl font-semibold text-content leading-tight mb-3 text-center">Welcome back</h1>
            <p class="text-base text-content-muted leading-relaxed mb-8 text-center">
                Sign in with your email and password.
            </p>

            <form @onsubmit="HandleSubmit" @onsubmit:preventDefault="true" class="w-full space-y-4">
                <div>
                    <label for="email" class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Email</label>
                    <input id="email" type="email" autocomplete="username"
                           value="@email" @oninput="e => email = e.Value?.ToString() ?? string.Empty"
                           class="w-full rounded-lg border border-line bg-surface-raised px-3 py-2.5 text-sm text-content placeholder:text-content-faint focus:outline-none focus:ring-2 focus:ring-accent focus:border-line-strong" />
                </div>
                <div>
                    <label for="password" class="block text-xs uppercase tracking-wider text-content-subtle font-semibold mb-1">Password</label>
                    <input id="password" type="password" autocomplete="current-password"
                           value="@password" @oninput="e => password = e.Value?.ToString() ?? string.Empty"
                           class="w-full rounded-lg border border-line bg-surface-raised px-3 py-2.5 text-sm text-content placeholder:text-content-faint focus:outline-none focus:ring-2 focus:ring-accent focus:border-line-strong" />
                </div>

                @if (error is not null)
                {
                    <p class="text-sm text-negative">@error</p>
                }

                <button type="submit" disabled="@(busy || !CanSubmit)"
                        class="w-full rounded-lg bg-accent text-accent-ink font-medium px-4 py-2.5 hover:bg-accent-hover disabled:opacity-50 disabled:cursor-not-allowed transition">
                    @(busy ? "Signing in…" : "Sign in")
                </button>
            </form>

            <p class="mt-6 text-xs text-content-subtle leading-relaxed text-center">
                Need access? Ask a Jewel administrator to invite you — you'll get a link to set your password.
            </p>
        </div>

        <p class="shrink-0 max-w-md mx-auto text-center text-[11px] text-content-subtle leading-relaxed">
            <span class="text-content-muted font-medium">Jewel Project Management System</span> is the
            operational backbone for Jewel Bespoke Build and its clients — carrying every job from first lead
            through drawings, procurement, site delivery and commercial valuations to final account, with
            health &amp; safety, cashflow and portfolio insight in one role-aware workspace.
        </p>

    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? error;
    private bool busy;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(email) && !string.IsNullOrWhiteSpace(password);

    protected override async Task OnInitializedAsync()
    {
        await Auth.EnsureInitialisedAsync();
        if (Auth.IsSignedIn) Nav.NavigateTo("/dashboard", replace: true);
    }

    private async Task HandleSubmit()
    {
        if (!CanSubmit || busy) return;
        busy = true;
        error = null;
        error = await Auth.LoginAsync(email.Trim(), password);
        busy = false;
        if (error is null) Nav.NavigateTo("/dashboard", replace: true);
    }
}
