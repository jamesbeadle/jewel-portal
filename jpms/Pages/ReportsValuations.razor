@page "/reports/valuations"
@inject AuthService Auth
@inject SessionService Session
@using Jewel.JPMS.Features.Projects
@inject ICommercialStore CommercialStore
@inject ProjectListReadModel Projects
@inject NavigationManager Nav

<PageTitle>Valuations report · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/reports" class="text-content-subtle hover:text-content underline underline-offset-4">Reports</a>
            <span class="text-content-subtle mx-2">/</span>
            <span class="text-content-muted font-medium">Approved valuations</span>
        </nav>

        <header class="mb-6 flex items-end justify-between gap-4">
            <div>
                <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Approved valuations</h1>
                <p class="text-sm text-content-muted mt-2">@IssuedValuations.Count issued valuations across the portfolio.</p>
            </div>
            <a href="@CsvDownloadUrl" download="@FileName"
               class="rounded-lg bg-accent text-accent-ink font-medium text-sm px-4 py-2 hover:bg-accent-hover transition">
                Download CSV
            </a>
        </header>

        <ValuationsReportTable Valuations="IssuedValuations" />
    </section>
}

@code {
    private bool isLoaded;

    private IReadOnlyList<Valuation> IssuedValuations =>
        (Projects.Current ?? Array.Empty<Project>())
            .SelectMany(project => CommercialStore.ValuationsFor(project.ProjectId))
            .Where(valuation => valuation.IsIssued)
            .OrderByDescending(valuation => valuation.IssuedAt ?? DateTimeOffset.MinValue)
            .ToList()
            .AsReadOnly();

    private string FileName => $"jpms-valuations-{DateTime.UtcNow:yyyyMMdd}.csv";

    private string CsvDownloadUrl
    {
        get
        {
            var headers = new[] { "ValuationId", "ProjectReference", "ProjectName", "GrossValue", "RetentionPercent", "NetValue", "IssuedAt" };
            var rows = IssuedValuations.Select(valuation =>
            {
                var project = Projects.Find(valuation.ProjectId);
                return new object?[]
                {
                    valuation.ValuationId, project?.Reference ?? valuation.ProjectId, project?.Name ?? "",
                    valuation.GrossValue, valuation.RetentionPercent, valuation.NetValue, valuation.IssuedAt
                };
            });
            return CsvBuilder.ToDataUrl(CsvBuilder.BuildRows(headers, rows));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
        isLoaded = true;
    }
}
