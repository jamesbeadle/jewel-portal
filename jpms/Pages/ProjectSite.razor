@page "/projects/{ProjectId}/site"
@inject AuthService Auth
@inject SessionService Session
@inject ISiteStore SiteStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Site · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="site">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
            <div>
                <h2 class="text-lg font-semibold text-slate-900 mb-3">Programme</h2>
                <ProgrammeTable Tasks="SiteStore.ProgrammeFor(ProjectId)" />
            </div>
            <div>
                <h2 class="text-lg font-semibold text-slate-900 mb-3">Recent reports</h2>
                <SiteReportList Reports="SiteStore.ReportsFor(ProjectId)" />
            </div>
        </div>
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        SiteStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => SiteStore.OnChange -= StateHasChanged;
}
