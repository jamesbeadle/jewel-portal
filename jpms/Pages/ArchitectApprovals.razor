@page "/portal/architect/submittals"
@page "/portal/architect/variations"
@layout PortalLayout
@using Jewel.JPMS.Features.Projects
@inject PortalContext PortalContext
@inject IRequestRegister RequestRegister
@inject ProjectListReadModel Projects
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@PageHeading · Architect portal</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <nav class="mb-4 text-sm">
        <a href="/portal/architect" class="text-content-subtle hover:text-content underline underline-offset-4">Architect portal</a>
        <span class="text-content-subtle mx-2">/</span>
        <span class="text-content-muted font-medium">@PageHeading</span>
    </nav>

    <header class="mb-6">
        <h1 class="text-2xl md:text-3xl font-semibold text-content">@PageHeading</h1>
        <p class="text-sm text-content-muted mt-1">@PageSubheading</p>
    </header>

    @if (Pending.Count == 0)
    {
        <p class="text-sm text-content-subtle italic">Nothing pending your approval.</p>
    }
    else
    {
        <div class="rounded-xl border border-line bg-surface divide-y divide-line">
            @foreach (var (record, project) in Pending)
            {
                <ArchitectApprovalCard Record="record" ProjectName="@project.Name" />
            }
        </div>
    }
</section>

@code {
    private RequestType Kind => CurrentPath.EndsWith("variations") ? RequestType.Rfc : RequestType.Rfa;
    private string CurrentPath => new Uri(Nav.Uri).AbsolutePath;
    private string PageHeading => Kind == RequestType.Rfc ? "Variation orders" : "Submittals";
    private string PageSubheading => Kind == RequestType.Rfc
        ? "Cost-impacting changes pending your sign-off."
        : "Material and sample submittals pending approval before installation.";

    private IReadOnlyList<(Request Record, Project Project)> Pending =>
        (Projects.Current ?? Array.Empty<Project>())
            .SelectMany(project => RequestRegister.ForProject(project.ProjectId, Kind)
                .Where(record => record.Status is RequestStatus.Open or RequestStatus.AwaitingResponse)
                .Select(record => (record, project)))
            .ToList()
            .AsReadOnly();

    protected override async Task OnInitializedAsync()
    {
        RequestRegister.OnChange += StateHasChanged;
        Projects.OnChanged += StateHasChanged;
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
    }

    public void Dispose()
    {
        RequestRegister.OnChange -= StateHasChanged;
        Projects.OnChanged -= StateHasChanged;
    }
}
