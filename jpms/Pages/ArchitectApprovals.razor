@page "/portal/architect/submittals"
@page "/portal/architect/variations"
@layout PortalLayout
@using Jewel.JPMS.Features.Projects
@inject PortalContext PortalContext
@inject IChangeRegister ChangeRegister
@inject ProjectListReadModel Projects
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>@PageHeading · Architect portal</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <nav class="mb-4 text-sm">
        <a href="/portal/architect" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Architect portal</a>
        <span class="text-slate-400 mx-2">/</span>
        <span class="text-slate-700 font-medium">@PageHeading</span>
    </nav>

    <header class="mb-6">
        <h1 class="text-2xl md:text-3xl font-semibold text-slate-900">@PageHeading</h1>
        <p class="text-sm text-slate-600 mt-1">@PageSubheading</p>
    </header>

    @if (Pending.Count == 0)
    {
        <p class="text-sm text-slate-500 italic">Nothing pending your approval.</p>
    }
    else
    {
        <div class="rounded-xl border border-slate-200 bg-white divide-y divide-slate-200">
            @foreach (var (record, project) in Pending)
            {
                <ArchitectApprovalCard Record="record" ProjectName="@project.Name" />
            }
        </div>
    }
</section>

@code {
    private ChangeKind Kind => CurrentPath.EndsWith("variations") ? ChangeKind.Variation : ChangeKind.Submittal;
    private string CurrentPath => new Uri(Nav.Uri).AbsolutePath;
    private string PageHeading => Kind == ChangeKind.Variation ? "Variation orders" : "Submittals";
    private string PageSubheading => Kind == ChangeKind.Variation
        ? "Cost-impacting changes pending your sign-off."
        : "Material and sample submittals pending approval before installation.";

    private IReadOnlyList<(ChangeRecord Record, Project Project)> Pending =>
        (Projects.Current ?? Array.Empty<Project>())
            .SelectMany(project => ChangeRegister.ForProject(project.ProjectId, Kind)
                .Where(record => record.Status is ChangeStatus.Open or ChangeStatus.AwaitingResponse)
                .Select(record => (record, project)))
            .ToList()
            .AsReadOnly();

    protected override async Task OnInitializedAsync()
    {
        ChangeRegister.OnChange += StateHasChanged;
        Projects.OnChanged += StateHasChanged;
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
    }

    public void Dispose()
    {
        ChangeRegister.OnChange -= StateHasChanged;
        Projects.OnChanged -= StateHasChanged;
    }
}
