@page "/projects/{ProjectId}/procurement/{PackageId}/compare"
@inject AuthService Auth
@inject SessionService Session
@inject IProcurementStore ProcurementStore
@inject NavigationManager Nav

<PageTitle>Quote comparison · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="procurement">
        <nav class="mb-4 text-sm">
            <a href="@($"/projects/{ProjectId}/procurement")" class="text-content-subtle hover:text-content underline underline-offset-4">Procurement</a>
            <span class="text-content-subtle mx-2">/</span>
            <span class="text-content-muted font-medium">@(package?.Title ?? "Package")</span>
            <span class="text-content-subtle mx-2">/</span>
            <span class="text-content-muted font-medium">Compare quotes</span>
        </nav>

        @if (package is null)
        {
            <p class="text-sm text-content-subtle italic">Bid package not found.</p>
        }
        else
        {
            <h2 class="text-lg font-semibold text-content mb-3">@package.Title</h2>
            <QuoteComparisonGrid Quotes="Quotes" />
        }
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string PackageId { get; set; } = "";

    private bool isLoaded;
    private BidPackage? package;

    private IReadOnlyList<Quote> Quotes => ProcurementStore.QuotesFor(PackageId);

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        package = ProcurementStore.FindPackage(PackageId);
        isLoaded = true;
    }
}
