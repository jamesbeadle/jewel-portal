@page "/estimating-queue"
@inject AuthService Auth
@inject SessionService Session
@inject ILeadStore LeadStore
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Estimating queue · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="px-6 md:px-8 py-8 md:py-12">
        <header class="mb-6 md:mb-8">
            <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · QS</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Estimating queue</h1>
            <p class="text-sm text-content-muted mt-2">
                Leads at Tendering / Feasibility, ordered by capture date (oldest first).
            </p>
        </header>

        <div class="mb-3 flex items-center justify-end">
            <ExportToExcelButton FileName="Estimating queue"
                                 Disabled="@(Queue.Count == 0)"
                                 BuildWorkbook="BuildExportWorkbook" />
        </div>

        @if (Queue.Count == 0)
        {
            <p class="text-sm text-content-subtle italic">No leads currently in the estimating queue.</p>
        }
        else
        {
            <LeadsTable Leads="Queue" />
        }
    </section>
}

@code {
    private bool isLoaded;

    private IReadOnlyList<Lead> Queue =>
        LeadStore.All()
            .Where(lead => lead.Stage is LeadStage.Tendering or LeadStage.FeasibilityReview)
            .OrderBy(lead => lead.CapturedAt)
            .ToList()
            .AsReadOnly();

    private ExcelWorkbook? BuildExportWorkbook(bool _)
    {
        var leads = Queue;
        if (leads.Count == 0) return null;

        var workbook = new ExcelWorkbook();
        var sheet = workbook.AddSheet("Estimating queue",
            new ExcelColumn("Reference"),
            new ExcelColumn("Contact"),
            new ExcelColumn("Site"),
            new ExcelColumn("Source"),
            new ExcelColumn("Value", ExcelFormat.Currency),
            new ExcelColumn("Stage"));

        foreach (var lead in leads)
        {
            sheet.AddRow(
                lead.Reference,
                lead.ContactName,
                lead.SiteAddress,
                lead.Source.DisplayName(),
                lead.EstimatedValue,
                lead.Stage.DisplayName());
        }
        return workbook;
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        LeadStore.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => LeadStore.OnChange -= StateHasChanged;
}
