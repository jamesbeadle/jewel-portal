@page "/cashflow/director"
@inject AuthService Auth
@inject SessionService Session
@using Jewel.JPMS.Features.Projects
@inject ICommercialStore CommercialStore
@inject ProjectListReadModel Projects
@inject NavigationManager Nav

<PageTitle>Cashflow — Director · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/cashflow" class="text-content-subtle hover:text-content underline underline-offset-4">Cashflow</a>
            <span class="text-content-subtle mx-2">/</span>
            <span class="text-content-muted font-medium">Director view</span>
        </nav>

        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-content">Cashflow — Director view</h1>
            <p class="text-sm text-content-muted mt-1">Headline numbers across the portfolio for board reporting.</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4 mb-6">
            <Stat Label="Expected income (13w)"    Value="@Money(Snapshot.ExpectedIncome13Week)" />
            <Stat Label="Committed spend (13w)"    Value="@Money(Snapshot.CommittedSpend13Week)" />
            <Stat Label="Net position"             Value="@Money(Snapshot.NetPosition13Week)" />
        </div>

        <CashflowByProjectTable Projects="@(Projects.Current ?? Array.Empty<Project>())" />
    </section>
}

@code {
    private bool isLoaded;
    private CashflowSnapshot Snapshot => CommercialStore.LatestCashflow();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        if (Projects.Current is null) await Projects.RefreshAsync(CancellationToken.None);
        isLoaded = true;
    }

    private static string Money(decimal value) =>
        value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
