@page "/projects/{ProjectId}/cashflow"
@using Jewel.JPMS.Commercial
@using Jewel.JPMS.Contracts.Commercial
@using Jewel.JPMS.Contracts.Procurement
@using Jewel.JPMS.Contracts.ValuationInvoices
@using Jewel.JPMS.Features.Commercial
@using Jewel.JPMS.Features.Procurement
@using Jewel.JPMS.Models
@inject AuthService Auth
@inject SessionService Session
@inject ProjectFinancialSummaryReadModel Summary
@inject ProjectWorkOrdersReadModel WorkOrders
@inject IValuationReportStore ValuationReport
@inject IProjectRetentionStore Retention
@inject IQueryClient Queries
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Cashflow · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="cashflow">
        <h2 class="text-lg font-semibold text-content mb-1">Cashflow</h2>
        <p class="text-sm text-content-subtle mb-4">
            The project's cash position in one place: what has come in from the client and what is
            still to come, against what has gone out to suppliers and what is still to be paid.
        </p>

        @* ── Funds in — the client side, from valuation invoices ─────────────── *@
        <h3 class="text-sm font-semibold text-content mb-2">Funds in — client</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-6">
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="The valuation report's counting lines — contract works, provisional sums, contingency and variations">Contract sales value</p>
                <p class="text-lg font-semibold text-content">@Money(ContractSales)</p>
            </div>
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="Issued and paid valuation invoices — certified to date">Invoiced to date</p>
                <p class="text-lg font-semibold text-content">@Money(invoiceSummary?.TotalInvoiced ?? 0m)</p>
                @if ((invoiceSummary?.TotalAwaitingApproval ?? 0m) != 0m)
                {
                    <p class="text-xs text-content-subtle mt-0.5">+ @Money(invoiceSummary!.TotalAwaitingApproval) awaiting approval</p>
                }
            </div>
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="Valuation invoices the client has paid — money received">Funds in</p>
                <p class="text-lg font-semibold text-positive">@Money(invoiceSummary?.TotalPaid ?? 0m)</p>
            </div>
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="Valuation invoices issued to the client but not yet paid">Awaiting payment</p>
                <p class="text-lg font-semibold text-content">@Money(invoiceSummary?.Outstanding ?? 0m)</p>
            </div>
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="Retention withheld by the client on works complete — held less released. From the project's retention terms when set (see the Setup tab), else the latest claim on the Valuation Report. Earned but not invoiceable until released">Retention held</p>
                <p class="text-lg font-semibold text-content">@Money(RetentionOutstanding)</p>
                @if (RetentionTerms is { } terms && Schedule is { } schedule)
                {
                    <p class="text-xs text-content-subtle mt-0.5">
                        @Money(schedule.HeldToDate) held (@Pct(terms.RetentionPercent)) ·
                        @Money(schedule.ReleasedToDate) released
                    </p>
                    <p class="text-xs text-content-subtle mt-0.5">@ReleaseLine(schedule.CompletionRelease, $"{Pct(terms.CompletionReleasePercent)} at completion")</p>
                    <p class="text-xs text-content-subtle">@ReleaseLine(schedule.FinalRelease, $"balance after {terms.DefectsPeriodMonths} months")</p>
                }
                else if (ValuationFigures.RetentionHeld != 0m || ValuationFigures.RetentionReleased != 0m)
                {
                    <p class="text-xs text-content-subtle mt-0.5">
                        @Money(ValuationFigures.RetentionHeld) held (@Pct(ValuationFigures.RetentionPercent)) ·
                        @Money(ValuationFigures.RetentionReleased) released
                    </p>
                }
            </div>
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="Contract sales value less funds in — everything not yet received, whether invoiced, retained or still to invoice">Left to come in</p>
                <p class="text-lg font-semibold text-content">@Money(LeftToComeIn)</p>
                <p class="text-xs text-content-subtle mt-0.5">
                    of which @Money(invoiceSummary?.Outstanding ?? 0m) invoiced ·
                    @Money(RetentionOutstanding) retention
                </p>
            </div>
        </div>

        @* ── Funds out — the cost side: work orders and Xero spend ──────────── *@
        <h3 class="text-sm font-semibold text-content mb-2">Funds out — costs</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-6">
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="The value committed to work orders — see the Work Orders tab">Committed to work orders</p>
                <p class="text-lg font-semibold text-content">@Money(WoCommitted)</p>
            </div>
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="Xero purchase spend allocated to this project, net of credit notes — see the WO Allocation tab">Actual cost of sales</p>
                <p class="text-lg font-semibold text-content">@Money(CostOfSales)</p>
            </div>
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="Cost of sales on bills Xero shows as paid — money actually out the door">Paid to suppliers</p>
                <p class="text-lg font-semibold text-content">@Money(BillsPaid)</p>
            </div>
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="Cost of sales on bills received but not yet paid in Xero — due now">Bills awaiting payment</p>
                <p class="text-lg font-semibold @(BillsUnpaid == 0m ? "text-content" : "text-negative")">@Money(BillsUnpaid)</p>
            </div>
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="Work-order value not yet invoiced by suppliers — committed spend still to bill; see the WO Allocation tab">WO left to invoice</p>
                <p class="text-lg font-semibold text-content">@Money(WoLeftToInvoice)</p>
            </div>
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
                <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                   title="Target cost less work orders and non-work-order cost of sales — the funds still available; negative means overspent. Matches the Financials tab's drawdown, project-wide">Drawdown available</p>
                <p class="text-lg font-semibold @(Drawdown < 0m ? "text-negative" : "text-content")">@Money(Drawdown)</p>
            </div>
        </div>

        @* ── The position: what's still to come in against what's due to go out ── *@
        <h3 class="text-sm font-semibold text-content mb-2">Position</h3>
        <div class="rounded-xl border border-line bg-surface px-4 py-4 mb-4">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                       title="Contract sales value less funds in">Still to come in from income</p>
                    <p class="text-xl font-semibold text-content">@Money(LeftToComeIn)</p>
                    <p class="text-xs text-content-subtle mt-1">
                        @Money(invoiceSummary?.Outstanding ?? 0m) invoiced &amp; awaiting payment ·
                        @Money(RetentionOutstanding) retention held ·
                        @Money(NotYetInvoicedIncome - RetentionOutstanding) works not yet invoiced
                    </p>
                </div>
                <div>
                    <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                       title="Unpaid supplier bills plus committed work-order value suppliers haven't billed yet">Due to be paid out in total</p>
                    <p class="text-xl font-semibold text-content">@Money(DueOut)</p>
                    <p class="text-xs text-content-subtle mt-1">
                        @Money(BillsUnpaid) bills awaiting payment ·
                        @Money(WoLeftToInvoice) WO still to be invoiced
                    </p>
                </div>
                <div>
                    <p class="text-[11px] uppercase tracking-wider text-content-subtle font-semibold"
                       title="Still to come in, less due to go out — the project's remaining net cash movement">Net still to come</p>
                    <p class="text-xl font-semibold @(NetPosition < 0m ? "text-negative" : "text-positive")">@Money(NetPosition)</p>
                </div>
            </div>
        </div>

        <p class="text-xs text-content-subtle">
            Funds in figures come from valuation invoices (Issued counts as invoiced; Paid as
            received). Committed and left-to-invoice come from work orders and the invoice links
            managed on the WO Allocation tab. Bills awaiting payment reads each allocated Xero
            purchase line's payment status, so it moves when bills are paid in Xero and re-synced.
            Due to be paid out is the sum of those unpaid bills and the work-order value suppliers
            haven't billed yet — spend on top of work orders (non-WO cost of sales) appears here
            only once billed. Drawdown matches the Financials tab: target cost less work orders and
            non-WO cost of sales. Retention comes from the project's retention terms (Setup tab)
            when they're recorded — held to date is the retention % of works complete, with the
            two releases forecast against the revised contract sum and their due dates anchored
            to practical completion — otherwise from the latest claim on the Valuation Report.
            Valuation invoices are raised net of retention, so retention held is money earned but
            not invoiceable until it's released.
        </p>
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private bool isLoaded;

    private ProjectValuationInvoiceSummary? invoiceSummary;
    private IReadOnlyList<WorkOrderInvoiceSummary> woSummaries = Array.Empty<WorkOrderInvoiceSummary>();
    private IReadOnlyList<ProjectCostOfSalesLine> costLines = Array.Empty<ProjectCostOfSalesLine>();

    // ── Funds in — from valuation invoices and the valuation's counting lines ──
    private decimal ContractSales => Summary.Current(ProjectId).Sum(row => row.BudgetedSales);
    private decimal TargetCost => Summary.Current(ProjectId).Sum(row => row.BudgetedCost);
    private decimal NonWoCostOfSales => Summary.Current(ProjectId).Sum(row => row.NonWorkOrderActualCost);

    private decimal LeftToComeIn => ContractSales - (invoiceSummary?.TotalPaid ?? 0m);
    private decimal NotYetInvoicedIncome => ContractSales - (invoiceSummary?.TotalInvoiced ?? 0m);

    // ── Retention — from the latest claim on the Valuation Report (live for drafts),
    // computed by the same helper as the valuation summary footer so the tabs agree.
    private ValuationClaim? LatestClaim =>
        ValuationReport.ClaimsFor(ProjectId).OrderByDescending(claim => claim.ClaimNumber).FirstOrDefault();

    private ValuationSummaryFigures ValuationFigures => ValuationSummaryFigures.For(
        ValuationReport.LinesFor(ProjectId),
        LatestClaim is { Status: ValuationClaimStatus.Draft } draft
            ? ValuationReport.EntriesFor(draft.ValuationClaimId)
            : Array.Empty<ClaimLine>(),
        LatestClaim,
        invoiceSummary?.TotalInvoiced ?? 0m);

    // ── Retention terms + schedule — the project's retention record (Setup tab) when one
    // exists; the claim-based figure is the fallback for projects without terms recorded.
    private ProjectRetention? RetentionTerms => Retention.RetentionFor(ProjectId);

    private RetentionSchedule? Schedule => RetentionTerms is { } terms
        ? RetentionSchedule.For(terms, ValuationFigures.TotalWorksComplete, ValuationFigures.RevisedContractSum)
        : null;

    private decimal RetentionOutstanding => Schedule?.Outstanding ?? ValuationFigures.RetentionOutstanding;

    private static string ReleaseLine(RetentionScheduleLine line, string label) => line.IsConfirmed
        ? $"{label}: {Money(line.Amount)} released {line.ConfirmedAt?.ToString("d MMM yyyy")}"
        : $"{label}: {Money(line.Amount)}{(line.DueOn is { } due ? $" due {due:d MMM yyyy}" : "")} (forecast)";

    // ── Funds out — work orders committed and Xero purchase spend ──
    private decimal WoCommitted => WorkOrders.Current(ProjectId).Sum(detail => detail.Order.Value);
    private decimal WoInvoiced => woSummaries.Sum(summary => summary.InvoicedToDate);
    private decimal WoLeftToInvoice => WoCommitted - WoInvoiced;

    private decimal CostOfSales => costLines.Sum(line => line.Net);
    private decimal BillsPaid => costLines.Where(line => line.IsPaid).Sum(line => line.Net);
    private decimal BillsUnpaid => costLines.Where(line => !line.IsPaid).Sum(line => line.Net);

    private decimal Drawdown => TargetCost - WoCommitted - NonWoCostOfSales;

    // ── Position ──
    private decimal DueOut => BillsUnpaid + WoLeftToInvoice;
    private decimal NetPosition => LeftToComeIn - DueOut;

    private static string Money(decimal value) =>
        value.ToString(value == Math.Truncate(value) ? "C0" : "C2",
            System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    private static string Pct(decimal value) =>
        value.ToString("0.##", System.Globalization.CultureInfo.GetCultureInfo("en-GB")) + "%";

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        Summary.OnChanged += StateHasChanged;
        WorkOrders.OnChanged += StateHasChanged;
        ValuationReport.OnChange += StateHasChanged;
        Retention.OnChange += StateHasChanged;
        // Refresh once per tab entry (stale-while-revalidate, per the front-end
        // data-loading convention) — cached figures render immediately, then update.
        _ = Summary.RefreshAsync(ProjectId, CancellationToken.None);
        _ = WorkOrders.RefreshAsync(ProjectId, CancellationToken.None);
        ValuationReport.Refresh(ProjectId);
        Retention.Refresh(ProjectId);
        isLoaded = true;

        var invoiceSummaryTask = Queries.AskAsync(new GetProjectValuationInvoiceSummary(ProjectId), CancellationToken.None);
        var woSummariesTask = Queries.AskAsync(new ListWorkOrderInvoiceSummaries(ProjectId), CancellationToken.None);
        var costLinesTask = Queries.AskAsync(new ListProjectCostOfSalesLines(ProjectId), CancellationToken.None);
        invoiceSummary = await invoiceSummaryTask;
        woSummaries = await woSummariesTask;
        costLines = await costLinesTask;
    }

    public void Dispose()
    {
        Summary.OnChanged -= StateHasChanged;
        WorkOrders.OnChanged -= StateHasChanged;
        ValuationReport.OnChange -= StateHasChanged;
        Retention.OnChange -= StateHasChanged;
    }
}
