@page "/projects/{ProjectId}/voq/{VoqId}"
@using Jewel.JPMS.Contracts.RecordLinks
@inject AuthService Auth
@inject SessionService Session
@inject IVariationStore Variations
@inject ISubcontractorStore Subcontractors
@inject IRequestRegister RequestRegister
@inject IQueryClient Queries
@inject NavigationManager Nav
@inject IJSRuntime Js
@implements IDisposable

<PageTitle>Variation Order Quote · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (voq is null)
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="requests">
        <p class="text-sm text-content-subtle italic">That variation order quote could not be found.</p>
    </ProjectPageShell>
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="requests">
        @* Portal-accepted VOQs (subcontractor variation requests) have no originating request. *@
        @if (!string.IsNullOrWhiteSpace(voq.RequestId))
        {
            <a href="@RequestHref" class="text-sm text-content-muted hover:text-content inline-flex items-center gap-1 mb-4">
                &larr; Originating request
            </a>
        }
        else
        {
            <a href="@($"/projects/{ProjectId}/requests/variations")" class="text-sm text-content-muted hover:text-content inline-flex items-center gap-1 mb-4">
                &larr; Variations
            </a>
        }

        <div class="flex flex-wrap items-center gap-3 mb-1">
            <span class="font-mono text-sm font-semibold text-content">@voq.DisplayNumber</span>
            @if (CanManage)
            {
                @* The status pill doubles as the status control. Direct moves cover the
                   side-effect-free stages; the commercial transitions route to their real flows —
                   Approved opens the approve panel (cost code + value), and leaving Approved goes
                   through Return to tendering, which reverses the approval's writes. *@
                <div class="relative">
                    <button type="button"
                            class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-medium bg-surface-raised text-content-muted"
                            title="Change status"
                            disabled="@busy"
                            @onclick="() => voqStatusMenuOpen = !voqStatusMenuOpen">
                        @StatusLabel(voq.Status) <span class="text-[9px]" aria-hidden="true">▾</span>
                    </button>
                    @if (voqStatusMenuOpen)
                    {
                        <div class="absolute left-0 mt-2 w-60 rounded-lg border border-line bg-surface shadow-lg z-20 overflow-hidden">
                            <ul class="divide-y divide-line">
                                @if (voq.Status == VariationOrderQuoteStatus.Approved)
                                {
                                    <li>
                                        <button type="button" class="w-full text-left px-3 py-2 text-sm text-content hover:bg-surface-raised transition"
                                                @onclick="ReturnToTenderingFromPill"
                                                title="Un-approves the VOQ — reverses the approval's valuation / CVR / budget writes">
                                            Tendering — un-approve…
                                        </button>
                                    </li>
                                }
                                else
                                {
                                    @foreach (var option in VoqStatusOptions)
                                    {
                                        var status = option;
                                        // Approving needs the approve panel (cost code + value), which only
                                        // renders while no live VO exists; Selected needs a recorded tender.
                                        if (status == VariationOrderQuoteStatus.Approved && vo is not null) { continue; }
                                        var isCurrent = status == voq.Status;
                                        var selectable = !isCurrent
                                            && (status != VariationOrderQuoteStatus.Selected || !string.IsNullOrEmpty(voq.SelectedBidPackageId));
                                        <li>
                                            <button type="button"
                                                    class="w-full text-left px-3 py-2 text-sm transition @(selectable ? "text-content hover:bg-surface-raised" : "text-content-subtle cursor-default")"
                                                    disabled="@(busy || !selectable)"
                                                    title="@(status == VariationOrderQuoteStatus.Approved ? "Approving raises the VO and writes the contract figures — opens the approve panel" : !selectable && !isCurrent ? "Record a winning tender first — use the Select winning tender panel" : null)"
                                                    @onclick="() => ChangeVoqStatus(status)">
                                                @StatusLabel(status)@(status == VariationOrderQuoteStatus.Approved ? "…" : "")@(isCurrent ? " ✓" : "")
                                            </button>
                                        </li>
                                    }
                                }
                            </ul>
                        </div>
                    }
                </div>
            }
            else
            {
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium bg-surface-raised text-content-muted">@StatusLabel(voq.Status)</span>
            }
        </div>
        <h2 class="text-xl font-semibold text-content mb-5">@voq.Title</h2>

        <RecordLineage ProjectId="@ProjectId" ActiveId="voq"
                       Request="request" Voq="voq" Vo="vo" BidPackages="packages"
                       OnVoClick="FocusVariationOrderPanel" />

        @if (error is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4">@error</p>
        }

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
            <div class="lg:col-span-2 space-y-5">
                <div class="panel p-5">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="eyebrow">Bid packages</h3>
                        @if (CanManage)
                        {
                            <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => addingPackage = true">Add bid package</button>
                        }
                    </div>

                    @if (packages.Count == 0)
                    {
                        <p class="text-sm text-content-subtle italic">No bid packages yet. Add one to invite subcontractors to tender.</p>
                    }
                    else
                    {
                        <ul class="divide-y divide-line">
                            @foreach (var package in packages)
                            {
                                <li class="py-2 flex items-center justify-between gap-3">
                                    <div>
                                        <a href="@PackageHref(package.BidPackageId)" class="text-sm font-medium text-content hover:underline">@package.Title</a>
                                        <span class="text-xs text-content-subtle ml-2">@package.Trade</span>
                                        @if (voq.SelectedBidPackageId == package.BidPackageId)
                                        {
                                            <span class="ml-2 inline-flex items-center rounded bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-600">Selected</span>
                                        }
                                    </div>
                                    <a href="@PackageHref(package.BidPackageId)" class="text-xs text-content-muted hover:text-content">Open →</a>
                                </li>
                            }
                        </ul>
                    }

                    @if (addingPackage)
                    {
                        <div class="mt-4 pt-4 border-t border-line space-y-3">
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                <FormField Label="Package title" Value="@newTitle" OnChange="v => newTitle = v" Required="true" />
                                <FormField Label="Trade" Value="@newTrade" OnChange="v => newTrade = v" Required="true" />
                            </div>
                            <div class="flex gap-2">
                                <button type="button" class="btn-primary" disabled="@busy" @onclick="AddPackage">Create package</button>
                                <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => addingPackage = false">Cancel</button>
                            </div>
                        </div>
                    }
                </div>

                @* ---- Originating request: repair the missing link on the record itself ----
                       Seeded (historic) variations predate the VOQ→request link, so the lineage
                       bar shows "No request". This is where the missing RFI/request gets attached
                       — one deliberate pick on the record, not squeezed into the register. *@
                @if (voq is not null && string.IsNullOrWhiteSpace(voq.RequestId))
                {
                    <div class="panel p-5">
                        <h3 class="eyebrow mb-2">Originating request</h3>
                        @if (CanManage)
                        {
                            <p class="text-sm text-content-muted mb-3">
                                This variation isn't linked to the request (RFI) it was raised from — its history
                                can't be traced yet. Pick the right one to complete the chain; the lineage bar
                                above fills in as soon as it's linked.
                            </p>
                            <div class="flex flex-wrap items-center gap-2">
                                <SearchSelect Options="@LinkCandidateOptions"
                                              Value="@linkTargetRequestId"
                                              ValueChanged="v => linkTargetRequestId = v"
                                              Placeholder="Choose a request…"
                                              WidthClass="w-full sm:w-96"
                                              InputClass="bg-surface border border-line px-3 py-2"
                                              Disabled="@linkBusy" />
                                <button type="button" class="btn-primary"
                                        disabled="@(linkBusy || string.IsNullOrWhiteSpace(linkTargetRequestId))"
                                        @onclick="LinkToRequest">
                                    @(linkBusy ? "Linking…" : "Link request")
                                </button>
                            </div>
                            @if (linkError is not null)
                            {
                                <p class="text-xs text-negative mt-2">@linkError</p>
                            }
                            <p class="text-xs text-content-subtle mt-3">
                                RFIs are listed first — the stage a VOQ is normally raised from. Requests already
                                carrying a VOQ aren't offered (a request has at most one).
                            </p>
                        }
                        else
                        {
                            <p class="text-sm text-content-subtle italic">
                                This variation isn't linked to an originating request. A project manager or QS can
                                attach the right RFI here.
                            </p>
                        }
                    </div>
                }

                @* ---- Communications: the mail behind this record, read live by tag ----
                       Emails tagged to the VOQ or its VO in mailbox triage appear here, so the
                       correspondence behind the quote and the order is visible where the record
                       lives — not only on the project's Communications tab. *@
                <div class="panel p-5">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="eyebrow">Communications</h3>
                        @if (emailsLoaded && emails.Count > 0)
                        {
                            <span class="inline-flex items-center rounded-full bg-accent/10 px-2 py-0.5 text-[11px] font-medium text-accent">@emails.Count</span>
                        }
                    </div>

                    @if (emailsError is not null)
                    {
                        <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@emailsError</p>
                    }

                    @if (!emailsLoaded)
                    {
                        <p class="text-sm text-content-subtle">Loading…</p>
                    }
                    else if (emails.Count == 0)
                    {
                        <p class="text-sm text-content-subtle italic">
                            No emails are tagged to this variation yet. Tag an email to
                            <span class="font-medium not-italic text-content">@voq?.Reference</span>@(vo is { } order ? $" or {order.VariationRef}" : "")
                            in mailbox triage and it appears here.
                        </p>
                    }
                    else
                    {
                        <ul class="space-y-2">
                            @foreach (var email in emails)
                            {
                                <li class="rounded-lg border border-line bg-surface px-4 py-3">
                                    <div class="flex flex-wrap items-center justify-between gap-2">
                                        <span class="text-sm font-medium text-content">@(string.IsNullOrWhiteSpace(email.FromName) ? email.FromEmail : email.FromName)</span>
                                        <span class="text-xs text-content-subtle">@email.ReceivedAt.LocalDateTime.ToString("d MMM yyyy, HH:mm")</span>
                                    </div>
                                    <p class="text-sm text-content mt-0.5">
                                        @email.Subject
                                        @if (email.HasAttachments)
                                        {
                                            <span class="ml-2 inline-flex items-center rounded bg-surface-raised border border-line px-1.5 py-0.5 text-[10px] text-content-subtle">attachment</span>
                                        }
                                    </p>
                                    @if (!string.IsNullOrWhiteSpace(email.BodyPreview))
                                    {
                                        <p class="text-xs text-content-subtle mt-1 line-clamp-2">@email.BodyPreview</p>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <div class="space-y-5">
                <div class="panel p-5 space-y-3 text-sm">
                    <div class="flex justify-between"><span class="text-content-subtle">Reference</span><span class="font-mono">@voq.Reference</span></div>
                    <div class="flex justify-between"><span class="text-content-subtle">Status</span><span>@StatusLabel(voq.Status)</span></div>
                    <div class="flex justify-between"><span class="text-content-subtle">Estimated value</span><span>@(voq.EstimatedValue is null ? "—" : Money(voq.EstimatedValue.Value))</span></div>
                    <div class="flex justify-between"><span class="text-content-subtle">Selected sub</span><span>@SelectedSubName()</span></div>
                </div>

                @if (vo is not null)
                {
                    @* id anchors the lineage bar's VO chip: clicking it scrolls here and flashes
                       the panel (jpmsFocusElement), so the click lands visibly. *@
                    <div id="variation-order" class="panel p-5 space-y-3">
                        <h3 class="eyebrow">Variation Order</h3>
                        <div class="text-sm text-content flex items-center">
                            <span class="font-mono font-semibold">@vo.VariationRef</span>
                            @if (CanManage && vo.Status != VariationOrderStatus.Cancelled)
                            {
                                @* The VO pill is the status control: Issued / back to Approved are
                                   record corrections; Cancelled is a real commercial event and opens
                                   a confirm spelling out the reversal before anything happens. *@
                                <div class="relative ml-2">
                                    <button type="button"
                                            class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-medium bg-surface-raised text-content-muted"
                                            title="Change status"
                                            disabled="@busy"
                                            @onclick="() => voStatusMenuOpen = !voStatusMenuOpen">
                                        @vo.Status <span class="text-[9px]" aria-hidden="true">▾</span>
                                    </button>
                                    @if (voStatusMenuOpen)
                                    {
                                        <div class="absolute left-0 mt-2 w-44 rounded-lg border border-line bg-surface shadow-lg z-20 overflow-hidden">
                                            <ul class="divide-y divide-line">
                                                @foreach (var option in VoStatusOptions)
                                                {
                                                    var status = option;
                                                    var isCurrent = status == vo.Status;
                                                    <li>
                                                        <button type="button"
                                                                class="w-full text-left px-3 py-2 text-sm transition @(isCurrent ? "text-content-subtle cursor-default" : status == VariationOrderStatus.Cancelled ? "text-negative hover:bg-surface-raised" : "text-content hover:bg-surface-raised")"
                                                                disabled="@(busy || isCurrent)"
                                                                title="@(status == VariationOrderStatus.Cancelled ? "A real commercial event — reverses the approval's valuation / CVR / budget writes" : null)"
                                                                @onclick="() => ChangeVoStatus(status)">
                                                            @(status == VariationOrderStatus.Cancelled ? "Cancelled…" : status.ToString())@(isCurrent ? " ✓" : "")
                                                        </button>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium bg-surface-raised text-content-muted ml-2">@vo.Status</span>
                            }
                        </div>
                        <div class="flex justify-between text-sm"><span class="text-content-subtle">Value</span><span>@Money(vo.Value)</span></div>
                        <div class="flex justify-between text-sm"><span class="text-content-subtle">Cost code</span><span class="font-mono">@vo.CostCode</span></div>
                        <p class="text-xs text-content-subtle">Added to the Valuation Report and committed to the cost centre.</p>
                        @if (CanManage && vo.Status == VariationOrderStatus.Approved)
                        {
                            <button type="button" class="btn-secondary w-full" disabled="@busy" @onclick="IssueVo">Mark as issued</button>
                        }
                        @if (CanManage && vo.Status != VariationOrderStatus.Cancelled)
                        {
                            @if (!revisingValue)
                            {
                                <button type="button" class="btn-secondary w-full" disabled="@busy" @onclick="StartReviseValue">Revise value</button>
                            }
                            else
                            {
                                <div class="pt-3 border-t border-line space-y-3">
                                    <FormField Label="Revised value (£)" Value="@reviseValue" OnChange="v => reviseValue = v" InputType="number" Required="true" />
                                    <p class="text-xs text-content-subtle">
                                        Re-prices the @vo.VariationRef line on the Valuation Report, records the
                                        difference on the CVR and moves the committed cost-centre budget.
                                    </p>
                                    <div class="flex gap-2">
                                        <button type="button" class="btn-primary" disabled="@busy" @onclick="ReviseVoValue">Save revised value</button>
                                        <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => revisingValue = false">Cancel</button>
                                    </div>
                                </div>
                            }
                        }
                        @if (CanManage && vo.Status != VariationOrderStatus.Cancelled)
                        {
                            <div class="pt-3 border-t border-line space-y-2">
                                @if (!returningToTendering)
                                {
                                    <button type="button" class="w-full text-xs text-content-subtle hover:text-negative underline underline-offset-2"
                                            disabled="@busy" @onclick="() => returningToTendering = true">
                                        Approved in error? Return to tendering…
                                    </button>
                                }
                                else
                                {
                                    <p class="text-xs text-content-subtle">
                                        Un-approves this variation: <span class="font-mono">@vo.VariationRef</span> is removed
                                        (its number is freed for a future approval), its value comes off the Valuation Report,
                                        CVR and cost-centre budget, and @voq.Reference returns to <span class="font-medium text-content">Tendering</span>.
                                        For approvals that shouldn't have happened — a real cancellation should use Cancel so
                                        the VO stays on the record. Blocked once work orders instruct it or value has been claimed.
                                    </p>
                                    <div class="flex gap-2">
                                        <button type="button" class="btn-secondary w-full text-negative" disabled="@busy" @onclick="ReturnToTendering">
                                            @(busy ? "Returning…" : "Confirm — return to tendering")
                                        </button>
                                        <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => returningToTendering = false">Keep</button>
                                    </div>
                                }
                            </div>
                        }
                        @if (CanManage && cancellingVo && vo.Status != VariationOrderStatus.Cancelled)
                        {
                            <div class="pt-3 border-t border-line space-y-2">
                                <p class="text-xs text-content-subtle">
                                    Cancelling <span class="font-mono">@vo.VariationRef</span> is a real commercial
                                    event: the VO stays on the register as Cancelled, its line comes off the
                                    Valuation Report, an offsetting omit is recorded on the CVR and the committed
                                    cost-centre budget is released. If the approval itself was a data error, use
                                    Return to tendering instead so the V-ref is freed.
                                </p>
                                <div class="flex gap-2">
                                    <button type="button" class="btn-secondary w-full text-negative" disabled="@busy" @onclick="CancelVo">
                                        @(busy ? "Cancelling…" : "Confirm — cancel variation order")
                                    </button>
                                    <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => cancellingVo = false">Keep</button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (CanManage && voq.Status is not (VariationOrderQuoteStatus.Rejected or VariationOrderQuoteStatus.Approved))
                {
                    @* Approval runs from any pre-approved status. With a selected tender this is
                       the normal end of the pipeline; without one it is a MANUAL approval — the
                       route for historic (seeded) and client-instructed variations that never
                       tendered through the app. The write-through (Valuation Report, CVR,
                       cost-centre budget) is identical either way. *@
                    var isManualApproval = voq.Status != VariationOrderQuoteStatus.Selected;
                    @* id anchors the status pill's "Approved…" pick: it scrolls here and flashes
                       the panel, because approval always needs the cost code + value below. *@
                    <div id="approve-voq" class="panel p-5 space-y-3">
                        <h3 class="eyebrow">@(isManualApproval ? "Approve manually & raise Variation Order" : "Approve & raise Variation Order")</h3>
                        @if (isManualApproval)
                        {
                            <p class="text-xs text-content-subtle">
                                No winning tender has been selected — approving here raises the VO without a
                                subcontractor attached. The value still writes through to the Valuation Report,
                                the CVR and the cost-centre budget, exactly like a tendered approval.
                            </p>
                        }
                        else
                        {
                            <p class="text-xs text-content-subtle">Approving writes the value into the Valuation Report, the CVR and the cost-centre budget.</p>
                        }
                        <FormField Label="Cost code" Value="@approveCostCode" OnChange="v => approveCostCode = v" Required="true" />
                        <FormField Label="Value (£)" Value="@approveValue" OnChange="v => approveValue = v" InputType="number" />
                        <p class="text-xs text-content-subtle">Use a negative value for an omit — work removed from the contract scope.</p>
                        <button type="button" class="btn-primary w-full" disabled="@busy" @onclick="ApproveVoq">
                            @(isManualApproval ? "Approve manually & raise VO" : "Approve & raise VO")
                        </button>
                    </div>
                }
                else if (CanManage && voq.Status == VariationOrderQuoteStatus.Approved)
                {
                    @* Data anomaly: a VOQ marked Approved with no live VO behind it (e.g. partially
                       seeded history, or its VO was cancelled). Offer the same repair route. *@
                    <div class="panel p-5 space-y-3">
                        <h3 class="eyebrow">Approved — no variation order</h3>
                        <p class="text-xs text-content-subtle">
                            This quote is marked Approved but no live variation order exists for it.
                            Return it to Tendering to re-run the approval properly.
                        </p>
                        <button type="button" class="btn-secondary w-full" disabled="@busy" @onclick="ReturnToTendering">
                            @(busy ? "Returning…" : "Return to tendering")
                        </button>
                    </div>
                }

                @if (CanManage && packages.Count > 0 && vo is null)
                {
                    <div class="panel p-5 space-y-3">
                        <h3 class="eyebrow">Select winning tender</h3>
                        <div>
                            <label class="eyebrow block mb-1">Bid package</label>
                            <select class="field" value="@selBidPackageId" @onchange="OnBidPackageChanged">
                                <option value="">— Choose —</option>
                                @foreach (var package in packages)
                                {
                                    <option value="@package.BidPackageId">@package.Title</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="eyebrow block mb-1">Subcontractor</label>
                            <select class="field" value="@selSubId" @onchange="OnSubChanged">
                                <option value="">— Choose —</option>
                                @foreach (var sub in Subs)
                                {
                                    <option value="@sub.SubcontractorId">@sub.CompanyName</option>
                                }
                            </select>
                        </div>
                        <FormField Label="Agreed value (£)" Value="@selValue" OnChange="v => selValue = v" InputType="number" />
                        <button type="button" class="btn-primary w-full" disabled="@busy" @onclick="SelectTender">Record selection</button>
                    </div>
                }
            </div>
        </div>
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string VoqId { get; set; } = "";

    private bool isLoaded;
    private bool busy;
    private string? error;
    private VariationOrderQuote? voq;
    private VariationOrder? vo;
    private IReadOnlyList<BidPackage> packages = Array.Empty<BidPackage>();
    private Request? request; // originating request, for the lineage bar

    private string approveCostCode = "";
    private string approveValue = "";

    private bool revisingValue;
    private string reviseValue = "";

    private bool returningToTendering;

    // Status pill dropdowns (VOQ header and VO panel) — same dismiss pattern as the request
    // page's Actions dropdown: every item closes it before running, the toggle is the dismiss.
    private bool voqStatusMenuOpen;
    private bool voStatusMenuOpen;
    // Cancelling a VO reverses the approval's commercial writes, so the pill routes through an
    // inline confirm rather than acting on the click.
    private bool cancellingVo;

    private static readonly VariationOrderQuoteStatus[] VoqStatusOptions =
    {
        VariationOrderQuoteStatus.Draft, VariationOrderQuoteStatus.Inviting,
        VariationOrderQuoteStatus.Tendering, VariationOrderQuoteStatus.Selected,
        VariationOrderQuoteStatus.Approved, VariationOrderQuoteStatus.Rejected
    };

    private static readonly VariationOrderStatus[] VoStatusOptions =
    {
        VariationOrderStatus.Approved, VariationOrderStatus.Issued, VariationOrderStatus.Cancelled
    };

    private bool addingPackage;
    private string newTitle = "";
    private string newTrade = "";

    private string selBidPackageId = "";
    private string selSubId = "";
    private string selValue = "";

    // ---- Originating-request repair (the register's old inline Link… UI now lives here) ----
    private string linkTargetRequestId = "";
    private bool linkBusy;
    private string? linkError;
    private IReadOnlyList<VariationOrderQuote> projectQuotes = Array.Empty<VariationOrderQuote>();

    // ---- Communications: emails tagged to the VOQ and (once raised) its VO ----
    private bool emailsLoaded;
    private string? emailsError;
    private IReadOnlyList<MailboxMessage> emails = Array.Empty<MailboxMessage>();

    private string RequestHref => voq is null ? $"/projects/{ProjectId}/requests" : $"/projects/{ProjectId}/requests/view/{voq.RequestId}";
    private string PackageHref(string bidPackageId) => $"/projects/{ProjectId}/bid-package-invites/{bidPackageId}";

    private bool CanManage => Session.AvailableRoles.Any(role =>
        role is Role.Admin or Role.ManagingDirector or Role.ProjectManager or Role.QuantitySurveyor);

    private IReadOnlyList<Subcontractor> Subs => Subcontractors.All();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        Subcontractors.OnChange += StateHasChanged;
        _ = Subcontractors.All(); // warm the directory cache for the tender dropdown
        // Revalidate the request register in the background (stale-while-revalidate) — it feeds
        // the originating-request picker for unlinked (seeded) VOQs.
        RequestRegister.Refresh(ProjectId);
        RequestRegister.OnChange += StateHasChanged;
        await ReloadAsync();
        isLoaded = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Arriving via a VO chip elsewhere in the app ("…/voq/{id}?focus=vo"): land focused on
        // the Variation Order panel so the navigation visibly reaches the VO, not just the page.
        if (firstRender && vo is not null && WantsVoFocus())
            await FocusVariationOrderPanel();
    }

    private bool WantsVoFocus()
    {
        var query = new Uri(Nav.Uri).Query;
        return query.Contains("focus=vo", StringComparison.OrdinalIgnoreCase);
    }

    // The lineage bar's VO chip on this page: the VO lives here, so scroll to and flash its panel.
    private async Task FocusVariationOrderPanel()
    {
        try { await Js.InvokeVoidAsync("jpmsFocusElement", "variation-order"); }
        catch { /* purely cosmetic — never let a scroll failure break the page */ }
    }

    public void Dispose()
    {
        Subcontractors.OnChange -= StateHasChanged;
        RequestRegister.OnChange -= StateHasChanged;
    }

    private async Task ReloadAsync()
    {
        try
        {
            voq = await Variations.GetByIdAsync(VoqId);
            packages = await Variations.ListBidPackagesAsync(VoqId);
            vo = await Variations.GetVariationOrderByVoqAsync(VoqId);
            // Originating request for the lineage bar — best-effort, the bar shows a placeholder
            // without it. Portal-accepted VOQs have no request at all (RequestId is empty).
            if (voq is not null && !string.IsNullOrWhiteSpace(voq.RequestId))
            {
                try { request = await RequestRegister.GetAsync(voq.RequestId); }
                catch { request = null; }
            }
            if (string.IsNullOrEmpty(approveValue) && voq?.EstimatedValue is { } est)
                approveValue = est.ToString(System.Globalization.CultureInfo.InvariantCulture);
            // The originating-request picker must not offer requests already carrying a VOQ
            // (a request has at most one), so it needs the project's other quotes to exclude.
            if (voq is not null && string.IsNullOrWhiteSpace(voq.RequestId))
                projectQuotes = await Variations.ListForProjectAsync(ProjectId);
            error = null;
        }
        catch { error = "Couldn't load the variation order quote. Please try again."; }

        await LoadEmailsAsync();
    }

    // The mail behind this record: everything tagged to the VOQ plus, once the VO is raised,
    // everything tagged to the VO — one merged, newest-first list (an email tagged to both, e.g.
    // a whole thread synced across the approval, appears once).
    private async Task LoadEmailsAsync()
    {
        emailsError = null;
        try
        {
            var tagged = new List<MailboxMessage>(
                await Queries.AskAsync(new ListRecordEmails(RecordType.VariationQuote, VoqId), CancellationToken.None));
            if (vo is not null)
                tagged.AddRange(await Queries.AskAsync(new ListRecordEmails(RecordType.Variation, vo.VariationOrderId), CancellationToken.None));
            emails = tagged
                .GroupBy(email => string.IsNullOrEmpty(email.InternetMessageId) ? email.Id : email.InternetMessageId)
                .Select(group => group.First())
                .OrderByDescending(email => email.ReceivedAt)
                .ToList();
        }
        catch
        {
            emails = Array.Empty<MailboxMessage>();
            emailsError = "Couldn't load this variation's emails. Please try again.";
        }
        finally { emailsLoaded = true; }
    }

    // ---- Originating-request repair --------------------------------------------------------

    // RFIs first — the stage a VOQ is normally raised from — then the rest of the register;
    // requests already carrying a VOQ are out (a request has at most one).
    private IReadOnlyList<SearchSelect.Option> LinkCandidateOptions
    {
        get
        {
            var taken = projectQuotes
                .Where(quote => !string.IsNullOrWhiteSpace(quote.RequestId) && quote.VariationOrderQuoteId != VoqId)
                .Select(quote => quote.RequestId)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            return RequestRegister.ForProject(ProjectId)
                .Where(r => !taken.Contains(r.RequestId))
                .OrderBy(r => r.Kind == RequestType.Rfi ? 0 : 1)
                .ThenBy(r => r.Reference, StringComparer.OrdinalIgnoreCase)
                .Select(r => new SearchSelect.Option(r.RequestId, $"{RefLabel(r)} — {r.Title}"))
                .ToList();
        }
    }

    private static string RefLabel(Request record) =>
        string.IsNullOrWhiteSpace(record.Reference) ? record.DisplayNumber : record.Reference;

    private async Task LinkToRequest()
    {
        if (linkBusy || string.IsNullOrWhiteSpace(linkTargetRequestId)) return;
        linkError = null;
        try
        {
            linkBusy = true;
            await Variations.LinkToRequestAsync(VoqId, linkTargetRequestId);
            linkTargetRequestId = "";
            await ReloadAsync(); // the lineage bar re-renders with the request chip in place
        }
        catch (CommandFailedException ex) { linkError = ex.Message; }
        catch { linkError = "Couldn't link the request. Please try again."; }
        finally { linkBusy = false; }
    }

    private async Task AddPackage()
    {
        if (busy) return;
        error = null;
        if (string.IsNullOrWhiteSpace(newTitle) || string.IsNullOrWhiteSpace(newTrade)) { error = "A title and trade are required."; return; }
        try
        {
            busy = true;
            await Variations.AddBidPackageAsync(VoqId, newTitle.Trim(), newTrade.Trim());
            newTitle = newTrade = "";
            addingPackage = false;
            await ReloadAsync();
        }
        catch { error = "Couldn't add the bid package. Please try again."; }
        finally { busy = false; }
    }

    private void OnBidPackageChanged(ChangeEventArgs e) => selBidPackageId = e.Value?.ToString() ?? "";
    private void OnSubChanged(ChangeEventArgs e) => selSubId = e.Value?.ToString() ?? "";

    private async Task ApproveVoq()
    {
        if (busy) return;
        error = null;
        if (string.IsNullOrWhiteSpace(approveCostCode)) { error = "A cost code is required to approve."; return; }
        decimal? value = decimal.TryParse(approveValue, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var parsed) ? parsed : null;
        if (value is 0m || (value is null && voq?.EstimatedValue is null or 0m))
        {
            error = "Enter the agreed value — negative for an omit. A zero value cannot be approved.";
            return;
        }
        try
        {
            busy = true;
            vo = await Variations.ApproveVoqAsync(VoqId, approveCostCode.Trim(), value);
            await ReloadAsync();
        }
        catch { error = "Couldn't approve the VOQ. Please try again."; }
        finally { busy = false; }
    }

    private async Task IssueVo()
    {
        if (busy || vo is null) return;
        error = null;
        try
        {
            busy = true;
            vo = await Variations.IssueVariationOrderAsync(vo.VariationOrderId);
            await ReloadAsync();
        }
        catch { error = "Couldn't issue the variation order. Please try again."; }
        finally { busy = false; }
    }

    // ---- Status pill dropdowns ------------------------------------------------------------------

    // Direct moves between the side-effect-free VOQ stages. The two commercial transitions route
    // to their real flows instead: Approved scrolls to the approve panel (it needs a cost code and
    // value, and writes the contract figures), and leaving Approved goes through Return to
    // tendering so the approval's writes are reversed, never skipped.
    private async Task ChangeVoqStatus(VariationOrderQuoteStatus status)
    {
        voqStatusMenuOpen = false;
        if (busy || voq is null || status == voq.Status) return;
        error = null;

        if (status == VariationOrderQuoteStatus.Approved)
        {
            await FocusApprovePanel();
            return;
        }

        try
        {
            busy = true;
            voq = await Variations.SetVoqStatusAsync(VoqId, status);
            await ReloadAsync();
        }
        catch (CommandFailedException ex) { error = ex.Message; }
        catch { error = "Couldn't change the status. Please try again."; }
        finally { busy = false; }
    }

    // Leaving Approved from the pill: with a live VO the existing confirm (in the VO panel) takes
    // over so the reversal is spelled out; with no VO behind the approval (the data-anomaly case)
    // the return runs directly, mirroring the "Approved — no variation order" panel's button.
    private async Task ReturnToTenderingFromPill()
    {
        voqStatusMenuOpen = false;
        if (busy) return;
        if (vo is not null)
        {
            returningToTendering = true;
            await FocusVariationOrderPanel();
        }
        else
        {
            await ReturnToTendering();
        }
    }

    // The VO pill: Issued and back-to-Approved are record corrections and run directly; Cancelled
    // is a real commercial event, so the pick opens the inline confirm instead of acting.
    private async Task ChangeVoStatus(VariationOrderStatus status)
    {
        voStatusMenuOpen = false;
        if (busy || vo is null || status == vo.Status) return;
        error = null;

        if (status == VariationOrderStatus.Cancelled)
        {
            cancellingVo = true;
            return;
        }

        try
        {
            busy = true;
            vo = status == VariationOrderStatus.Issued
                ? await Variations.IssueVariationOrderAsync(vo.VariationOrderId)
                : await Variations.RevertVariationOrderToApprovedAsync(vo.VariationOrderId);
            await ReloadAsync();
        }
        catch (CommandFailedException ex) { error = ex.Message; }
        catch { error = "Couldn't change the variation order status. Please try again."; }
        finally { busy = false; }
    }

    private async Task CancelVo()
    {
        if (busy || vo is null) return;
        error = null;
        try
        {
            busy = true;
            vo = await Variations.CancelVariationOrderAsync(vo.VariationOrderId);
            cancellingVo = false;
            await ReloadAsync();
        }
        catch (CommandFailedException ex) { error = ex.Message; }
        catch { error = "Couldn't cancel the variation order. Please try again."; }
        finally { busy = false; }
    }

    private async Task FocusApprovePanel()
    {
        try { await Js.InvokeVoidAsync("jpmsFocusElement", "approve-voq"); }
        catch { /* purely cosmetic — never let a scroll failure break the page */ }
    }

    private async Task ReturnToTendering()
    {
        if (busy) return;
        error = null;
        try
        {
            busy = true;
            voq = await Variations.ReturnToTenderingAsync(VoqId);
            vo = null;
            returningToTendering = false;
            await ReloadAsync(); // lineage bar drops the VO chip; the approve panel reappears
        }
        catch (CommandFailedException ex) { error = ex.Message; }
        catch { error = "Couldn't return the VOQ to tendering. Please try again."; }
        finally { busy = false; }
    }

    private void StartReviseValue()
    {
        reviseValue = vo?.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
        revisingValue = true;
        error = null;
    }

    private async Task ReviseVoValue()
    {
        if (busy || vo is null) return;
        error = null;
        if (!decimal.TryParse(reviseValue, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var value))
        {
            error = "Enter a valid revised value.";
            return;
        }
        try
        {
            busy = true;
            vo = await Variations.ReviseVariationOrderValueAsync(vo.VariationOrderId, value);
            revisingValue = false;
            await ReloadAsync();
        }
        catch { error = "Couldn't revise the variation order value. Please try again."; }
        finally { busy = false; }
    }

    private async Task SelectTender()
    {
        if (busy) return;
        error = null;
        if (string.IsNullOrWhiteSpace(selBidPackageId) || string.IsNullOrWhiteSpace(selSubId)) { error = "Choose a bid package and a subcontractor."; return; }
        decimal? value = decimal.TryParse(selValue, out var parsed) ? parsed : null;
        try
        {
            busy = true;
            voq = await Variations.SelectTenderAsync(VoqId, selBidPackageId, selSubId, value);
            await ReloadAsync();
        }
        catch { error = "Couldn't record the selection. Please try again."; }
        finally { busy = false; }
    }

    private string SelectedSubName()
    {
        if (voq?.SelectedSubcontractorId is null) return "—";
        return Subcontractors.Find(voq.SelectedSubcontractorId)?.CompanyName ?? voq.SelectedSubcontractorId;
    }

    private static string StatusLabel(VariationOrderQuoteStatus status) => status switch
    {
        VariationOrderQuoteStatus.Draft     => "Draft",
        VariationOrderQuoteStatus.Inviting  => "Inviting",
        VariationOrderQuoteStatus.Tendering => "Tendering",
        VariationOrderQuoteStatus.Selected  => "Selected",
        VariationOrderQuoteStatus.Approved  => "Approved",
        VariationOrderQuoteStatus.Rejected  => "Rejected",
        _ => status.ToString()
    };

    private static string Money(decimal value) => value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
