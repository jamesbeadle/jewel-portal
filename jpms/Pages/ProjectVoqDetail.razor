@page "/projects/{ProjectId}/voq/{VoqId}"
@using Jewel.JPMS.Contracts.RecordLinks
@inject AuthService Auth
@inject SessionService Session
@inject IVariationStore Variations
@inject ISubcontractorStore Subcontractors
@inject IRequestRegister RequestRegister
@inject IQueryClient Queries
@inject NavigationManager Nav
@inject IJSRuntime Js
@implements IDisposable

<PageTitle>Variation Order · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else if (order is null)
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="requests">
        <p class="text-sm text-content-subtle italic">That variation order could not be found.</p>
    </ProjectPageShell>
}
else
{
    <ProjectPageShell ProjectId="@ProjectId" ActiveTab="requests">
        @* Portal-accepted variation orders (subcontractor variation requests) have no originating request. *@
        @if (!string.IsNullOrWhiteSpace(order.RequestId))
        {
            <a href="@RequestHref" class="text-sm text-content-muted hover:text-content inline-flex items-center gap-1 mb-4">
                &larr; Originating request
            </a>
        }
        else
        {
            <a href="@($"/projects/{ProjectId}/requests/variations")" class="text-sm text-content-muted hover:text-content inline-flex items-center gap-1 mb-4">
                &larr; Variations
            </a>
        }

        <div class="flex flex-wrap items-center gap-3 mb-1">
            <span class="font-mono text-sm font-semibold text-content">@order.DisplayNumber</span>
            @if (CanManage && order.Status != VariationOrderStatus.Rejected)
            {
                @* The status pill doubles as the status control. Direct moves cover the
                   side-effect-free stages (Quoting, Issued, Awaiting AI); the commercial transitions route to
                   their real flows — Approved opens the approve panel (cost code + value), Rejected
                   from Approved reverses the approval's writes, and leaving Approved for Quoting is
                   the "return to quoting" repair. Rejected is terminal — no menu once reached. *@
                <div class="relative">
                    <button type="button"
                            class="inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[11px] font-medium bg-surface-raised text-content-muted"
                            title="Change status"
                            disabled="@busy"
                            @onclick="() => orderStatusMenuOpen = !orderStatusMenuOpen">
                        @StatusLabel(order.Status) <span class="text-[9px]" aria-hidden="true">▾</span>
                    </button>
                    @if (orderStatusMenuOpen)
                    {
                        <div class="absolute left-0 mt-2 w-64 rounded-lg border border-line bg-surface shadow-lg z-20 overflow-hidden">
                            <ul class="divide-y divide-line">
                                @foreach (var option in OrderStatusOptions)
                                {
                                    var status = option;
                                    var isCurrent = status == order.Status;
                                    var blocked = order.Status == VariationOrderStatus.Approved && status == VariationOrderStatus.Issued;
                                    var selectable = !isCurrent && !blocked;
                                    <li>
                                        <button type="button"
                                                class="w-full text-left px-3 py-2 text-sm transition @(selectable ? "text-content hover:bg-surface-raised" : "text-content-subtle cursor-default")"
                                                disabled="@(busy || !selectable)"
                                                title="@PillOptionTitle(status)"
                                                @onclick="() => ChangeStatus(status)">
                                            @PillOptionLabel(status)@(isCurrent ? " ✓" : "")
                                        </button>
                                    </li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }
            else
            {
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium bg-surface-raised text-content-muted">@StatusLabel(order.Status)</span>
            }
        </div>
        <h2 class="text-xl font-semibold text-content mb-5">@order.Title</h2>

        <RecordLineage ProjectId="@ProjectId" ActiveId="voq"
                       Request="request" Voq="order" Vo="@(order?.Status == VariationOrderStatus.Approved ? order : null)" BidPackages="packages"
                       OnVoClick="FocusVariationOrderPanel" />

        @if (error is not null)
        {
            <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-4">@error</p>
        }

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
            <div class="lg:col-span-2 space-y-5">
                <div class="panel p-5">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="eyebrow">Bid packages</h3>
                        @if (CanManage)
                        {
                            <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => addingPackage = true">Add bid package</button>
                        }
                    </div>

                    @if (packages.Count == 0)
                    {
                        <p class="text-sm text-content-subtle italic">No bid packages yet. Add one to invite subcontractors to tender.</p>
                    }
                    else
                    {
                        <ul class="divide-y divide-line">
                            @foreach (var package in packages)
                            {
                                <li class="py-2 flex items-center justify-between gap-3">
                                    <div>
                                        <a href="@PackageHref(package.BidPackageId)" class="text-sm font-medium text-content hover:underline">@package.Title</a>
                                        <span class="text-xs text-content-subtle ml-2">@package.Trade</span>
                                        @if (order.SelectedBidPackageId == package.BidPackageId)
                                        {
                                            <span class="ml-2 inline-flex items-center rounded bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-amber-600">Selected</span>
                                        }
                                    </div>
                                    <a href="@PackageHref(package.BidPackageId)" class="text-xs text-content-muted hover:text-content">Open →</a>
                                </li>
                            }
                        </ul>
                    }

                    @if (addingPackage)
                    {
                        <div class="mt-4 pt-4 border-t border-line space-y-3">
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                <FormField Label="Package title" Value="@newTitle" OnChange="v => newTitle = v" Required="true" />
                                <FormField Label="Trade" Value="@newTrade" OnChange="v => newTrade = v" Required="true" />
                            </div>
                            <div class="flex gap-2">
                                <button type="button" class="btn-primary" disabled="@busy" @onclick="AddPackage">Create package</button>
                                <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => addingPackage = false">Cancel</button>
                            </div>
                        </div>
                    }
                </div>

                @* ---- Originating request: repair the missing link on the record itself ----
                       Seeded (historic) variations predate the request link, so the lineage
                       bar shows "No request". This is where the missing RFI/request gets attached
                       — one deliberate pick on the record, not squeezed into the register. *@
                @if (string.IsNullOrWhiteSpace(order.RequestId))
                {
                    <div class="panel p-5">
                        <h3 class="eyebrow mb-2">Originating request</h3>
                        @if (CanManage)
                        {
                            <p class="text-sm text-content-muted mb-3">
                                This variation isn't linked to the request (RFI) it was raised from — its history
                                can't be traced yet. Pick the right one to complete the chain; the lineage bar
                                above fills in as soon as it's linked.
                            </p>
                            <div class="flex flex-wrap items-center gap-2">
                                <SearchSelect Options="@LinkCandidateOptions"
                                              Value="@linkTargetRequestId"
                                              ValueChanged="v => linkTargetRequestId = v"
                                              Placeholder="Choose a request…"
                                              WidthClass="w-full sm:w-96"
                                              InputClass="bg-surface border border-line px-3 py-2"
                                              Disabled="@linkBusy" />
                                <button type="button" class="btn-primary"
                                        disabled="@(linkBusy || string.IsNullOrWhiteSpace(linkTargetRequestId))"
                                        @onclick="LinkToRequest">
                                    @(linkBusy ? "Linking…" : "Link request")
                                </button>
                            </div>
                            @if (linkError is not null)
                            {
                                <p class="text-xs text-negative mt-2">@linkError</p>
                            }
                            <p class="text-xs text-content-subtle mt-3">
                                RFIs are listed first — the stage a variation order is normally raised from. Requests
                                already carrying a variation order aren't offered (a request has at most one).
                            </p>
                        }
                        else
                        {
                            <p class="text-sm text-content-subtle italic">
                                This variation isn't linked to an originating request. A project manager or QS can
                                attach the right RFI here.
                            </p>
                        }
                    </div>
                }

                @* ---- Communications: the mail behind this record, read live by tag ----
                       Emails tagged to the record's quoting reference or (once approved) its V-ref
                       in mailbox triage appear here, so the correspondence behind the variation is
                       visible where the record lives — not only on the project's Communications tab. *@
                <div class="panel p-5">
                    <div class="flex items-center justify-between mb-3">
                        <h3 class="eyebrow">Communications</h3>
                        @if (emailsLoaded && emails.Count > 0)
                        {
                            <span class="inline-flex items-center rounded-full bg-accent/10 px-2 py-0.5 text-[11px] font-medium text-accent">@emails.Count</span>
                        }
                    </div>

                    @if (emailsError is not null)
                    {
                        <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative mb-3">@emailsError</p>
                    }

                    @if (!emailsLoaded)
                    {
                        <p class="text-sm text-content-subtle">Loading…</p>
                    }
                    else if (emails.Count == 0)
                    {
                        <p class="text-sm text-content-subtle italic">
                            No emails are tagged to this variation yet. Tag an email to
                            <span class="font-medium not-italic text-content">@order.Reference</span>@(ApprovedOrder is not null ? $" or {order.VariationRef}" : "")
                            in mailbox triage and it appears here.
                        </p>
                    }
                    else
                    {
                        <ul class="space-y-2">
                            @foreach (var email in emails)
                            {
                                <li class="rounded-lg border border-line bg-surface px-4 py-3">
                                    <div class="flex flex-wrap items-center justify-between gap-2">
                                        <span class="text-sm font-medium text-content">@(string.IsNullOrWhiteSpace(email.FromName) ? email.FromEmail : email.FromName)</span>
                                        <span class="text-xs text-content-subtle">@email.ReceivedAt.LocalDateTime.ToString("d MMM yyyy, HH:mm")</span>
                                    </div>
                                    <p class="text-sm text-content mt-0.5">
                                        @email.Subject
                                        @if (email.HasAttachments)
                                        {
                                            <span class="ml-2 inline-flex items-center rounded bg-surface-raised border border-line px-1.5 py-0.5 text-[10px] text-content-subtle">attachment</span>
                                        }
                                    </p>
                                    @if (!string.IsNullOrWhiteSpace(email.BodyPreview))
                                    {
                                        <p class="text-xs text-content-subtle mt-1 line-clamp-2">@email.BodyPreview</p>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <div class="space-y-5">
                <div class="panel p-5 space-y-3 text-sm">
                    <div class="flex justify-between"><span class="text-content-subtle">Reference</span><span class="font-mono">@order.Reference</span></div>
                    <div class="flex justify-between"><span class="text-content-subtle">Status</span><span>@StatusLabel(order.Status)</span></div>
                    <div class="flex justify-between"><span class="text-content-subtle">Estimated value</span><span>@(order.EstimatedValue is null ? "—" : Money(order.EstimatedValue.Value))</span></div>
                    <div class="flex justify-between"><span class="text-content-subtle">Selected sub</span><span>@SelectedSubName()</span></div>
                </div>

                @if (ApprovedOrder is not null)
                {
                    var approved = ApprovedOrder!;
                    @* id anchors the lineage bar's VO chip (and the pill's Reject / Return-to-quoting
                       routes): clicking it scrolls here and flashes the panel (jpmsFocusElement), so
                       the click lands visibly. This is simply the approved-state section of the one
                       record — there is no separate VO document any more. *@
                    <div id="variation-order" class="panel p-5 space-y-3">
                        <h3 class="eyebrow">Variation Order</h3>
                        <div class="text-sm text-content flex items-center">
                            <span class="font-mono font-semibold">@(approved.VariationRef ?? approved.DisplayNumber)</span>
                        </div>
                        <div class="flex justify-between text-sm"><span class="text-content-subtle">Value</span><span>@Money(approved.Value)</span></div>
                        <div class="flex justify-between text-sm"><span class="text-content-subtle">Cost code</span><span class="font-mono">@(approved.CostCode ?? "—")</span></div>
                        <p class="text-xs text-content-subtle">Added to the Valuation Report and committed to the cost centre.</p>
                        @if (CanManage)
                        {
                            <button type="button" class="btn-secondary w-full" disabled="@busy" @onclick="IssueWorkOrder">Issue work order</button>
                        }
                        @if (CanManage)
                        {
                            @if (!revisingValue)
                            {
                                <button type="button" class="btn-secondary w-full" disabled="@busy" @onclick="StartReviseValue">Revise value</button>
                            }
                            else
                            {
                                <div class="pt-3 border-t border-line space-y-3">
                                    <FormField Label="Revised value (£)" Value="@reviseValue" OnChange="v => reviseValue = v" InputType="number" Required="true" />
                                    <p class="text-xs text-content-subtle">
                                        Re-prices the @(approved.VariationRef ?? approved.DisplayNumber) line on the Valuation Report, records the
                                        difference on the CVR and moves the committed cost-centre budget.
                                    </p>
                                    <div class="flex gap-2">
                                        <button type="button" class="btn-primary" disabled="@busy" @onclick="ReviseVoValue">Save revised value</button>
                                        <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => revisingValue = false">Cancel</button>
                                    </div>
                                </div>
                            }
                        }
                        @if (CanManage)
                        {
                            <div class="pt-3 border-t border-line space-y-2">
                                @if (!returningToQuoting)
                                {
                                    <button type="button" class="w-full text-xs text-content-subtle hover:text-negative underline underline-offset-2"
                                            disabled="@busy" @onclick="() => returningToQuoting = true">
                                        Approved in error? Return to quoting…
                                    </button>
                                }
                                else
                                {
                                    <p class="text-xs text-content-subtle">
                                        Un-approves this variation: <span class="font-mono">@(approved.VariationRef ?? approved.DisplayNumber)</span> is removed
                                        (its number is freed for a future approval), its value comes off the Valuation Report,
                                        CVR and cost-centre budget, and @order.Reference returns to <span class="font-medium text-content">Quoting</span>.
                                        For approvals that shouldn't have happened — a real rejection should use Reject so
                                        the record stays on the register. Blocked once work orders instruct it or value has been claimed.
                                    </p>
                                    <div class="flex gap-2">
                                        <button type="button" class="btn-secondary w-full text-negative" disabled="@busy" @onclick="ReturnToQuoting">
                                            @(busy ? "Returning…" : "Confirm — return to quoting")
                                        </button>
                                        <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => returningToQuoting = false">Keep</button>
                                    </div>
                                }
                            </div>
                        }
                        @if (CanManage && rejectingOrder)
                        {
                            <div class="pt-3 border-t border-line space-y-2">
                                <p class="text-xs text-content-subtle">
                                    Rejecting <span class="font-mono">@(approved.VariationRef ?? approved.DisplayNumber)</span> is a real commercial
                                    event: the order stays on the register as Rejected, its line comes off the
                                    Valuation Report, an offsetting omit is recorded on the CVR and the committed
                                    cost-centre budget is released. If the approval itself was a data error, use
                                    Return to quoting instead so the V-ref is freed.
                                </p>
                                <div class="flex gap-2">
                                    <button type="button" class="btn-secondary w-full text-negative" disabled="@busy" @onclick="RejectOrder">
                                        @(busy ? "Rejecting…" : "Confirm — reject variation order")
                                    </button>
                                    <button type="button" class="btn-secondary" disabled="@busy" @onclick="() => rejectingOrder = false">Keep</button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (CanManage && order.Status is VariationOrderStatus.Quoting or VariationOrderStatus.Issued or VariationOrderStatus.AwaitingArchitectInstruction)
                {
                    @* Approval runs from either pre-approved status. With a selected tender this is
                       the normal end of the pipeline; without one it is a MANUAL approval — the
                       route for historic (seeded) and client-instructed variations that never
                       tendered through the app. The write-through (Valuation Report, CVR,
                       cost-centre budget) is identical either way. *@
                    var isManualApproval = string.IsNullOrEmpty(order.SelectedBidPackageId);
                    @* id anchors the status pill's "Approved…" pick: it scrolls here and flashes
                       the panel, because approval always needs the cost code + value below. *@
                    <div id="approve-voq" class="panel p-5">
                        <VariationApprovePanel IsManual="@isManualApproval"
                                               EstimatedValue="order.EstimatedValue"
                                               DefaultDescription="@order.Title"
                                               Busy="@busy"
                                               OnApprove="ApproveWithLines" />
                    </div>
                }

                @if (CanManage && packages.Count > 0 && ApprovedOrder is null)
                {
                    <div class="panel p-5 space-y-3">
                        <h3 class="eyebrow">Select winning tender</h3>
                        <div>
                            <label class="eyebrow block mb-1">Bid package</label>
                            <select class="field" value="@selBidPackageId" @onchange="OnBidPackageChanged">
                                <option value="">— Choose —</option>
                                @foreach (var package in packages)
                                {
                                    <option value="@package.BidPackageId">@package.Title</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label class="eyebrow block mb-1">Subcontractor</label>
                            <select class="field" value="@selSubId" @onchange="OnSubChanged">
                                <option value="">— Choose —</option>
                                @foreach (var sub in Subs)
                                {
                                    <option value="@sub.SubcontractorId">@sub.CompanyName</option>
                                }
                            </select>
                        </div>
                        <FormField Label="Agreed value (£)" Value="@selValue" OnChange="v => selValue = v" InputType="number" />
                        <button type="button" class="btn-primary w-full" disabled="@busy" @onclick="SelectTender">Record selection</button>
                    </div>
                }
            </div>
        </div>
    </ProjectPageShell>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";
    [Parameter] public string VoqId { get; set; } = "";

    private bool isLoaded;
    private bool busy;
    private string? error;
    private VariationOrder? order;
    private IReadOnlyList<BidPackage> packages = Array.Empty<BidPackage>();
    private Request? request; // originating request, for the lineage bar


    private bool revisingValue;
    private string reviseValue = "";

    private bool returningToQuoting;
    private bool rejectingOrder;

    // Status pill dropdown — same dismiss pattern as the request page's Actions dropdown: every
    // item closes it before running, the toggle is the dismiss.
    private bool orderStatusMenuOpen;

    private static readonly VariationOrderStatus[] OrderStatusOptions =
    {
        VariationOrderStatus.Quoting, VariationOrderStatus.Issued,
        VariationOrderStatus.AwaitingArchitectInstruction,
        VariationOrderStatus.Approved, VariationOrderStatus.Rejected
    };

    private bool addingPackage;
    private string newTitle = "";
    private string newTrade = "";

    private string selBidPackageId = "";
    private string selSubId = "";
    private string selValue = "";

    // ---- Originating-request repair (the register's old inline Link… UI now lives here) ----
    private string linkTargetRequestId = "";
    private bool linkBusy;
    private string? linkError;
    private IReadOnlyList<VariationOrder> projectQuotes = Array.Empty<VariationOrder>();

    // ---- Communications: emails tagged to the record's quoting reference and (once approved) its V-ref ----
    private bool emailsLoaded;
    private string? emailsError;
    private IReadOnlyList<MailboxMessage> emails = Array.Empty<MailboxMessage>();

    // The record only carries commercial figures (V-ref, value, cost code) once approved — this is
    // the "VO" the old two-record model kept separately; here it's just the current record, or null.
    private VariationOrder? ApprovedOrder => order is { Status: VariationOrderStatus.Approved } ? order : null;

    private string RequestHref => order is null ? $"/projects/{ProjectId}/requests" : $"/projects/{ProjectId}/requests/view/{order.RequestId}";
    private string PackageHref(string bidPackageId) => $"/projects/{ProjectId}/bid-package-invites/{bidPackageId}";

    private bool CanManage => Session.AvailableRoles.Any(role =>
        role is Role.Admin or Role.ManagingDirector or Role.ProjectManager or Role.QuantitySurveyor);

    private IReadOnlyList<Subcontractor> Subs => Subcontractors.All();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        Subcontractors.OnChange += StateHasChanged;
        _ = Subcontractors.All(); // warm the directory cache for the tender dropdown
        // Revalidate the request register in the background (stale-while-revalidate) — it feeds
        // the originating-request picker for unlinked (seeded) variation orders.
        RequestRegister.Refresh(ProjectId);
        RequestRegister.OnChange += StateHasChanged;
        await ReloadAsync();
        isLoaded = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Arriving via a VO chip elsewhere in the app ("…/voq/{id}?focus=vo"): land focused on
        // the Variation Order panel so the navigation visibly reaches the approved section, not
        // just the page.
        if (firstRender && ApprovedOrder is not null && WantsVoFocus())
            await FocusVariationOrderPanel();
    }

    private bool WantsVoFocus()
    {
        var query = new Uri(Nav.Uri).Query;
        return query.Contains("focus=vo", StringComparison.OrdinalIgnoreCase);
    }

    // The lineage bar's VO chip on this page: the approved section lives here, so scroll to and
    // flash its panel. Also reused by the status pill when routing Reject / Return-to-quoting from
    // Approved, so the confirm the user needs lands visibly instead of acting silently.
    private async Task FocusVariationOrderPanel()
    {
        try { await Js.InvokeVoidAsync("jpmsFocusElement", "variation-order"); }
        catch { /* purely cosmetic — never let a scroll failure break the page */ }
    }

    public void Dispose()
    {
        Subcontractors.OnChange -= StateHasChanged;
        RequestRegister.OnChange -= StateHasChanged;
    }

    private async Task ReloadAsync()
    {
        try
        {
            order = await Variations.GetByIdAsync(VoqId);
            packages = await Variations.ListBidPackagesAsync(VoqId);
            // Originating request for the lineage bar — best-effort, the bar shows a placeholder
            // without it. Portal-accepted variation orders have no request at all (RequestId is empty).
            if (order is not null && !string.IsNullOrWhiteSpace(order.RequestId))
            {
                try { request = await RequestRegister.GetAsync(order.RequestId); }
                catch { request = null; }
            }
            // The originating-request picker must not offer requests already carrying a variation
            // order (a request has at most one), so it needs the project's other orders to exclude.
            if (order is not null && string.IsNullOrWhiteSpace(order.RequestId))
                projectQuotes = await Variations.ListForProjectAsync(ProjectId);
            error = null;
        }
        catch { error = "Couldn't load the variation order. Please try again."; }

        await LoadEmailsAsync();
    }

    // The mail behind this record: everything tagged to its quoting reference plus, once approved,
    // everything tagged to its V-ref — one merged, newest-first list (an email tagged to both, e.g.
    // a whole thread synced across the approval, appears once).
    private async Task LoadEmailsAsync()
    {
        emailsError = null;
        try
        {
            var tagged = new List<MailboxMessage>(
                await Queries.AskAsync(new ListRecordEmails(RecordType.VariationQuote, VoqId), CancellationToken.None));
            if (ApprovedOrder is { } approved)
                tagged.AddRange(await Queries.AskAsync(new ListRecordEmails(RecordType.Variation, approved.VariationOrderId), CancellationToken.None));
            emails = tagged
                .GroupBy(email => string.IsNullOrEmpty(email.InternetMessageId) ? email.Id : email.InternetMessageId)
                .Select(group => group.First())
                .OrderByDescending(email => email.ReceivedAt)
                .ToList();
        }
        catch
        {
            emails = Array.Empty<MailboxMessage>();
            emailsError = "Couldn't load this variation's emails. Please try again.";
        }
        finally { emailsLoaded = true; }
    }

    // ---- Originating-request repair --------------------------------------------------------

    // RFIs first — the stage a variation order is normally raised from — then the rest of the
    // register; requests already carrying a variation order are out (a request has at most one).
    private IReadOnlyList<SearchSelect.Option> LinkCandidateOptions
    {
        get
        {
            var taken = projectQuotes
                .Where(quote => !string.IsNullOrWhiteSpace(quote.RequestId) && quote.VariationOrderId != VoqId)
                .Select(quote => quote.RequestId)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            return RequestRegister.ForProject(ProjectId)
                .Where(r => !taken.Contains(r.RequestId))
                .OrderBy(r => r.Kind == RequestType.Rfi ? 0 : 1)
                .ThenBy(r => r.Reference, StringComparer.OrdinalIgnoreCase)
                .Select(r => new SearchSelect.Option(r.RequestId, $"{RefLabel(r)} — {r.Title}"))
                .ToList();
        }
    }

    private static string RefLabel(Request record) =>
        string.IsNullOrWhiteSpace(record.Reference) ? record.DisplayNumber : record.Reference;

    private async Task LinkToRequest()
    {
        if (linkBusy || string.IsNullOrWhiteSpace(linkTargetRequestId)) return;
        linkError = null;
        try
        {
            linkBusy = true;
            await Variations.LinkToRequestAsync(VoqId, linkTargetRequestId);
            linkTargetRequestId = "";
            await ReloadAsync(); // the lineage bar re-renders with the request chip in place
        }
        catch (CommandFailedException ex) { linkError = ex.Message; }
        catch { linkError = "Couldn't link the request. Please try again."; }
        finally { linkBusy = false; }
    }

    private async Task AddPackage()
    {
        if (busy) return;
        error = null;
        if (string.IsNullOrWhiteSpace(newTitle) || string.IsNullOrWhiteSpace(newTrade)) { error = "A title and trade are required."; return; }
        try
        {
            busy = true;
            await Variations.AddBidPackageAsync(VoqId, newTitle.Trim(), newTrade.Trim());
            newTitle = newTrade = "";
            addingPackage = false;
            await ReloadAsync();
        }
        catch { error = "Couldn't add the bid package. Please try again."; }
        finally { busy = false; }
    }

    private void OnBidPackageChanged(ChangeEventArgs e) => selBidPackageId = e.Value?.ToString() ?? "";
    private void OnSubChanged(ChangeEventArgs e) => selSubId = e.Value?.ToString() ?? "";

    private async Task ApproveWithLines(VariationApprovePanel.ApproveRequest request)
    {
        if (busy) return;
        error = null;
        try
        {
            busy = true;
            // The panel supplies the priced build-up; the value and primary cost code are derived
            // from it. The server writes one report line per entry under this variation's V-ref.
            order = await Variations.ApproveAsync(VoqId, request.PrimaryCostCode, request.Total, request.Lines);
            await ReloadAsync();
        }
        catch (System.Exception ex)
        {
            error = string.IsNullOrWhiteSpace(ex.Message) ? "Couldn't approve the variation order. Please try again." : ex.Message;
        }
        finally { busy = false; }
    }

    private async Task IssueWorkOrder()
    {
        if (busy || ApprovedOrder is not { } approved) return;
        error = null;
        try
        {
            busy = true;
            await Variations.IssueWorkOrderForVariationOrderAsync(approved.VariationOrderId);
            await ReloadAsync();
        }
        catch (CommandFailedException ex) { error = ex.Message; }
        catch { error = "Couldn't issue the work order. Please try again."; }
        finally { busy = false; }
    }

    // ---- Status pill dropdown ---------------------------------------------------------------

    private string PillOptionLabel(VariationOrderStatus status)
    {
        var needsConfirm = status == VariationOrderStatus.Approved
            || status == VariationOrderStatus.Rejected
            || (order?.Status == VariationOrderStatus.Approved && status == VariationOrderStatus.Quoting);
        return needsConfirm ? $"{StatusLabel(status)}…" : StatusLabel(status);
    }

    private string? PillOptionTitle(VariationOrderStatus status)
    {
        if (status == VariationOrderStatus.Approved)
            return "Approving writes the contract figures — opens the approve panel";
        if (order?.Status == VariationOrderStatus.Approved && status == VariationOrderStatus.Quoting)
            return "Un-approves the variation order — reverses the approval's valuation / CVR / budget writes";
        if (status == VariationOrderStatus.Rejected && order?.Status == VariationOrderStatus.Approved)
            return "Rejecting an approved order reverses the valuation / CVR / budget writes";
        if (order?.Status == VariationOrderStatus.Approved && status == VariationOrderStatus.Issued)
            return "Not allowed directly from Approved — return to quoting first";
        if (status == VariationOrderStatus.AwaitingArchitectInstruction)
            return "Issued and waiting on a formal Architect's Instruction — no commercial effect yet";
        return null;
    }

    // Routes the pill's chosen target per the unified transition rules: Approved always opens the
    // approve panel (it needs a cost code and value, and writes the contract figures); Rejected
    // reverses the approval's writes when leaving Approved (routed through the inline confirm) and
    // is a plain move otherwise; leaving Approved for Quoting is the "return to quoting" repair
    // (also routed through an inline confirm); Approved -> Issued is never allowed; everything else
    // between Quoting, Issued and Awaiting AI moves directly.
    private async Task ChangeStatus(VariationOrderStatus target)
    {
        orderStatusMenuOpen = false;
        if (busy || order is null || target == order.Status) return;
        error = null;

        if (order.Status == VariationOrderStatus.Approved && target == VariationOrderStatus.Issued)
            return; // not a valid transition

        if (target == VariationOrderStatus.Approved)
        {
            await FocusApprovePanel();
            return;
        }

        if (target == VariationOrderStatus.Rejected)
        {
            if (order.Status == VariationOrderStatus.Approved)
            {
                rejectingOrder = true;
                await FocusVariationOrderPanel();
            }
            else
            {
                await RejectOrder();
            }
            return;
        }

        if (order.Status == VariationOrderStatus.Approved && target == VariationOrderStatus.Quoting)
        {
            returningToQuoting = true;
            await FocusVariationOrderPanel();
            return;
        }

        // Direct moves between the side-effect-free stages (Quoting, Issued, Awaiting AI).
        try
        {
            busy = true;
            order = await Variations.SetStatusAsync(VoqId, target);
            await ReloadAsync();
        }
        catch (CommandFailedException ex) { error = ex.Message; }
        catch { error = "Couldn't change the status. Please try again."; }
        finally { busy = false; }
    }

    private async Task RejectOrder()
    {
        if (busy || order is null) return;
        error = null;
        try
        {
            busy = true;
            order = await Variations.RejectAsync(VoqId);
            rejectingOrder = false;
            await ReloadAsync();
        }
        catch (CommandFailedException ex) { error = ex.Message; }
        catch { error = "Couldn't reject the variation order. Please try again."; }
        finally { busy = false; }
    }

    private async Task FocusApprovePanel()
    {
        try { await Js.InvokeVoidAsync("jpmsFocusElement", "approve-voq"); }
        catch { /* purely cosmetic — never let a scroll failure break the page */ }
    }

    private async Task ReturnToQuoting()
    {
        if (busy) return;
        error = null;
        try
        {
            busy = true;
            order = await Variations.ReturnToQuotingAsync(VoqId);
            returningToQuoting = false;
            await ReloadAsync(); // the approved section drops away; the approve panel reappears
        }
        catch (CommandFailedException ex) { error = ex.Message; }
        catch { error = "Couldn't return the variation order to quoting. Please try again."; }
        finally { busy = false; }
    }

    private void StartReviseValue()
    {
        reviseValue = order?.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
        revisingValue = true;
        error = null;
    }

    private async Task ReviseVoValue()
    {
        if (busy || order is null) return;
        error = null;
        if (!decimal.TryParse(reviseValue, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var value))
        {
            error = "Enter a valid revised value.";
            return;
        }
        try
        {
            busy = true;
            order = await Variations.ReviseVariationOrderValueAsync(VoqId, value);
            revisingValue = false;
            await ReloadAsync();
        }
        catch { error = "Couldn't revise the variation order value. Please try again."; }
        finally { busy = false; }
    }

    private async Task SelectTender()
    {
        if (busy) return;
        error = null;
        if (string.IsNullOrWhiteSpace(selBidPackageId) || string.IsNullOrWhiteSpace(selSubId)) { error = "Choose a bid package and a subcontractor."; return; }
        decimal? value = decimal.TryParse(selValue, out var parsed) ? parsed : null;
        try
        {
            busy = true;
            order = await Variations.SelectTenderAsync(VoqId, selBidPackageId, selSubId, value);
            await ReloadAsync();
        }
        catch { error = "Couldn't record the selection. Please try again."; }
        finally { busy = false; }
    }

    private string SelectedSubName()
    {
        if (order?.SelectedSubcontractorId is null) return "—";
        return Subcontractors.Find(order.SelectedSubcontractorId)?.CompanyName ?? order.SelectedSubcontractorId;
    }

    private static string StatusLabel(VariationOrderStatus status) => status switch
    {
        VariationOrderStatus.Quoting  => "Quoting",
        VariationOrderStatus.Issued   => "Issued",
        VariationOrderStatus.AwaitingArchitectInstruction => "Awaiting AI",
        VariationOrderStatus.Approved => "Approved",
        VariationOrderStatus.Rejected => "Rejected",
        _ => status.ToString()
    };

    private static string Money(decimal value) => value.ToString("C0", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));
}
