@page "/finance/allocation"
@using Jewel.JPMS.Contracts.Xero
@using Jewel.JPMS.Features.Projects
@inject AuthService Auth
@inject SessionService Session
@inject IXeroLedgerStore Ledger
@inject IQueryClient Queries
@inject ICostCenterStore CostCenters
@inject ProjectListReadModel ProjectsReadModel
@inject AllocationTabStorage TabStorage
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Cost allocation · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="w-full px-6 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    @* Full-width (no max-w cap): the allocation table is the whole page. A capped,
       centred container left growing side margins when zooming out instead of giving
       the columns the reclaimed space. *@
    <section class="w-full px-6 py-8 md:py-12">
        <header class="mb-6 md:mb-8 flex items-end justify-between gap-4">
            <div>
                <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · Finance</p>
                <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Cost allocation</h1>
                <p class="text-sm text-content-muted mt-2">
                    Reconcile the accounts system with the projects: every Xero cost-of-sales purchase line
                    (nominal accounts starting 3) is allocated to a project and master cost centre — or split
                    across several centres. Suggestions come from the line's Xero tracking — you confirm.
                    Once every line of a draft bill (published from Dext) is allocated, its Sites and Cost Code
                    tracking are confirmed back to Xero and the bill is approved automatically.
                </p>
            </div>
            <div class="flex items-center gap-4 whitespace-nowrap">
                <button class="text-sm font-medium text-content-muted hover:text-content underline underline-offset-4 disabled:opacity-50"
                        disabled="@isBusy" @onclick="RecheckMatchesAsync">
                    @(isRechecking ? "Re-checking…" : "Re-check matches")
                </button>
                <button class="text-sm font-medium text-content-muted hover:text-content underline underline-offset-4 disabled:opacity-50"
                        disabled="@isBusy" @onclick="SyncAsync">
                    @(isSyncing ? "Syncing…" : "Sync from Xero")
                </button>
            </div>
        </header>

        @if (syncMessage is not null)
        {
            <div class="rounded-xl border border-line bg-surface-raised px-5 py-3 text-sm text-content-muted mb-6">@syncMessage</div>
        }
        @if (errorMessage is not null)
        {
            <div class="rounded-xl border border-line bg-surface-raised px-5 py-3 text-sm text-content mb-6">@errorMessage</div>
        }

        @if (Lines is null)
        {
            <p class="text-sm text-content-subtle py-8">Loading the stored ledger…</p>
        }
        else if (Lines.Count == 0)
        {
            <p class="text-sm text-content-subtle py-8">
                Nothing stored yet — press “Sync from Xero” to pull the purchase ledger in for allocation.
            </p>
        }
        else
        {
            @if (activeTab == XeroAllocationStatus.Unallocated && FullyMatchedCount > 0)
            {
                <div class="mb-4 rounded-xl border border-line bg-surface-raised px-4 py-3 flex items-center gap-3 flex-wrap text-sm">
                    <span class="text-content-muted">
                        <span class="text-content font-medium">@FullyMatchedCount lines</span> have both a project and a
                        cost centre matched from their Xero tracking.
                    </span>
                    @if (!confirmAllocateMatched)
                    {
                        <button class="text-sm font-medium rounded-lg px-3 py-1.5 bg-content text-surface disabled:opacity-50"
                                disabled="@isBusy" @onclick="() => confirmAllocateMatched = true">
                            Allocate all matched…
                        </button>
                    }
                    else
                    {
                        <button class="text-sm font-medium rounded-lg px-3 py-1.5 bg-content text-surface disabled:opacity-50"
                                disabled="@isBusy" @onclick="AllocateMatchedAsync">
                            @(isBusy ? "Allocating…" : $"Confirm — allocate {FullyMatchedCount} lines")
                        </button>
                        <button class="text-xs text-content-subtle underline underline-offset-4"
                                @onclick="() => confirmAllocateMatched = false">Cancel</button>
                    }
                    <span class="text-xs text-content-subtle">Noted as auto-matched; each line stays reversible via Undo.</span>
                </div>
            }

            <div class="mb-4 flex items-center justify-between gap-4 flex-wrap">
                @* The incoming queue is split by project: a line whose project is set
                   (Xero suggestion, or the dropdown pick) sits in that project's tab, so
                   people working a specific project approve just their own costs.
                   "Unallocated" keeps only the lines nobody has pointed at a project yet. *@
                <div class="inline-flex flex-wrap rounded-lg border border-line overflow-hidden">
                    <button class="@TabClass(XeroAllocationStatus.Unallocated)" @onclick="() => SwitchTab(XeroAllocationStatus.Unallocated)">
                        Unallocated (@UnassignedCount)
                    </button>
                    @foreach (var tab in ProjectTabs)
                    {
                        var projectId = tab.ProjectId;
                        <button class="@ProjectTabClass(projectId)" @onclick="() => SwitchTab(XeroAllocationStatus.Unallocated, projectId)">
                            @tab.Name (@tab.Count)
                        </button>
                    }
                    <button class="@TabClass(XeroAllocationStatus.Allocated)" @onclick="() => SwitchTab(XeroAllocationStatus.Allocated)">
                        Allocated (@CountOf(XeroAllocationStatus.Allocated))
                    </button>
                    <button class="@TabClass(XeroAllocationStatus.Bucketed)" @onclick="() => SwitchTab(XeroAllocationStatus.Bucketed)">
                        Buckets (@CountOf(XeroAllocationStatus.Bucketed))
                    </button>
                    <button class="@TabClass(XeroAllocationStatus.Ignored)" @onclick="() => SwitchTab(XeroAllocationStatus.Ignored)">
                        Ignored (@CountOf(XeroAllocationStatus.Ignored))
                    </button>
                </div>
                <input class="text-sm bg-surface border border-line rounded-lg px-3 py-1.5 text-content placeholder:text-content-subtle w-64"
                       placeholder="Search supplier, description, number…"
                       value="@search" @oninput="OnSearchChanged" />
            </div>

            @if (activeTab == XeroAllocationStatus.Unallocated && selectedIds.Count > 0)
            {
                <div class="mb-4 rounded-xl border border-line bg-surface-raised px-4 py-3 flex items-center gap-3 flex-wrap text-sm">
                    <span class="text-content font-medium">@selectedIds.Count selected</span>
                    <select class="bg-surface border border-line rounded-lg px-2 py-1.5 text-content text-sm" @bind="bulkProjectId">
                        <option value="">Project…</option>
                        @foreach (var project in Projects)
                        {
                            <option value="@project.ProjectId">@project.Name</option>
                        }
                    </select>
                    <select class="bg-surface border border-line rounded-lg px-2 py-1.5 text-content text-sm" @bind="bulkCostCenterCode">
                        <option value="">Cost centre…</option>
                        @foreach (var centre in CostCenters.ActiveAlphabetical())
                        {
                            <option value="@centre.Code">@centre.Code @centre.Name</option>
                        }
                    </select>
                    <button class="text-sm font-medium rounded-lg px-3 py-1.5 bg-content text-surface disabled:opacity-50"
                            disabled="@(isBusy || string.IsNullOrEmpty(bulkProjectId) || string.IsNullOrEmpty(bulkCostCenterCode))"
                            @onclick="BulkAllocateAsync">Allocate selected</button>
                    <span class="text-content-subtle">·</span>
                    <select class="bg-surface border border-line rounded-lg px-2 py-1.5 text-content text-sm" @bind="bulkBucket">
                        <option value="">Bucket…</option>
                        @foreach (var bucket in XeroBuckets.All)
                        {
                            <option value="@bucket">@bucket</option>
                        }
                    </select>
                    <button class="text-sm font-medium rounded-lg px-3 py-1.5 border border-line text-content-muted hover:text-content disabled:opacity-50"
                            disabled="@(isBusy || string.IsNullOrEmpty(bulkBucket))" @onclick="BulkBucketAsync">Bucket selected</button>
                    <button class="text-sm font-medium rounded-lg px-3 py-1.5 border border-line text-content-muted hover:text-content disabled:opacity-50"
                            disabled="@isBusy" @onclick="BulkIgnoreAsync">Ignore selected</button>
                    <button class="text-xs text-content-subtle underline underline-offset-4" @onclick="() => selectedIds.Clear()">Clear</button>
                </div>
            }

            @if (activeTab == XeroAllocationStatus.Bucketed)
            {
                <div class="mb-4 flex flex-wrap gap-2">
                    @foreach (var bucket in XeroBuckets.All)
                    {
                        <button class="@BucketChipClass(bucket)" @onclick="() => ToggleBucketFilter(bucket)">
                            @bucket · @Money(BucketTotal(bucket))
                        </button>
                    }
                </div>
            }

            <div class="rounded-xl border border-line bg-surface overflow-x-auto overflow-y-auto max-h-[85vh]">
                <table class="w-full min-w-[82rem] text-sm">
                    <thead class="bg-surface-raised border-b border-line">
                        <tr class="text-left text-[11px] uppercase tracking-wider text-content-subtle font-semibold">
                            @if (activeTab == XeroAllocationStatus.Unallocated)
                            {
                                <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 w-8">
                                    <input type="checkbox" checked="@AllVisibleSelected" @onchange="ToggleSelectAll" />
                                </th>
                            }
                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3">Date</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3">Supplier</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3">Description</th>
                            <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 text-right">Net</th>
                            @if (activeTab == XeroAllocationStatus.Unallocated)
                            {
                                <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3">Project</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3">Cost centre</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3">Bucket</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3"></th>
                            }
                            else
                            {
                                <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3">
                                    @(activeTab == XeroAllocationStatus.Allocated ? "Allocated to"
                                      : activeTab == XeroAllocationStatus.Bucketed ? "Bucket" : "Reason")
                                </th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3 hidden md:table-cell">By</th>
                                <th class="sticky top-0 z-20 bg-surface-raised px-3 py-3"></th>
                            }
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-line">
                        @foreach (var line in Paged)
                        {
                            <tr>
                                @if (activeTab == XeroAllocationStatus.Unallocated)
                                {
                                    <td class="px-3 py-2.5">
                                        <input type="checkbox" checked="@selectedIds.Contains(line.XeroLedgerLineId)"
                                               @onchange="() => ToggleSelected(line.XeroLedgerLineId)" />
                                    </td>
                                }
                                <td class="px-3 py-2.5 text-content-muted whitespace-nowrap">@DateText(line.Date)</td>
                                <td class="px-3 py-2.5 text-content font-medium">
                                    @(line.ContactName ?? "—")
                                    @if (line.Type == "ACCPAYCREDIT")
                                    {
                                        <span class="ml-1.5 text-[10px] uppercase tracking-wider font-semibold border border-line rounded px-1 py-0.5">Credit</span>
                                    }
                                    @if (IsAwaitingApproval(line))
                                    {
                                        <span class="ml-1.5 text-[10px] uppercase tracking-wider font-semibold border border-line rounded px-1 py-0.5"
                                              title="Awaiting approval in Xero — allocating every line of this bill confirms its cost codes to Xero and approves it">Draft</span>
                                    }
                                </td>
                                <td class="px-3 py-2.5 text-content-muted max-w-xs">
                                    <span class="block truncate" title="@line.Description">@(line.Description ?? "—")</span>
                                    <span class="flex items-center gap-1 text-xs text-content-subtle">
                                        @if (line.HasAttachments)
                                        {
                                            @* The supplier's document as Xero holds it (published by Dext) —
                                               previewed in place without leaving the queue. *@
                                            <button type="button" title="View the invoice document"
                                                    class="inline-flex items-center justify-center w-5 h-5 -ml-1 rounded text-content-subtle hover:text-content hover:bg-surface-raised"
                                                    @onclick="() => OpenInvoiceViewAsync(line)">
                                                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                                     stroke-linecap="round" stroke-linejoin="round">
                                                    <path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48" />
                                                </svg>
                                            </button>
                                        }
                                        <span>@(line.InvoiceNumber ?? "—") · @(line.XeroSite ?? "no site") · @(line.XeroCostCode ?? "no Xero code")</span>
                                    </span>
                                </td>
                                <td class="px-3 py-2.5 text-right text-content font-medium whitespace-nowrap">@Money(SignedNet(line))</td>

                                @if (activeTab == XeroAllocationStatus.Unallocated)
                                {
                                    <td class="px-3 py-2.5">
                                        <select class="bg-surface border border-line rounded-lg px-2 py-1 text-content text-sm w-44"
                                                value="@SelectedProjectFor(line)"
                                                @onchange="e => SetProject(line.XeroLedgerLineId, e.Value?.ToString())">
                                            <option value="">—</option>
                                            @foreach (var project in Projects)
                                            {
                                                <option value="@project.ProjectId">@project.Name</option>
                                            }
                                        </select>
                                    </td>
                                    <td class="px-3 py-2.5">
                                        <select class="bg-surface border border-line rounded-lg px-2 py-1 text-content text-sm w-52"
                                                value="@SelectedCostCenterFor(line)"
                                                @onchange="e => SetCostCenter(line.XeroLedgerLineId, e.Value?.ToString())">
                                            <option value="">—</option>
                                            @foreach (var centre in CostCenters.ActiveAlphabetical())
                                            {
                                                <option value="@centre.Code">@centre.Code @centre.Name</option>
                                            }
                                        </select>
                                    </td>
                                    <td class="px-3 py-2.5">
                                        <select class="bg-surface border border-line rounded-lg px-2 py-1 text-content text-sm w-36"
                                                value="@SelectedBucketFor(line)"
                                                @onchange="e => SetBucket(line.XeroLedgerLineId, e.Value?.ToString())">
                                            <option value="">—</option>
                                            @foreach (var bucket in XeroBuckets.All)
                                            {
                                                <option value="@bucket">@bucket</option>
                                            }
                                        </select>
                                    </td>
                                    <td class="px-3 py-2.5 text-right whitespace-nowrap">
                                        @* Exactly one Allocate is ever active: project + cost centre arms the
                                           first; a bucket choice arms the second (and wins if both are set,
                                           since picking a bucket was the later, deliberate act). *@
                                        <button class="text-xs font-medium rounded-lg px-2.5 py-1 bg-content text-surface disabled:opacity-40"
                                                disabled="@(isBusy || !CanAllocate(line) || CanBucket(line))"
                                                @onclick="() => AllocateAsync(line)">Allocate</button>
                                        <button class="text-xs text-content-subtle underline underline-offset-4 ml-2"
                                                disabled="@isBusy"
                                                @onclick="() => OpenSplit(line)">Split…</button>
                                        <button class="text-xs font-medium rounded-lg px-2.5 py-1 bg-content text-surface ml-2 disabled:opacity-40"
                                                disabled="@(isBusy || !CanBucket(line))"
                                                @onclick="() => BucketAsync(line, SelectedBucketFor(line))">Allocate to bucket</button>
                                        <button class="text-xs text-content-subtle underline underline-offset-4 ml-2"
                                                disabled="@isBusy"
                                                @onclick="() => IgnoreAsync(line)">Ignore</button>
                                    </td>
                                }
                                else
                                {
                                    <td class="px-3 py-2.5 text-content-muted">
                                        @if (activeTab == XeroAllocationStatus.Allocated)
                                        {
                                            @if (line.Splits is { Count: > 0 })
                                            {
                                                var multiProject = line.Splits.Select(split => split.ProjectId ?? line.ProjectId)
                                                    .Distinct().Count() > 1;
                                                <span class="text-content">@(multiProject ? "Multiple projects" : ProjectName(line.ProjectId ?? line.Splits[0].ProjectId))</span>
                                                foreach (var split in line.Splits)
                                                {
                                                    <span class="block text-xs text-content-subtle">
                                                        @if (multiProject)
                                                        {
                                                            <span class="text-content-muted">@ProjectName(split.ProjectId ?? line.ProjectId) · </span>
                                                        }
                                                        @CostCenterText(split.CostCenterCode) · @Money(line.Type == "ACCPAYCREDIT" ? -split.Net : split.Net)
                                                    </span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-content">@ProjectName(line.ProjectId)</span>
                                                <span class="block text-xs text-content-subtle">@CostCenterText(line.CostCenterCode)</span>
                                            }
                                            @if (WriteBackBadge(line) is { } badge)
                                            {
                                                <span class="block text-xs mt-0.5 @badge.Css" title="@badge.Tooltip">@badge.Text</span>
                                                @* The tooltip is easy to miss — failures need their reason readable at a glance. *@
                                                @if (line.WriteBackStatus == XeroWriteBackStatus.Failed
                                                     && !string.IsNullOrWhiteSpace(line.WriteBackError))
                                                {
                                                    <span class="block text-xs mt-0.5 text-content-subtle whitespace-normal max-w-md">@line.WriteBackError</span>
                                                }
                                            }
                                        }
                                        else if (activeTab == XeroAllocationStatus.Bucketed)
                                        {
                                            <span class="text-content">@(line.Bucket ?? "—")</span>
                                        }
                                        else
                                        {
                                            @(line.Note ?? "—")
                                        }
                                    </td>
                                    <td class="px-3 py-2.5 text-content-subtle text-xs hidden md:table-cell">
                                        @(line.AllocatedBy ?? "—")
                                        <span class="block">@(line.AllocatedAtUtc?.ToLocalTime().ToString("d MMM yyyy") ?? "")</span>
                                    </td>
                                    <td class="px-3 py-2.5 text-right whitespace-nowrap">
                                        @if (activeTab == XeroAllocationStatus.Allocated && line.WriteBackStatus == XeroWriteBackStatus.Failed)
                                        {
                                            <button class="text-xs font-medium rounded-lg px-2.5 py-1 bg-content text-surface disabled:opacity-40"
                                                    disabled="@isBusy" title="@line.WriteBackError"
                                                    @onclick="() => RetryWriteBackAsync(line)">Retry Xero</button>
                                        }
                                        <button class="text-xs text-content-subtle underline underline-offset-4 ml-2"
                                                disabled="@isBusy" @onclick="() => ResetAsync(line)">Undo</button>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="mt-3 flex items-center justify-between gap-4 flex-wrap">
                <p class="text-xs text-content-subtle">
                    @Visible.Count lines · @Money(Visible.Sum(SignedNet)) net.
                    Allocating every line of a draft bill writes its Sites / Cost Code tracking back to Xero
                    and approves it; bills already approved in Xero are allocated in JPMS only.
                </p>
                @if (PageCount > 1)
                {
                    <div class="flex items-center gap-3 text-xs text-content-muted">
                        <button class="underline underline-offset-4 disabled:opacity-40 disabled:no-underline"
                                disabled="@(page == 0)" @onclick="() => page--">‹ Prev</button>
                        <span>Page @(page + 1) of @PageCount</span>
                        <button class="underline underline-offset-4 disabled:opacity-40 disabled:no-underline"
                                disabled="@(page >= PageCount - 1)" @onclick="() => page++">Next ›</button>
                    </div>
                }
            </div>
        }

        <Modal IsOpen="@(splitLine is not null)" Title="Split across projects and cost centres"
               ConfirmLabel="@(isApplying ? "Allocating…" : "Allocate split")" CancelLabel="Cancel"
               ConfirmDisabled="@isBusy" OnConfirm="ApplySplitAsync" OnCancel="CloseSplit" Class="max-w-3xl">
            @if (splitLine is not null)
            {
                <div class="space-y-4">
                    <div class="rounded-lg border border-line bg-surface-raised px-4 py-3 text-sm">
                        <span class="text-content font-medium">@(splitLine.ContactName ?? "—")</span>
                        <span class="text-content-muted"> · @(splitLine.Description ?? "—")</span>
                        <span class="block text-xs text-content-subtle mt-0.5">
                            @(splitLine.InvoiceNumber ?? "—") · @Money(splitLine.Net) net
                        </span>
                    </div>

                    @if (splitError is not null)
                    {
                        <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@splitError</p>
                    }

                    <div class="space-y-2">
                        <div class="flex items-center gap-2 text-xs uppercase tracking-wider text-content-subtle font-semibold">
                            <span class="w-56">Project</span>
                            <span class="grow">Cost centre</span>
                            <span class="w-32 text-right">Net £</span>
                            <span class="w-7"></span>
                        </div>
                        @foreach (var row in splitRows)
                        {
                            <div class="flex items-center gap-2">
                                <select class="w-56 bg-surface border border-line rounded-lg px-2 py-1.5 text-content text-sm"
                                        value="@row.ProjectId" @onchange="e => OnSplitProjectChanged(row, e.Value?.ToString())">
                                    <option value="">—</option>
                                    @foreach (var project in Projects)
                                    {
                                        <option value="@project.ProjectId">@project.Name</option>
                                    }
                                </select>
                                <select class="grow bg-surface border border-line rounded-lg px-2 py-1.5 text-content text-sm"
                                        value="@row.Code" @onchange="e => OnSplitCodeChanged(row, e.Value?.ToString())">
                                    <option value="">—</option>
                                    @foreach (var centre in CostCenters.ActiveAlphabetical())
                                    {
                                        <option value="@centre.Code">@centre.Code @centre.Name</option>
                                    }
                                </select>
                                <input class="w-32 bg-surface border border-line rounded-lg px-2 py-1.5 text-content text-sm text-right"
                                       type="number" step="0.01" min="0" placeholder="0.00"
                                       value="@(row.Amount?.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture))"
                                       @onchange="e => OnSplitAmountChanged(row, e.Value?.ToString())" />
                                <button type="button" aria-label="Remove row" disabled="@(splitRows.Count <= 2)"
                                        class="inline-flex items-center justify-center w-7 h-7 rounded-md text-content-subtle hover:text-content hover:bg-surface-raised disabled:opacity-40"
                                        @onclick="() => RemoveSplitRow(row)">
                                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                         stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
                                </button>
                            </div>
                        }
                        <button type="button" class="text-xs font-medium text-content-muted hover:text-content underline underline-offset-4"
                                @onclick="AddSplitRow">+ Add row</button>
                    </div>

                    <p class="text-sm @(SplitRemaining == 0m ? "text-content-muted" : "text-negative")">
                        @Money(SplitAssigned) of @Money(splitLine.Net) assigned
                        @(SplitRemaining == 0m ? "— fully assigned." : $"— {Money(SplitRemaining)} remaining.")
                    </p>
                    <p class="text-xs text-content-subtle">
                        Rows can point at different projects. On approval the Xero line is split into one line
                        per row (amounts pro-rated, invoice total unchanged) with each row's project site and
                        cost code stamped on it.
                    </p>
                </div>
            }
        </Modal>

        <Modal IsOpen="@(viewLine is not null)" Title="Invoice document" ShowFooter="false"
               OnCancel="CloseInvoiceView" Class="max-w-4xl">
            @if (viewLine is not null)
            {
                <div class="space-y-3">
                    <div class="rounded-lg border border-line bg-surface-raised px-4 py-3 text-sm">
                        <span class="text-content font-medium">@(viewLine.ContactName ?? "—")</span>
                        <span class="text-content-muted"> · @(viewLine.Description ?? "—")</span>
                        <span class="block text-xs text-content-subtle mt-0.5">
                            @(viewLine.InvoiceNumber ?? "—") · @DateText(viewLine.Date) · @Money(SignedNet(viewLine)) net
                        </span>
                    </div>

                    @if (viewError is not null)
                    {
                        <p class="rounded-lg bg-negative/10 border border-negative/30 px-3 py-2 text-sm text-negative">@viewError</p>
                    }
                    else if (viewAttachments is null)
                    {
                        <p class="text-sm text-content-subtle py-6">Fetching the document from Xero…</p>
                    }
                    else
                    {
                        @if (viewAttachments.Count > 1)
                        {
                            <div class="flex flex-wrap gap-2">
                                @foreach (var attachment in viewAttachments)
                                {
                                    <button type="button" class="@InvoiceAttachmentChipClass(attachment)"
                                            @onclick="() => viewSelected = attachment">@attachment.FileName</button>
                                }
                            </div>
                        }

                        @if (viewSelected is not null)
                        {
                            <div class="rounded-lg border border-line overflow-hidden">
                                <div class="flex items-center justify-between gap-3 px-3 py-2 bg-surface-raised border-b border-line">
                                    <span class="text-xs text-content-muted font-medium truncate">@viewSelected.FileName</span>
                                    <span class="flex items-center gap-3 whitespace-nowrap">
                                        <a class="text-xs font-medium text-content-muted hover:text-content underline underline-offset-4"
                                           href="@InvoiceAttachmentUrl(viewSelected, inline: true)" target="_blank" rel="noopener">Open in new tab</a>
                                        <a class="text-xs font-medium text-content-muted hover:text-content underline underline-offset-4"
                                           href="@InvoiceAttachmentUrl(viewSelected, inline: false)" target="_blank" rel="noopener">Download</a>
                                    </span>
                                </div>
                                @if (IsPreviewable(viewSelected))
                                {
                                    @* Same pattern as the triage attachment preview: the iframe hits the
                                       download endpoint with ?inline=1 so the browser renders the PDF/image
                                       in place. Bytes are proxied from Xero on demand — nothing stored. *@
                                    <iframe src="@InvoiceAttachmentUrl(viewSelected, inline: true)"
                                            class="w-full h-[65vh] bg-white" title="Invoice document preview"></iframe>
                                }
                                else
                                {
                                    <p class="px-4 py-8 text-sm text-content-subtle">
                                        This file type can't be previewed here — use Download to open it.
                                    </p>
                                }
                            </div>
                        }
                    }
                </div>
            }
        </Modal>
    </section>
}

@code {
    private bool isLoaded;
    private bool isSyncing;
    private bool isRechecking;
    private bool isApplying;
    private string search = string.Empty;
    private string? syncMessage;
    private string? errorMessage;
    private XeroAllocationStatus activeTab = XeroAllocationStatus.Unallocated;

    // Which project tab of the incoming queue is open. Only meaningful while
    // activeTab is Unallocated: null is the plain "Unallocated" tab (no project
    // set yet); otherwise the tab for that project. Changing a line's project
    // dropdown moves it between these tabs (projectChoiceVersion invalidates the
    // memoized filter — chosenProject is mutated in place, so the dictionary
    // reference alone can't tell the cache anything changed).
    private string? activeProjectId;
    private int projectChoiceVersion;

    private readonly HashSet<string> selectedIds = new();
    private readonly Dictionary<string, string?> chosenProject = new();
    private readonly Dictionary<string, string?> chosenCostCenter = new();
    private readonly Dictionary<string, string?> chosenBucket = new();
    private string bulkProjectId = "";
    private string bulkCostCenterCode = "";
    private string bulkBucket = "";
    private string? bucketFilter;
    private bool confirmAllocateMatched;

    private bool isBusy => isSyncing || isRechecking || isApplying;

    private IReadOnlyList<XeroLedgerLine>? Lines => Ledger.Lines();

    private IReadOnlyList<Jewel.JPMS.Models.Project> Projects =>
        ProjectsReadModel.Current ?? Array.Empty<Jewel.JPMS.Models.Project>();

    // -- filtering & paging ----------------------------------------------------
    // The filtered list is memoized: Blazor reads Visible several times per render
    // and with thousands of lines the repeated LINQ passes (and re-rendering every
    // row's dropdowns) is what made tab switches crawl. Only PageSize rows render.

    private const int PageSize = 50;
    private int page;
    private IReadOnlyList<XeroLedgerLine>? visibleCache;
    private (IReadOnlyList<XeroLedgerLine>? Lines, object Projects, string Search, XeroAllocationStatus Tab,
             string? ProjectTab, string? Bucket, int ChoiceVersion) visibleCacheKey;

    private IReadOnlyList<XeroLedgerLine> Visible
    {
        get
        {
            // Projects and projectChoiceVersion are in the key because the
            // unallocated filter groups by SelectedProjectFor, which reads both.
            var key = (Lines, (object)Projects, search, activeTab, activeProjectId, bucketFilter, projectChoiceVersion);
            if (visibleCache is null || key != visibleCacheKey)
            {
                visibleCache = Lines is null
                    ? Array.Empty<XeroLedgerLine>()
                    : Lines.Where(line => line.AllocationStatus == activeTab)
                           .Where(line => activeTab != XeroAllocationStatus.Unallocated
                                          || SelectedProjectFor(line) == (activeProjectId ?? ""))
                           .Where(line => activeTab != XeroAllocationStatus.Bucketed
                                          || bucketFilter is null || line.Bucket == bucketFilter)
                           .Where(MatchesSearch)
                           .ToList();
                visibleCacheKey = key;
                page = Math.Clamp(page, 0, Math.Max(0, (visibleCache.Count - 1) / PageSize));
            }
            return visibleCache;
        }
    }

    // -- project tabs -----------------------------------------------------------
    // One tab per project that has incoming lines pointing at it (suggestion or a
    // user's dropdown pick), alphabetical. The open tab stays in the bar even at
    // zero lines — allocating the last line mustn't yank the user elsewhere, and a
    // remembered tab restored on load may be empty by now.

    private IReadOnlyList<(string ProjectId, string Name, int Count)>? projectTabsCache;
    private (IReadOnlyList<XeroLedgerLine>? Lines, object Projects, string? ProjectTab, int ChoiceVersion) projectTabsCacheKey;

    private IReadOnlyList<(string ProjectId, string Name, int Count)> ProjectTabs
    {
        get
        {
            var key = (Lines, (object)Projects, activeProjectId, projectChoiceVersion);
            if (projectTabsCache is null || key != projectTabsCacheKey)
            {
                var tabs = (Lines ?? Array.Empty<XeroLedgerLine>())
                    .Where(line => line.AllocationStatus == XeroAllocationStatus.Unallocated)
                    .GroupBy(SelectedProjectFor)
                    .Where(group => group.Key != "")
                    .Select(group => (ProjectId: group.Key, Name: ProjectName(group.Key), Count: group.Count()))
                    .ToList();
                if (activeTab == XeroAllocationStatus.Unallocated && activeProjectId is not null
                    && !tabs.Any(tab => tab.ProjectId == activeProjectId))
                    tabs.Add((activeProjectId, ProjectName(activeProjectId), 0));
                projectTabsCache = tabs.OrderBy(tab => tab.Name, StringComparer.OrdinalIgnoreCase).ToList();
                projectTabsCacheKey = key;
            }
            return projectTabsCache;
        }
    }

    private int UnassignedCount =>
        Lines?.Count(line => line.AllocationStatus == XeroAllocationStatus.Unallocated
                             && SelectedProjectFor(line) == "") ?? 0;

    private int PageCount => Math.Max(1, (Visible.Count + PageSize - 1) / PageSize);

    private IEnumerable<XeroLedgerLine> Paged =>
        Visible.Skip(page * PageSize).Take(PageSize);

    private void OnSearchChanged(ChangeEventArgs args)
    {
        search = args.Value?.ToString() ?? string.Empty;
        page = 0;
    }

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        await RestoreLastTabAsync();
        Ledger.OnChange += StateHasChanged;
        CostCenters.OnChange += StateHasChanged;
        ProjectsReadModel.OnChanged += StateHasChanged;
        isLoaded = true;

        if (ProjectsReadModel.Current is null) _ = ProjectsReadModel.RefreshAsync(CancellationToken.None);
        _ = Ledger.RefreshAsync();
    }

    /// <summary>
    /// Re-runs the matching without touching Xero: reloads the project list (new
    /// projects added since the page opened) and re-reads the ledger — the API
    /// recomputes every unallocated line's suggestions against the live project
    /// and cost-centre masters on each read, so new projects get suggested and
    /// the "Allocate all matched" banner updates to include them.
    /// </summary>
    private async Task RecheckMatchesAsync()
    {
        isRechecking = true; syncMessage = null; errorMessage = null;
        try
        {
            var matchedBefore = FullyMatchedCount;
            await ProjectsReadModel.RefreshAsync(CancellationToken.None);
            await Ledger.RefreshAsync();
            var newlyMatched = FullyMatchedCount - matchedBefore;
            syncMessage = newlyMatched > 0
                ? $"Re-checked: {newlyMatched} more lines now match a project and cost centre — {FullyMatchedCount} matched in total."
                : $"Re-checked against the current project list: {FullyMatchedCount} lines fully matched.";
        }
        catch (CommandFailedException failure) { errorMessage = failure.Message; }
        finally { isRechecking = false; }
    }

    private async Task SyncAsync()
    {
        isSyncing = true; syncMessage = null; errorMessage = null;
        try
        {
            var result = await Ledger.SyncAsync();
            syncMessage = !result.IsConfigured
                ? "Xero isn't connected — add the Xero__ClientId / Xero__ClientSecret app settings."
                : result.Error is not null
                    ? $"Xero returned an error: {result.Error}"
                    : $"Synced. {result.NewLines} new lines, {result.UpdatedLines} refreshed"
                      + (result.RemovedLines > 0 ? $", {result.RemovedLines} voided/deleted lines removed from the queue" : "")
                      + $" — {result.UnallocatedLines} of {result.TotalLines} now awaiting allocation.";
        }
        catch (CommandFailedException failure) { errorMessage = failure.Message; }
        finally { isSyncing = false; }
    }

    private async Task AllocateAsync(XeroLedgerLine line) =>
        await ApplyAsync(new SetXeroAllocation(
            new[] { line.XeroLedgerLineId },
            XeroAllocationAction.Allocate,
            SelectedProjectFor(line),
            SelectedCostCenterFor(line)));

    private async Task IgnoreAsync(XeroLedgerLine line) =>
        await ApplyAsync(new SetXeroAllocation(new[] { line.XeroLedgerLineId }, XeroAllocationAction.Ignore));

    private async Task ResetAsync(XeroLedgerLine line) =>
        await ApplyAsync(new SetXeroAllocation(new[] { line.XeroLedgerLineId }, XeroAllocationAction.Reset));

    private async Task BulkAllocateAsync() =>
        await ApplyAsync(new SetXeroAllocation(selectedIds.ToList(), XeroAllocationAction.Allocate, bulkProjectId, bulkCostCenterCode));

    private async Task BulkIgnoreAsync() =>
        await ApplyAsync(new SetXeroAllocation(selectedIds.ToList(), XeroAllocationAction.Ignore));

    private async Task BucketAsync(XeroLedgerLine line, string bucket) =>
        await ApplyAsync(new SetXeroAllocation(new[] { line.XeroLedgerLineId }, XeroAllocationAction.AllocateToBucket, Bucket: bucket));

    // The bucket dropdown works like the project/cost-centre ones: pre-selected with
    // the suggestion when one was inferred, blank otherwise, always overridable.
    private string SelectedBucketFor(XeroLedgerLine line) =>
        (chosenBucket.TryGetValue(line.XeroLedgerLineId, out var chosen) ? chosen : line.SuggestedBucket) ?? "";

    private void SetBucket(string lineId, string? bucket) => chosenBucket[lineId] = bucket;

    private bool CanBucket(XeroLedgerLine line) => !string.IsNullOrEmpty(SelectedBucketFor(line));

    private async Task BulkBucketAsync() =>
        await ApplyAsync(new SetXeroAllocation(selectedIds.ToList(), XeroAllocationAction.AllocateToBucket, Bucket: bulkBucket));

    private decimal BucketTotal(string bucket) =>
        Lines?.Where(line => line.AllocationStatus == XeroAllocationStatus.Bucketed && line.Bucket == bucket)
              .Sum(SignedNet) ?? 0m;

    private void ToggleBucketFilter(string bucket) =>
        bucketFilter = bucketFilter == bucket ? null : bucket;

    private string BucketChipClass(string bucket) =>
        (bucketFilter == bucket
            ? "bg-content text-surface border-content"
            : "bg-surface text-content-muted border-line hover:text-content")
        + " text-xs font-medium border rounded-full px-3 py-1 transition-colors";

    private int FullyMatchedCount =>
        Lines?.Count(line => line.AllocationStatus == XeroAllocationStatus.Unallocated
                             && line.SuggestedProjectId is not null
                             && line.SuggestedCostCenterCode is not null) ?? 0;

    private async Task AllocateMatchedAsync()
    {
        isApplying = true; errorMessage = null; confirmAllocateMatched = false;
        try
        {
            var allocated = await Ledger.AllocateSuggestedAsync();
            syncMessage = $"{allocated} matched lines allocated — what's left in the queue needs a human decision.";
        }
        catch (CommandFailedException failure) { errorMessage = failure.Message; }
        finally { isApplying = false; }
    }

    private async Task ApplyAsync(SetXeroAllocation command)
    {
        isApplying = true; errorMessage = null;
        try
        {
            await Ledger.ApplyAsync(command);
            foreach (var id in command.XeroLedgerLineIds)
            {
                selectedIds.Remove(id);
                chosenProject.Remove(id);
                chosenCostCenter.Remove(id);
                chosenBucket.Remove(id);
            }
        }
        catch (CommandFailedException failure) { errorMessage = failure.Message; }
        finally { isApplying = false; }
    }

    // -- split editor ----------------------------------------------------------
    // A line's value shared across several projects and/or cost centres. The
    // amounts must add up to the line's net exactly; the API enforces the same
    // rules server-side.

    private sealed class SplitRow
    {
        public string ProjectId { get; set; } = "";
        public string Code { get; set; } = "";
        public decimal? Amount { get; set; }
    }

    private XeroLedgerLine? splitLine;
    private string? splitError;
    private List<SplitRow> splitRows = new();

    private void OpenSplit(XeroLedgerLine line)
    {
        splitLine = line;
        splitError = null;
        // First row pre-filled from the line's chosen/suggested project + centre;
        // second row starts on the same project (same-project splits are the
        // common case) with the centre left open.
        var project = SelectedProjectFor(line);
        splitRows = new List<SplitRow>
        {
            new() { ProjectId = project, Code = SelectedCostCenterFor(line) },
            new() { ProjectId = project }
        };
    }

    private void CloseSplit()
    {
        splitLine = null;
        splitError = null;
    }

    // New rows inherit the previous row's project — retyping the same project
    // for every row of a same-project split would be pure friction.
    private void AddSplitRow() =>
        splitRows.Add(new SplitRow { ProjectId = splitRows.LastOrDefault()?.ProjectId ?? "" });

    private void RemoveSplitRow(SplitRow row)
    {
        if (splitRows.Count > 2) splitRows.Remove(row);
    }

    private void OnSplitProjectChanged(SplitRow row, string? projectId) => row.ProjectId = projectId ?? "";

    private void OnSplitCodeChanged(SplitRow row, string? code) => row.Code = code ?? "";

    private void OnSplitAmountChanged(SplitRow row, string? raw) =>
        row.Amount = decimal.TryParse(raw, System.Globalization.NumberStyles.Number,
            System.Globalization.CultureInfo.InvariantCulture, out var amount)
            ? amount
            : null;

    private decimal SplitAssigned => splitRows.Sum(row => row.Amount ?? 0m);
    private decimal SplitRemaining => (splitLine?.Net ?? 0m) - SplitAssigned;

    private async Task ApplySplitAsync()
    {
        if (splitLine is null || isBusy) return;

        var rows = splitRows
            .Where(row => !string.IsNullOrEmpty(row.ProjectId) || !string.IsNullOrEmpty(row.Code) || row.Amount is not null)
            .ToList();
        if (rows.Count < 2) { splitError = "A split needs at least two rows — use Allocate for a single project + centre."; return; }
        if (rows.Any(row => string.IsNullOrEmpty(row.ProjectId) || string.IsNullOrEmpty(row.Code) || row.Amount is not > 0m))
        { splitError = "Every row needs a project, a cost centre and an amount above zero."; return; }
        if (rows.Select(row => $"{row.ProjectId}:{row.Code}").Distinct(StringComparer.OrdinalIgnoreCase).Count() != rows.Count)
        { splitError = "Each project + cost centre combination can appear only once."; return; }
        if (rows.Sum(row => row.Amount!.Value) != splitLine.Net)
        { splitError = $"The amounts must add up to {Money(splitLine.Net)} net — currently {Money(SplitAssigned)}."; return; }

        isApplying = true; splitError = null;
        try
        {
            await Ledger.ApplyAsync(new SetXeroAllocation(
                new[] { splitLine.XeroLedgerLineId },
                XeroAllocationAction.Allocate,
                Splits: rows.Select(row => new XeroCostSplit(row.Code, row.Amount!.Value, row.ProjectId)).ToList()));
            selectedIds.Remove(splitLine.XeroLedgerLineId);
            chosenProject.Remove(splitLine.XeroLedgerLineId);
            chosenCostCenter.Remove(splitLine.XeroLedgerLineId);
            chosenBucket.Remove(splitLine.XeroLedgerLineId);
            CloseSplit();
        }
        catch (CommandFailedException failure) { splitError = failure.Message; }
        finally { isApplying = false; }
    }

    // -- invoice document viewer -------------------------------------------------
    // The supplier's document as Xero holds it (published by Dext with the bill).
    // The list is fetched live from Xero when the modal opens; the bytes are
    // proxied through the API on demand — nothing is stored in JPMS.

    private XeroLedgerLine? viewLine;
    private IReadOnlyList<XeroInvoiceAttachment>? viewAttachments;
    private XeroInvoiceAttachment? viewSelected;
    private string? viewError;

    private async Task OpenInvoiceViewAsync(XeroLedgerLine line)
    {
        viewLine = line;
        viewAttachments = null;
        viewSelected = null;
        viewError = null;
        try
        {
            var attachments = await Queries.AskAsync(
                new ListXeroInvoiceAttachments(line.XeroInvoiceId, line.Type == "ACCPAYCREDIT"),
                CancellationToken.None);
            if (viewLine != line) return; // The modal was closed (or reopened) while fetching.
            viewAttachments = attachments;
            // PDFs and images preview in place; pre-select the first previewable one.
            viewSelected = attachments.FirstOrDefault(IsPreviewable) ?? attachments.FirstOrDefault();
            if (attachments.Count == 0)
                viewError = "Xero holds no documents for this invoice — it may have been removed since the last sync.";
        }
        catch (Exception)
        {
            if (viewLine != line) return;
            viewError = "Couldn't fetch the invoice's documents from Xero. If this keeps happening, check that the "
                + "Xero custom connection has the accounting.attachments scope ticked in the Xero developer portal.";
        }
    }

    private void CloseInvoiceView()
    {
        viewLine = null;
        viewAttachments = null;
        viewSelected = null;
        viewError = null;
    }

    // Same previewable set as the triage and drawing viewers: browsers render PDFs
    // and images natively in an iframe; everything else gets a Download link only.
    private static bool IsPreviewable(XeroInvoiceAttachment attachment) =>
        attachment.MimeType.Contains("pdf", StringComparison.OrdinalIgnoreCase)
        || attachment.MimeType.StartsWith("image/", StringComparison.OrdinalIgnoreCase);

    // The file name travels in the query string, never the path — supplier file
    // names carry spaces and characters that don't survive a URL path segment.
    private string InvoiceAttachmentUrl(XeroInvoiceAttachment attachment, bool inline) =>
        $"/api/xero/invoice/attachment?id={Uri.EscapeDataString(viewLine?.XeroInvoiceId ?? "")}"
        + $"&file={Uri.EscapeDataString(attachment.FileName)}"
        + (viewLine?.Type == "ACCPAYCREDIT" ? "&credit=1" : "")
        + (inline ? "&inline=1" : "");

    private string InvoiceAttachmentChipClass(XeroInvoiceAttachment attachment) =>
        (viewSelected == attachment
            ? "bg-content text-surface border-content"
            : "bg-surface text-content-muted border-line hover:text-content")
        + " text-xs font-medium border rounded-full px-3 py-1 transition-colors";

    // -- Xero write-back status -------------------------------------------------

    private sealed record WriteBackBadgeModel(string Text, string? Tooltip, string Css);

    /// <summary>Status line under an allocated line's cost centre(s): what Xero knows.</summary>
    private WriteBackBadgeModel? WriteBackBadge(XeroLedgerLine line) => line.WriteBackStatus switch
    {
        XeroWriteBackStatus.Approved => new("✓ Approved in Xero",
            line.WriteBackAtUtc?.ToLocalTime().ToString("d MMM yyyy HH:mm"), "text-positive"),
        XeroWriteBackStatus.Failed => new("⚠ Xero write-back failed",
            line.WriteBackError, "text-negative"),
        _ when IsAwaitingApproval(line) => new("Draft — approves in Xero once the whole bill is allocated",
            null, "text-content-subtle"),
        _ => null
    };

    private static bool IsAwaitingApproval(XeroLedgerLine line) =>
        line.InvoiceStatus.Equals("DRAFT", StringComparison.OrdinalIgnoreCase)
        || line.InvoiceStatus.Equals("SUBMITTED", StringComparison.OrdinalIgnoreCase);

    private async Task RetryWriteBackAsync(XeroLedgerLine line)
    {
        isApplying = true; errorMessage = null;
        try
        {
            var outcome = await Ledger.RetryWriteBackAsync(line.XeroInvoiceId);
            syncMessage = outcome.Succeeded
                ? $"Invoice {line.InvoiceNumber ?? line.XeroInvoiceId} confirmed and approved in Xero."
                : null;
            errorMessage = outcome.Succeeded ? null : outcome.Error;
        }
        catch (CommandFailedException failure) { errorMessage = failure.Message; }
        finally { isApplying = false; }
    }

    // -- selection & per-line choices ----------------------------------------

    // A value that isn't in the dropdown's options (e.g. a suggestion for a project or
    // code that no longer exists) counts as empty — otherwise the select renders blank
    // while the Allocate button believes a value is set.
    private string SelectedProjectFor(XeroLedgerLine line)
    {
        var value = (chosenProject.TryGetValue(line.XeroLedgerLineId, out var chosen) ? chosen : line.SuggestedProjectId) ?? "";
        return ValidProjectIds.Contains(value) ? value : "";
    }

    // SelectedProjectFor now runs for every line when grouping the queue into
    // project tabs (not just the 50 rendered rows), so the validity check is a
    // set lookup rather than a scan of the project list per line.
    private HashSet<string>? validProjectIdsCache;
    private object? validProjectIdsCacheKey;

    private HashSet<string> ValidProjectIds
    {
        get
        {
            if (validProjectIdsCache is null || !ReferenceEquals(validProjectIdsCacheKey, Projects))
            {
                validProjectIdsCache = Projects.Select(project => project.ProjectId).ToHashSet();
                validProjectIdsCacheKey = Projects;
            }
            return validProjectIdsCache;
        }
    }

    private string SelectedCostCenterFor(XeroLedgerLine line)
    {
        var value = (chosenCostCenter.TryGetValue(line.XeroLedgerLineId, out var chosen) ? chosen : line.SuggestedCostCenterCode) ?? "";
        return CostCenters.Active().Any(centre => centre.Code == value) ? value : "";
    }

    private void SetProject(string lineId, string? projectId)
    {
        chosenProject[lineId] = projectId;
        projectChoiceVersion++;
        // Pointing a line at a different project moves it to that project's tab;
        // don't leave it invisibly selected in a tab it no longer belongs to.
        if (activeTab == XeroAllocationStatus.Unallocated && (projectId ?? "") != (activeProjectId ?? ""))
            selectedIds.Remove(lineId);
    }

    private void SetCostCenter(string lineId, string? code) => chosenCostCenter[lineId] = code;

    private bool CanAllocate(XeroLedgerLine line) =>
        !string.IsNullOrEmpty(SelectedProjectFor(line)) && !string.IsNullOrEmpty(SelectedCostCenterFor(line));

    private void ToggleSelected(string lineId)
    {
        if (!selectedIds.Remove(lineId)) selectedIds.Add(lineId);
    }

    // Select-all works on the current page — a deliberate guard against silently
    // bulk-acting on thousands of filtered lines. Narrow with search, then select.
    private bool AllVisibleSelected
    {
        get
        {
            var any = false;
            foreach (var line in Paged) { any = true; if (!selectedIds.Contains(line.XeroLedgerLineId)) return false; }
            return any;
        }
    }

    private void ToggleSelectAll(ChangeEventArgs args)
    {
        if (args.Value is true)
            foreach (var line in Paged) selectedIds.Add(line.XeroLedgerLineId);
        else
            selectedIds.Clear();
    }

    private void SwitchTab(XeroAllocationStatus tab, string? projectId = null)
    {
        activeTab = tab;
        activeProjectId = tab == XeroAllocationStatus.Unallocated ? projectId : null;
        selectedIds.Clear();
        bucketFilter = null;
        page = 0;
        // On a project tab every line is already pointed at that project, so
        // pre-arm the bulk bar's project with it.
        if (activeProjectId is not null) bulkProjectId = activeProjectId;
        _ = PersistTabAsync();
    }

    // -- last-tab memory --------------------------------------------------------
    // The screen reopens on whatever tab the user last had open (per browser, per
    // user): project people land straight back on their project's queue.

    private const string ProjectTabPrefix = "Project:";

    private async Task RestoreLastTabAsync()
    {
        var stored = await TabStorage.ReadAsync(Auth.CurrentUser!.Email);
        if (string.IsNullOrWhiteSpace(stored)) return;
        if (stored.StartsWith(ProjectTabPrefix, StringComparison.Ordinal))
        {
            activeTab = XeroAllocationStatus.Unallocated;
            activeProjectId = stored[ProjectTabPrefix.Length..];
            bulkProjectId = activeProjectId;
        }
        else if (Enum.TryParse<XeroAllocationStatus>(stored, out var status))
        {
            activeTab = status;
        }
    }

    private Task PersistTabAsync() =>
        Auth.CurrentUser is null
            ? Task.CompletedTask
            : TabStorage.WriteAsync(Auth.CurrentUser.Email,
                activeProjectId is not null ? $"{ProjectTabPrefix}{activeProjectId}" : activeTab.ToString());

    // -- display helpers ------------------------------------------------------

    private int CountOf(XeroAllocationStatus status) =>
        Lines?.Count(line => line.AllocationStatus == status) ?? 0;

    private bool MatchesSearch(XeroLedgerLine line)
    {
        if (string.IsNullOrWhiteSpace(search)) return true;
        var term = search.Trim();
        return Contains(line.ContactName) || Contains(line.Description) || Contains(line.InvoiceNumber)
            || Contains(line.Reference) || Contains(line.XeroSite) || Contains(line.XeroCostCode);

        bool Contains(string? value) =>
            value is not null && value.Contains(term, StringComparison.OrdinalIgnoreCase);
    }

    private string ProjectName(string? projectId) =>
        Projects.FirstOrDefault(project => project.ProjectId == projectId)?.Name ?? projectId ?? "—";

    private string CostCenterText(string? code)
    {
        if (code is null) return "—";
        var centre = CostCenters.All().FirstOrDefault(c => c.Code == code);
        return centre is null ? code : $"{centre.Code} {centre.Name}";
    }

    // The plain Unallocated tab is active only when no project tab is open.
    private string TabClass(XeroAllocationStatus tab) =>
        TabCss(activeTab == tab && (tab != XeroAllocationStatus.Unallocated || activeProjectId is null));

    private string ProjectTabClass(string projectId) =>
        TabCss(activeTab == XeroAllocationStatus.Unallocated && activeProjectId == projectId);

    private static string TabCss(bool active) =>
        (active ? "bg-content text-surface" : "bg-surface text-content-muted hover:text-content")
        + " text-sm font-medium px-4 py-1.5 transition-colors";

    private static decimal SignedNet(XeroLedgerLine line) =>
        line.Type == "ACCPAYCREDIT" ? -line.Net : line.Net;

    private static string DateText(DateTime? date) => date?.ToString("d MMM yyyy") ?? "—";

    private static string Money(decimal value) =>
        value.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-GB"));

    public void Dispose()
    {
        Ledger.OnChange -= StateHasChanged;
        CostCenters.OnChange -= StateHasChanged;
        ProjectsReadModel.OnChanged -= StateHasChanged;
    }
}
