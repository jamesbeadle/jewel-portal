@page "/rate-library"
@inject AuthService Auth
@inject SessionService Session
@inject IRateLibrary Rates
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Rate library · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="px-6 md:px-8 py-12 text-content-subtle text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="px-6 md:px-8 py-8 md:py-12">
        <header class="mb-6 md:mb-8 flex items-end justify-between gap-4">
            <div>
                <p class="text-xs uppercase tracking-wider text-content-subtle font-medium mb-1">JPMS · QS</p>
                <h1 class="text-2xl md:text-3xl font-semibold text-content leading-tight">Rate library</h1>
                <p class="text-sm text-content-muted mt-2">@Rates.All().Count rates · @StaleCount stale.</p>
            </div>
            <a href="/rate-library/stale"
               class="text-sm font-medium text-content-muted hover:text-content underline underline-offset-4">
                View stale rates →
            </a>
        </header>

        <RateTable Rates="Rates.All()" />
    </section>
}

@code {
    private const int StaleDayThreshold = 60;
    private bool isLoaded;

    private int StaleCount => Rates.Stale(StaleDayThreshold).Count;

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        Rates.OnChange += StateHasChanged;
        isLoaded = true;
    }

    public void Dispose() => Rates.OnChange -= StateHasChanged;
}
