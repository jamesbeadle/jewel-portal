@page "/site/projects/{ProjectId}/capture-photo"
@layout SiteLayout

<PageTitle>Capture photo · JPMS</PageTitle>

<SiteHeader Eyebrow="Capture" Title="Photo" BackHref="@($"/site/projects/{ProjectId}")" />

<section class="max-w-md mx-auto px-4 py-6 space-y-4">
    <div class="rounded-2xl border-2 border-dashed border-line-strong bg-surface p-12 text-center">
        <p class="text-4xl mb-2" aria-hidden="true">📷</p>
        <p class="text-sm text-content-muted font-medium">Tap to take a photo</p>
        <p class="text-xs text-content-subtle mt-1">Auto-tagged to today, this project, your name</p>
    </div>

    <p class="text-xs text-content-subtle text-center">
        Camera integration lands with the native PWA install. Photos taken now save to your phone gallery.
    </p>
</section>

@code {
    [Parameter] public string ProjectId { get; set; } = "";
}
