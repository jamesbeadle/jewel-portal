@page "/portfolio/subcontractor-exposure"
@inject AuthService Auth
@inject SessionService Session
@inject ISubcontractorStore SubcontractorStore
@inject IProcurementStore ProcurementStore
@inject NavigationManager Nav

<PageTitle>Subcontractor exposure · JPMS</PageTitle>

@if (!isLoaded)
{
    <section class="max-w-5xl mx-auto px-4 py-12 text-slate-500 text-sm">Loading…</section>
}
else if (!Session.IsApproved)
{
    <RequestAccessView Email="@Auth.CurrentUser!.Email" DisplayName="@Auth.CurrentUser.DisplayName" />
}
else
{
    <section class="max-w-5xl mx-auto px-4 py-8 md:py-12">
        <nav class="mb-4 text-sm">
            <a href="/portfolio" class="text-slate-500 hover:text-slate-900 underline underline-offset-4">Portfolio</a>
            <span class="text-slate-400 mx-2">/</span>
            <span class="text-slate-700 font-medium">Subcontractor exposure</span>
        </nav>

        <header class="mb-6">
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900">Subcontractor exposure</h1>
            <p class="text-sm text-slate-600 mt-1">Financial concentration risk across the portfolio.</p>
        </header>

        <SubExposureTable Rows="ExposureRows" />
    </section>
}

@code {
    private bool isLoaded;

    private IReadOnlyList<ExposureRow> ExposureRows =>
        SubcontractorStore.All().Select(sub =>
        {
            var orders = ProcurementStore.AllWorkOrders()
                .Where(workOrder => workOrder.SubcontractorId == sub.SubcontractorId)
                .ToList();
            return new ExposureRow(sub.CompanyName, sub.PrimaryTrade, orders.Count, orders.Sum(o => o.Value));
        })
        .Where(row => row.WorkOrderCount > 0)
        .OrderByDescending(row => row.TotalValue)
        .ToList()
        .AsReadOnly();

    protected override async Task OnInitializedAsync()
    {
        await Session.EnsureLoadedAsync();
        if (!Auth.IsSignedIn) { Nav.NavigateTo("/login", forceLoad: true); return; }
        isLoaded = true;
    }
}
