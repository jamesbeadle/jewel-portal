@page "/portal/subcontractor"
@layout PortalLayout
@inject PortalContext PortalContext
@inject ISubcontractorStore SubcontractorStore
@inject IProcurementStore ProcurementStore
@implements IDisposable

<PageTitle>Subcontractor portal · JPMS</PageTitle>

<section class="max-w-4xl mx-auto px-4 py-8 md:py-12">
    <SubcontractorActAsPicker />

    @if (Subcontractor is null)
    {
        <p class="text-sm text-slate-500 italic">Choose a subcontractor above to continue.</p>
    }
    else
    {
        <header class="mb-6">
            <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-1">Welcome</p>
            <h1 class="text-2xl md:text-3xl font-semibold text-slate-900">@Subcontractor.CompanyName</h1>
            <p class="text-sm text-slate-600 mt-2">@Subcontractor.PrimaryTrade · @Subcontractor.ContactName</p>
        </header>

        <div class="grid grid-cols-2 gap-3 md:gap-4 mb-6">
            <Stat Label="Open invitations" Value="@OpenBidCount.ToString()" />
            <Stat Label="Compliance docs"  Value="@ComplianceCount.ToString()" />
        </div>

        <nav class="rounded-xl border border-slate-200 bg-white divide-y divide-slate-200">
            <PortalNavLink Href="/portal/subcontractor/bids"        Label="Bid invitations"   Detail="Open bid packages waiting for your quote" />
            <PortalNavLink Href="/portal/subcontractor/compliance"  Label="Compliance"        Detail="Insurance, certificates, expiry dates" />
        </nav>
    }
</section>

@code {
    private Subcontractor? Subcontractor =>
        string.IsNullOrEmpty(PortalContext.ActingSubcontractorId)
            ? null
            : SubcontractorStore.Find(PortalContext.ActingSubcontractorId);

    private int OpenBidCount =>
        ProcurementStore.AllWorkOrders().Count;
    private int ComplianceCount =>
        Subcontractor is null ? 0 : SubcontractorStore.ComplianceFor(Subcontractor.SubcontractorId).Count;

    protected override void OnInitialized() => PortalContext.OnChange += StateHasChanged;

    public void Dispose() => PortalContext.OnChange -= StateHasChanged;
}
