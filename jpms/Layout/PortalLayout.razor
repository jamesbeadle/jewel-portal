@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav

<div class="min-h-dvh flex flex-col bg-canvas text-content antialiased">
    <header class="border-b border-line bg-surface sticky top-0 z-10">
        <div class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between gap-3">
            <a href="/" class="flex items-center gap-2.5 font-semibold text-content shrink-0">
                <JewelIcon Class="w-8 h-8 text-content" />
                <span>JPMS Portal</span>
            </a>
            @if (Auth.IsSignedIn)
            {
                <RoleSwitcher />
            }
            else
            {
                <span class="eyebrow">External access</span>
            }
        </div>
    </header>

    <main class="flex-1">
        <SecureLinkBanner />
        @Body
    </main>

    <footer class="border-t border-line bg-surface">
        <div class="max-w-4xl mx-auto px-4 py-3 text-xs text-content-subtle flex items-center justify-between">
            <span>Jewel Enterprises · external portal</span>
            <a href="/" class="hover:text-content underline underline-offset-4">Jewel staff sign-in</a>
        </div>
    </footer>
</div>
