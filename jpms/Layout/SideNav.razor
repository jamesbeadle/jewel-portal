@inject AuthService Auth
@inject SessionService Session
@inject NavigationManager Nav
@implements IDisposable

<div class="h-full flex flex-col bg-white">

    <div class="px-5 py-4 border-b border-slate-200">
        <a href="@HomeHref" @onclick="HandleNavigate" @onclick:preventDefault="false"
           class="flex items-center gap-2 font-semibold text-slate-900">
            <span class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-slate-900 text-white text-xs">JP</span>
            <span>JPMS</span>
        </a>
    </div>

    <nav class="flex-1 px-3 py-4 overflow-y-auto">
        <ul class="space-y-1 text-sm">
            @foreach (var item in VisibleItems)
            {
                <li>
                    <a href="@item.Href" @onclick="HandleNavigate" @onclick:preventDefault="false"
                       class="@LinkClassFor(item.Href)">
                        @item.Label
                    </a>
                </li>
            }
        </ul>
    </nav>

    @if (Auth.IsSignedIn)
    {
        <div class="border-t border-slate-200 px-5 py-4 text-sm">
            <p class="text-xs uppercase tracking-wider text-slate-500 font-semibold mb-1">Signed in as</p>
            <p class="text-slate-900 font-medium truncate" title="@Auth.CurrentUser!.Email">@Auth.CurrentUser.DisplayName</p>
            <p class="text-xs text-slate-500 truncate mb-3" title="@Auth.CurrentUser.Email">@Auth.CurrentUser.Email</p>
            <button type="button" @onclick="SignOut"
                    class="w-full rounded-lg border border-slate-200 bg-white text-slate-700 font-medium text-sm px-3 py-2 hover:border-slate-300 hover:text-slate-900 transition">
                Sign out
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback OnNavigate { get; set; }

    private IReadOnlyList<NavigationItem> VisibleItems =>
        Session.ActiveRole is null
            ? Array.Empty<NavigationItem>()
            : NavigationCatalog.ItemsFor(Session.ActiveRole.Value);

    private string HomeHref =>
        Session.ActiveRole is null ? "/dashboard" : NavigationCatalog.HomeRouteFor(Session.ActiveRole.Value);

    protected override void OnInitialized() => Session.OnChange += StateHasChanged;

    private string LinkClassFor(string href)
    {
        var current = new Uri(Nav.Uri).AbsolutePath;
        var isActive = current == href || current.StartsWith(href + "/");
        if (isActive) return "block px-3 py-2 rounded-md bg-slate-900 text-white font-medium transition";
        return "block px-3 py-2 rounded-md text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition";
    }

    private Task HandleNavigate() => OnNavigate.InvokeAsync();

    private void SignOut() => Nav.NavigateTo("/logout", forceLoad: true);

    public void Dispose() => Session.OnChange -= StateHasChanged;
}
