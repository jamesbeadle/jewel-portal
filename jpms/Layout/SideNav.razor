@inject AuthService Auth
@inject SessionService Session
@inject NavigationManager Nav
@inject ILabourStore Labour
@implements IDisposable

<div class="h-full flex flex-col bg-surface">

    <div class="@HeaderLayout border-b border-line">
        <a href="@HomeHref" @onclick="HandleNavigate" @onclick:preventDefault="false"
           class="flex items-center gap-3 px-3 font-semibold text-content overflow-hidden">
            <JewelIcon Class="w-5 h-5 text-content shrink-0" />
            <span class="@LabelClass">JPMS</span>
        </a>
        <button type="button" @onclick="OnToggleExpand"
                class="hidden md:inline-flex items-center justify-center w-8 h-8 rounded-md text-content-subtle hover:text-content hover:bg-surface-raised"
                aria-label="Toggle navigation">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <path d="@(IsExpanded ? "M15 6l-6 6 6 6" : "M9 6l6 6-6 6")" />
            </svg>
        </button>
    </div>

    <nav class="flex-1 px-2 py-3 overflow-y-auto">
        <ul class="space-y-1">
            @foreach (var item in VisibleItems)
            {
                <li>
                    <a href="@item.Href" @onclick="HandleNavigate" @onclick:preventDefault="false"
                       class="@LinkClassFor(item)" title="@item.Label">
                        <NavIcon Route="@item.Href" Class="w-5 h-5 shrink-0" />
                        <span class="@LabelClass">@item.Label</span>
                    </a>
                </li>
            }
        </ul>
    </nav>

    @if (Auth.IsSignedIn)
    {
        <div class="border-t border-line px-3 py-3">
            <div class="@(IsExpanded ? "hidden md:block" : "hidden") mb-3">
                <p class="eyebrow mb-1">Signed in as</p>
                <p class="text-content text-sm font-medium truncate" title="@Auth.CurrentUser!.Email">@Auth.CurrentUser.DisplayName</p>
                <p class="text-xs text-content-subtle truncate" title="@Auth.CurrentUser.Email">@Auth.CurrentUser.Email</p>
            </div>
            <button type="button" @onclick="SignOut" class="btn-secondary w-full" title="Sign out">
                <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                     stroke-linecap="round" stroke-linejoin="round"><path d="M15 12H3m0 0l4-4m-4 4l4 4M11 4h6a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2h-6" /></svg>
                <span class="@LabelClass">Sign out</span>
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback OnNavigate { get; set; }
    [Parameter] public bool IsExpanded { get; set; } = true;
    [Parameter] public EventCallback OnToggleExpand { get; set; }

    private string LabelClass => IsExpanded ? "hidden md:inline truncate" : "hidden";

    private string HeaderLayout => IsExpanded
        ? "h-14 px-2 flex items-center justify-center md:justify-between"
        : "px-2 py-3 flex flex-col items-center gap-2";

    private IReadOnlyList<NavigationItem> VisibleItems
    {
        get
        {
            if (Session.ActiveRole is null) return Array.Empty<NavigationItem>();
            var items = NavigationCatalog.ItemsFor(Session.ActiveRole.Value);

            // "My day" is role-visible (Site Operative / Foreman / Site Manager) but only
            // useful to accounts linked to a worker record — hide it until the link is
            // confirmed. The MyDay lookup is fetch-once via the store, so this costs one
            // call and only for roles that could see the entry at all.
            if (items.Any(item => item.Href == "/my-day") && !HasWorkerRecord)
                items = items.Where(item => item.Href != "/my-day").ToList();
            return items;
        }
    }

    private bool HasWorkerRecord => Labour.MyDay() is { WorkerId: not "" };

    private string HomeHref =>
        Session.ActiveRole is null ? "/dashboard" : NavigationCatalog.HomeRouteFor(Session.ActiveRole.Value);

    protected override void OnInitialized()
    {
        Session.OnChange += StateHasChanged;
        Labour.OnChange += StateHasChanged;
    }

    private string LinkClassFor(NavigationItem item)
    {
        var current = new Uri(Nav.Uri).AbsolutePath;
        // Grouped entries (Financials / Project Management / Operations) stay lit across every
        // page folded into them, via the item's match prefixes.
        var isActive = item.IsActiveFor(current);
        var layout = IsExpanded ? "md:justify-start" : "";
        var baseClass = $"flex items-center gap-3 justify-center {layout} px-3 py-2 rounded-lg text-sm transition";
        if (isActive) return $"{baseClass} text-content font-semibold";
        return $"{baseClass} text-content-subtle font-medium hover:text-content hover:bg-surface-raised";
    }

    private Task HandleNavigate() => OnNavigate.InvokeAsync();

    private void SignOut() => Nav.NavigateTo("/logout", forceLoad: true);

    public void Dispose()
    {
        Session.OnChange -= StateHasChanged;
        Labour.OnChange -= StateHasChanged;
    }
}
