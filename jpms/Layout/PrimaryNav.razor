@inject NavigationManager Nav

<nav class="hidden sm:flex items-center gap-1 text-sm">
    @foreach (var item in NavigationItems)
    {
        <a href="@item.Href"
           class="@LinkClassFor(item.Href)">
            @item.Label
        </a>
    }
</nav>

@code {
    private record NavigationItem(string Label, string Href);

    private static readonly NavigationItem[] NavigationItems =
    {
        new("Dashboard",       "/dashboard"),
        new("Leads",           "/leads"),
        new("Projects",        "/projects"),
        new("Subcontractors",  "/subcontractors"),
        new("Work orders",     "/work-orders"),
        new("H&S",             "/hs"),
        new("Cashflow",        "/cashflow"),
        new("Portfolio",       "/portfolio"),
        new("Rates",           "/rate-library")
    };

    private string LinkClassFor(string href)
    {
        var current = new Uri(Nav.Uri).AbsolutePath;
        var isActive = current == href || current.StartsWith(href + "/");
        if (isActive)
        {
            return "px-3 py-1.5 rounded-md bg-slate-900 text-white font-medium transition";
        }
        return "px-3 py-1.5 rounded-md text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition";
    }
}
