@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav
@implements IDisposable

<div class="min-h-dvh flex flex-col bg-canvas text-content antialiased">
    <header class="bg-surface border-b border-line sticky top-0 z-10">
        <div class="max-w-md mx-auto px-4 py-3 flex items-center justify-between gap-3">
            <a href="/site/today" class="flex items-center gap-2.5 font-semibold shrink-0">
                <JewelIcon Class="w-8 h-8 text-content" />
                <span>JPMS Site</span>
            </a>
            @if (Auth.IsSignedIn)
            {
                <button class="text-xs font-medium text-content-muted hover:text-content underline underline-offset-4"
                        @onclick="SignOut">
                    Sign out
                </button>
            }
        </div>
    </header>

    <main class="flex-1">
        @Body
    </main>

    <footer class="bg-surface border-t border-line">
        <div class="max-w-md mx-auto px-4 py-3 text-xs text-content-subtle flex items-center justify-between">
            <span>Field app</span>
            <a href="/dashboard" class="hover:text-content underline underline-offset-4">Desktop</a>
        </div>
    </footer>
</div>

@code {
    protected override void OnInitialized() => Auth.OnChange += StateHasChanged;

    private void SignOut() => Nav.NavigateTo("/logout", forceLoad: true);

    public void Dispose() => Auth.OnChange -= StateHasChanged;
}
