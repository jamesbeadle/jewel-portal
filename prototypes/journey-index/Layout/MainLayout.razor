@inherits LayoutComponentBase

<div class="min-h-dvh flex flex-col bg-slate-50 text-slate-900 antialiased">
    <header class="border-b border-slate-200 bg-white sticky top-0 z-10">
        <div class="max-w-3xl mx-auto px-4 py-3 flex items-center justify-between">
            <a href="/" class="flex items-center gap-2 font-semibold text-slate-900">
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-md bg-slate-900 text-white text-xs">JE</span>
                <span>Jewel Enterprises</span>
            </a>
            <span class="text-[11px] uppercase tracking-wider text-slate-500 font-medium">Scoping Prototype</span>
        </div>
    </header>

    <main class="flex-1">
        @Body
    </main>

    <footer class="border-t border-slate-200 bg-white">
        <div class="max-w-3xl mx-auto px-4 py-3 text-xs text-slate-500 flex items-center justify-between">
            <span>Discovery phase</span>
            <span>v0.1</span>
        </div>
    </footer>
</div>
