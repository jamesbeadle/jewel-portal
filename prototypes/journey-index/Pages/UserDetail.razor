@page "/users/{Slug}"

@if (persona is null)
{
    <PageTitle>User not found · Jewel Bespoke Build</PageTitle>
    <section class="max-w-3xl mx-auto px-4 py-12">
        <p class="text-xs uppercase tracking-wider text-slate-500 font-medium mb-2">
            <a href="/" class="hover:text-slate-900">← Back to home</a>
        </p>
        <h1 class="text-2xl font-semibold text-slate-900 mb-2">User not found</h1>
        <p class="text-slate-700">No persona with the slug <code class="text-slate-700 bg-slate-100 px-1.5 py-0.5 rounded text-xs">@Slug</code>.</p>
    </section>
}
else
{
    <PageTitle>@persona.Name · Jewel Bespoke Build</PageTitle>

    <section class="max-w-3xl mx-auto px-4 py-6 md:py-10">

        <nav class="mb-4">
            <a href="/" class="text-xs text-slate-500 hover:text-slate-900 font-medium uppercase tracking-wider">← Back to users</a>
        </nav>

        <header class="mb-6 md:mb-8">
            <div class="flex items-center gap-2 mb-2">
                <span class="inline-block w-2 h-2 rounded-full @persona.AccentDotClass"></span>
                <span class="text-[11px] uppercase tracking-wider text-slate-500 font-semibold">@persona.Code</span>
            </div>
            <h1 class="text-3xl md:text-4xl font-semibold text-slate-900 leading-tight mb-3">@persona.Name</h1>
            <p class="text-base md:text-lg text-slate-700 leading-relaxed">@persona.ShortDescription</p>
        </header>

        <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 md:gap-4 mb-8">
            <Stat Label="Role" Value="@persona.Role" />
            <Stat Label="Reports to" Value="@persona.ReportsTo" />
            <Stat Label="Tooling today" Value="@persona.ToolingToday" />
            <Stat Label="Frequency on platform" Value="@persona.Frequency" />
        </dl>

        <BulletCard Title="Goals" AccentDotClass="@persona.AccentDotClass" Items="persona.Goals" />
        <BulletCard Title="Pain points (current state)" AccentDotClass="@persona.AccentDotClass" Items="persona.PainPoints" />
        <BulletCard Title="Key responsibilities" AccentDotClass="@persona.AccentDotClass" Items="persona.KeyResponsibilities" />

        <article class="rounded-xl border border-slate-200 bg-white p-5 mb-4">
            <h2 class="text-sm font-medium text-slate-500 uppercase tracking-wide mb-2">Devices &amp; environment</h2>
            <p class="text-slate-800 leading-relaxed">@persona.DevicesAndEnvironment</p>
        </article>

        @if (!string.IsNullOrWhiteSpace(persona.Note))
        {
            <article class="rounded-xl border border-amber-200 bg-amber-50 p-5 mb-8">
                <h2 class="text-sm font-medium text-amber-800 uppercase tracking-wide mb-2">Note</h2>
                <p class="text-amber-900 leading-relaxed">@persona.Note</p>
            </article>
        }

        <section class="rounded-xl border border-slate-200 bg-white overflow-hidden">
            <header class="px-5 py-3 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
                <h2 class="text-sm font-medium text-slate-700">User journeys</h2>
                <span class="text-xs text-slate-500">@persona.Journeys.Count</span>
            </header>
            @if (persona.Journeys.Count == 0)
            {
                <div class="p-5">
                    <p class="text-slate-500 italic text-sm">
                        No journeys captured yet for @persona.Name. They'll appear here once they're articulated in
                        <code class="text-slate-700 bg-slate-100 px-1.5 py-0.5 rounded text-xs">/docs/user-journeys/</code>
                        and seeded into the prototype.
                    </p>
                </div>
            }
            else
            {
                <ul class="divide-y divide-slate-200">
                    @foreach (var j in persona.Journeys)
                    {
                        <li class="px-5 py-3 flex items-center justify-between">
                            <span class="text-slate-800">@j.Title</span>
                            <span class="text-xs text-slate-500">@j.Status</span>
                        </li>
                    }
                </ul>
            }
        </section>

        <p class="mt-6 text-xs text-slate-500">
            Source of truth: <code class="text-slate-700 bg-slate-100 px-1.5 py-0.5 rounded">docs/requirements/personas.md</code>
        </p>

    </section>
}

@code {
    [Parameter] public string Slug { get; set; } = "";

    private Persona? persona;

    protected override void OnParametersSet()
    {
        persona = Personas.GetBySlug(Slug);
    }
}
