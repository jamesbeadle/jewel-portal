@* Small labelled stat card used on the user detail page. *@

<article class="rounded-xl border border-slate-200 bg-white p-4">
    <p class="text-[11px] uppercase tracking-wider text-slate-500 font-semibold mb-1">@Label</p>
    <p class="text-slate-900 text-sm leading-snug">@Value</p>
</article>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public string Value { get; set; } = "";
}
