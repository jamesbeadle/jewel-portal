@* Card with a coloured-dot title and a bullet list. *@

<article class="rounded-xl border border-slate-200 bg-white p-5 mb-4">
    <div class="flex items-center gap-2 mb-3">
        <span class="inline-block w-2 h-2 rounded-full @AccentDotClass"></span>
        <h2 class="text-sm font-medium text-slate-700 uppercase tracking-wide">@Title</h2>
    </div>
    <ul class="space-y-2">
        @foreach (var item in Items)
        {
            <li class="flex gap-2 text-slate-800 leading-relaxed">
                <span class="text-slate-400 mt-1 shrink-0">•</span>
                <span>@item</span>
            </li>
        }
    </ul>
</article>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter, EditorRequired] public string AccentDotClass { get; set; } = "bg-slate-400";
    [Parameter, EditorRequired] public IReadOnlyList<string> Items { get; set; } = Array.Empty<string>();
}
