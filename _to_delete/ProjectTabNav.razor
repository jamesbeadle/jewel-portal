@using Jewel.JPMS.Services.Navigation

@*
    The active section's tab row — the only navigation the project view renders. Switching
    section (Financials / Project Management / Operations) happens in the side nav, whose grouped
    entries follow the last-viewed project; the project landing page (/projects/{id}) shows the
    section cards instead. Renders nothing when ActiveTab is empty (the landing page).
*@

@if (Active is not null)
{
    <nav class="border-b border-line mb-6 overflow-x-auto" aria-label="@Active.Label tabs">
        <ul class="flex items-center gap-1 text-sm whitespace-nowrap">
            @foreach (var tab in Active.Tabs)
            {
                <li><a href="@ProjectSections.HrefFor(ProjectId, tab)" class="@TabClassFor(tab.Slug)">@tab.Label</a></li>
            }
        </ul>
    </nav>
}

@code {
    [Parameter, EditorRequired] public string ProjectId { get; set; } = "";
    [Parameter, EditorRequired] public string ActiveTab { get; set; } = "";

    private ProjectSectionInfo? Active => ProjectSections.SectionForTab(ActiveTab);

    private string TabClassFor(string slug)
    {
        var isActive = slug == ActiveTab;
        if (isActive)
        {
            return "inline-block px-3 py-2 border-b-2 border-accent text-content font-medium";
        }
        return "inline-block px-3 py-2 border-b-2 border-transparent text-content-subtle hover:text-content hover:border-line-strong";
    }
}
